{%- liquid
  assign source_product = product
  if source_product == blank
    assign source_product = section.settings.product
  endif

  assign variant_images = source_product.images | where: 'attached_to_variant?', true | map: 'src'
  assign first_3d_model = source_product.media | where: 'media_type', 'model' | first
-%}

{{ 'section-main-product.css' | asset_url | stylesheet_tag }}
{{ 'component-accordion.css' | asset_url | stylesheet_tag }}
{{ 'component-price.css' | asset_url | stylesheet_tag }}
{{ 'component-slider.css' | asset_url | stylesheet_tag }}
{{ 'component-rating.css' | asset_url | stylesheet_tag }}
{{ 'component-deferred-media.css' | asset_url | stylesheet_tag }}
{{ 'bloomli-trust-icons.css' | asset_url | stylesheet_tag }}
{{ 'what-youll-feel.css' | asset_url | stylesheet_tag }}
{{ 'bloomli-product-information.css' | asset_url | stylesheet_tag }}

<section
  id="glp1-offers"
  class="bloomli-product-information color-{{ section.settings.color_scheme }} gradient"
  style="
    --bpi-accent: {{ section.settings.accent_color }};
    --bpi-emphasis: {{ section.settings.emphasis_color }};
    --bpi-heading: {{ section.settings.heading_size }}px;
    --bpi-heading-mobile: {{ section.settings.heading_size_mobile }}px;
    --bpi-padding-top: {{ section.settings.padding_top }}px;
    --bpi-padding-bottom: {{ section.settings.padding_bottom }}px;
    --bpi-padding-top-mobile: {{ section.settings.padding_top_mobile }}px;
    --bpi-padding-bottom-mobile: {{ section.settings.padding_bottom_mobile }}px;
  "
  data-section="{{ section.id }}"
  {% if source_product != blank %}data-product-id="{{ source_product.id }}"{% endif %}
>
  {%- if section.settings.show_intro -%}
    <header class="bloomli-product-information__intro">
      {%- if section.settings.heading != blank -%}
        <h2 class="bloomli-product-information__heading">{{ section.settings.heading }}</h2>
      {%- endif -%}
      {%- if section.settings.subtext != blank -%}
        <div class="bloomli-product-information__subtext rte">{{ section.settings.subtext }}</div>
      {%- endif -%}
    </header>
  {%- endif -%}

  {%- if source_product != blank -%}
    <div id="bloomli-product-form" class="page-width">
      <div class="product product--{{ section.settings.media_size }} product--{{ section.settings.media_position }} product--{{ section.settings.gallery_layout }} product--mobile-{{ section.settings.mobile_thumbnails }} grid grid--1-col{% if source_product.media.size > 0 %} grid--2-col-tablet{% else %} product--no-media{% endif %}">
        <div class="grid__item product__media-wrapper">
          {%- render 'product-media-gallery',
            product: source_product,
            variant_images: variant_images,
            first_3d_model: first_3d_model
          -%}
        </div>

        <div class="product__info-wrapper grid__item">
          <div id="ProductInfo-{{ section.id }}" class="product__info-container{% if section.settings.enable_sticky_info %} product__column-sticky{% endif %}">
            {%- if section.settings.show_title -%}
              <div class="product__title">
                <h2 class="h1">{{ source_product.title | escape }}</h2>
              </div>
            {%- endif -%}

            {%- if section.settings.show_review_badge -%}
              <div class="bloomli-product-information__rating">
                <div class="jdgm-widget jdgm-preview-badge" data-id="{{ source_product.id }}">
                  {{ source_product.metafields.judgeme.badge }}
                </div>
              </div>
            {%- endif -%}

            {%- if section.settings.show_description and source_product.description != blank -%}
              <div class="bloomli-product-information__description rte">
                {{ source_product.description }}
              </div>
            {%- endif -%}

            {%- if section.settings.show_price -%}
              <div role="status">
                {%- render 'price', product: source_product, use_variant: true, show_badges: true, price_class: 'price--large' -%}
              </div>
            {%- endif -%}

            {%- for block in section.blocks -%}
              {%- case block.type -%}
                {%- when 'volume_tier' -%}
                  {%- render 'bloomli-volume-tier', block: block, product: source_product, section_id: section.id -%}

                {%- when 'trust_icons' -%}
                  {%- render 'bloomli-trust-icons', block: block -%}

                {%- when 'what_youll_feel' -%}
                  {%- assign benefits_metafield = source_product.metafields.custom[block.settings.metafield_key] -%}
                  {%- if block.settings.prefer_product_metafield and benefits_metafield != blank -%}
                    <div class="what-youll-feel" {{ block.shopify_attributes }}>
                      <div class="what-youll-feel__card">
                        {%- if block.settings.heading != blank -%}
                          <h3 class="what-youll-feel__heading">{{ block.settings.heading }}</h3>
                        {%- endif -%}
                        <div class="rte">{{ benefits_metafield | metafield_tag }}</div>
                      </div>
                    </div>
                  {%- else -%}
                    {%- render 'what-youll-feel', block: block -%}
                  {%- endif -%}

                {%- when 'product_detail' -%}
                  {%- liquid
                    assign detail_namespace = block.settings.metafield_namespace | default: 'custom'
                    assign detail_key = block.settings.metafield_key
                    assign detail_metafield = source_product.metafields[detail_namespace][detail_key]
                  -%}
                  {%- if detail_metafield != blank or block.settings.fallback_content != blank -%}
                    <details class="bloomli-product-information__detail" {% if block.settings.open_by_default %}open{% endif %} {{ block.shopify_attributes }}>
                      <summary>{{ block.settings.title | escape }}</summary>
                      <div class="bloomli-product-information__detail-content rte">
                        {%- if detail_metafield != blank -%}
                          {{ detail_metafield | metafield_tag }}
                        {%- else -%}
                          {{ block.settings.fallback_content }}
                        {%- endif -%}
                      </div>
                    </details>
                  {%- endif -%}
              {%- endcase -%}
            {%- endfor -%}
          </div>
        </div>
      </div>
    </div>

    {%- render 'product-media-modal', product: source_product, variant_images: variant_images -%}

    <script src="{{ 'media-gallery.js' | asset_url }}" defer="defer"></script>
    <script src="{{ 'product-modal.js' | asset_url }}" defer="defer"></script>
    <script src="{{ 'product-form.js' | asset_url }}" defer="defer"></script>
  {%- else -%}
    <div class="bloomli-product-information__missing">
      Select a product in this section to display its live product information and purchase options.
    </div>
  {%- endif -%}
</section>

{% schema %}
{
  "name": "Bloomli product info",
  "tag": "section",
  "class": "section",
  "enabled_on": { "templates": ["page", "product"] },
  "settings": [
    { "type": "color_scheme", "id": "color_scheme", "label": "Color scheme", "default": "scheme-1" },
    { "type": "product", "id": "product", "label": "Product for landing pages", "info": "Product templates use the current product automatically. Page templates use this selection." },
    { "type": "header", "content": "Section introduction" },
    { "type": "checkbox", "id": "show_intro", "label": "Show section introduction", "default": true },
    { "type": "inline_richtext", "id": "heading", "label": "Heading", "default": "Meet the routine behind <em>healthier-looking hair.</em>" },
    { "type": "richtext", "id": "subtext", "label": "Subtext", "default": "<p>The original Bloomli gummies product, with live product media, pricing, subscription options and details.</p>" },
    { "type": "header", "content": "Product information" },
    { "type": "checkbox", "id": "show_title", "label": "Show product title", "default": true },
    { "type": "checkbox", "id": "show_review_badge", "label": "Show Judge.me review badge", "default": true },
    { "type": "checkbox", "id": "show_description", "label": "Show product description", "default": true },
    { "type": "checkbox", "id": "show_price", "label": "Show standard price above purchase options", "default": false },
    { "type": "checkbox", "id": "enable_sticky_info", "label": "Sticky product information on desktop", "default": true },
    { "type": "header", "content": "Gallery" },
    { "type": "select", "id": "media_size", "label": "Media size", "options": [
      { "value": "small", "label": "Small" },
      { "value": "medium", "label": "Medium" },
      { "value": "large", "label": "Large" }
    ], "default": "large" },
    { "type": "checkbox", "id": "constrain_to_viewport", "label": "Constrain media to viewport", "default": true },
    { "type": "select", "id": "media_fit", "label": "Media fit", "options": [
      { "value": "contain", "label": "Contain" },
      { "value": "cover", "label": "Cover" }
    ], "default": "contain" },
    { "type": "select", "id": "gallery_layout", "label": "Desktop gallery", "options": [
      { "value": "stacked", "label": "Stacked" },
      { "value": "columns", "label": "Columns" },
      { "value": "thumbnail", "label": "Thumbnails" },
      { "value": "thumbnail_slider", "label": "Thumbnail slider" }
    ], "default": "stacked" },
    { "type": "select", "id": "mobile_thumbnails", "label": "Mobile thumbnails", "options": [
      { "value": "columns", "label": "Columns" },
      { "value": "show", "label": "Show" },
      { "value": "hide", "label": "Hide" }
    ], "default": "hide" },
    { "type": "select", "id": "media_position", "label": "Media position", "options": [
      { "value": "left", "label": "Left" },
      { "value": "right", "label": "Right" }
    ], "default": "left" },
    { "type": "select", "id": "image_zoom", "label": "Image zoom", "options": [
      { "value": "lightbox", "label": "Lightbox" },
      { "value": "none", "label": "None" }
    ], "default": "lightbox" },
    { "type": "checkbox", "id": "hide_variants", "label": "Hide variant media", "default": true },
    { "type": "checkbox", "id": "enable_video_looping", "label": "Loop videos", "default": false },
    { "type": "header", "content": "Style" },
    { "type": "color", "id": "accent_color", "label": "Accent", "default": "#B23A6F" },
    { "type": "color", "id": "emphasis_color", "label": "Emphasis", "default": "#7B2151" },
    { "type": "range", "id": "heading_size", "label": "Heading size desktop", "min": 36, "max": 72, "step": 2, "default": 58, "unit": "px" },
    { "type": "range", "id": "heading_size_mobile", "label": "Heading size mobile", "min": 30, "max": 46, "step": 2, "default": 38, "unit": "px" },
    { "type": "header", "content": "Spacing" },
    { "type": "range", "id": "padding_top", "min": 0, "max": 160, "step": 8, "unit": "px", "label": "Padding top", "default": 112 },
    { "type": "range", "id": "padding_bottom", "min": 0, "max": 160, "step": 8, "unit": "px", "label": "Padding bottom", "default": 112 },
    { "type": "range", "id": "padding_top_mobile", "min": 0, "max": 120, "step": 8, "unit": "px", "label": "Padding top mobile", "default": 72 },
    { "type": "range", "id": "padding_bottom_mobile", "min": 0, "max": 120, "step": 8, "unit": "px", "label": "Padding bottom mobile", "default": 72 }
  ],
  "blocks": [
    {
      "type": "volume_tier",
      "name": "Purchase options",
      "limit": 1,
      "settings": [
        { "type": "text", "id": "heading", "label": "Size heading", "default": "Select your delivery:" },
        { "type": "image_picker", "id": "override_product_image", "label": "Product image override" },
        { "type": "text", "id": "add_to_cart_label", "label": "Add to cart label", "default": "Start your journey" },
        { "type": "text", "id": "sold_out_label", "label": "Sold out label", "default": "Sold out" },
        { "type": "color", "id": "save_badge_background", "label": "Save badge background", "default": "#B23A6F" },
        { "type": "color", "id": "save_badge_text_color", "label": "Save badge text", "default": "#FDFAF7" },
        { "type": "color", "id": "tier_tag_background", "label": "Tier tag background", "default": "#8A6678" },
        { "type": "color", "id": "tier_tag_text_color", "label": "Tier tag text", "default": "#FDFAF7" },
        { "type": "range", "id": "desktop_tier_title_size", "label": "Tier title size", "min": 8, "max": 18, "step": 1, "default": 14, "unit": "px" },
        { "type": "range", "id": "desktop_tier_count_size", "label": "Tier description size", "min": 8, "max": 14, "step": 1, "default": 11, "unit": "px" },
        { "type": "range", "id": "desktop_tier_daily_size", "label": "Daily price size", "min": 8, "max": 14, "step": 1, "default": 9, "unit": "px" },
        { "type": "header", "content": "Tier 1" },
        { "type": "checkbox", "id": "tier_1_show", "label": "Show tier 1", "default": true },
        { "type": "number", "id": "tier_1_qty", "label": "Tier 1 supply count", "default": 1 },
        { "type": "product", "id": "tier_1_bundle_product", "label": "Tier 1 product" },
        { "type": "text", "id": "tier_1_bundle_product_handle", "label": "Tier 1 handle fallback" },
        { "type": "text", "id": "tier_1_label", "label": "Tier 1 label", "default": "Monthly delivery" },
        { "type": "text", "id": "tier_1_count_text", "label": "Tier 1 description", "default": "A 1-month supply delivered monthly." },
        { "type": "text", "id": "tier_1_daily_text", "label": "Tier 1 daily text" },
        { "type": "image_picker", "id": "tier_1_image", "label": "Tier 1 image" },
        { "type": "text", "id": "tier_1_badge", "label": "Tier 1 badge" },
        { "type": "text", "id": "tier_1_tag", "label": "Tier 1 tag" },
        { "type": "number", "id": "tier_1_discount_pct", "label": "Tier 1 volume discount", "default": 0 },
