{{ 'bloomli-before-after.css' | asset_url | stylesheet_tag }}
<script src="{{ 'bloomli-before-after.js' | asset_url }}" defer="defer"></script>

{%- liquid
  assign visible_desktop = section.settings.cards_visible_desktop | default: 3 | at_most: 3
  assign result_count = section.blocks.size
  assign static_count = result_count | at_least: 1 | at_most: 3
  assign use_carousel = false
  if result_count > 3
    assign use_carousel = true
  endif
  assign track_id = 'BloomliResultsTrack-' | append: section.id
-%}

<section
  class="bloomli-before-after color-{{ section.settings.color_scheme }}{% if use_carousel %} is-carousel{% endif %}"
  data-bloomli-results-gallery
  data-bloomli-results-gallery-carousel="{{ use_carousel }}"
  style="
    --bba-max-width: {{ section.settings.max_width }}px;
    --bba-accent: rgb(var(--color-button));
    --bba-muted: rgba(var(--color-foreground), 0.68);
    --bba-radius: {{ section.settings.corner_radius }}px;
    --bba-image-radius: var(--media-radius, {{ section.settings.image_corner_radius }}px);
    --bba-image-aspect-ratio: 3 / 4;
    --bba-image-position: {{ section.settings.image_position }};
    --bba-heading-size: {{ section.settings.heading_size }}px;
    --bba-heading-size-mobile: {{ section.settings.heading_size_mobile }}px;
    --bba-body-size: {{ section.settings.body_size }}px;
    --bba-body-size-mobile: {{ section.settings.body_size_mobile }}px;
    --bba-gap: {{ section.settings.card_gap }}px;
    --bba-cards-desktop: {{ visible_desktop }};
    --bba-static-count: {{ static_count }};
    --bba-padding-top: {{ section.settings.padding_top }}px;
    --bba-padding-bottom: {{ section.settings.padding_bottom }}px;
    --bba-padding-top-mobile: {{ section.settings.padding_top_mobile }}px;
    --bba-padding-bottom-mobile: {{ section.settings.padding_bottom_mobile }}px;
  "
>
  <div class="bloomli-before-after__inner">
    {%- if section.settings.eyebrow != blank or section.settings.heading != blank or section.settings.copy != blank -%}
      <div class="bloomli-before-after__header">
        {%- if section.settings.eyebrow != blank -%}
          <p class="smallcaps bloomli-before-after__eyebrow">{{ section.settings.eyebrow }}</p>
        {%- endif -%}

        {%- if section.settings.heading != blank -%}
          <h2 class="bloomli-before-after__heading">{{ section.settings.heading }}</h2>
        {%- endif -%}

        {%- if section.settings.copy != blank -%}
          <div class="bloomli-before-after__copy rte">
            {{ section.settings.copy }}
          </div>
        {%- endif -%}
      </div>
    {%- endif -%}

    <div class="bloomli-before-after__gallery">
      <div
        id="{{ track_id }}"
        class="bloomli-before-after__viewport"
        aria-label="{{ section.settings.heading | default: 'Real women, real results' | escape }}"
        data-bloomli-results-viewport
      >
        <div class="bloomli-before-after__track" data-bloomli-results-track>
          {%- if section.blocks.size > 0 -%}
            {%- for block in section.blocks -%}
              {%- liquid
                assign before_alt = block.settings.before_image.alt | default: block.settings.before_label | default: 'Before result'
                assign after_alt = block.settings.after_image.alt | default: block.settings.after_label | default: block.settings.timeframe | default: 'After result'
                assign before_label = block.settings.before_label | default: 'Month 0'
                assign after_label = block.settings.after_label | default: 'Month 6'
                assign verified_label = block.settings.verified_label | default: section.settings.verified_label
              -%}

              <article class="bloomli-before-after__card" {{ block.shopify_attributes }}>
                <div class="bloomli-before-after__media-pair">
                  <figure class="bloomli-before-after__media">
                    <div class="bloomli-before-after__media-frame">
                      {%- if block.settings.before_image != blank -%}
                        {{
                          block.settings.before_image
                          | image_url: width: 900
                          | image_tag:
                            class: 'bloomli-before-after__image',
                            alt: before_alt,
                            widths: '240, 360, 520, 700, 900',
                            sizes: '(max-width: 749px) 119px, (max-width: 989px) 25vw, 16vw',
                            loading: 'lazy',
                            decoding: 'async'
                        }}
                      {%- else -%}
                        <div class="bloomli-before-after__placeholder">{{ before_label }}</div>
                      {%- endif -%}
                    </div>
                    <figcaption class="bloomli-before-after__image-label">{{ before_label }}</figcaption>
                  </figure>

                  <figure class="bloomli-before-after__media">
                    <div class="bloomli-before-after__media-frame">
                      {%- if block.settings.after_image != blank -%}
                        {{
                          block.settings.after_image
                          | image_url: width: 900
                          | image_tag:
                            class: 'bloomli-before-after__image',
                            alt: after_alt,
                            widths: '240, 360, 520, 700, 900',
                            sizes: '(max-width: 749px) 119px, (max-width: 989px) 25vw, 16vw',
                            loading: 'lazy',
                            decoding: 'async'
                        }}
                      {%- else -%}
                        <div class="bloomli-before-after__placeholder">{{ after_label }}</div>
                      {%- endif -%}
                    </div>
                    <figcaption class="bloomli-before-after__image-label">{{ after_label }}</figcaption>
                  </figure>
                </div>

                <div class="bloomli-before-after__content">
                  {%- if block.settings.timeframe != blank -%}
                    <p class="smallcaps bloomli-before-after__timeframe">{{ block.settings.timeframe }}</p>
                  {%- endif -%}

                  {%- if block.settings.review_text != blank -%}
                    <blockquote class="bloomli-before-after__review">{{ block.settings.review_text }}</blockquote>
                  {%- endif -%}
                </div>

                <div class="bloomli-before-after__footer">
                  <div class="bloomli-before-after__reviewer">
                    {%- if block.settings.reviewer_name != blank -%}
                      <p class="bloomli-before-after__name">{{ block.settings.reviewer_name }}</p>
                    {%- endif -%}

                    {%- if block.settings.verified_review -%}
                      <p class="smallcaps bloomli-before-after__verified">
                        <svg width="12" height="12" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M3 8.5 6.5 12 13 4"/></svg>
                        {{ verified_label }}
                      </p>
                    {%- endif -%}
                  </div>

                  {%- if block.settings.result_tag_1 != blank or block.settings.result_tag_2 != blank or block.settings.result_tag_3 != blank -%}
                    <div class="bloomli-before-after__tags" aria-label="Reported results">
                      {%- if block.settings.result_tag_1 != blank -%}
                        <span>{{ block.settings.result_tag_1 }}</span>
                      {%- endif -%}
                      {%- if block.settings.result_tag_2 != blank -%}
                        <span>{{ block.settings.result_tag_2 }}</span>
                      {%- endif -%}
                      {%- if block.settings.result_tag_3 != blank -%}
                        <span>{{ block.settings.result_tag_3 }}</span>
                      {%- endif -%}
                    </div>
                  {%- endif -%}
                </div>
              </article>
            {%- endfor -%}
          {%- else -%}
            <article class="bloomli-before-after__card">
              <div class="bloomli-before-after__media-pair">
                <figure class="bloomli-before-after__media">
                  <div class="bloomli-before-after__media-frame">
                    <div class="bloomli-before-after__placeholder">Month 0</div>
                  </div>
                  <figcaption class="bloomli-before-after__image-label">Month 0</figcaption>
                </figure>

                <figure class="bloomli-before-after__media">
                  <div class="bloomli-before-after__media-frame">
                    <div class="bloomli-before-after__placeholder">Month 6</div>
                  </div>
                  <figcaption class="bloomli-before-after__image-label">Month 6</figcaption>
                </figure>
              </div>

              <div class="bloomli-before-after__content">
                <p class="smallcaps bloomli-before-after__timeframe">Consistent routine</p>
                <blockquote class="bloomli-before-after__review">Visible progress from a consistent Bloomli supplement routine.</blockquote>
              </div>

              <div class="bloomli-before-after__footer">
                <div class="bloomli-before-after__reviewer">
                  <p class="bloomli-before-after__name">Bloomli customer</p>
                  <p class="smallcaps bloomli-before-after__verified">
                    <svg width="12" height="12" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M3 8.5 6.5 12 13 4"/></svg>
                    {{ section.settings.verified_label }}
                  </p>
                </div>
              </div>
            </article>
          {%- endif -%}
        </div>
      </div>

      {%- if use_carousel -%}
        <div class="bloomli-before-after__controls" aria-label="Result gallery controls">
          <button
            class="bloomli-before-after__arrow"
            type="button"
            aria-label="Previous result"
            aria-controls="{{ track_id }}"
            data-bloomli-results-prev
          >
            <svg width="18" height="18" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m12.5 4.5-5 5.5 5 5.5"/></svg>
          </button>

          <button
            class="bloomli-before-after__arrow"
            type="button"
            aria-label="Next result"
            aria-controls="{{ track_id }}"
            data-bloomli-results-next
          >
            <svg width="18" height="18" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m7.5 4.5 5 5.5-5 5.5"/></svg>
          </button>
        </div>
      {%- endif -%}
    </div>

    {%- if section.settings.caption != blank -%}
      <div class="bloomli-before-after__caption">
        {{ section.settings.caption }}
      </div>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Bloomli - Result Gallery",
  "tag": "div",
  "max_blocks": 12,
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-6d8ba907-aae6-4c49-9120-e1031d9cdb3f"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Real women, real results"
    },
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "Heading",
      "default": "The results you've been waiting for"
    },
    {
      "type": "richtext",
      "id": "copy",
      "label": "Subheading",
      "default": "<p>Static before-and-after photos paired with verified routine notes from Bloomli customers.</p>"
    },
    {
      "type": "header",
      "content": "Card style"
    },
    {
      "type": "range",
      "id": "corner_radius",
      "label": "Card corner radius",
      "min": 4,
      "max": 24,
      "step": 2,
      "default": 10,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "image_corner_radius",
      "label": "Image corner radius",
      "min": 4,
      "max": 20,
      "step": 2,
      "default": 8,
      "unit": "px"
    },
    {
      "type": "header",
      "content": "Images"
    },
    {
      "type": "select",
      "id": "image_position",
      "label": "Image crop position",
      "options": [
        {
          "value": "center center",
          "label": "Center"
        },
        {
          "value": "center top",
          "label": "Top"
        },
        {
          "value": "center bottom",
          "label": "Bottom"
        },
        {
          "value": "left center",
          "label": "Left"
        },
        {
          "value": "right center",
          "label": "Right"
        }
      ],
      "default": "center center"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "cards_visible_desktop",
      "label": "Cards shown on desktop",
      "min": 1,
      "max": 3,
      "step": 1,
      "default": 3
    },
    {
      "type": "range",
      "id": "max_width",
      "label": "Content width",
      "min": 960,
      "max": 1440,
      "step": 40,
      "default": 1200,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "card_gap",
      "label": "Card gap",
      "min": 12,
      "max": 36,
      "step": 4,
      "default": 20,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "heading_size",
      "label": "Heading size desktop",
      "min": 34,
      "max": 64,
      "step": 2,
      "default": 46,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "heading_size_mobile",
      "label": "Heading size mobile",
      "min": 28,
      "max": 46,
      "step": 2,
      "default": 36,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "body_size",
      "label": "Body size desktop",
      "min": 14,
      "max": 20,
      "step": 1,
      "default": 15,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "body_size_mobile",
      "label": "Body size mobile",
      "min": 13,
      "max": 18,
      "step": 1,
      "default": 15,
      "unit": "px"
    },
    {
      "type": "text",
      "id": "verified_label",
      "label": "Verified review label",
      "default": "Verified review"
    },
    {
      "type": "textarea",
      "id": "caption",
      "label": "Caption",
      "default": "Results vary. Before and after photos should represent real customers and be used only with permission."
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top desktop",
      "min": 40,
      "max": 176,
      "step": 8,
      "default": 96,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom desktop",
      "min": 40,
      "max": 176,
      "step": 8,
      "default": 96,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "label": "Padding top mobile",
      "min": 32,
      "max": 120,
      "step": 8,
      "default": 64,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "label": "Padding bottom mobile",
      "min": 32,
      "max": 120,
      "step": 8,
      "default": 64,
      "unit": "px"
    }
  ],
  "blocks": [
    {
      "type": "result",
      "name": "Result review",
      "settings": [
        {
          "type": "image_picker",
          "id": "before_image",
          "label": "Before image"
        },
        {
          "type": "image_picker",
          "id": "after_image",
          "label": "After image"
        },
        {
          "type": "text",
          "id": "before_label",
          "label": "Before/month label",
          "default": "Month 0"
        },
        {
          "type": "text",
          "id": "after_label",
          "label": "After/month label",
          "default": "Month 6"
        },
        {
          "type": "text",
          "id": "reviewer_name",
          "label": "Reviewer name",
          "default": "Priya K."
        },
        {
          "type": "textarea",
          "id": "review_text",
          "label": "Review text",
          "default": "\"My part line filled in noticeably at month four. The routine felt easy to stay consistent with.\""
        },
        {
          "type": "text",
          "id": "timeframe",
          "label": "Timeframe",
          "default": "6 months"
        },
        {
          "type": "text",
          "id": "result_tag_1",
          "label": "Result tag 1",
          "default": "Visibly fuller"
        },
        {
          "type": "text",
          "id": "result_tag_2",
          "label": "Result tag 2",
          "default": "Less shedding"
        },
        {
          "type": "text",
          "id": "result_tag_3",
          "label": "Result tag 3",
          "default": "Stronger hair"
        },
        {
          "type": "checkbox",
          "id": "verified_review",
          "label": "Show verified review",
          "default": true
        },
        {
          "type": "text",
          "id": "verified_label",
          "label": "Verified review text",
          "default": "Verified review"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Bloomli - Result Gallery",
      "blocks": [
        {
          "type": "result",
          "settings": {
            "reviewer_name": "Priya K.",
            "review_text": "\"My part line filled in noticeably at month four. The routine felt easy to stay consistent with.\"",
            "timeframe": "6 months",
            "result_tag_1": "Visibly fuller",
            "result_tag_2": "Less shedding",
            "result_tag_3": "Stronger hair"
          }
        },
        {
          "type": "result",
          "settings": {
            "reviewer_name": "Leah M.",
            "review_text": "\"The shedding slowed down first, then I started seeing baby hairs around my hairline.\"",
            "timeframe": "3 months",
            "result_tag_1": "Less shedding",
            "result_tag_2": "New growth",
            "result_tag_3": ""
          }
        },
        {
          "type": "result",
          "settings": {
            "reviewer_name": "Marisol R.",
            "review_text": "\"My hair feels stronger and the difference in photos made me realize the routine was working.\"",
            "timeframe": "6 months",
            "result_tag_1": "Stronger hair",
            "result_tag_2": "Visible progress",
            "result_tag_3": ""
          }
        }
      ]
    }
  ]
}
{% endschema %}
