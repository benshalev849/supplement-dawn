{% comment %}
  Renders cart drawer

  Usage:
  {% render 'cart-drawer' %}
{% endcomment %}

{{ 'quantity-popover.css' | asset_url | stylesheet_tag }}
{{ 'component-card.css' | asset_url | stylesheet_tag }}
{{ 'bloomli-product-stack.css' | asset_url | stylesheet_tag }}
{{ 'bloomli-cart-drawer.css' | asset_url | stylesheet_tag }}
{{ 'bloomli-cart-subscription-upsell.css' | asset_url | stylesheet_tag }}

<script src="{{ 'cart.js' | asset_url }}" defer="defer"></script>
<script src="{{ 'quantity-popover.js' | asset_url }}" defer="defer"></script>
<script src="{{ 'bloomli-cart-drawer.js' | asset_url }}" defer="defer"></script>
<script src="{{ 'bloomli-cart-subscription-upsell.js' | asset_url }}" defer="defer"></script>

<style>
  .drawer {
    visibility: hidden;
  }
</style>

<cart-drawer class="drawer{% if cart == empty %} is-empty{% endif %}">
  <div
    id="CartDrawer"
    class="cart-drawer"
    style="
      --bloomli-cart-accent: {{ settings.cart_drawer_accent_color | default: '#B23A6F' }};
      --bloomli-cart-accent-contrast: {{ settings.cart_drawer_accent_text_color | default: '#FDFAF7' }};
      --bloomli-cart-text: {{ settings.cart_drawer_text_color | default: '#2A2622' }};
      --bloomli-cart-soft-bg: {{ settings.cart_drawer_soft_background | default: '#FDFAF7' }};
      --bloomli-cart-shipping-bg: {{ settings.cart_drawer_shipping_background | default: '#F5E0DC' }};
      --bloomli-cart-product-bg: {{ settings.cart_drawer_product_background | default: '#FFFDFC' }};
      --bloomli-cart-product-card-bg: {{ settings.cart_drawer_product_card_background | default: '#FFFDFC' }};
      --bloomli-cart-border: {{ settings.cart_drawer_border_color | default: '#E8DED8' }};
      --bloomli-cart-compare: {{ settings.cart_drawer_compare_price_color | default: '#9A8F89' }};
      --bloomli-cart-footer-bg: {{ settings.cart_drawer_footer_background | default: '#FDFAF7' }};
      --bloomli-cart-heading-size: {{ settings.cart_drawer_heading_font_size | default: 20 }}px;
      --bloomli-cart-body-size: {{ settings.cart_drawer_body_font_size | default: 15 }}px;
      --bloomli-cart-price-size: {{ settings.cart_drawer_price_font_size | default: 17 }}px;
      --bloomli-cart-product-name-size: {{ settings.cart_drawer_product_name_font_size | default: 15 }}px;
      --bloomli-cart-frequency-size: {{ settings.cart_drawer_frequency_font_size | default: 15 }}px;
      --bloomli-cart-tax-note-size: {{ settings.cart_drawer_tax_note_font_size | default: 11 }}px;
      --bloomli-cart-image-size: {{ settings.cart_drawer_product_image_size | default: 124 }}px;
      --bloomli-cart-item-row-gap: {{ settings.cart_drawer_item_row_gap | default: 6 }}px;
      --bloomli-cart-item-column-gap: {{ settings.cart_drawer_item_column_gap | default: 8 }}px;
      --bloomli-cart-frequency-top-spacing: {{ settings.cart_drawer_frequency_top_spacing | default: 6 }}px;
      --bloomli-cart-price-top-offset: {{ settings.cart_drawer_price_top_offset | default: 0 }}px;
      --bloomli-cart-checkout-radius: {{ settings.cart_drawer_checkout_radius | default: 8 }}px;
      --bloomli-cart-offer-height: {{ settings.cart_drawer_quantity_offer_height | default: 32 }}px;
      --bloomli-cart-offer-font-size: {{ settings.cart_drawer_quantity_offer_font_size | default: 12 }}px;
    "
  >
    <div id="CartDrawer-Overlay" class="cart-drawer__overlay"></div>
    <div
      class="drawer__inner gradient color-{{ settings.cart_color_scheme }}"
      role="dialog"
      aria-modal="true"
      aria-label="{{ 'sections.cart.title' | t }}"
      tabindex="-1"
    >
      {%- if cart == empty -%}
        <div class="drawer__inner-empty">
          <div class="cart-drawer__warnings center{% if settings.cart_drawer_collection != blank %} cart-drawer__warnings--has-collection{% endif %}">
            <div class="cart-drawer__empty-content">
              <h2 class="cart__empty-text">{{ 'sections.cart.empty' | t }}</h2>
              <button
                class="drawer__close"
                type="button"
                onclick="this.closest('cart-drawer').close()"
                aria-label="{{ 'accessibility.close' | t }}"
              >
                <span class="svg-wrapper">
                  {{- 'icon-close.svg' | inline_asset_content -}}
                </span>
              </button>
              <a href="{{ routes.all_products_collection_url }}" class="button">
                {{ 'general.continue_shopping' | t }}
              </a>

              {%- if shop.customer_accounts_enabled and customer == null -%}
                <p class="cart__login-title h3">{{ 'sections.cart.login.title' | t }}</p>
                <p class="cart__login-paragraph">
                  {{ 'sections.cart.login.paragraph_html' | t: link: routes.account_login_url }}
                </p>
              {%- endif -%}
            </div>
          </div>
          {%- if settings.cart_drawer_collection != blank -%}
            <div class="cart-drawer__collection">
              {% render 'card-collection', card_collection: settings.cart_drawer_collection, columns: 1 %}
            </div>
          {%- endif -%}
        </div>
      {%- endif -%}
      <div class="drawer__header">
        <h2 class="drawer__heading">
          {{ 'sections.cart.title' | t }}
          <span class="bloomli-cart-drawer__count">({{ cart.item_count }})</span>
        </h2>
        <button
          class="drawer__close"
          type="button"
          onclick="this.closest('cart-drawer').close()"
          aria-label="{{ 'accessibility.close' | t }}"
        >
          <span class="svg-wrapper">
            {{- 'icon-close.svg' | inline_asset_content -}}
          </span>
        </button>
      </div>
      {%- if cart != empty and settings.cart_free_shipping_bar_enabled -%}
        {%- liquid
          assign has_subscription_item = false
          for item in cart.items
            if item.selling_plan_allocation != null or item.selling_plan != blank
              assign has_subscription_item = true
              break
            endif
          endfor

          assign free_shipping_threshold = settings.cart_free_shipping_threshold | default: 100 | times: 100
          assign free_shipping_remaining = free_shipping_threshold | minus: cart.total_price
          if has_subscription_item
            assign free_shipping_remaining = 0
          endif
          assign free_shipping_progress = 100
          if free_shipping_threshold > 0 and free_shipping_remaining > 0
            assign free_shipping_progress = cart.total_price | times: 100 | divided_by: free_shipping_threshold
          endif
          if free_shipping_progress > 100
            assign free_shipping_progress = 100
          endif
          assign free_shipping_progress_text = settings.cart_free_shipping_progress_text | default: 'Add [amount] more and get Free Shipping'
          assign free_shipping_remaining_money = free_shipping_remaining | money
          assign free_shipping_remaining_markup = '<strong>' | append: free_shipping_remaining_money | append: '</strong>'
          assign free_shipping_message = free_shipping_progress_text | replace: '[amount]', free_shipping_remaining_markup
          if free_shipping_remaining <= 0
            assign free_shipping_message = settings.cart_free_shipping_unlocked_text | default: "Congrats, you've unlocked Free Shipping!"
            assign free_shipping_message = free_shipping_message | replace: 'Free Shipping', '<strong>Free Shipping</strong>'
            assign free_shipping_message = free_shipping_message | replace: 'FREE SHIPPING', '<strong>FREE SHIPPING</strong>'
          endif
        -%}
        <div class="bloomli-cart-shipping" data-bloomli-cart-shipping>
          <p class="bloomli-cart-shipping__text">{{ free_shipping_message }}</p>
          <div class="bloomli-cart-shipping__track" aria-hidden="true">
            <span class="bloomli-cart-shipping__fill" style="width: {{ free_shipping_progress }}%;"></span>
          </div>
        </div>
      {%- endif -%}
      <cart-drawer-items
        {% if cart == empty %}
          class=" is-empty"
        {% endif %}
      >
        <form
          action="{{ routes.cart_url }}"
          id="CartDrawer-Form"
          class="cart__contents cart-drawer__form"
          method="post"
        >
          <div id="CartDrawer-CartItems" class="drawer__contents js-contents">
            {%- if cart != empty -%}
              <div class="drawer__cart-items-wrapper">
                <table class="cart-items" role="table">
                  <thead role="rowgroup">
                    <tr role="row">
                      <th id="CartDrawer-ColumnProductImage" role="columnheader">
                        <span class="visually-hidden">{{ 'sections.cart.headings.image' | t }}</span>
                      </th>
                      <th
                        id="CartDrawer-ColumnProduct"
                        class="caption-with-letter-spacing"
                        scope="col"
                        role="columnheader"
                      >
                        {{ 'sections.cart.headings.product' | t }}
                      </th>
                      <th
                        id="CartDrawer-ColumnTotal"
                        class="right caption-with-letter-spacing"
                        scope="col"
                        role="columnheader"
                      >
                        {{ 'sections.cart.headings.total' | t }}
                      </th>
                      <th id="CartDrawer-ColumnQuantity" role="columnheader">
                        <span class="visually-hidden">{{ 'sections.cart.headings.quantity' | t }}</span>
                      </th>
                    </tr>
                  </thead>

                  <tbody role="rowgroup">
                    {%- for item in cart.items -%}
                      <tr
                        id="CartDrawer-Item-{{ item.index | plus: 1 }}"
                        class="cart-item{% if item.parent_relationship.parent != null %} cart-item__nested-line{% endif %}"
                        role="row"
                        {% if item.parent_relationship.parent != null %}
                          aria-label="{{- 'products.product.nested_label' | t: title: item.product.title, parent_title: item.parent_relationship.parent.title | escape -}}"
                        {% endif %}
                      >
                        <td
                          class="cart-item__media"
                          role="cell"
                          headers="CartDrawer-ColumnProductImage"
                        >
                          {% if item.image %}
                            <a href="{{ item.url }}" class="bloomli-cart-media-link" aria-label="{{ item.product.title | escape }}">
                              <img
                                src="{{ item.image | image_url: width: 520 }}"
                                class="cart-item__image bloomli-cart-media-image"
                                alt="{{ item.image.alt | default: item.product.title | escape }}"
                                loading="lazy"
                                width="260"
                                height="{{ 260 | divided_by: item.image.aspect_ratio | ceil }}"
                              >
                            </a>
                          {% endif %}
                        </td>

                        <td class="cart-item__details" role="cell" headers="CartDrawer-ColumnProduct">
                          {%- if settings.show_vendor -%}
                            <p class="caption-with-letter-spacing light">{{ item.product.vendor }}</p>
                          {%- endif -%}

                          <a href="{{ item.url }}" class="cart-item__name h4 break">
                            {{- item.product.title | escape -}}
                          </a>

                          <cart-remove-button
                            id="CartDrawer-Remove-{{ item.index | plus: 1 }}"
                            data-index="{{ item.index | plus: 1 }}"
                          >
                            <button
                              type="button"
                              class="button button--tertiary cart-remove-button"
                              aria-label="{{ 'sections.cart.remove_title' | t: title: item.title | escape }}"
                              data-variant-id="{{ item.variant.id }}"
                              {% if item.instructions and item.instructions.can_remove == false %}
                                class="hidden"
                              {% endif %}
                            >
                              <span class="svg-wrapper">
                                {{- 'icon-remove.svg' | inline_asset_content -}}
                              </span>
                            </button>
                          </cart-remove-button>

                          {%- if item.product.has_only_default_variant == false
                            or item.properties.size != 0
                            or item.selling_plan_allocation != null
                          -%}
                            <dl>
                              {%- if item.product.has_only_default_variant == false -%}
                                {%- for option in item.options_with_values -%}
                                  <div class="product-option">
                                    <dt>{{ option.name }}:</dt>
                                    <dd>
                                      {{ option.value -}}
                                      {%- unless forloop.last %}, {% endunless %}
                                    </dd>
                                  </div>
                                {%- endfor -%}
                              {%- endif -%}

                              {%- for property in item.properties -%}
                                {%- assign property_first_char = property.first | slice: 0 -%}
                                {%- if property.last != blank and property_first_char != '_' -%}
                                  <div class="product-option">
                                    <dt>{{ property.first }}:</dt>
                                    <dd>
                                      {%- if property.last contains '/uploads/' -%}
                                        <a
                                          href="{{ property.last }}"
                                          class="link"
                                          target="_blank"
                                          aria-describedby="a11y-new-window-message"
                                        >
                                          {{ property.last | split: '/' | last }}
                                        </a>
                                      {%- else -%}
                                        {{ property.last }}
                                      {%- endif -%}
                                    </dd>
                                  </div>
                                {%- endif -%}
                              {%- endfor -%}
                            </dl>

                          {%- endif -%}

                          <ul
                            class="discounts list-unstyled"
                            role="list"
                            aria-label="{{ 'customer.order.discount' | t }}"
                          >
                            {%- for discount in item.line_level_discount_allocations -%}
                              <li class="discounts__discount">
                                {{- 'icon-discount.svg' | inline_asset_content -}}
                                {{ discount.discount_application.title }}
                              </li>
                            {%- endfor -%}
                          </ul>
                        </td>

                        <td class="cart-item__totals right" role="cell" headers="CartDrawer-ColumnTotal">
                          {%- render 'loading-spinner' -%}
                          <div class="cart-item__price-wrapper">
                            {%- liquid
                              assign line_compare_price = item.original_line_price
                              if item.variant.compare_at_price and item.variant.compare_at_price > item.variant.price
                                assign line_compare_price = item.variant.compare_at_price | times: item.quantity
                              endif
                            -%}
                            {%- if line_compare_price > item.final_line_price -%}
                              <div class="cart-item__discounted-prices">
                                <span class="visually-hidden">
                                  {{ 'products.product.price.regular_price' | t }}
                                </span>
                                <s class="cart-item__old-price price price--end">
                                  {{ line_compare_price | money }}
                                </s>
                                <span class="visually-hidden">
                                  {{ 'products.product.price.sale_price' | t }}
                                </span>
                                <span class="price price--end">
                                  {{ item.final_line_price | money }}
                                </span>
                              </div>
                            {%- else -%}
                              <span class="price price--end">
                                {{ item.original_line_price | money }}
                              </span>
                            {%- endif -%}

                            {%- if item.variant.available and item.unit_price_measurement -%}
                              {% render 'unit-price', price: item.unit_price, measurement: item.unit_price_measurement %}
                            {%- endif -%}
                          </div>
                        </td>
                        {%- liquid
                          assign has_qty_rules = false
                          if item.variant.quantity_rule.increment > 1 or item.variant.quantity_rule.min > 1 or item.variant.quantity_rule.max != null
                            assign has_qty_rules = true
                          endif

                          assign has_vol_pricing = false
                          if item.variant.quantity_price_breaks.size > 0
                            assign has_vol_pricing = true
                          endif

                          assign bloomli_quantity_max = 15
                          if item.variant.quantity_rule.max != null and item.variant.quantity_rule.max < bloomli_quantity_max
                            assign bloomli_quantity_max = item.variant.quantity_rule.max
                          endif
                        -%}
                        <td
                          class="cart-item__quantity {% if has_qty_rules or has_vol_pricing %} cart-item__quantity--info{% endif %}"
                          role="cell"
                          headers="CartDrawer-ColumnQuantity"
                        >
                          <quantity-popover>
                            <div class="cart-item__quantity-wrapper quantity-popover-wrapper">
                              <div class="quantity-popover-container{% if has_qty_rules or has_vol_pricing %} quantity-popover-container--hover{% endif %}">
                                <quantity-input class="quantity cart-quantity">
                                  <button
                                    class="quantity__button"
                                    name="minus"
                                    type="button"
                                    {% if item.instructions and item.instructions.can_update_quantity == false %}
                                      disabled
                                    {% endif %}
                                  >
                                    <span class="visually-hidden">
                                      {{-
                                        'products.product.quantity.decrease'
                                        | t: product: item.product.title
                                        | escape
                                      -}}
                                    </span>
                                    <span class="svg-wrapper">
                                      {{- 'icon-minus.svg' | inline_asset_content -}}
                                    </span>
                                  </button>
                                  <input
                                    class="quantity__input"
                                    type="number"
                                    data-quantity-variant-id="{{ item.variant.id }}"
                                    name="updates[]"
                                    value="{{ item.quantity }}"
                                    {% # theme-check-disable %}
                                    data-cart-quantity="{{ cart | item_count_for_variant: item.variant.id }}"
                                    min="0"
                                    data-min="{{ item.variant.quantity_rule.min }}"
                                    max="{{ bloomli_quantity_max }}"
                                    step="{{ item.variant.quantity_rule.increment }}"
                                    {% # theme-check-enable %}
                                    {% render 'bloomli-selling-plan-quantity-attrs', item: item %}
                                    aria-label="{{ 'products.product.quantity.input_label' | t: product: item.product.title | escape }}"
                                    id="Drawer-quantity-{{ item.index | plus: 1 }}"
                                    data-index="{{ item.index | plus: 1 }}"
                                    {% if item.instructions and item.instructions.can_update_quantity == false %}
                                      disabled
                                    {% endif %}
                                  >
                                  <button
                                    class="quantity__button"
                                    name="plus"
                                    type="button"
                                    {% if item.instructions and item.instructions.can_update_quantity == false %}
                                      disabled
                                    {% endif %}
                                  >
                                    <span class="visually-hidden">
                                      {{-
                                        'products.product.quantity.increase'
                                        | t: product: item.product.title
                                        | escape
                                      -}}
                                    </span>
                                    <span class="svg-wrapper">
                                      {{- 'icon-plus.svg' | inline_asset_content -}}
                                    </span>
                                  </button>
                                </quantity-input>
                              </div>
                            </div>
                            {%- if has_qty_rules or has_vol_pricing -%}
                              <button
                                type="button"
                                class="quantity-popover__info-button quantity-popover__info-button--icon-with-label button button--tertiary"
                                aria-expanded="false"
                              >
                                <span class="svg-wrapper">
                                  {{- 'icon-info.svg' | inline_asset_content -}}
                                </span>
                                <span>
                                  {%- if has_vol_pricing -%}
                                    {{ 'products.product.volume_pricing.note' | t }}
                                  {%- elsif has_qty_rules -%}
                                    {{ 'products.product.quantity.note' | t }}
                                  {%- endif -%}
                                </span>
                              </button>
                            {%- endif -%}
                            {%- if has_vol_pricing or has_qty_rules -%}
                              <div
                                class="cart-items__info global-settings-popup quantity-popover__info"
                                tabindex="-1"
                                hidden
                              >
                                {%- if has_qty_rules == false -%}
                                  <span class="volume-pricing-label caption">
                                    {{- 'products.product.volume_pricing.title' | t -}}
                                  </span>
                                {%- endif -%}
                                <div class="quantity__rules caption">
                                  {%- if item.variant.quantity_rule.increment > 1 -%}
                                    <span class="divider">
                                      {{-
                                        'products.product.quantity.multiples_of'
                                        | t: quantity: item.variant.quantity_rule.increment
                                      -}}
                                    </span>
                                  {%- endif -%}
                                  {%- if item.variant.quantity_rule.min > 1 -%}
                                    <span class="divider">
                                      {{-
                                        'products.product.quantity.min_of'
                                        | t: quantity: item.variant.quantity_rule.min
                                      -}}
                                    </span>
                                  {%- endif -%}
                                  {%- if item.variant.quantity_rule.max != null -%}
                                    <span class="divider">
                                      {{-
                                        'products.product.quantity.max_of'
                                        | t: quantity: item.variant.quantity_rule.max
                                      -}}
                                    </span>
                                  {%- endif -%}
                                </div>
                                <button
                                  class="button-close button button--tertiary"
                                  type="button"
                                  aria-label="{{ 'accessibility.close' | t }}"
                                >
                                  <span class="svg-wrapper">
                                    {{- 'icon-close.svg' | inline_asset_content -}}
                                  </span>
                                </button>
                                {%- if item.variant.quantity_price_breaks.size > 0 -%}
                                  <volume-pricing class="parent-display">
                                    <ul class="list-unstyled">
                                      <li>
                                        <span>{{ item.variant.quantity_rule.min }}+</span>
                                        <span>{{ item.variant.price | money_with_currency }}/ea</span>
                                      </li>
                                      {%- for price_break in item.variant.quantity_price_breaks -%}
                                        <li>
                                          <span>
                                            {{- price_break.minimum_quantity -}}
                                            <span aria-hidden="true">+</span></span
                                          >
                                          <span>{{ price_break.price | money_with_currency }}/ea</span>
                                        </li>
                                      {%- endfor -%}
                                    </ul>
                                  </volume-pricing>
                                {%- endif -%}
                              </div>
                            {%- endif -%}
                            <div
                              id="CartDrawer-LineItemError-{{ item.index | plus: 1 }}"
                              class="cart-item__error"
                              role="alert"
                            >
                              <small class="cart-item__error-text"></small>
                              <span class="svg-wrapper">
                                {{- 'icon-error.svg' | inline_asset_content -}}
                              </span>
                            </div>
                          </quantity-popover>
                        </td>

                        <td
                          class="bloomli-cart-offers-cell"
                          role="cell"
                          headers="CartDrawer-ColumnQuantity"
                        >
                          {%- liquid
                            assign offer_label_template = settings.cart_drawer_quantity_offer_label_template | default: 'BUY [qty] SAVE [percent]%'
                            assign cart_subscription_discount = settings.cart_drawer_subscription_discount_pct | default: 10 | plus: 0
                            assign offer_3_volume_savings = settings.cart_drawer_quantity_offer_3_savings | default: 15 | plus: 0
                            assign offer_4_volume_savings = settings.cart_drawer_quantity_offer_4_savings | default: 18 | plus: 0
                            assign offer_5_volume_savings = settings.cart_drawer_quantity_offer_5_savings | default: 20 | plus: 0
                            assign offer_3_savings = offer_3_volume_savings
                            assign offer_4_savings = offer_4_volume_savings
                            assign offer_5_savings = offer_5_volume_savings
                            if item.selling_plan_allocation != null
                              comment
                                Volume and subscription discounts compound: 15% + 10% displays as 24%, not 25%.
                              endcomment
                              assign subscription_factor = 100.0 | minus: cart_subscription_discount
                              assign offer_3_factor = 100.0 | minus: offer_3_volume_savings | times: subscription_factor | divided_by: 100.0
                              assign offer_4_factor = 100.0 | minus: offer_4_volume_savings | times: subscription_factor | divided_by: 100.0
                              assign offer_5_factor = 100.0 | minus: offer_5_volume_savings | times: subscription_factor | divided_by: 100.0
                              assign offer_3_savings = 100.0 | minus: offer_3_factor
                              assign offer_4_savings = 100.0 | minus: offer_4_factor
                              assign offer_5_savings = 100.0 | minus: offer_5_factor
                            endif
                            if item.variant.compare_at_price and item.variant.compare_at_price > item.variant.price
                              assign bloomli_compare_unit = item.variant.compare_at_price | times: 1.0
                              assign bloomli_vol3_factor = 100.0 | minus: offer_3_volume_savings | divided_by: 100.0
                              assign bloomli_vol4_factor = 100.0 | minus: offer_4_volume_savings | divided_by: 100.0
                              assign bloomli_vol5_factor = 100.0 | minus: offer_5_volume_savings | divided_by: 100.0
                              assign bloomli_discounted3 = item.variant.price | times: bloomli_vol3_factor
                              assign bloomli_discounted4 = item.variant.price | times: bloomli_vol4_factor
                              assign bloomli_discounted5 = item.variant.price | times: bloomli_vol5_factor
                              if item.selling_plan_allocation != null
                                assign bloomli_sub_factor = 100.0 | minus: cart_subscription_discount | divided_by: 100.0
                                assign bloomli_discounted3 = bloomli_discounted3 | times: bloomli_sub_factor
                                assign bloomli_discounted4 = bloomli_discounted4 | times: bloomli_sub_factor
                                assign bloomli_discounted5 = bloomli_discounted5 | times: bloomli_sub_factor
                              endif
                              assign offer_3_savings = bloomli_compare_unit | minus: bloomli_discounted3 | times: 100.0 | divided_by: bloomli_compare_unit
                              assign offer_4_savings = bloomli_compare_unit | minus: bloomli_discounted4 | times: 100.0 | divided_by: bloomli_compare_unit
                              assign offer_5_savings = bloomli_compare_unit | minus: bloomli_discounted5 | times: 100.0 | divided_by: bloomli_compare_unit
                            endif
                            assign offer_3_rounded = offer_3_savings | round
                            assign offer_4_rounded = offer_4_savings | round
                            assign offer_5_rounded = offer_5_savings | round
                            assign offer_3_label = offer_label_template | replace: '[qty]', '3' | replace: '[percent]', offer_3_rounded
                            assign offer_4_label = offer_label_template | replace: '[qty]', '4' | replace: '[percent]', offer_4_rounded
                            assign offer_5_label = offer_label_template | replace: '[qty]', '5' | replace: '[percent]', offer_5_rounded
                            assign can_update_line = true
                            if item.instructions and item.instructions.can_update_quantity == false
                              assign can_update_line = false
                            endif
                          -%}
                          <div
                            class="bloomli-cart-offers"
                            data-bloomli-cart-offers
                            {% render 'bloomli-selling-plan-quantity-attrs', item: item %}
                          >
                            <button
                              type="button"
                              class="bloomli-cart-offer{% if item.quantity >= 3 %} is-active{% endif %}"
                              data-bloomli-cart-quantity-offer
                              data-line="{{ item.index | plus: 1 }}"
                              data-quantity="3"
                              {% if item.quantity >= 3 or can_update_line == false %}disabled{% endif %}
                            >
                              {{ offer_3_label }}
                            </button>
                            <button
                              type="button"
                              class="bloomli-cart-offer{% if item.quantity >= 4 %} is-active{% endif %}"
                              data-bloomli-cart-quantity-offer
                              data-line="{{ item.index | plus: 1 }}"
                              data-quantity="4"
                              {% if item.quantity >= 4 or can_update_line == false %}disabled{% endif %}
                            >
                              {{ offer_4_label }}
                            </button>
                            <button
                              type="button"
                              class="bloomli-cart-offer{% if item.quantity >= 5 %} is-active{% endif %}"
                              data-bloomli-cart-quantity-offer
                              data-line="{{ item.index | plus: 1 }}"
                              data-quantity="5"
                              {% if item.quantity >= 5 or can_update_line == false %}disabled{% endif %}
                            >
                              {{ offer_5_label }}
                            </button>
                          </div>
                        </td>

                          {%- if item.selling_plan_allocation != null -%}
                            <td
                              class="bloomli-cart-frequency-cell"
                              role="cell"
                              headers="CartDrawer-ColumnQuantity"
                            >
                            {%- liquid
                              assign current_selling_plan_id = item.selling_plan_allocation.selling_plan.id
                              assign frequency_prefix = settings.cart_subscription_frequency_prefix | default: 'Delivers every'
                              assign savings_prefix = settings.cart_subscription_savings_prefix | default: 'SAVE'
                            -%}
                            {%- for selling_plan_group in item.product.selling_plan_groups -%}
                              {%- liquid
                                assign group_has_current_plan = false
                                for selling_plan in selling_plan_group.selling_plans
                                  if selling_plan.id == current_selling_plan_id
                                    assign group_has_current_plan = true
                                  endif
                                endfor
                              -%}
                              {%- if group_has_current_plan -%}
                                <div class="bloomli-cart-frequency" data-bloomli-cart-frequency>
                                  {%- assign current_save_label = '' -%}
                                  {%- assign current_plan_label = item.selling_plan_allocation.selling_plan.name -%}
                                  <label class="visually-hidden" for="CartDrawer-Frequency-{{ item.index | plus: 1 }}">
                                    Subscription frequency
                                  </label>
                                  <select
                                    id="CartDrawer-Frequency-{{ item.index | plus: 1 }}"
                                    class="bloomli-cart-frequency__select"
                                    tabindex="-1"
                                    aria-hidden="true"
                                    data-bloomli-frequency-select
                                    data-line="{{ item.index | plus: 1 }}"
                                    data-line-key="{{ item.key }}"
                                    data-quantity="{{ item.quantity }}"
                                  >
                                    {%- for selling_plan in selling_plan_group.selling_plans -%}
                                      {%- liquid
                                        assign plan_label = selling_plan.name
                                        assign plan_option = selling_plan.options | first
                                        assign plan_option_value = plan_option.value | downcase
                                        if plan_option_value contains 'month'
                                          assign month_count = plan_option_value | split: 'month' | first | plus: 0
                                          if month_count > 0
                                            assign plan_label = frequency_prefix | append: ' ' | append: month_count | append: ' month'
                                            unless month_count == 1
                                              assign plan_label = plan_label | append: 's'
                                            endunless
                                          endif
                                        endif

                                        assign save_label = ''
                                        assign plan_adjustment = selling_plan.price_adjustments | first
                                        if plan_adjustment and plan_adjustment.value_type == 'percentage'
                                          assign save_value = plan_adjustment.value | plus: 0
                                          if item.variant.compare_at_price and item.variant.compare_at_price > item.variant.price
                                            assign bloomli_sub_factor = 100.0 | minus: save_value | divided_by: 100.0
                                            assign bloomli_sub_unit = item.variant.price | times: bloomli_sub_factor
                                            assign bloomli_compare_u = item.variant.compare_at_price | times: 1.0
                                            assign save_value = bloomli_compare_u | minus: bloomli_sub_unit | times: 100.0 | divided_by: bloomli_compare_u | round
                                          endif
                                          if save_value > 0
                                            assign save_label = savings_prefix | append: ' ' | append: save_value | append: '%'
                                          endif
                                        endif
                                      -%}
                                      <option
                                        value="{{ selling_plan.id }}"
                                        data-label="{{ plan_label | escape }}"
                                        data-saving="{{ save_label | escape }}"
                                        {% if selling_plan.id == current_selling_plan_id %}
                                          selected
                                        {% endif %}
                                      >
                                        {{ plan_label }}
                                      </option>
                                      {%- if selling_plan.id == current_selling_plan_id -%}
                                        {%- assign current_save_label = save_label -%}
                                        {%- assign current_plan_label = plan_label -%}
                                      {%- endif -%}
                                    {%- endfor -%}
                                  </select>
                                  <button
                                    type="button"
                                    class="bloomli-cart-frequency__toggle"
                                    data-bloomli-frequency-toggle
                                    aria-expanded="false"
                                    aria-controls="CartDrawer-FrequencyMenu-{{ item.index | plus: 1 }}"
                                  >
                                    <span class="bloomli-cart-frequency__label">{{ current_plan_label }}</span>
                                    {%- if current_save_label != blank -%}
                                      <span class="bloomli-cart-frequency__saving">{{ current_save_label }}</span>
                                    {%- endif -%}
                                    <span class="bloomli-cart-frequency__chevron">
                                      {{- 'icon-caret.svg' | inline_asset_content -}}
                                    </span>
                                  </button>
                                  <ul
                                    id="CartDrawer-FrequencyMenu-{{ item.index | plus: 1 }}"
                                    class="bloomli-cart-frequency__menu"
                                    data-bloomli-frequency-menu
                                    hidden
                                  >
                                    {%- for selling_plan in selling_plan_group.selling_plans -%}
                                      {%- liquid
                                        assign plan_label = selling_plan.name
                                        assign plan_option = selling_plan.options | first
                                        assign plan_option_value = plan_option.value | downcase
                                        if plan_option_value contains 'month'
                                          assign month_count = plan_option_value | split: 'month' | first | plus: 0
                                          if month_count > 0
                                            assign plan_label = frequency_prefix | append: ' ' | append: month_count | append: ' month'
                                            unless month_count == 1
                                              assign plan_label = plan_label | append: 's'
                                            endunless
                                          endif
                                        endif

                                        assign save_label = ''
                                        assign plan_adjustment = selling_plan.price_adjustments | first
                                        if plan_adjustment and plan_adjustment.value_type == 'percentage'
                                          assign save_value = plan_adjustment.value | plus: 0
                                          if item.variant.compare_at_price and item.variant.compare_at_price > item.variant.price
                                            assign bloomli_sub_factor = 100.0 | minus: save_value | divided_by: 100.0
                                            assign bloomli_sub_unit = item.variant.price | times: bloomli_sub_factor
                                            assign bloomli_compare_u = item.variant.compare_at_price | times: 1.0
                                            assign save_value = bloomli_compare_u | minus: bloomli_sub_unit | times: 100.0 | divided_by: bloomli_compare_u | round
                                          endif
                                          if save_value > 0
                                            assign save_label = savings_prefix | append: ' ' | append: save_value | append: '%'
                                          endif
                                        endif
                                      -%}
                                      <li class="bloomli-cart-frequency__menu-item">
                                        <button
                                          type="button"
                                          class="bloomli-cart-frequency__option{% if selling_plan.id == current_selling_plan_id %} is-selected{% endif %}"
                                          data-bloomli-frequency-option
                                          data-selling-plan="{{ selling_plan.id }}"
                                          data-label="{{ plan_label | escape }}"
                                          data-saving="{{ save_label | escape }}"
                                        >
                                          <span class="bloomli-cart-frequency__check" aria-hidden="true">&#10003;</span>
                                          <span class="bloomli-cart-frequency__option-label">{{ plan_label }}</span>
                                          {%- if save_label != blank -%}
                                            <span class="bloomli-cart-frequency__option-saving">{{ save_label }}</span>
                                          {%- endif -%}
                                        </button>
                                      </li>
                                    {%- endfor -%}
                                  </ul>
                                </div>
                                {%- break -%}
                              {%- endif -%}
                            {%- endfor -%}
                            </td>
                          {%- endif -%}
                      </tr>
                      {%- if settings.cart_line_subscription_upsell_enabled != false and item.selling_plan_allocation == null -%}
                        <tr class="bloomli-cart-line-upsell-row" role="row">
                          <td colspan="4" role="cell">
                            {%- render 'bloomli-cart-subscription-upsell', item: item, context: 'drawer' -%}
                          </td>
                        </tr>
                      {%- endif -%}
                    {%- endfor -%}
                  </tbody>
                </table>
              </div>
            {%- endif -%}
            <p id="CartDrawer-LiveRegionText" class="visually-hidden" role="status"></p>
            <p id="CartDrawer-LineItemStatus" class="visually-hidden" aria-hidden="true" role="status">
              {{ 'accessibility.loading' | t }}
            </p>
          </div>
          <div id="CartDrawer-CartErrors" role="alert"></div>
        </form>
      </cart-drawer-items>
      <div class="drawer__footer">
        {%- if settings.show_cart_note -%}
          <details id="Details-CartDrawer">
            <summary>
              <span class="summary__title">
                {{ 'sections.cart.note' | t }}
                {{- 'icon-caret.svg' | inline_asset_content -}}
              </span>
            </summary>
            <cart-note class="cart__note field">
              <label class="visually-hidden" for="CartDrawer-Note">{{ 'sections.cart.note' | t }}</label>
              <textarea
                id="CartDrawer-Note"
                class="text-area text-area--resize-vertical field__input"
                name="note"
                placeholder="{{ 'sections.cart.note' | t }}"
              >{{ cart.note }}</textarea>
            </cart-note>
          </details>
        {%- endif -%}

        <!-- Start blocks -->
        <!-- Subtotals -->

        <div class="cart-drawer__footer" {{ block.shopify_attributes }}>
          <div>
            {%- if cart.cart_level_discount_applications.size > 0 -%}
              <ul class="discounts list-unstyled" role="list" aria-label="{{ 'customer.order.discount' | t }}">
                {%- for discount in cart.cart_level_discount_applications -%}
                  <li class="discounts__discount discounts__discount--end">
                    {{- 'icon-discount.svg' | inline_asset_content -}}
                    {{ discount.title | escape }}
                    (-{{ discount.total_allocated_amount | money }})
                  </li>
                {%- endfor -%}
              </ul>
            {%- endif -%}
          </div>

          {%- liquid
            assign bloomli_cart_compare_price = 0
            for item in cart.items
              assign bloomli_line_compare_price = item.original_line_price
              if item.variant.compare_at_price and item.variant.compare_at_price > item.variant.price
                assign bloomli_line_compare_price = item.variant.compare_at_price | times: item.quantity
              endif

              if bloomli_line_compare_price < item.final_line_price
                assign bloomli_line_compare_price = item.final_line_price
              endif

              assign bloomli_cart_compare_price = bloomli_cart_compare_price | plus: bloomli_line_compare_price
            endfor

            if bloomli_cart_compare_price < cart.original_total_price
              assign bloomli_cart_compare_price = cart.original_total_price
            endif

            assign bloomli_cart_savings_percent = 0
            if bloomli_cart_compare_price > cart.total_price
              assign bloomli_cart_savings_percent = bloomli_cart_compare_price | minus: cart.total_price | times: 100 | divided_by: bloomli_cart_compare_price
            endif
          -%}

          <div class="totals" role="status">
            <h2 class="totals__total">{{ settings.cart_drawer_subtotal_label | default: 'Subtotal' }}</h2>
            <p class="totals__total-value">
              {%- if bloomli_cart_compare_price > cart.total_price -%}
                <span class="bloomli-cart-subtotal-save">{{ bloomli_cart_savings_percent }}% off</span>
                <s class="bloomli-cart-subtotal-compare">{{ bloomli_cart_compare_price | money }}</s>
              {%- endif -%}
              <span class="bloomli-cart-subtotal-final">{{ cart.total_price | money_with_currency }}</span>
            </p>
          </div>
        </div>

        <!-- CTAs -->

        <div class="cart__ctas" {{ block.shopify_attributes }}>
          <button
            type="submit"
            id="CartDrawer-Checkout"
            class="cart__checkout-button button"
            name="checkout"
            form="CartDrawer-Form"
            {% if cart == empty %}
              disabled
            {% endif %}
          >
            {{ settings.cart_drawer_checkout_label | default: 'CHECKOUT' }}
          </button>
          <small class="tax-note caption-large">
            {{ settings.cart_drawer_tax_note | default: '*Taxes, shipping and discounts calculated at checkout.' }}
          </small>
        </div>
      </div>
    </div>
  </div>
</cart-drawer>
