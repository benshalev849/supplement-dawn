{%- liquid
  assign popup_enabled = section.settings.enabled | default: true, allow_false: true
  assign popup_color_scheme = section.settings.color_scheme | default: 'scheme-1'
  assign popup_background_color = section.settings.popup_background_color | default: '#f6eee8'
  assign popup_text_color = section.settings.popup_text_color | default: '#322922'
  assign popup_option_background_color = section.settings.option_button_background_color | default: '#d56d78'
  assign popup_option_text_color = section.settings.option_button_text_color | default: '#fff9f4'
  assign popup_pill_radius = section.settings.pill_radius | default: 50
  assign popup_delay_seconds = section.settings.delay_seconds | default: 7
  assign popup_close_cooldown_days = section.settings.close_cooldown_days | default: 7
  assign popup_show_launcher = section.settings.show_launcher_after_close | default: true, allow_false: true
  assign popup_launcher_label = section.settings.launcher_label | default: 'Get 47% Off'
  assign popup_close_button_label = section.settings.close_button_label | default: 'Close signup offer'
  assign popup_launcher_close_button_label = section.settings.launcher_close_button_label | default: 'Dismiss signup offer'
  assign popup_logo_text = section.settings.logo_text | default: 'Bloomli'
  assign popup_show_image = section.settings.show_image | default: true, allow_false: true
  assign popup_image_position_desktop = section.settings.image_position_desktop | default: 'right'
  assign popup_headline_step_1 = section.settings.headline_step_1 | default: 'Unlock Your'
  assign popup_discount_line_step_1 = section.settings.discount_line_step_1 | default: '47% off'
  assign popup_subheading_step_1 = section.settings.subheading_step_1 | default: 'To claim, share what problem you are trying to solve:'
  assign popup_problem_option_1_label = section.settings.problem_option_1_label | default: 'Shedding'
  assign popup_problem_option_1_tag = section.settings.problem_option_1_handle | default: 'shedding'
  assign popup_problem_option_2_label = section.settings.problem_option_2_label | default: 'Breakage'
  assign popup_problem_option_2_tag = section.settings.problem_option_2_handle | default: 'breakage'
  assign popup_problem_option_3_label = section.settings.problem_option_3_label | default: 'Slow growth'
  assign popup_problem_option_3_tag = section.settings.problem_option_3_handle | default: 'slow-growth'
  assign popup_problem_option_4_label = section.settings.problem_option_4_label | default: 'Dry scalp'
  assign popup_problem_option_4_tag = section.settings.problem_option_4_handle | default: 'dry-scalp'
  assign popup_no_thanks_text = section.settings.no_thanks_text | default: "No thanks, I don't like savings"
  assign popup_options_group_label = section.settings.options_group_label | default: 'Select your hair concern'
  assign popup_headline_step_2 = section.settings.headline_step_2 | default: 'Unlock Your'
  assign popup_discount_line_step_2 = section.settings.discount_line_step_2 | default: '47% off'
  assign popup_body_step_2 = section.settings.body_step_2 | default: 'Sign up for email to receive your discount!'
  assign popup_email_placeholder = section.settings.email_placeholder | default: 'Enter your email'
  assign popup_submit_button_label = section.settings.submit_button_label | default: 'Get My 47% Off'
  assign popup_success_message = section.settings.success_message | default: 'Check your email for your Bloomli offer.'
  assign popup_content_padding_mobile = section.settings.content_padding_mobile | default: 28
  assign popup_content_padding_desktop = section.settings.content_padding_desktop | default: 64

  assign popup_visible = false
  if request.page_type != 'checkout'
    assign popup_visible = true
  endif

  assign form_id = 'BloomliSignupPopupForm-' | append: section.id
  assign email_id = 'BloomliSignupPopupEmail-' | append: section.id
  assign title_id = 'BloomliSignupPopupTitle-' | append: section.id
  assign error_id = 'BloomliSignupPopupError-' | append: section.id
  assign success_id = 'BloomliSignupPopupSuccess-' | append: section.id
  assign popup_logo = section.settings.logo_image | default: settings.logo
  assign primary_image = section.settings.image_desktop | default: section.settings.image_mobile
-%}

{%- if popup_visible -%}
  {{ 'bloomli-signup-popup.css' | asset_url | stylesheet_tag }}
  <script src="{{ 'bloomli-signup-popup.js' | asset_url }}" defer="defer"></script>

  <div
    class="bloomli-signup-popup color-{{ popup_color_scheme }} gradient"
    data-bloomli-signup-popup
    data-enabled="{{ popup_enabled }}"
    data-delay-seconds="{{ popup_delay_seconds }}"
    data-close-cooldown-days="{{ popup_close_cooldown_days }}"
    data-show-launcher="{{ popup_show_launcher }}"
    data-customer-marketing="{% if customer and customer.accepts_marketing %}true{% else %}false{% endif %}"
    data-custom-colors="{{ section.settings.enable_custom_colors }}"
    data-popup-background="{{ popup_background_color }}"
    data-popup-text="{{ popup_text_color }}"
    data-option-background="{{ popup_option_background_color }}"
    data-option-text="{{ popup_option_text_color }}"
    data-pill-radius="{{ popup_pill_radius }}"
    data-padding-mobile="{{ popup_content_padding_mobile }}"
    data-padding-desktop="{{ popup_content_padding_desktop }}"
  >
    <div class="bloomli-signup-popup__modal" data-bloomli-popup-modal hidden>
      <div
        class="bloomli-signup-popup__dialog bloomli-signup-popup__dialog--media-{{ popup_image_position_desktop }}{% unless popup_show_image %} bloomli-signup-popup__dialog--no-media{% endunless %}"
        role="dialog"
        aria-modal="true"
        aria-labelledby="{{ title_id }}"
        tabindex="-1"
      >
        <button
          class="bloomli-signup-popup__close"
          type="button"
          aria-label="{{ popup_close_button_label | escape }}"
          data-bloomli-popup-close
        >
          {{- 'icon-close.svg' | inline_asset_content -}}
        </button>

        <div class="bloomli-signup-popup__content">
          <div class="bloomli-signup-popup__logo">
            {%- if popup_logo != blank -%}
              {{
                popup_logo
                | image_url: width: 360
                | image_tag:
                  class: 'bloomli-signup-popup__logo-image',
                  loading: 'lazy',
                  widths: '80, 120, 160, 240',
                  sizes: '(max-width: 749px) 80px, 120px'
              }}
            {%- elsif popup_logo_text != blank -%}
              <span class="bloomli-signup-popup__logo-text">{{ popup_logo_text | escape }}</span>
            {%- endif -%}
          </div>

          <h2
            class="bloomli-signup-popup__title"
            id="{{ title_id }}"
          >
            <span
              data-bloomli-popup-title-line
              data-title-step-one="{{ popup_headline_step_1 | escape }}"
              data-title-step-two="{{ popup_headline_step_2 | escape }}"
            >
              {{- popup_headline_step_1 | escape -}}
            </span>
            <span
              data-bloomli-popup-title-line
              data-title-step-one="{{ popup_discount_line_step_1 | escape }}"
              data-title-step-two="{{ popup_discount_line_step_2 | escape }}"
            >
              {{- popup_discount_line_step_1 | escape -}}
            </span>
          </h2>

          <div class="bloomli-signup-popup__steps" data-bloomli-popup-steps>
            <div class="bloomli-signup-popup__step bloomli-signup-popup__step--one" data-bloomli-popup-step="1">
              <p class="bloomli-signup-popup__text">{{ popup_subheading_step_1 | escape }}</p>

              <div class="bloomli-signup-popup__options" aria-label="{{ popup_options_group_label | escape }}">
                <button type="button" class="bloomli-signup-popup__option" data-bloomli-popup-option data-concern-tag="{{ popup_problem_option_1_tag | escape }}">
                  {{ popup_problem_option_1_label | escape }}
                </button>
                <button type="button" class="bloomli-signup-popup__option" data-bloomli-popup-option data-concern-tag="{{ popup_problem_option_2_tag | escape }}">
                  {{ popup_problem_option_2_label | escape }}
                </button>
                <button type="button" class="bloomli-signup-popup__option" data-bloomli-popup-option data-concern-tag="{{ popup_problem_option_3_tag | escape }}">
                  {{ popup_problem_option_3_label | escape }}
                </button>
                <button type="button" class="bloomli-signup-popup__option" data-bloomli-popup-option data-concern-tag="{{ popup_problem_option_4_tag | escape }}">
                  {{ popup_problem_option_4_label | escape }}
                </button>
              </div>

              <button class="bloomli-signup-popup__decline" type="button" data-bloomli-popup-decline>
                {{ popup_no_thanks_text | escape }}
              </button>
            </div>

            <div
              class="bloomli-signup-popup__step bloomli-signup-popup__step--two"
              data-bloomli-popup-step="2"
              aria-hidden="true"
            >
              <p class="bloomli-signup-popup__text">{{ popup_body_step_2 | escape }}</p>

              {%- form 'customer', id: form_id, class: 'bloomli-signup-popup__form', return_to: 'back' -%}
                <div
                  data-bloomli-popup-form-state="{% if form.posted_successfully? %}success{% elsif form.errors %}error{% else %}idle{% endif %}"
                >
                  <input type="hidden" name="contact[tags]" value="newsletter,bloomli-email-popup" data-bloomli-popup-tags>
                  <label class="visually-hidden" for="{{ email_id }}">{{ popup_email_placeholder | escape }}</label>
                  <input
                    class="bloomli-signup-popup__email"
                    id="{{ email_id }}"
                    type="email"
                    name="contact[email]"
                    value="{{ form.email }}"
                    autocorrect="off"
                    autocapitalize="off"
                    autocomplete="email"
                    aria-required="true"
                    {% if form.errors %}
                      aria-invalid="true"
                      aria-describedby="{{ error_id }}"
                    {% endif %}
                    placeholder="{{ popup_email_placeholder | escape }}"
                    required
                    data-bloomli-popup-email
                  >
                  <button class="bloomli-signup-popup__submit" type="submit" name="commit">
                    {{ popup_submit_button_label | escape }}
                  </button>

                  {%- if form.errors -%}
                    <small class="bloomli-signup-popup__message bloomli-signup-popup__message--error" id="{{ error_id }}">
                      {{- form.errors.translated_fields.email | capitalize }} {{ form.errors.messages.email -}}
                    </small>
                  {%- endif -%}
                </div>
              {%- endform -%}
            </div>
          </div>
        </div>

        {%- if popup_show_image -%}
          <div class="bloomli-signup-popup__media">
            {%- if primary_image != blank -%}
              <picture>
                {%- if section.settings.image_mobile != blank -%}
                  <source
                    media="(max-width: 749px)"
                    srcset="
                      {{ section.settings.image_mobile | image_url: width: 480 }} 480w,
                      {{ section.settings.image_mobile | image_url: width: 750 }} 750w,
                      {{ section.settings.image_mobile | image_url: width: 1100 }} 1100w
                    "
                    sizes="100vw"
                  >
                {%- endif -%}
                {{
                  primary_image
                  | image_url: width: 1800
                  | image_tag:
                    class: 'bloomli-signup-popup__image',
                    loading: 'lazy',
                    widths: '480, 750, 1100, 1500, 1800',
                    sizes: '(min-width: 750px) 50vw, 100vw'
                }}
              </picture>
            {%- else -%}
              <div class="bloomli-signup-popup__image-placeholder" aria-hidden="true"></div>
            {%- endif -%}
          </div>
        {%- endif -%}
      </div>
    </div>

    <div class="bloomli-signup-popup__launcher" data-bloomli-popup-launcher hidden>
      <button
        class="bloomli-signup-popup__launcher-close"
        type="button"
        aria-label="{{ popup_launcher_close_button_label | escape }}"
        data-bloomli-popup-launcher-close
      >
        {{- 'icon-close.svg' | inline_asset_content -}}
      </button>
      <button class="bloomli-signup-popup__launcher-open" type="button" data-bloomli-popup-reopen>
        {{ popup_launcher_label | escape }}
      </button>
    </div>

    <p
      class="bloomli-signup-popup__success"
      id="{{ success_id }}"
      role="status"
      data-bloomli-popup-success
      hidden
    >
      {{ popup_success_message | escape }}
    </p>

  </div>
{%- endif -%}

{% schema %}
{
  "name": "Bloomli signup popup",
  "enabled_on": {
    "groups": ["footer"]
  },
  "settings": [
    {
      "type": "checkbox",
      "id": "enabled",
      "label": "Enable popup",
      "default": true
    },
    {
      "type": "header",
      "content": "Logo and imagery"
    },
    {
      "type": "image_picker",
      "id": "logo_image",
      "label": "Logo image",
      "info": "Upload a logo for this popup, or leave blank to use the header logo."
    },
    {
      "type": "text",
      "id": "logo_text",
      "label": "Logo text if no header logo exists",
      "default": "Bloomli"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "checkbox",
      "id": "enable_custom_colors",
      "label": "Override color scheme colors",
      "default": false
    },
    {
      "type": "color",
      "id": "popup_background_color",
      "label": "Popup background color",
      "default": "#f6eee8",
      "visible_if": "{{ section.settings.enable_custom_colors }}"
    },
    {
      "type": "color",
      "id": "popup_text_color",
      "label": "Popup text color",
      "default": "#322922",
      "visible_if": "{{ section.settings.enable_custom_colors }}"
    },
    {
      "type": "color",
      "id": "option_button_background_color",
      "label": "Option button background color",
      "default": "#d56d78",
      "visible_if": "{{ section.settings.enable_custom_colors }}"
    },
    {
      "type": "color",
      "id": "option_button_text_color",
      "label": "Option button text color",
      "default": "#fff9f4",
      "visible_if": "{{ section.settings.enable_custom_colors }}"
    },
    {
      "type": "range",
      "id": "pill_radius",
      "label": "Button/pill corner radius",
      "unit": "px",
      "min": 0,
      "max": 50,
      "step": 1,
      "default": 50
    },
    {
      "type": "checkbox",
      "id": "show_image",
      "label": "Show image panel",
      "default": true
    },
    {
      "type": "image_picker",
      "id": "image_desktop",
      "label": "Desktop image",
      "visible_if": "{{ section.settings.show_image }}"
    },
    {
      "type": "image_picker",
      "id": "image_mobile",
      "label": "Mobile image",
      "visible_if": "{{ section.settings.show_image }}"
    },
    {
      "type": "select",
      "id": "image_position_desktop",
      "label": "Desktop image position",
      "default": "right",
      "options": [
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "right",
          "label": "Right"
        }
      ],
      "visible_if": "{{ section.settings.show_image }}"
    },
    {
      "type": "header",
      "content": "Step 1"
    },
    {
      "type": "text",
      "id": "headline_step_1",
      "label": "Headline line 1",
      "default": "Unlock Your"
    },
    {
      "type": "text",
      "id": "discount_line_step_1",
      "label": "Headline line 2",
      "default": "47% off"
    },
    {
      "type": "textarea",
      "id": "subheading_step_1",
      "label": "Subheading",
      "default": "To claim, share what problem you're trying to solve:"
    },
    {
      "type": "text",
      "id": "problem_option_1_label",
      "label": "Problem option 1 label",
      "default": "Shedding"
    },
    {
      "type": "text",
      "id": "problem_option_1_handle",
      "label": "Problem option 1 customer tag",
      "default": "shedding"
    },
    {
      "type": "text",
      "id": "problem_option_2_label",
      "label": "Problem option 2 label",
      "default": "Breakage"
    },
    {
      "type": "text",
      "id": "problem_option_2_handle",
      "label": "Problem option 2 customer tag",
      "default": "breakage"
    },
    {
      "type": "text",
      "id": "problem_option_3_label",
      "label": "Problem option 3 label",
      "default": "Slow growth"
    },
    {
      "type": "text",
      "id": "problem_option_3_handle",
      "label": "Problem option 3 customer tag",
      "default": "slow-growth"
    },
    {
      "type": "text",
      "id": "problem_option_4_label",
      "label": "Problem option 4 label",
      "default": "Dry scalp"
    },
    {
      "type": "text",
      "id": "problem_option_4_handle",
      "label": "Problem option 4 customer tag",
      "default": "dry-scalp"
    },
    {
      "type": "text",
      "id": "no_thanks_text",
      "label": "No thanks text",
      "default": "No thanks, I don't like savings"
    },
    {
      "type": "text",
      "id": "options_group_label",
      "label": "Options accessible label",
      "default": "Select your hair concern"
    },
    {
      "type": "header",
      "content": "Step 2"
    },
    {
      "type": "text",
      "id": "headline_step_2",
      "label": "Headline step 2 line 1",
      "default": "Unlock Your",
      "info": "Keep this the same as Step 1 for the smoothest transition."
    },
    {
      "type": "text",
      "id": "discount_line_step_2",
      "label": "Headline step 2 line 2",
      "default": "47% off"
    },
    {
      "type": "textarea",
      "id": "body_step_2",
      "label": "Body text",
      "default": "Sign up for email to receive your discount!"
    },
    {
      "type": "text",
      "id": "email_placeholder",
      "label": "Email placeholder",
      "default": "Enter your email"
    },
    {
      "type": "text",
      "id": "submit_button_label",
      "label": "Submit button label",
      "default": "Get My 47% Off"
    },
    {
      "type": "text",
      "id": "success_message",
      "label": "Success message",
      "default": "Check your email for your Bloomli offer."
    },
    {
      "type": "header",
      "content": "Behavior"
    },
    {
      "type": "range",
      "id": "delay_seconds",
      "label": "Open delay",
      "unit": "s",
      "min": 0,
      "max": 30,
      "step": 1,
      "default": 7
    },
    {
      "type": "range",
      "id": "close_cooldown_days",
      "label": "Close cooldown",
      "unit": "day",
      "min": 1,
      "max": 30,
      "step": 1,
      "default": 7
    },
    {
      "type": "checkbox",
      "id": "show_launcher_after_close",
      "label": "Show launcher after close",
      "default": true
    },
    {
      "type": "text",
      "id": "close_button_label",
      "label": "Popup close accessible label",
      "default": "Close signup offer"
    },
    {
      "type": "text",
      "id": "launcher_label",
      "label": "Launcher label",
      "default": "Get 47% Off",
      "visible_if": "{{ section.settings.show_launcher_after_close }}"
    },
    {
      "type": "text",
      "id": "launcher_close_button_label",
      "label": "Launcher close accessible label",
      "default": "Dismiss signup offer",
      "visible_if": "{{ section.settings.show_launcher_after_close }}"
    },
    {
      "type": "header",
      "content": "Layout spacing"
    },
    {
      "type": "range",
      "id": "content_padding_mobile",
      "label": "Mobile content padding",
      "unit": "px",
      "min": 16,
      "max": 56,
      "step": 2,
      "default": 28
    },
    {
      "type": "range",
      "id": "content_padding_desktop",
      "label": "Desktop content padding",
      "unit": "px",
      "min": 32,
      "max": 120,
      "step": 4,
      "default": 64
    }
  ]
}
{% endschema %}
