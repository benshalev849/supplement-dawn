{{ 'bloomli-trust-row.css' | asset_url | stylesheet_tag }}
<script src="{{ 'bloomli-trust-row.js' | asset_url }}" defer="defer"></script>

{%- liquid
  assign card_count = section.blocks.size
  assign use_carousel = false
  if card_count > 3
    assign use_carousel = true
  endif
  assign track_id = 'BloomliTrustTrack-' | append: section.id
-%}

<section
  class="bloomli-trust bloomli-trust--pt-{{ section.settings.padding_top }} bloomli-trust--pb-{{ section.settings.padding_bottom }} color-{{ section.settings.color_scheme }} gradient{% if use_carousel %} is-carousel{% endif %}"
  data-bloomli-trust-gallery
  data-bloomli-trust-gallery-carousel="{{ use_carousel }}"
>
  <div class="bloomli-trust__inner">
    <div class="bloomli-trust__gallery">
      <div
        id="{{ track_id }}"
        class="bloomli-trust__viewport"
        aria-label="Bloomli proof points"
        data-bloomli-trust-viewport
      >
        <div class="bloomli-trust__track" data-bloomli-trust-track>
          {%- for block in section.blocks -%}
            <article class="bloomli-trust__card" {{ block.shopify_attributes }}>
              {%- if block.settings.title != blank -%}
                <h3 class="bloomli-trust__title">{{ block.settings.title | escape }}</h3>
              {%- endif -%}

              {%- if block.settings.quote != blank -%}
                <p class="bloomli-trust__quote">{{ block.settings.quote | escape }}</p>
              {%- endif -%}
            </article>
          {%- endfor -%}
        </div>
      </div>

      {%- if use_carousel -%}
        <div class="bloomli-trust__controls" aria-label="Proof carousel controls">
          <button
            class="bloomli-trust__arrow bloomli-trust__arrow--prev"
            type="button"
            aria-label="Previous proof card"
            aria-controls="{{ track_id }}"
            data-bloomli-trust-prev
          >
            <svg width="18" height="18" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m12.5 4.5-5 5.5 5 5.5"/></svg>
          </button>

          <button
            class="bloomli-trust__arrow bloomli-trust__arrow--next"
            type="button"
            aria-label="Next proof card"
            aria-controls="{{ track_id }}"
            data-bloomli-trust-next
          >
            <svg width="18" height="18" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m7.5 4.5 5 5.5-5 5.5"/></svg>
          </button>
        </div>
      {%- endif -%}

      {%- if section.blocks.size > 1 -%}
        <div class="bloomli-trust__footer slider-buttons">
          <div class="bloomli-trust__counter slider-counter slider-counter--dots" aria-label="Proof card pagination">
            {%- for block in section.blocks -%}
              <button
                class="slider-counter__link slider-counter__link--dots link{% if forloop.first %} slider-counter__link--active{% endif %}"
                type="button"
                aria-label="Go to proof card {{ forloop.index }} of {{ section.blocks.size }}"
                aria-controls="{{ track_id }}"
                {% if forloop.first %}
                  aria-current="true"
                {% endif %}
                data-bloomli-trust-dot
              >
                <span class="dot"></span>
              </button>
            {%- endfor -%}
          </div>
        </div>
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Bloomli - Trust Row",
  "tag": "div",
  "max_blocks": 6,
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-6d8ba907-aae6-4c49-9120-e1031d9cdb3f"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "min": 8,
      "max": 48,
      "step": 2,
      "default": 18
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "min": 8,
      "max": 48,
      "step": 2,
      "default": 18
    }
  ],
  "blocks": [
    {
      "type": "proof",
      "name": "Proof card",
      "settings": [
        {
          "type": "textarea",
          "id": "quote",
          "label": "Proof sentence",
          "default": "Tested for purity, label accuracy, and quality."
        },
        {
          "type": "text",
          "id": "title",
          "label": "Proof title",
          "default": "Third-party tested"
        },
        {
          "type": "select",
          "id": "icon",
          "label": "Optional icon",
          "options": [
            { "value": "none", "label": "None" },
            { "value": "flask", "label": "Flask" },
            { "value": "shield", "label": "Shield / Check" },
            { "value": "leaf", "label": "Leaf" },
            { "value": "star", "label": "Star" },
            { "value": "check", "label": "Circle check" },
            { "value": "globe", "label": "Globe / USA" },
            { "value": "refresh", "label": "Refresh / Pause" },
            { "value": "sparkle", "label": "Sparkle" }
          ],
          "default": "none"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Bloomli - Trust Row",
      "blocks": [
        {
          "type": "proof",
          "settings": {
            "quote": "Tested for purity, label accuracy, and quality.",
            "title": "Third-party tested"
          }
        },
        {
          "type": "proof",
          "settings": {
            "quote": "Daily beauty support without turning your supplement into candy.",
            "title": "2g sugar per gummy"
          }
        },
        {
          "type": "proof",
          "settings": {
            "quote": "Pectin-based gummies made without gelatin.",
            "title": "Gelatin-free"
          }
        },
        {
          "type": "proof",
          "settings": {
            "quote": "Produced with quality standards you can trust.",
            "title": "Made in the USA"
          }
        },
        {
          "type": "proof",
          "settings": {
            "quote": "Try the ritual and see how it fits.",
            "title": "30-day guarantee"
          }
        },
        {
          "type": "proof",
          "settings": {
            "quote": "Subscriptions should feel easy, not stressful.",
            "title": "Cancel anytime"
          }
        }
      ]
    }
  ]
}
{% endschema %}
