{% comment %}
  PDP trust icons row (4 items).
  Usage: {% render 'bloomli-pdp-trust' %}
{% endcomment %}

<div style="display: grid; grid-template-columns: repeat(4, 1fr); gap: 8px; margin: 20px 0 32px;">

  {% assign trust_items = 'truck|Free shipping,refresh|Cancel anytime,shield|30-day guarantee,leaf|Vegan & clean' | split: ',' %}
  {% for item in trust_items %}
    {% assign parts = item | split: '|' %}
    <div style="text-align: center;">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#6E4A63" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" style="display: block; margin: 0 auto;">
        {% case parts[0] %}
          {% when 'truck' %}
            <path d="M3 7h11v10H3z"/><path d="M14 10h4l3 3v4h-7z"/><circle cx="7" cy="18" r="1.5"/><circle cx="17" cy="18" r="1.5"/>
          {% when 'refresh' %}
            <path d="M3 12a9 9 0 0 1 15-6.7L21 8"/><path d="M21 3v5h-5"/><path d="M21 12a9 9 0 0 1-15 6.7L3 16"/><path d="M3 21v-5h5"/>
          {% when 'shield' %}
            <path d="M12 3l8 3v6c0 5-3.5 8.5-8 10-4.5-1.5-8-5-8-10V6l8-3z"/>
          {% when 'leaf' %}
            <path d="M5 19c0-8 6-14 14-14 0 8-6 14-14 14z"/><path d="M5 19c4-4 8-8 14-14"/>
        {% endcase %}
      </svg>
      <div style="font-size: 10px; color: rgba(42,38,34,0.65); margin-top: 6px; text-transform: uppercase; letter-spacing: 0.06em; font-weight: 500; font-family: 'DM Sans', sans-serif;">{{ parts[1] }}</div>
    </div>
  {% endfor %}

</div>
