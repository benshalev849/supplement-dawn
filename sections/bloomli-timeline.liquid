<section class="bloomli-timeline" style="padding: {{ section.settings.padding_top }}px 48px {{ section.settings.padding_bottom }}px; background: var(--cream);">
  <div style="max-width: 1280px; margin: 0 auto;">

    <div class="bloomli-timeline__header" style="text-align: center; margin-bottom: 80px;">
      {%- if section.settings.eyebrow != blank -%}
        <div class="smallcaps" style="color: var(--aubergine); margin-bottom: 14px;">{{ section.settings.eyebrow }}</div>
      {%- endif -%}
      <h2 class="bloomli-timeline__heading" style="font-family: 'Fraunces', serif; font-variation-settings: 'SOFT' 100; font-size: 56px; font-weight: 400; color: var(--charcoal); margin: 0; line-height: 1.05;">
        {{ section.settings.heading }}
      </h2>
    </div>

    {%- assign circle_size = section.settings.circle_size | default: 100 -%}
    {%- assign icon_size = section.settings.icon_size | default: 64 -%}
    {%- assign line_top = circle_size | divided_by: 2 -%}
    {%- assign block_count = section.blocks.size | default: 3 -%}
    {%- assign line_inset = 100 | divided_by: block_count | divided_by: 2 -%}
    {%- assign connector_color = section.settings.connector_color | default: '#D6C7BC' -%}
    {%- assign connector_style = section.settings.connector_style | default: 'dashed' -%}
    {%- assign connector_width = section.settings.connector_width | default: 1 -%}

    <div class="bloomli-timeline__wrap" style="--timeline-line-top: {{ line_top }}px; --timeline-line-inset: {{ line_inset }}%; --timeline-line-color: {{ connector_color }}; --timeline-line-width: {{ connector_width }}px; --timeline-line-style: {{ connector_style }}; position: relative;">
      <div class="bloomli-timeline__grid" style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 32px; position: relative; z-index: 1;">
        {%- for block in section.blocks -%}
          <div class="bloomli-timeline__step" {{ block.shopify_attributes }} style="text-align: center; position: relative; z-index: 2; min-width: 0;">
            <div class="bloomli-timeline__circle" style="width: {{ circle_size }}px; height: {{ circle_size }}px; margin: 0 auto 24px; border-radius: 999px; background: var(--pearl); display: flex; align-items: center; justify-content: center; border: 1px solid rgba(110,74,99,0.1); overflow: hidden; position: relative; z-index: 3;">
              {%- if block.settings.image != blank -%}
                <img
                  class="bloomli-timeline__icon-img"
                  src="{{ block.settings.image | image_url: width: 240 }}"
                  alt="{{ block.settings.image.alt | default: block.settings.title | escape }}"
                  loading="lazy"
                  style="width: {{ icon_size }}px; height: {{ icon_size }}px; max-width: none; object-fit: contain;"
                >
              {%- else -%}
                <svg class="bloomli-timeline__icon-svg" width="{{ icon_size }}" height="{{ icon_size }}" viewBox="0 0 80 80" fill="none" stroke="#6E4A63" stroke-width="1.25" stroke-linecap="round" stroke-linejoin="round">
                  {%- case block.settings.icon -%}
                    {%- when 'seed' -%}
                      <ellipse cx="40" cy="44" rx="12" ry="18"/><path d="M40 26 Q 48 22, 56 26"/><path d="M40 44 L40 60"/>
                    {%- when 'sprout' -%}
                      <path d="M40 70 L40 40"/><path d="M40 40 Q 28 34, 24 22 Q 36 24, 40 40Z"/><path d="M40 46 Q 52 40, 56 28 Q 44 30, 40 46Z"/>
                    {%- when 'bloom' -%}
                      <circle cx="40" cy="40" r="6"/><ellipse cx="40" cy="24" rx="7" ry="11"/><ellipse cx="56" cy="40" rx="11" ry="7"/><ellipse cx="40" cy="56" rx="7" ry="11"/><ellipse cx="24" cy="40" rx="11" ry="7"/><path d="M40 60 L40 72"/>
                  {%- endcase -%}
                </svg>
              {%- endif -%}
            </div>
            <div class="smallcaps" style="color: var(--aubergine); margin-bottom: 10px;">{{ block.settings.range }}</div>
            <h3 class="bloomli-timeline__title" style="font-family: 'Fraunces', serif; font-size: 28px; font-weight: 400; margin: 0 0 12px; color: var(--charcoal); line-height: 1.15;">{{ block.settings.title }}</h3>
            <p class="bloomli-timeline__copy" style="font-size: 15px; color: rgba(42,38,34,0.7); line-height: 1.6; max-width: 300px; margin: 0 auto; word-wrap: break-word; overflow-wrap: break-word;">{{ block.settings.description }}</p>
          </div>
        {%- endfor -%}
      </div>
    </div>

  </div>
</section>

<style>
  .bloomli-timeline__icon-img { max-width: none !important; }
  .bloomli-timeline__wrap::before {
    content: '';
    position: absolute;
    top: var(--timeline-line-top);
    left: var(--timeline-line-inset);
    right: var(--timeline-line-inset);
    border-top: var(--timeline-line-width) var(--timeline-line-style) var(--timeline-line-color);
    z-index: 2;
    pointer-events: none;
  }

  @media (max-width: 749px) {
    .bloomli-timeline {
      padding-left: 16px !important;
      padding-right: 16px !important;
      padding-top: 64px !important;
      padding-bottom: 64px !important;
    }
    .bloomli-timeline__wrap::before { display: none !important; }
    .bloomli-timeline__grid {
      grid-template-columns: 1fr !important;
      gap: 40px !important;
    }
    .bloomli-timeline__heading { font-size: 32px !important; }
    .bloomli-timeline__title { font-size: 22px !important; }
    .bloomli-timeline__header { margin-bottom: 40px !important; }
  }
</style>

{% schema %}
{
  "name": "Bloomli — Timeline",
  "tag": "div",
  "max_blocks": 3,
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Your 6-month journey" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Your ritual, over time." },
    { "type": "header", "content": "Icon sizing (applies to both SVG and uploaded images)" },
    { "type": "range", "id": "circle_size", "label": "Circle size", "min": 60, "max": 180, "step": 4, "default": 100, "unit": "px" },
    { "type": "range", "id": "icon_size", "label": "Icon size inside circle", "min": 24, "max": 160, "step": 2, "default": 64, "unit": "px" },
    { "type": "header", "content": "Connector line" },
    { "type": "checkbox", "id": "show_connector", "label": "Show connector line", "default": true },
    { "type": "color", "id": "connector_color", "label": "Connector color", "default": "#D6C7BC" },
    { "type": "select", "id": "connector_style", "label": "Connector style", "options": [
      { "value": "dashed", "label": "Dashed" },
      { "value": "dotted", "label": "Dotted" },
      { "value": "solid", "label": "Solid" }
    ], "default": "dashed" },
    { "type": "range", "id": "connector_width", "label": "Connector width", "min": 1, "max": 4, "step": 1, "default": 1, "unit": "px" },
    { "type": "header", "content": "Spacing" },
    { "type": "range", "id": "padding_top", "label": "Padding top (px)", "min": 48, "max": 160, "step": 8, "default": 128 },
    { "type": "range", "id": "padding_bottom", "label": "Padding bottom (px)", "min": 48, "max": 160, "step": 8, "default": 128 }
  ],
  "blocks": [
    {
      "type": "step",
      "name": "Step",
      "settings": [
        { "type": "header", "content": "Icon" },
        { "type": "paragraph", "content": "Upload a transparent PNG/SVG to override the default icon. The image is centered inside the circle and scales to fit." },
        { "type": "image_picker", "id": "image", "label": "Custom icon (optional)" },
        { "type": "select", "id": "icon", "label": "Default icon (used if no image)", "options": [
          { "value": "seed", "label": "Seed" },
          { "value": "sprout", "label": "Sprout" },
          { "value": "bloom", "label": "Bloom" }
        ], "default": "seed" },
        { "type": "header", "content": "Text" },
        { "type": "text", "id": "range", "label": "Month range", "default": "Month 1–3" },
        { "type": "text", "id": "title", "label": "Title", "default": "Foundation" },
        { "type": "textarea", "id": "description", "label": "Description", "default": "Nourishment reaches the follicle. Expect less shedding and a healthier scalp feel." }
      ]
    }
  ],
  "presets": [{
    "name": "Bloomli — Timeline",
    "blocks": [
      { "type": "step", "settings": { "icon": "seed", "range": "Month 1–3", "title": "Foundation", "description": "Nourishment reaches the follicle. Expect less shedding and a healthier scalp feel." } },
      { "type": "step", "settings": { "icon": "sprout", "range": "Month 3–6", "title": "Visible Shift", "description": "New growth begins. Many see fuller density at the part line and temples." } },
      { "type": "step", "settings": { "icon": "bloom", "range": "Month 6+", "title": "Full Bloom", "description": "Thicker, stronger, shinier hair. Results consolidate with consistent use." } }
    ]
  }]
}
{% endschema %}
