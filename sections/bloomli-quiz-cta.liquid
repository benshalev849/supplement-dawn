<section
  class="bloomli-quiz bloomli-section color-{{ section.settings.color_scheme }} gradient"
  style="--bloomli-padding-top: {{ section.settings.padding_top }}px; --bloomli-padding-bottom: {{ section.settings.padding_bottom }}px;"
>
  <div class="bloomli-quiz__inner">

    {%- render 'bloomli-icon', icon: 'sparkle', class: 'bloomli-quiz__icon' -%}

    <h2 class="bloomli-quiz__heading">
      {{ section.settings.heading }}
    </h2>

    {%- if section.settings.subtext != blank -%}
      <p class="bloomli-quiz__copy">
        {{ section.settings.subtext }}
      </p>
    {%- endif -%}

    {%- if section.settings.cta_label != blank and section.settings.cta_url != blank -%}
      <a href="{{ section.settings.cta_url }}" class="button bloomli-quiz__cta">
        {{ section.settings.cta_label }}
      </a>
    {%- endif -%}

  </div>
</section>

{% schema %}
{
  "name": "Bloomli — Quiz CTA",
  "tag": "div",
  "settings": [
    { "type": "color_scheme", "id": "color_scheme", "label": "Color scheme", "default": "scheme-6d8ba907-aae6-4c49-9120-e1031d9cdb3f" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Not sure where to start?" },
    { "type": "textarea", "id": "subtext", "label": "Subtext", "default": "Take our 2-minute quiz and get a personalized hair wellness routine." },
    { "type": "text", "id": "cta_label", "label": "CTA label", "default": "Take the Quiz" },
    { "type": "url", "id": "cta_url", "label": "CTA URL" },
    { "type": "range", "id": "padding_top", "label": "Padding top (px)", "min": 64, "max": 176, "step": 8, "default": 128 },
    { "type": "range", "id": "padding_bottom", "label": "Padding bottom (px)", "min": 64, "max": 176, "step": 8, "default": 128 }
  ],
  "presets": [{ "name": "Bloomli — Quiz CTA" }]
}
{% endschema %}
