{{ 'bloomli-science.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign image_alt = section.settings.ritual_image.alt | default: section.settings.heading
-%}

<section
  id="ritual"
  class="bloomli-science-section bloomli-ritual-system color-{{ section.settings.color_scheme }} gradient"
  style="--section-padding-top: {{ section.settings.padding_top }}px; --section-padding-bottom: {{ section.settings.padding_bottom }}px; --section-padding-top-mobile: {{ section.settings.padding_top_mobile }}px; --section-padding-bottom-mobile: {{ section.settings.padding_bottom_mobile }}px;"
>
  <div class="bloomli-science-section__inner">
    <div class="bloomli-ritual-system__header">
      {%- if section.settings.heading != blank -%}
        <h2 class="bloomli-science-section__heading">{{ section.settings.heading | escape }}</h2>
      {%- endif -%}
      {%- if section.settings.intro != blank -%}
        <div class="bloomli-science-section__copy rte">{{ section.settings.intro }}</div>
      {%- endif -%}
    </div>

    <div class="bloomli-science-grid bloomli-ritual-system__cards">
      {%- for block in section.blocks -%}
        <article class="bloomli-science-card bloomli-ritual-system__card" {{ block.shopify_attributes }}>
          <span class="bloomli-science-card__number">{{ forloop.index }}</span>
          <h3>{{ block.settings.title | escape }}</h3>
          <div class="bloomli-ritual-system__role">{{ block.settings.role | escape }}</div>
          <div class="bloomli-science-card__text">{{ block.settings.copy }}</div>
          <div class="bloomli-ritual-system__detail">{{ block.settings.routine_detail | escape }}</div>
          {%- if block.settings.note != blank -%}
            <div class="bloomli-ritual-system__note">{{ block.settings.note | escape }}</div>
          {%- endif -%}
          {%- if block.settings.cta_label != blank -%}
            <a class="button button--secondary" href="{{ block.settings.cta_link }}">{{ block.settings.cta_label | escape }}</a>
          {%- endif -%}
        </article>
      {%- endfor -%}
    </div>

    {%- if section.settings.footnote != blank -%}
      <div class="bloomli-ritual-system__footnote">{{ section.settings.footnote | escape }}</div>
    {%- endif -%}

    <div class="bloomli-science-media bloomli-ritual-system__media">
      {%- if section.settings.ritual_image != blank -%}
        {{
          section.settings.ritual_image
          | image_url: width: 1400
          | image_tag:
            widths: '500, 700, 900, 1100, 1400',
            sizes: '(min-width: 990px) 88vw, 100vw',
            loading: 'lazy',
            decoding: 'async',
            alt: image_alt
        }}
      {%- else -%}
        <div class="bloomli-science-media__placeholder">{{ section.settings.placeholder_label | escape }}</div>
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Bloomli - Ritual System",
  "tag": "div",
  "max_blocks": 3,
  "settings": [
    { "type": "color_scheme", "id": "color_scheme", "label": "Color scheme", "default": "scheme-6d8ba907-aae6-4c49-9120-e1031d9cdb3f" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "One routine. Three ways to support healthier-looking hair." },
    { "type": "richtext", "id": "intro", "label": "Intro", "default": "<p>Each Bloomli product has a different role in the ritual. The gummies make daily beauty-nutrient support simple. The capsules offer more comprehensive inside-out support. The serum brings the routine directly to the scalp.</p>" },
    { "type": "text", "id": "footnote", "label": "Footnote", "default": "Full ingredients and Supplement Facts are available on each product page." },
    { "type": "image_picker", "id": "ritual_image", "label": "Product ritual image - gummies, capsules, serum together" },
    { "type": "text", "id": "placeholder_label", "label": "Placeholder label", "default": "Product ritual image - gummies, capsules, serum together" },
    { "type": "range", "id": "padding_top", "label": "Padding top", "min": 0, "max": 160, "step": 8, "default": 88, "unit": "px" },
    { "type": "range", "id": "padding_bottom", "label": "Padding bottom", "min": 0, "max": 160, "step": 8, "default": 88, "unit": "px" },
    { "type": "range", "id": "padding_top_mobile", "label": "Padding top mobile", "min": 0, "max": 120, "step": 8, "default": 56, "unit": "px" },
    { "type": "range", "id": "padding_bottom_mobile", "label": "Padding bottom mobile", "min": 0, "max": 120, "step": 8, "default": 56, "unit": "px" }
  ],
  "blocks": [
    {
      "type": "product_role",
      "name": "Product role",
      "settings": [
        { "type": "text", "id": "title", "label": "Title", "default": "Hair Vitamins Gummies" },
        { "type": "text", "id": "role", "label": "Role", "default": "Daily beauty-nutrient support" },
        { "type": "richtext", "id": "copy", "label": "Copy", "default": "<p>A simple daily gummy designed to support hair, skin, and nails from within, with beauty-supporting nutrients like biotin, vitamins, zinc, collagen, and silicon.*</p>" },
        { "type": "text", "id": "routine_detail", "label": "Routine detail", "default": "2 gummies daily" },
        { "type": "text", "id": "note", "label": "Note", "default": "Contains fish-derived collagen." },
        { "type": "text", "id": "cta_label", "label": "CTA label", "default": "View Gummies" },
        { "type": "url", "id": "cta_link", "label": "CTA link", "default": "/products/hair-vitamins-gummies" }
      ]
    }
  ],
  "presets": [{ "name": "Bloomli - Ritual System" }]
}
{% endschema %}
