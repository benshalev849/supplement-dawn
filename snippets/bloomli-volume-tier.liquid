{% doc %}
  Bloomli Volume Tier - block snippet rendered inside main-product.liquid.

  Renders 1-5 horizontal size cards (Create-Wellness style) plus an optional
  One-Time / Subscribe toggle. Sets the buy-buttons form's `quantity` and
  optional `selling_plan` through normal form-associated inputs.

  Tier-to-plan mapping: by default quantity N chooses a plan whose group/name
  contains "{N}-pack" and "{N}mo". For quantity 6+ (e.g. a 6-pack tier), the
  filter falls back to "5-pack" since Appstle plans only go up to 5-pack.
  Per-tier plan filters can override the pack text.

  @param {block} block - Block object with all settings.
  @param {product} product - Current product.
  @param {string} section_id - Parent section ID for unique element IDs.

  @example
  {% render 'bloomli-volume-tier', block: block, product: product, section_id: section.id %}
{% enddoc %}

{{ 'bloomli-volume-tier.css' | asset_url | stylesheet_tag }}
{{ 'bloomli-product-stack.css' | asset_url | stylesheet_tag }}
<script src="{{ 'bloomli-volume-tier.js' | asset_url }}" defer="defer"></script>

{%- liquid
  assign uid = section_id | append: '-' | append: block.id
  assign bloomli_product_form_id = 'bloomli-product-form-' | append: uid

  assign unit_price = product.selected_or_first_available_variant.price
  assign unit_compare = product.selected_or_first_available_variant.compare_at_price | default: unit_price

  assign default_idx = -1
  assign default_qty = 1
  assign subscribe_enabled = block.settings.subscribe_enabled
  assign default_mode = block.settings.default_mode | default: 'onetime'
  assign subscription_discount_pct = block.settings.subscription_discount_pct | default: 10 | plus: 0
  assign discount_badge_template = block.settings.discount_badge_template | default: 'SAVE [percent]%'
  assign subscription_extra_template = block.settings.subscription_extra_label_template | default: 'an extra [percent]%'
  assign add_to_cart_label = block.settings.add_to_cart_label | default: 'Add to cart'
  assign sold_out_label = block.settings.sold_out_label | default: 'Sold out'
-%}

<div class="bloomli-vt"
     data-bloomli-vt
     data-uid="{{ uid }}"
     data-form-id="{{ bloomli_product_form_id }}"
     data-unit-price="{{ unit_price }}"
     data-unit-compare="{{ unit_compare }}"
     data-subscription-discount-pct="{{ subscription_discount_pct }}"
     data-discount-badge-template="{{ discount_badge_template | escape }}"
     data-subscription-extra-template="{{ subscription_extra_template | escape }}"
     data-add-to-cart-label="{{ add_to_cart_label | escape }}"
     data-sold-out-label="{{ sold_out_label | escape }}"
     data-money-format="{{ shop.money_format | escape }}"
     style="
       --bloomli-vt-save-badge-bg: {{ block.settings.save_badge_background | default: '#B23A6F' }};
       --bloomli-vt-save-badge-text: {{ block.settings.save_badge_text_color | default: '#FDFAF7' }};
       --bloomli-vt-tier-tag-bg: {{ block.settings.tier_tag_background | default: '#8A6678' }};
       --bloomli-vt-tier-tag-text: {{ block.settings.tier_tag_text_color | default: '#FDFAF7' }};
       --bloomli-vt-shipping-pill-bg: {{ block.settings.shipping_pill_background | default: '#8A6678' }};
       --bloomli-vt-shipping-pill-text: {{ block.settings.shipping_pill_text_color | default: '#FDFAF7' }};
       --bloomli-vt-desktop-title-size: {{ block.settings.desktop_tier_title_size | default: 11 }}px;
       --bloomli-vt-desktop-count-size: {{ block.settings.desktop_tier_count_size | default: 9 }}px;
       --bloomli-vt-desktop-daily-size: {{ block.settings.desktop_tier_daily_size | default: 9 }}px;
     "
     {{ block.shopify_attributes }}>

  {%- if block.settings.eyebrow != blank -%}
    <div class="bloomli-vt__eyebrow">{{ block.settings.eyebrow }}</div>
  {%- endif -%}

  {%- if block.settings.heading != blank -%}
    <h3 class="bloomli-vt__title">{{ block.settings.heading }}</h3>
  {%- endif -%}

  <div class="bloomli-vt__sizes" role="radiogroup" aria-label="{{ block.settings.heading | default: 'Pack size' | escape }}">
    {%- for i in (1..5) reversed -%}
      {%- liquid
        case i
          when 1
            assign show = block.settings.tier_1_show
            assign qty = block.settings.tier_1_qty | default: 1
            assign label = block.settings.tier_1_label
            assign count_text = block.settings.tier_1_count_text | default: block.settings.tier_1_description
            assign daily_text = block.settings.tier_1_daily_text
            assign image = block.settings.tier_1_image
            assign badge = block.settings.tier_1_badge
            assign tag = block.settings.tier_1_tag
            assign show_shipping = block.settings.tier_1_show_shipping
            assign discount_pct = block.settings.tier_1_discount_pct | default: 0
            assign sub_discount_pct = subscription_discount_pct
            assign plan_filter = block.settings.tier_1_plan_filter
            assign is_default = block.settings.tier_1_default
          when 2
            assign show = block.settings.tier_2_show
            assign qty = block.settings.tier_2_qty | default: 2
            assign label = block.settings.tier_2_label
            assign count_text = block.settings.tier_2_count_text | default: block.settings.tier_2_description
            assign daily_text = block.settings.tier_2_daily_text
            assign image = block.settings.tier_2_image
            assign badge = block.settings.tier_2_badge
            assign tag = block.settings.tier_2_tag
            assign show_shipping = block.settings.tier_2_show_shipping
            assign discount_pct = block.settings.tier_2_discount_pct | default: 0
            assign sub_discount_pct = subscription_discount_pct
            assign plan_filter = block.settings.tier_2_plan_filter
            assign is_default = block.settings.tier_2_default
          when 3
            assign show = block.settings.tier_3_show
            assign qty = block.settings.tier_3_qty | default: 3
            assign label = block.settings.tier_3_label
            assign count_text = block.settings.tier_3_count_text | default: block.settings.tier_3_description
            assign daily_text = block.settings.tier_3_daily_text
            assign image = block.settings.tier_3_image
            assign badge = block.settings.tier_3_badge
            assign tag = block.settings.tier_3_tag
            assign show_shipping = block.settings.tier_3_show_shipping
            assign discount_pct = block.settings.tier_3_discount_pct | default: 0
            assign sub_discount_pct = subscription_discount_pct
            assign plan_filter = block.settings.tier_3_plan_filter
            assign is_default = block.settings.tier_3_default
          when 4
            assign show = block.settings.tier_4_show
            assign qty = block.settings.tier_4_qty | default: 4
            assign label = block.settings.tier_4_label
            assign count_text = block.settings.tier_4_count_text | default: block.settings.tier_4_description
            assign daily_text = block.settings.tier_4_daily_text
            assign image = block.settings.tier_4_image
            assign badge = block.settings.tier_4_badge
            assign tag = block.settings.tier_4_tag
            assign show_shipping = block.settings.tier_4_show_shipping
            assign discount_pct = block.settings.tier_4_discount_pct | default: 0
            assign sub_discount_pct = subscription_discount_pct
            assign plan_filter = block.settings.tier_4_plan_filter
            assign is_default = block.settings.tier_4_default
          when 5
            assign show = block.settings.tier_5_show
            assign qty = block.settings.tier_5_qty | default: 5
            assign label = block.settings.tier_5_label
            assign count_text = block.settings.tier_5_count_text | default: block.settings.tier_5_description
            assign daily_text = block.settings.tier_5_daily_text
            assign image = block.settings.tier_5_image
            assign badge = block.settings.tier_5_badge
            assign tag = block.settings.tier_5_tag
            assign show_shipping = block.settings.tier_5_show_shipping
            assign discount_pct = block.settings.tier_5_discount_pct | default: 0
            assign sub_discount_pct = subscription_discount_pct
            assign plan_filter = block.settings.tier_5_plan_filter
            assign is_default = block.settings.tier_5_default
        endcase

        if show and is_default and default_idx == -1
          assign default_idx = forloop.index0
          assign default_qty = qty
        endif

        if plan_filter == blank
          assign plan_filter_qty = qty
          if plan_filter_qty > 5
            assign plan_filter_qty = 5
          endif
          assign plan_filter = plan_filter_qty | append: '-pack'
        endif

        assign frequency_qty = qty
        if frequency_qty > 5
          assign frequency_qty = 5
        endif
        assign frequency_filter = frequency_qty | append: 'mo'
        assign tier_plan_id = ''
        assign fallback_plan_id = ''
        for grp in product.selling_plan_groups
          assign grp_name_lower = grp.name | downcase
          assign filter_lower = plan_filter | downcase
          if grp_name_lower contains filter_lower
            assign first_plan = grp.selling_plans | first
            if first_plan
              if fallback_plan_id == blank
                assign fallback_plan_id = first_plan.id
              endif

              for selling_plan in grp.selling_plans
                assign frequency_source = grp.name | append: ' ' | append: selling_plan.name | downcase
                for option in selling_plan.options
                  assign frequency_source = frequency_source | append: ' ' | append: option.value | downcase
                endfor
                assign frequency_filter_spaced = frequency_qty | append: ' mo'
                assign frequency_filter_dash = frequency_qty | append: '-mo'
                assign frequency_filter_month = frequency_qty | append: ' month'
                assign frequency_filter_every = 'every ' | append: frequency_qty
                assign frequency_filter_appstle = frequency_qty | append: 'month'
                if frequency_source contains frequency_filter or frequency_source contains frequency_filter_spaced or frequency_source contains frequency_filter_dash or frequency_source contains frequency_filter_month or frequency_source contains frequency_filter_every or frequency_source contains frequency_filter_appstle
                  assign tier_plan_id = selling_plan.id
                  break
                endif
              endfor
              if tier_plan_id != blank
                break
              endif
            endif
          endif
        endfor
        if tier_plan_id == blank
          assign tier_plan_id = fallback_plan_id
        endif

        assign line_compare = unit_price | times: qty
        if unit_compare > unit_price
          assign line_compare = unit_compare | times: qty
        endif
        assign one_time_pct_factor = 100.0 | minus: discount_pct
        assign one_time_total_cents = unit_price | times: qty | times: one_time_pct_factor | divided_by: 100.0

        assign subscription_pct_factor = 100.0 | minus: sub_discount_pct
        assign compounded_pct_factor = one_time_pct_factor | times: subscription_pct_factor | divided_by: 100.0
        assign subscribe_total_cents = unit_price | times: qty | times: compounded_pct_factor | divided_by: 100.0
        assign rounded_discount_pct = discount_pct | round
        assign dynamic_badge = discount_badge_template | replace: '[percent]', rounded_discount_pct | replace: '[qty]', qty

        assign daily_cents = one_time_total_cents | divided_by: qty | divided_by: 30
        assign subscribe_daily_cents = subscribe_total_cents | divided_by: qty | divided_by: 30
        assign auto_daily = daily_cents | money
        assign auto_subscribe_daily = subscribe_daily_cents | money
        if daily_text == blank
          assign daily_text = '(' | append: auto_daily | append: ' / Day)'
        endif
        assign subscribe_daily_text = '(' | append: auto_subscribe_daily | append: ' / Day)'

        assign auto_count = qty | times: 60 | append: ' Count'
        if count_text == blank
          assign count_text = auto_count
        endif

        assign display_label = label
        if display_label == blank
          assign display_label = qty | append: ' Month'
        endif
      -%}

      {%- if show -%}
        <label class="bloomli-vt__size{% if forloop.index0 == default_idx %} is-selected{% endif %}"
               data-vt-size
               data-tier-index="{{ forloop.index0 }}"
               data-quantity="{{ qty }}"
               data-discount-pct="{{ discount_pct }}"
               data-sub-discount-pct="{{ sub_discount_pct }}"
               data-plan-id="{{ tier_plan_id }}"
               data-one-time-cents="{{ one_time_total_cents }}"
               data-subscribe-cents="{{ subscribe_total_cents }}"
               data-line-compare-cents="{{ line_compare }}">

          {%- if discount_pct > 0 or badge != blank -%}
            <span
              class="bloomli-vt__size-badge"
              data-vt-discount-badge
              data-manual-badge="{{ badge | escape }}"
            >
              {%- if discount_pct > 0 -%}
                {{ dynamic_badge }}
              {%- else -%}
                {{ badge }}
              {%- endif -%}
            </span>
          {%- endif -%}

          <input type="radio"
                 name="bloomli-vt-size-{{ uid }}"
                 value="{{ qty }}"
                 class="bloomli-vt__radio-native"
                 {% if forloop.index0 == default_idx %}checked{% endif %}>

          <div class="bloomli-vt__size-media">
            {%- render 'bloomli-product-image-stack',
              image: image,
              product: product,
              count: qty,
              alt: display_label,
              class: 'bloomli-vt__size-stack',
              width: 460
            -%}
          </div>

          <div class="bloomli-vt__size-body">
            <div class="bloomli-vt__size-label">{{ display_label }}</div>
            {%- if count_text != blank -%}
              <div class="bloomli-vt__size-count">{{ count_text }}</div>
            {%- endif -%}
            {%- if daily_text != blank -%}
              <div
                class="bloomli-vt__size-daily"
                data-vt-daily
                data-onetime-daily="{{ daily_text | escape }}"
                data-subscribe-daily="{{ subscribe_daily_text | escape }}"
              >
                {{ daily_text }}
              </div>
            {%- endif -%}
          </div>

          {%- if tag != blank -%}
            <span class="bloomli-vt__size-tag">{{ tag }}</span>
          {%- endif -%}

          {%- if show_shipping and block.settings.shipping_text != blank -%}
            <span class="bloomli-vt__shipping-pill">{{ block.settings.shipping_text }}</span>
          {%- endif -%}
        </label>
      {%- endif -%}
    {%- endfor -%}
  </div>

  {%- if subscribe_enabled -%}
    {%- liquid
      assign subscribe_popular_pill = block.settings.subscribe_popular_pill | default: 'Most Popular · Get an extra 10% off'
      assign subscribe_perk_1 = block.settings.subscribe_perk_1 | default: '30-day money-back guarantee'
      assign subscribe_perk_2 = block.settings.subscribe_perk_2 | default: 'Free shipping on every delivery'
      assign subscribe_perk_3 = block.settings.subscribe_perk_3 | default: 'Pause or cancel anytime, no fees'
    -%}

    <div class="bloomli-vt__modes" role="radiogroup" aria-label="Purchase mode">

      <label class="bloomli-vt__mode bloomli-vt__mode--subscribe{% if default_mode == 'subscribe' %} is-selected{% endif %}"
             data-vt-mode
             data-mode="subscribe">
        {%- if subscribe_popular_pill != blank -%}
          <span class="bloomli-vt__mode-popular" aria-hidden="true">{{ subscribe_popular_pill }}</span>
        {%- endif -%}
        <div class="bloomli-vt__mode-row">
          <input type="radio"
                 name="bloomli-vt-mode-{{ uid }}"
                 value="subscribe"
                 class="bloomli-vt__radio-native"
                 {% if default_mode == 'subscribe' %}checked{% endif %}>
          <span class="bloomli-vt__radio-visual" aria-hidden="true"></span>
          <span class="bloomli-vt__mode-text">
            <span class="bloomli-vt__mode-title">
              {{ block.settings.label_subscribe | default: 'Subscribe & Save' }}
              <span class="bloomli-vt__mode-savings" data-vt-sub-savings></span>
            </span>
            <span class="bloomli-vt__mode-price" data-vt-subscribe-price>{{ unit_price | money }}</span>
          </span>
        </div>
        {%- if block.settings.subscribe_show_perks != false -%}
          <ul class="bloomli-vt__mode-perks" aria-hidden="true">
            {%- if subscribe_perk_1 != blank -%}
              <li class="bloomli-vt__mode-perk">{{ subscribe_perk_1 }}</li>
            {%- endif -%}
            {%- if subscribe_perk_2 != blank -%}
              <li class="bloomli-vt__mode-perk">{{ subscribe_perk_2 }}</li>
            {%- endif -%}
            {%- if subscribe_perk_3 != blank -%}
              <li class="bloomli-vt__mode-perk">{{ subscribe_perk_3 }}</li>
            {%- endif -%}
          </ul>
        {%- endif -%}
      </label>

      <label class="bloomli-vt__mode{% if default_mode == 'onetime' %} is-selected{% endif %}"
             data-vt-mode
             data-mode="onetime">
        <input type="radio"
               name="bloomli-vt-mode-{{ uid }}"
               value="onetime"
               class="bloomli-vt__radio-native"
               {% if default_mode == 'onetime' %}checked{% endif %}>
        <span class="bloomli-vt__radio-visual" aria-hidden="true"></span>
        <span class="bloomli-vt__mode-text">
          <span class="bloomli-vt__mode-title">{{ block.settings.label_one_time | default: 'One-Time Purchase' }}</span>
          <span class="bloomli-vt__mode-price" data-vt-onetime-price>{{ unit_price | money }}</span>
        </span>
      </label>

    </div>
  {%- endif -%}

  <div class="bloomli-vt__footer">
    <div class="bloomli-vt__total-row">
      <span class="bloomli-vt__total-label">{{ block.settings.total_label | default: 'Total price:' }}</span>
      <span class="bloomli-vt__total-amount">
        <span data-vt-total>{{ unit_price | money }}</span>
        <span class="bloomli-vt__total-compare" data-vt-compare></span>
      </span>
    </div>

  {%- if block.settings.note != blank -%}
      <div class="bloomli-vt__note">{{ block.settings.note }}</div>
    {%- endif -%}
  </div>

  <product-form
    class="product-form bloomli-vt__product-form"
    data-hide-errors="false"
    data-section-id="{{ section_id }}"
  >
    <div class="product-form__error-message-wrapper" role="alert" hidden>
      <span class="svg-wrapper">
        {{- 'icon-error.svg' | inline_asset_content -}}
      </span>
      <span class="product-form__error-message"></span>
    </div>

    {%- form 'product',
      product,
      id: bloomli_product_form_id,
      class: 'form',
      novalidate: 'novalidate',
      data-type: 'add-to-cart-form'
    -%}
      <input
        type="hidden"
        name="id"
        value="{{ product.selected_or_first_available_variant.id }}"
        {% if product.selected_or_first_available_variant.available == false
          or product.selected_or_first_available_variant == null
        %}
          disabled
        {% endif %}
        class="product-variant-id"
      >
      <input
        type="hidden"
        name="quantity"
        value="{{ default_qty }}"
        data-vt-qty-input
      >
      <input
        type="hidden"
        name="selling_plan"
        value=""
        data-vt-sp-input
        disabled
      >
      <button
        id="ProductSubmitButton-{{ section_id }}"
        type="submit"
        name="add"
        class="bloomli-vt__custom-submit product-form__submit"
        data-vt-submit-button
        {% unless product.selected_or_first_available_variant.available %}
          disabled
        {% endunless %}
      >
        <span data-vt-submit-text>
          {%- if product.selected_or_first_available_variant.available -%}
            {{ add_to_cart_label }}
          {%- else -%}
            {{ sold_out_label }}
          {%- endif -%}
        </span>
        {%- render 'loading-spinner' -%}
      </button>
    {%- endform -%}
  </product-form>
</div>
