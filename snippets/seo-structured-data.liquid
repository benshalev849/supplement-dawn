{% doc %}
Renders site-level SEO structured data for crawlers.
@example
{% render 'seo-structured-data' %}
{% enddoc %}

{%- liquid
  assign seo_page_name = page_title | default: shop.name | strip
  assign seo_page_url = canonical_url | default: request.origin
  assign seo_logo = settings.logo | default: settings.favicon
-%}

<script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "Organization",
    "name": {{ shop.name | json }},
    "url": {{ request.origin | json }}
    {%- if seo_logo != blank -%}
      ,"logo": {{ seo_logo | image_url: width: 600 | prepend: 'https:' | json }}
    {%- endif -%}
    {%- if shop.description != blank -%}
      ,"description": {{ shop.description | strip_html | strip | json }}
    {%- endif -%}
    {%- if settings.social_twitter_link != blank
      or settings.social_facebook_link != blank
      or settings.social_instagram_link != blank
      or settings.social_pinterest_link != blank
      or settings.social_tiktok_link != blank
      or settings.social_youtube_link != blank
      or settings.social_vimeo_link != blank
      or settings.social_snapchat_link != blank
    -%}
      ,"sameAs": [
        {%- liquid
          assign seo_same_as_written = false
          if settings.social_twitter_link != blank
            echo settings.social_twitter_link | json
            assign seo_same_as_written = true
          endif
          if settings.social_facebook_link != blank
            if seo_same_as_written
              echo ','
            endif
            echo settings.social_facebook_link | json
            assign seo_same_as_written = true
          endif
          if settings.social_instagram_link != blank
            if seo_same_as_written
              echo ','
            endif
            echo settings.social_instagram_link | json
            assign seo_same_as_written = true
          endif
          if settings.social_pinterest_link != blank
            if seo_same_as_written
              echo ','
            endif
            echo settings.social_pinterest_link | json
            assign seo_same_as_written = true
          endif
          if settings.social_tiktok_link != blank
            if seo_same_as_written
              echo ','
            endif
            echo settings.social_tiktok_link | json
            assign seo_same_as_written = true
          endif
          if settings.social_youtube_link != blank
            if seo_same_as_written
              echo ','
            endif
            echo settings.social_youtube_link | json
            assign seo_same_as_written = true
          endif
          if settings.social_vimeo_link != blank
            if seo_same_as_written
              echo ','
            endif
            echo settings.social_vimeo_link | json
            assign seo_same_as_written = true
          endif
          if settings.social_snapchat_link != blank
            if seo_same_as_written
              echo ','
            endif
            echo settings.social_snapchat_link | json
          endif
        -%}
      ]
    {%- endif -%}
  }
</script>

<script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    "name": {{ shop.name | json }},
    "url": {{ request.origin | json }},
    "potentialAction": {
      "@type": "SearchAction",
      "target": {
        "@type": "EntryPoint",
        "urlTemplate": {{ request.origin | append: routes.search_url | append: '?q={search_term_string}' | json }}
      },
      "query-input": "required name=search_term_string"
    }
  }
</script>

{%- unless request.page_type == 'index' or request.page_type == 'password' -%}
  <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": [
        {
          "@type": "ListItem",
          "position": 1,
          "name": {{ shop.name | json }},
          "item": {{ request.origin | json }}
        }
        {%- if request.page_type == 'product' -%}
          ,{
            "@type": "ListItem",
            "position": 2,
            "name": {{ product.title | json }},
            "item": {{ seo_page_url | json }}
          }
        {%- elsif request.page_type == 'collection' -%}
          ,{
            "@type": "ListItem",
            "position": 2,
            "name": {{ collection.title | json }},
            "item": {{ seo_page_url | json }}
          }
        {%- elsif request.page_type == 'article' -%}
          ,{
            "@type": "ListItem",
            "position": 2,
            "name": {{ blog.title | json }},
            "item": {{ request.origin | append: blog.url | json }}
          },
          {
            "@type": "ListItem",
            "position": 3,
            "name": {{ article.title | json }},
            "item": {{ seo_page_url | json }}
          }
        {%- elsif request.page_type == 'blog' -%}
          ,{
            "@type": "ListItem",
            "position": 2,
            "name": {{ blog.title | json }},
            "item": {{ seo_page_url | json }}
          }
        {%- else -%}
          ,{
            "@type": "ListItem",
            "position": 2,
            "name": {{ seo_page_name | json }},
            "item": {{ seo_page_url | json }}
          }
        {%- endif -%}
      ]
    }
  </script>
{%- endunless -%}
