{% doc %}
  @prompt
    Create a comparison table custom liquid section that fits the brand similar to the attached image.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-comparison-table-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    margin: 0 auto;
    padding: {{ block.settings.section_padding }}px 20px;
    background-color: {{ block.settings.background_color }};
  }

  .ai-comparison-table__header-{{ ai_gen_id }} {
    text-align: center;
    margin-bottom: 40px;
  }

  .ai-comparison-table__title-{{ ai_gen_id }} {
    font-size: {{ block.settings.heading_size }}px;
    color: {{ block.settings.heading_color }};
    margin: 0 0 12px;
    font-weight: 600;
  }

  .ai-comparison-table__subtitle-{{ ai_gen_id }} {
    font-size: {{ block.settings.subheading_size }}px;
    color: {{ block.settings.text_color }};
    margin: 0;
  }

  .ai-comparison-table__wrapper-{{ ai_gen_id }} {
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
  }

  .ai-comparison-table__table-{{ ai_gen_id }} {
    width: 100%;
    border-collapse: separate;
    border-spacing: 0;
    border: {{ block.settings.border_thickness }}px solid {{ block.settings.border_color }};
    border-radius: {{ block.settings.border_radius }}px;
    overflow: hidden;
  }

  .ai-comparison-table__table-{{ ai_gen_id }} thead {
    background-color: {{ block.settings.header_background }};
  }

  .ai-comparison-table__table-{{ ai_gen_id }} th {
    padding: {{ block.settings.cell_padding }}px;
    text-align: center;
    font-size: {{ block.settings.header_font_size }}px;
    font-weight: 600;
    color: {{ block.settings.header_text_color }};
    border-bottom: {{ block.settings.border_thickness }}px solid {{ block.settings.border_color }};
  }

  .ai-comparison-table__table-{{ ai_gen_id }} th:not(:last-child) {
    border-right: {{ block.settings.border_thickness }}px solid {{ block.settings.border_color }};
  }

  .ai-comparison-table__table-{{ ai_gen_id }} tbody tr {
    background-color: {{ block.settings.row_background }};
  }

  .ai-comparison-table__table-{{ ai_gen_id }} tbody tr:nth-child(even) {
    background-color: {{ block.settings.row_alternate_background }};
  }

  .ai-comparison-table__table-{{ ai_gen_id }} td {
    padding: {{ block.settings.cell_padding }}px;
    text-align: center;
    font-size: {{ block.settings.body_font_size }}px;
    color: {{ block.settings.text_color }};
    border-bottom: {{ block.settings.border_thickness }}px solid {{ block.settings.border_color }};
  }

  .ai-comparison-table__table-{{ ai_gen_id }} td:not(:last-child) {
    border-right: {{ block.settings.border_thickness }}px solid {{ block.settings.border_color }};
  }

  .ai-comparison-table__table-{{ ai_gen_id }} tbody tr:last-child td {
    border-bottom: none;
  }

  .ai-comparison-table__table-{{ ai_gen_id }} td:first-child {
    text-align: left;
    font-weight: 500;
  }

  .ai-comparison-table__checkmark-{{ ai_gen_id }} {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 24px;
    height: 24px;
    border-radius: 50%;
    background-color: {{ block.settings.checkmark_background }};
  }

  .ai-comparison-table__checkmark-{{ ai_gen_id }} svg {
    width: 16px;
    height: 16px;
    stroke: {{ block.settings.checkmark_color }};
  }

  .ai-comparison-table__cross-{{ ai_gen_id }} {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 24px;
    height: 24px;
    border-radius: 50%;
    background-color: {{ block.settings.cross_background }};
  }

  .ai-comparison-table__cross-{{ ai_gen_id }} svg {
    width: 16px;
    height: 16px;
    stroke: {{ block.settings.cross_color }};
  }

  .ai-comparison-table__highlight-{{ ai_gen_id }} {
    background-color: {{ block.settings.highlight_background }} !important;
  }

  @media screen and (max-width: 749px) {
    .ai-comparison-table__title-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.heading_size }}px * 0.8);
    }

    .ai-comparison-table__subtitle-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.subheading_size }}px * 0.9);
    }

    .ai-comparison-table__table-{{ ai_gen_id }} th,
    .ai-comparison-table__table-{{ ai_gen_id }} td {
      padding: {{ block.settings.cell_padding | times: 0.7 }}px;
      font-size: calc({{ block.settings.body_font_size }}px * 0.9);
    }

    .ai-comparison-table__table-{{ ai_gen_id }} th {
      font-size: calc({{ block.settings.header_font_size }}px * 0.9);
    }
  }
{% endstyle %}

<comparison-table-{{ ai_gen_id }} class="ai-comparison-table-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  {% if block.settings.heading != blank or block.settings.subheading != blank %}
    <div class="ai-comparison-table__header-{{ ai_gen_id }}">
      {% if block.settings.heading != blank %}
        <h2 class="ai-comparison-table__title-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
      {% endif %}
      {% if block.settings.subheading != blank %}
        <p class="ai-comparison-table__subtitle-{{ ai_gen_id }}">{{ block.settings.subheading }}</p>
      {% endif %}
    </div>
  {% endif %}

  <div class="ai-comparison-table__wrapper-{{ ai_gen_id }}">
    <table class="ai-comparison-table__table-{{ ai_gen_id }}">
      <thead>
        <tr>
          <th>{{ block.settings.feature_column_header }}</th>
          <th {% if block.settings.highlight_column_1 %}class="ai-comparison-table__highlight-{{ ai_gen_id }}"{% endif %}>
            {{ block.settings.column_1_header }}
          </th>
          <th {% if block.settings.highlight_column_2 %}class="ai-comparison-table__highlight-{{ ai_gen_id }}"{% endif %}>
            {{ block.settings.column_2_header }}
          </th>
          <th {% if block.settings.highlight_column_3 %}class="ai-comparison-table__highlight-{{ ai_gen_id }}"{% endif %}>
            {{ block.settings.column_3_header }}
          </th>
        </tr>
      </thead>
      <tbody>
        {% for i in (1..8) %}
          {% liquid
            assign feature_key = 'row_' | append: i | append: '_feature'
            assign col1_key = 'row_' | append: i | append: '_col1'
            assign col2_key = 'row_' | append: i | append: '_col2'
            assign col3_key = 'row_' | append: i | append: '_col3'

            assign feature = block.settings[feature_key]
            assign col1 = block.settings[col1_key]
            assign col2 = block.settings[col2_key]
            assign col3 = block.settings[col3_key]
          %}

          {% if feature != blank %}
            <tr>
              <td>{{ feature }}</td>
              <td {% if block.settings.highlight_column_1 %}class="ai-comparison-table__highlight-{{ ai_gen_id }}"{% endif %}>
                {% if col1 == 'yes' %}
                  <span class="ai-comparison-table__checkmark-{{ ai_gen_id }}">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
                      <polyline points="20 6 9 17 4 12"></polyline>
                    </svg>
                  </span>
                {% elsif col1 == 'no' %}
                  <span class="ai-comparison-table__cross-{{ ai_gen_id }}">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
                      <line x1="18" y1="6" x2="6" y2="18"></line>
                      <line x1="6" y1="6" x2="18" y2="18"></line>
                    </svg>
                  </span>
                {% else %}
                  {{ col1 }}
                {% endif %}
              </td>
              <td {% if block.settings.highlight_column_2 %}class="ai-comparison-table__highlight-{{ ai_gen_id }}"{% endif %}>
                {% if col2 == 'yes' %}
                  <span class="ai-comparison-table__checkmark-{{ ai_gen_id }}">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
                      <polyline points="20 6 9 17 4 12"></polyline>
                    </svg>
                  </span>
                {% elsif col2 == 'no' %}
                  <span class="ai-comparison-table__cross-{{ ai_gen_id }}">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
                      <line x1="18" y1="6" x2="6" y2="18"></line>
                      <line x1="6" y1="6" x2="18" y2="18"></line>
                    </svg>
                  </span>
                {% else %}
                  {{ col2 }}
                {% endif %}
              </td>
              <td {% if block.settings.highlight_column_3 %}class="ai-comparison-table__highlight-{{ ai_gen_id }}"{% endif %}>
                {% if col3 == 'yes' %}
                  <span class="ai-comparison-table__checkmark-{{ ai_gen_id }}">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
                      <polyline points="20 6 9 17 4 12"></polyline>
                    </svg>
                  </span>
                {% elsif col3 == 'no' %}
                  <span class="ai-comparison-table__cross-{{ ai_gen_id }}">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
                      <line x1="18" y1="6" x2="6" y2="18"></line>
                      <line x1="6" y1="6" x2="18" y2="18"></line>
                    </svg>
                  </span>
                {% else %}
                  {{ col3 }}
                {% endif %}
              </td>
            </tr>
          {% endif %}
        {% endfor %}
      </tbody>
    </table>
  </div>
</comparison-table-{{ ai_gen_id }}>

<script>
  (function() {
    class ComparisonTable{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.setupAccessibility();
      }

      setupAccessibility() {
        const table = this.querySelector('table');
        if (table) {
          table.setAttribute('role', 'table');
          table.setAttribute('aria-label', 'Product comparison table');
        }
      }
    }

    customElements.define('comparison-table-{{ ai_gen_id }}', ComparisonTable{{ ai_gen_id }});
  })();
</script>

