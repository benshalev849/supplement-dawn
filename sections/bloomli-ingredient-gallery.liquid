<section class="bloomli-ingredient-gallery bloomli-section color-{{ section.settings.color_scheme }} gradient" style="--big-eyebrow-color: {{ section.settings.eyebrow_accent_color | default: '#8A6678' }}; --big-small-label-color: {{ section.settings.small_label_color | default: '#8A6678' }}; {% if section.settings.use_custom_background %}--big-bg: {{ section.settings.background_color }};{% else %}--big-bg: var(--bloomli-bg);{% endif %}{% case section.settings.circle_background %}{% when 'background' %}--big-circle-bg: var(--bloomli-bg);{% when 'surface_strong' %}--big-circle-bg: var(--bloomli-surface-strong);{% when 'accent_soft' %}--big-circle-bg: var(--bloomli-soft-blush);{% else %}--big-circle-bg: var(--bloomli-surface);{% endcase %} --bloomli-padding-top: {{ section.settings.padding_top }}px; --bloomli-padding-bottom: {{ section.settings.padding_bottom }}px; --big-image-size: {{ section.settings.image_size }}px; --big-image-size-mobile: {{ section.settings.image_size_mobile }}px;">
  <div class="bloomli-section__inner" style="--bloomli-section-width: 1120px;">
    <div class="bloomli-ingredient-gallery__header">
      {%- if section.settings.eyebrow != blank -%}
        <div class="smallcaps bloomli-ingredient-gallery__eyebrow">{{ section.settings.eyebrow }}</div>
      {%- endif -%}
      <h2 class="bloomli-ingredient-gallery__heading">{{ section.settings.heading }}</h2>
    </div>

    <div class="bloomli-ingredient-gallery__grid">
      {%- for block in section.blocks -%}
        <div class="bloomli-ingredient-gallery__item" {{ block.shopify_attributes }}>
          <div class="bloomli-ingredient-gallery__media" style="--big-item-bg: {% if block.settings.use_custom_circle_color %}{{ block.settings.circle_color }}{% else %}var(--big-circle-bg){% endif %}; {% if block.settings.image == blank %}--big-placeholder-lines: repeating-linear-gradient(135deg, var(--bloomli-line-soft) 0 1px, transparent 1px 18px);{% endif %}">
            {%- if block.settings.image != blank -%}
              {%- assign image_scale = block.settings.image_scale | divided_by: 100.0 -%}
              {%- assign image_style = '--big-image-scale: ' | append: image_scale | append: ';' -%}
              {%- assign image_alt = block.settings.image.alt | default: block.settings.title -%}
              {{
                block.settings.image
                | image_url: width: 620
                | image_tag:
                  class: 'bloomli-ingredient-gallery__image',
                  alt: image_alt,
                  widths: '240, 420, 620',
                  sizes: '(max-width: 749px) 150px, 220px',
                  loading: 'lazy', decoding: 'async',
                  style: image_style
              }}
            {%- endif -%}
            {%- if block.settings.photo_label != blank and block.settings.image == blank -%}
              <span class="smallcaps bloomli-section-placeholder-label">{{ block.settings.photo_label }}</span>
            {%- endif -%}
          </div>
          <h3 class="bloomli-ingredient-gallery__title">{{ block.settings.title }}</h3>
          {%- if block.settings.amount != blank -%}
            <div class="smallcaps bloomli-ingredient-gallery__amount">{{ block.settings.amount }}</div>
          {%- endif -%}
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Bloomli - Ing Gallery",
  "tag": "div",
  "max_blocks": 9,
  "settings": [
    { "type": "color_scheme", "id": "color_scheme", "label": "Color scheme", "default": "scheme-6d8ba907-aae6-4c49-9120-e1031d9cdb3f" },
    { "type": "checkbox", "id": "use_custom_background", "label": "Use custom background color", "default": false },
    { "type": "color", "id": "background_color", "label": "Section background color", "default": "#F3E1E5" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Every ingredient, photographed" },
    { "type": "color", "id": "eyebrow_accent_color", "label": "Eyebrow accent color", "default": "#8A6678" },
    { "type": "color", "id": "small_label_color", "label": "Small label color", "default": "#8A6678" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Nothing hidden." },
    { "type": "select", "id": "circle_background", "label": "Ingredient circle background", "options": [
      { "value": "surface", "label": "Scheme soft surface" },
      { "value": "surface_strong", "label": "Scheme stronger surface" },
      { "value": "background", "label": "Scheme background" },
      { "value": "accent_soft", "label": "Soft accent" }
    ], "default": "surface" },
    { "type": "range", "id": "image_size", "label": "Circle size desktop", "min": 160, "max": 300, "step": 10, "default": 220, "unit": "px" },
    { "type": "range", "id": "image_size_mobile", "label": "Circle size mobile", "min": 120, "max": 220, "step": 10, "default": 150, "unit": "px" },
    { "type": "range", "id": "padding_top", "label": "Padding top", "min": 48, "max": 176, "step": 8, "default": 112, "unit": "px" },
    { "type": "range", "id": "padding_bottom", "label": "Padding bottom", "min": 48, "max": 176, "step": 8, "default": 112, "unit": "px" }
  ],
  "blocks": [
    {
      "type": "ingredient",
      "name": "Ingredient",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Ingredient photo" },
        { "type": "range", "id": "image_scale", "label": "Uploaded image scale", "min": 70, "max": 140, "step": 5, "default": 100, "unit": "%" },
        { "type": "checkbox", "id": "use_custom_circle_color", "label": "Override circle background", "default": false },
        { "type": "color", "id": "circle_color", "label": "Custom circle background", "default": "#FFFFFF" },
        { "type": "text", "id": "photo_label", "label": "Placeholder label", "default": "Raw ingredient" },
        { "type": "text", "id": "title", "label": "Title", "default": "Biotin" },
        { "type": "text", "id": "amount", "label": "Amount", "default": "2500 MCG" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Bloomli - Ing Gallery",
      "blocks": [
        { "type": "ingredient", "settings": { "title": "Biotin", "amount": "2500 MCG", "photo_label": "Raw biotin - powder" } },
        { "type": "ingredient", "settings": { "title": "Saw Palmetto", "amount": "160 MG", "photo_label": "Saw palmetto - berry" } },
        { "type": "ingredient", "settings": { "title": "Marine Collagen", "amount": "500 MG", "photo_label": "Marine collagen - flake" } },
        { "type": "ingredient", "settings": { "title": "Ashwagandha", "amount": "300 MG", "photo_label": "Ashwagandha - root" } },
        { "type": "ingredient", "settings": { "title": "Zinc", "amount": "8 MG", "photo_label": "Zinc - mineral" } },
        { "type": "ingredient", "settings": { "title": "Vitamin D3", "amount": "2000 IU", "photo_label": "Vitamin D3 - droplet" } }
      ]
    }
  ]
}
{% endschema %}
