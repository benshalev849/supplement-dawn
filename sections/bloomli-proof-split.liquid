{%- liquid
  assign image_scale = section.settings.image_scale | divided_by: 100.0
  assign desktop_image_size = section.settings.desktop_image_size | default: 100 | divided_by: 100.0
  assign desktop_image_scale = image_scale | times: desktop_image_size
  assign image_alt = section.settings.image.alt | default: section.settings.heading_line1
  assign image_style = 'object-position: ' | append: section.settings.image_position | append: ';'
  assign icon_accent_color = section.settings.icon_accent_color | downcase
  assign layout_style = section.settings.layout_style | default: 'split'
  assign header_alignment = section.settings.header_alignment | default: 'left'
  assign header_position = section.settings.header_position | default: 'above_grid'
  assign mobile_image_position = section.settings.mobile_image_position | default: 'before_items'
  assign number_style = section.settings.number_style | default: 'leading_zero'
  assign content_density = section.settings.content_density | default: 'standard'
  assign card_grid_image_position = section.settings.card_grid_image_position | default: 'before_cards'
  assign show_image = section.settings.show_image
  if show_image == nil
    assign show_image = true
  endif
  assign enable_image_animation = section.settings.enable_image_animation
  if enable_image_animation == nil
    assign enable_image_animation = true
  endif
-%}

<section
  {% if section.settings.section_id != blank %}
    id="{{ section.settings.section_id | handleize }}"
  {% endif %}
  class="bloomli-proof-panel bloomli-proof-panel--layout-{{ layout_style }} bloomli-proof-panel--density-{{ content_density }} bloomli-proof-panel--image-{{ section.settings.image_side | default: 'left' }} bloomli-proof-panel--header-{{ header_alignment }} bloomli-proof-panel--header-position-{{ header_position }} bloomli-proof-panel--mobile-image-{{ mobile_image_position }} bloomli-proof-panel--card-image-{{ card_grid_image_position }}{% unless show_image %} bloomli-proof-panel--no-image{% endunless %}{% if enable_image_animation %} bloomli-proof-panel--movement{% else %} bloomli-proof-panel--static-image{% endif %} bloomli-section color-{{ section.settings.color_scheme }} gradient"
  style="
    --bpp-bg: {% if section.settings.use_custom_background %}{{ section.settings.background_color }}{% else %}rgb(var(--color-background)){% endif %};
    --bpp-accent: {% if icon_accent_color == '#6f7a5a' %}var(--bloomli-primary-action){% else %}{{ section.settings.icon_accent_color | default: 'var(--bloomli-primary-action)' }}{% endif %};
    --section-padding-top: {{ section.settings.padding_top }}px;
    --section-padding-bottom: {{ section.settings.padding_bottom }}px;
    --section-padding-top-mobile: {{ section.settings.padding_top_mobile }}px;
    --section-padding-bottom-mobile: {{ section.settings.padding_bottom_mobile }}px;
    --bpp-image-width: {{ section.settings.image_width | default: 620 }}px;
    --bpp-image-desktop-scale: {{ desktop_image_scale }};
    --bpp-image-mobile-size: {{ section.settings.image_size | default: 100 }}%;
    --bpp-image-radius: {{ section.settings.image_radius | default: 16 }}px;
    --bpp-image-scale: {{ image_scale }};
    --bpp-image-fit: {{ section.settings.image_fit | default: 'cover' }};
    --bpp-header-align: {{ header_alignment }};
    --bpp-card-columns-desktop: {{ section.settings.card_columns_desktop | default: 4 }};
    --bpp-card-columns-tablet: {{ section.settings.card_columns_tablet | default: 2 }};
    --bpp-card-grid-image-height: {{ section.settings.card_grid_image_height | default: 240 }}px;
    --bpp-card-border: {% if section.settings.show_card_borders %}1px solid color-mix(in srgb, var(--bloomli-editorial-accent) 18%, transparent){% else %}0{% endif %};
  "
>
  <div class="bloomli-proof-panel__inner">
    {%- capture proof_header -%}
      <div class="bloomli-proof-panel__header">
        <h2>
          {{ section.settings.heading_line1 | escape }}
        </h2>
        {%- if section.settings.copy != blank -%}
          <div class="bloomli-proof-panel__copy">{{ section.settings.copy }}</div>
        {%- endif -%}
      </div>
    {%- endcapture -%}

    {%- capture proof_list -%}
      <div class="bloomli-proof-panel__proof-list">
        {%- for block in section.blocks -%}
          {%- liquid
            assign displayed_number = forloop.index
            if number_style == 'leading_zero' and forloop.index < 10
              assign displayed_number = displayed_number | prepend: '0'
            endif
          -%}
          <article class="bloomli-proof-panel__proof-item" {{ block.shopify_attributes }}>
            {%- unless number_style == 'none' -%}
              <span class="bloomli-proof-panel__number">{{ displayed_number }}</span>
            {%- endunless -%}
            <div>
              {%- if block.settings.bullet_title != blank -%}
                <h3>{{ block.settings.bullet_title | escape }}</h3>
                {%- if block.settings.text != blank -%}
                  <p>{{ block.settings.text }}</p>
                {%- endif -%}
                {%- if block.settings.note != blank -%}
                  <div class="bloomli-proof-panel__proof-item-note">{{ block.settings.note | escape }}</div>
                {%- endif -%}
              {%- elsif block.settings.text != blank -%}
                <h3>{{ block.settings.text }}</h3>
              {%- endif -%}
            </div>
          </article>
        {%- endfor -%}
      </div>
    {%- endcapture -%}

    {%- capture proof_items -%}
      {{ proof_list }}
      {%- if section.settings.items_note != blank -%}
        <div class="bloomli-proof-panel__items-note rte">{{ section.settings.items_note }}</div>
      {%- endif -%}
    {%- endcapture -%}

    {%- capture proof_visual -%}
      <div class="bloomli-proof-panel__visual">
        {%- if section.settings.image != blank -%}
          <div class="bloomli-proof-panel__image-wrap">
            {{
              section.settings.image
              | image_url: width: 1400
              | image_tag:
                class: 'bloomli-proof-panel__image',
                alt: image_alt,
                widths: '500, 700, 900, 1200, 1400',
                sizes: '(max-width: 899px) calc(100vw - 84px), min(42vw, 560px)',
                loading: 'lazy',
                decoding: 'async',
                style: image_style
            }}
          </div>
        {%- elsif section.settings.image_label != blank -%}
          <span class="smallcaps bloomli-section-placeholder-label">{{ section.settings.image_label }}</span>
        {%- endif -%}

        {%- if section.settings.image_caption != blank -%}
          <div class="bloomli-proof-panel__image-caption">{{ section.settings.image_caption }}</div>
        {%- endif -%}
      </div>
    {%- endcapture -%}

    {%- if header_position == 'above_grid' -%}
      {{ proof_header }}
    {%- endif -%}

    <div class="bloomli-proof-panel__grid">
      {%- liquid
        assign show_visual_before_items = false
        if show_image
          if layout_style == 'cards_grid'
            if card_grid_image_position == 'before_cards'
              assign show_visual_before_items = true
            endif
          else
            assign show_visual_before_items = true
          endif
        endif
      -%}

      {%- if show_visual_before_items -%}
        {{ proof_visual }}
      {%- endif -%}

      {%- if header_position == 'with_items' -%}
        <div class="bloomli-proof-panel__content">
          {{ proof_header }}
          {{ proof_items }}
        </div>
      {%- else -%}
        {{ proof_items }}
      {%- endif -%}

      {%- if show_image and layout_style == 'cards_grid' and card_grid_image_position == 'after_cards' -%}
        {{ proof_visual }}
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Bloomli - Proof Split",
  "tag": "div",
  "max_blocks": 6,
  "settings": [
    { "type": "color_scheme", "id": "color_scheme", "label": "Color scheme", "default": "scheme-6d8ba907-aae6-4c49-9120-e1031d9cdb3f" },
    { "type": "text", "id": "section_id", "label": "Optional section anchor ID" },
    { "type": "select", "id": "layout_style", "label": "Layout style", "options": [
      { "value": "split", "label": "Split image and proof list" },
      { "value": "cards_grid", "label": "Header with card grid" }
    ], "default": "split" },
    { "type": "select", "id": "header_alignment", "label": "Header alignment", "options": [
      { "value": "left", "label": "Left" },
      { "value": "center", "label": "Center" }
    ], "default": "left" },
    { "type": "select", "id": "header_position", "label": "Header position", "options": [
      { "value": "above_grid", "label": "Above image and items" },
      { "value": "with_items", "label": "With proof items" }
    ], "default": "above_grid" },
    { "type": "select", "id": "content_density", "label": "Content density", "options": [
      { "value": "standard", "label": "Standard" },
      { "value": "compact", "label": "Compact" }
    ], "default": "standard" },
    { "type": "checkbox", "id": "use_custom_background", "label": "Use custom background color", "default": false },
    { "type": "color", "id": "background_color", "label": "Custom background color", "default": "#FDFAF7" },
    { "type": "color", "id": "icon_accent_color", "label": "Icon accent color", "default": "#6F7A5A" },
    { "type": "checkbox", "id": "show_image", "label": "Show image / visual column", "default": true },
    { "type": "image_picker", "id": "image", "label": "Image" },
    { "type": "select", "id": "image_side", "label": "Image position on desktop", "options": [
      { "value": "left", "label": "Left" },
      { "value": "right", "label": "Right" }
    ], "default": "left" },
    { "type": "select", "id": "mobile_image_position", "label": "Image position on mobile", "options": [
      { "value": "before_items", "label": "Before proof items" },
      { "value": "after_items", "label": "After proof items" }
    ], "default": "before_items" },
    { "type": "select", "id": "media_background", "label": "Image placeholder background", "options": [
      { "value": "surface", "label": "Scheme soft surface" },
      { "value": "surface_strong", "label": "Scheme stronger surface" },
      { "value": "background", "label": "Scheme background" },
      { "value": "accent_soft", "label": "Soft accent" }
    ], "default": "surface" },
    { "type": "text", "id": "image_label", "label": "Placeholder label", "default": "Editorial - morning ritual - natural light" },
    { "type": "richtext", "id": "image_caption", "label": "Text below image" },
    { "type": "range", "id": "image_scale", "label": "Uploaded image zoom", "min": 100, "max": 140, "step": 5, "default": 100, "unit": "%" },
    { "type": "select", "id": "image_fit", "label": "Image fit", "options": [
      { "value": "cover", "label": "Cover" },
      { "value": "contain", "label": "Contain" }
    ], "default": "cover" },
    { "type": "checkbox", "id": "enable_image_animation", "label": "Movement", "default": true },
    { "type": "select", "id": "image_position", "label": "Image crop position", "options": [
      { "value": "center center", "label": "Center" },
      { "value": "center top", "label": "Top" },
      { "value": "center bottom", "label": "Bottom" },
      { "value": "left center", "label": "Left" },
      { "value": "right center", "label": "Right" }
    ], "default": "center center" },
    { "type": "range", "id": "image_width", "label": "Image width", "min": 320, "max": 760, "step": 20, "default": 620, "unit": "px" },
    { "type": "range", "id": "desktop_image_size", "label": "Desktop image size", "min": 40, "max": 100, "step": 5, "default": 100, "unit": "%" },
    { "type": "range", "id": "image_size", "label": "Mobile image size", "min": 40, "max": 100, "step": 5, "default": 100, "unit": "%" },
    { "type": "range", "id": "image_radius", "label": "Image corner radius", "min": 0, "max": 40, "step": 2, "default": 16, "unit": "px" },
    { "type": "select", "id": "card_grid_image_position", "label": "Card grid image position", "options": [
      { "value": "before_cards", "label": "Before cards" },
      { "value": "after_cards", "label": "After cards" }
    ], "default": "before_cards" },
    { "type": "range", "id": "card_grid_image_height", "label": "Card grid image height", "min": 160, "max": 420, "step": 20, "default": 240, "unit": "px" },
    { "type": "checkbox", "id": "show_card_borders", "label": "Show card borders", "default": true },
    { "type": "select", "id": "number_style", "label": "Number style", "options": [
      { "value": "leading_zero", "label": "01, 02, 03" },
      { "value": "plain", "label": "1, 2, 3" },
      { "value": "none", "label": "Hide numbers" }
    ], "default": "leading_zero" },
    { "type": "range", "id": "card_columns_desktop", "label": "Card columns on desktop", "min": 2, "max": 4, "step": 1, "default": 4 },
    { "type": "range", "id": "card_columns_tablet", "label": "Card columns on tablet", "min": 1, "max": 3, "step": 1, "default": 2 },
    { "type": "text", "id": "heading_line1", "label": "Heading", "default": "Every milligram, intentional." },
    { "type": "richtext", "id": "copy", "label": "Copy", "default": "<p>We formulate at clinical doses - the amounts used in peer-reviewed studies - not the sprinkle-doses you'll find in most gummies. Every batch is independently tested. Nothing added for color, nothing hidden in a proprietary blend.</p>" },
    { "type": "richtext", "id": "items_note", "label": "Text below proof items" },
    { "type": "range", "id": "padding_top", "label": "Padding top", "min": 0, "max": 176, "step": 8, "default": 80, "unit": "px" },
    { "type": "range", "id": "padding_bottom", "label": "Padding bottom", "min": 0, "max": 176, "step": 8, "default": 80, "unit": "px" },
    { "type": "range", "id": "padding_top_mobile", "label": "Padding top mobile", "min": 0, "max": 176, "step": 8, "default": 56, "unit": "px" },
    { "type": "range", "id": "padding_bottom_mobile", "label": "Padding bottom mobile", "min": 0, "max": 176, "step": 8, "default": 56, "unit": "px" }
  ],
  "blocks": [
    {
      "type": "bullet",
      "name": "Proof item",
      "settings": [
        { "type": "text", "id": "bullet_title", "label": "Item title" },
        { "type": "text", "id": "text", "label": "Text", "default": "Clinically-dosed actives. No fairy dust." },
        { "type": "text", "id": "note", "label": "Small note" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Bloomli - Proof Split",
      "blocks": [
        { "type": "bullet", "settings": { "text": "Clinically-dosed actives. No fairy dust." } },
        { "type": "bullet", "settings": { "text": "Vegan pectin base. No gelatin, no artificial dyes." } },
        { "type": "bullet", "settings": { "text": "Third-party tested for purity and potency." } },
        { "type": "bullet", "settings": { "text": "Made in a GMP-certified facility in California." } }
      ]
    }
  ]
}
{% endschema %}
