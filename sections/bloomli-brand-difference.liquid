{{ 'bloomli-brand-difference.css' | asset_url | stylesheet_tag }}

<section
  class="bloomli-brand-difference color-{{ section.settings.color_scheme }} gradient"
  data-padding-top-mobile="{{ section.settings.padding_top_mobile }}"
  data-padding-bottom-mobile="{{ section.settings.padding_bottom_mobile }}"
  data-padding-top-desktop="{{ section.settings.padding_top_desktop }}"
  data-padding-bottom-desktop="{{ section.settings.padding_bottom_desktop }}"
>
  <div class="page-width">
    <div class="bloomli-brand-difference__statement">
      {%- if section.settings.heading != blank -%}
        <h2 class="bloomli-brand-difference__heading h1">
          {{ section.settings.heading | escape }}
        </h2>
      {%- endif -%}

      {%- if section.settings.body != blank -%}
        <div class="bloomli-brand-difference__body rte">
          {{ section.settings.body }}
        </div>
      {%- endif -%}
    </div>

    {%- if section.blocks.size > 0 -%}
      <div class="bloomli-brand-difference__cards">
        {%- for block in section.blocks -%}
          <article class="bloomli-brand-difference__card" {{ block.shopify_attributes }}>
            {%- if block.settings.number != blank -%}
              <p class="bloomli-brand-difference__number">
                {{ block.settings.number | escape }}
              </p>
            {%- endif -%}

            {%- if block.settings.title != blank -%}
              <h3 class="bloomli-brand-difference__card-title h4">
                {{ block.settings.title | escape }}
              </h3>
            {%- endif -%}

            {%- if block.settings.text != blank -%}
              <div class="bloomli-brand-difference__card-text rte">
                {{ block.settings.text }}
              </div>
            {%- endif -%}
          </article>
        {%- endfor -%}
      </div>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Bloomli Brand Difference",
  "tag": "section",
  "class": "section",
  "enabled_on": {
    "templates": ["index"]
  },
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Not just another hair supplement."
    },
    {
      "type": "richtext",
      "id": "body",
      "label": "Body",
      "default": "<p>Bloomli is built as a daily hair ritual &mdash; inside-out nutrients, flexible formats, and outside-in care for the scalp and strands.</p>"
    },
    {
      "type": "header",
      "content": "Desktop spacing"
    },
    {
      "type": "range",
      "id": "padding_top_desktop",
      "min": 0,
      "max": 120,
      "step": 8,
      "unit": "px",
      "label": "Padding top",
      "default": 72
    },
    {
      "type": "range",
      "id": "padding_bottom_desktop",
      "min": 0,
      "max": 120,
      "step": 8,
      "unit": "px",
      "label": "Padding bottom",
      "default": 72
    },
    {
      "type": "header",
      "content": "Mobile spacing"
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "min": 0,
      "max": 120,
      "step": 8,
      "unit": "px",
      "label": "Padding top",
      "default": 48
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "min": 0,
      "max": 120,
      "step": 8,
      "unit": "px",
      "label": "Padding bottom",
      "default": 48
    }
  ],
  "blocks": [
    {
      "type": "card",
      "name": "Card",
      "settings": [
        {
          "type": "text",
          "id": "number",
          "label": "Number",
          "default": "01"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Inside-out support"
        },
        {
          "type": "richtext",
          "id": "text",
          "label": "Text",
          "default": "<p>Daily nutrients chosen to support the foundation of healthier-looking hair, from roots to strands.</p>"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Bloomli Brand Difference",
      "blocks": [
        {
          "type": "card",
          "settings": {
            "number": "01",
            "title": "Inside-out support",
            "text": "<p>Daily nutrients chosen to support the foundation of healthier-looking hair, from roots to strands.</p>"
          }
        },
        {
          "type": "card",
          "settings": {
            "number": "02",
            "title": "Choose your format",
            "text": "<p>Gummies or capsules, so your hair wellness routine fits your real life &mdash; not the other way around.</p>"
          }
        },
        {
          "type": "card",
          "settings": {
            "number": "03",
            "title": "Complete the ritual",
            "text": "<p>Add botanical hair oil for outside-in scalp, strand, and end care when you want the full routine.</p>"
          }
        }
      ]
    }
  ]
}
{% endschema %}
