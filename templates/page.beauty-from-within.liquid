{% layout none %}
<style>
  .bloomli-bfw {
    --blush: #f7e3e8;
    --blush-soft: #fbf1f3;
    --berry: #b23a6f;
    --berry-dark: #7d254d;
    --charcoal: #2a2622;
    --muted: #75656b;
    --cream: #fffaf7;
    --white: #ffffff;
    --line: rgba(42, 38, 34, 0.12);

    color: var(--charcoal);
    background: var(--cream);
    font-family: inherit;
    overflow: hidden;
  }

  .bloomli-bfw * {
    box-sizing: border-box;
  }

  .bloomli-bfw a {
    color: inherit;
    text-decoration: none;
  }

  .bfw-container {
    width: min(1180px, calc(100% - 32px));
    margin: 0 auto;
  }

  .bfw-eyebrow {
    margin: 0 0 14px;
    color: var(--berry);
    font-size: 12px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    font-weight: 800;
  }

  .bfw-hero {
    padding: 90px 0 78px;
    background:
      radial-gradient(circle at 88% 16%, rgba(178, 58, 111, 0.13), transparent 30%),
      linear-gradient(135deg, #fffaf7 0%, #f7e3e8 100%);
  }

  .bfw-hero-grid {
    display: grid;
    grid-template-columns: 1.05fr 0.95fr;
    gap: 58px;
    align-items: center;
  }

  .bfw-hero h1 {
    margin: 0;
    max-width: 760px;
    font-size: clamp(44px, 6vw, 78px);
    line-height: 0.96;
    letter-spacing: -0.045em;
    font-weight: 500;
  }

  .bfw-hero h1 em {
    font-style: italic;
    color: var(--berry-dark);
  }

  .bfw-hero-text {
    margin: 24px 0 0;
    max-width: 640px;
    color: var(--muted);
    font-size: 19px;
    line-height: 1.65;
  }

  .bfw-actions {
    display: flex;
    gap: 14px;
    flex-wrap: wrap;
    margin-top: 34px;
  }

  .bfw-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 48px;
    padding: 0 24px;
    border-radius: 999px;
    font-size: 14px;
    font-weight: 800;
    letter-spacing: 0.02em;
    transition: transform 0.2s ease, opacity 0.2s ease;
  }

  .bfw-btn:hover {
    transform: translateY(-1px);
  }

  .bfw-btn-primary {
    background: var(--berry);
    color: #fff !important;
  }

  .bfw-btn-secondary {
    background: rgba(255, 255, 255, 0.74);
    border: 1px solid var(--line);
    color: var(--charcoal) !important;
  }

  .bfw-visual {
    position: relative;
    min-height: 470px;
    border-radius: 34px;
    background:
      radial-gradient(circle at 20% 18%, rgba(255,255,255,0.95), transparent 30%),
      linear-gradient(145deg, #f4d5dd, #fff7f3);
    border: 1px solid rgba(255,255,255,0.85);
    box-shadow: 0 28px 80px rgba(104, 52, 73, 0.14);
    overflow: hidden;
  }

  .bfw-orbit {
    position: absolute;
    inset: 38px;
    border: 1px solid rgba(178, 58, 111, 0.18);
    border-radius: 999px;
    transform: rotate(-12deg);
  }

  .bfw-product-card {
    position: absolute;
    background: rgba(255, 250, 247, 0.88);
    border: 1px solid rgba(255,255,255,0.95);
    box-shadow: 0 18px 45px rgba(104, 52, 73, 0.14);
    backdrop-filter: blur(10px);
    border-radius: 24px;
    padding: 18px;
    width: 170px;
    z-index: 2;
  }

  .bfw-product-card strong {
    display: block;
    font-size: 18px;
    letter-spacing: -0.03em;
    margin-bottom: 6px;
  }

  .bfw-product-card span {
    display: block;
    color: var(--muted);
    font-size: 13px;
    line-height: 1.4;
  }

  .bfw-product-card.one {
    top: 54px;
    left: 54px;
  }

  .bfw-product-card.two {
    top: 86px;
    right: 42px;
  }

  .bfw-product-card.three {
    bottom: 74px;
    left: 42px;
  }

  .bfw-product-card.four {
    bottom: 46px;
    right: 58px;
  }

  .bfw-center-mark {
    position: absolute;
    left: 50%;
    top: 50%;
    width: 180px;
    height: 180px;
    transform: translate(-50%, -50%);
    border-radius: 999px;
    background: rgba(255,255,255,0.72);
    border: 1px solid rgba(255,255,255,0.95);
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: 28px;
    color: var(--berry-dark);
    font-size: 28px;
    line-height: 1.02;
    letter-spacing: -0.04em;
    font-weight: 650;
    box-shadow: 0 18px 45px rgba(104, 52, 73, 0.12);
    z-index: 3;
  }

  .bfw-section {
    padding: 86px 0;
  }

  .bfw-centered {
    max-width: 790px;
    margin: 0 auto 48px;
    text-align: center;
  }

  .bfw-centered h2,
  .bfw-split h2 {
    margin: 0;
    font-size: clamp(34px, 4vw, 56px);
    line-height: 1.02;
    letter-spacing: -0.045em;
    font-weight: 500;
  }

  .bfw-centered p {
    margin: 18px auto 0;
    color: var(--muted);
    font-size: 18px;
    line-height: 1.65;
  }

  .bfw-cards {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 18px;
  }

  .bfw-card {
    background: #fff;
    border: 1px solid var(--line);
    border-radius: 26px;
    padding: 30px;
    min-height: 250px;
    box-shadow: 0 18px 44px rgba(42, 38, 34, 0.05);
  }

  .bfw-icon {
    width: 54px;
    height: 54px;
    border-radius: 18px;
    background: var(--blush);
    color: var(--berry);
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 22px;
    font-size: 24px;
  }

  .bfw-card h3 {
    margin: 0 0 10px;
    font-size: 23px;
    line-height: 1.15;
    letter-spacing: -0.03em;
    font-weight: 650;
  }

  .bfw-card p {
    margin: 0;
    color: var(--muted);
    font-size: 16px;
    line-height: 1.65;
  }

  .bfw-soft {
    background: var(--blush-soft);
  }

  .bfw-split {
    display: grid;
    grid-template-columns: 0.92fr 1.08fr;
    gap: 54px;
    align-items: center;
  }

  .bfw-split p {
    color: var(--muted);
    font-size: 18px;
    line-height: 1.7;
  }

  .bfw-highlight-box {
    border-radius: 34px;
    background: linear-gradient(145deg, #fff, #f8e4e9);
    padding: 34px;
    border: 1px solid rgba(42,38,34,0.08);
  }

  .bfw-highlight-list {
    display: grid;
    gap: 14px;
  }

  .bfw-highlight-item {
    display: flex;
    gap: 14px;
    align-items: flex-start;
    padding: 18px;
    border-radius: 20px;
    background: rgba(255,255,255,0.68);
    border: 1px solid rgba(42,38,34,0.07);
  }

  .bfw-check {
    width: 26px;
    height: 26px;
    min-width: 26px;
    border-radius: 50%;
    background: var(--berry);
    color: #fff;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 14px;
    margin-top: 2px;
  }

  .bfw-highlight-item strong {
    display: block;
    margin-bottom: 4px;
    font-size: 16px;
  }

  .bfw-highlight-item span {
    display: block;
    color: var(--muted);
    font-size: 15px;
    line-height: 1.45;
  }

  .bfw-products {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 16px;
  }

  .bfw-product {
    background: #fff;
    border: 1px solid var(--line);
    border-radius: 26px;
    padding: 28px;
    min-height: 240px;
  }

  .bfw-product-number {
    width: 38px;
    height: 38px;
    border-radius: 999px;
    background: var(--blush);
    color: var(--berry-dark);
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 800;
    margin-bottom: 20px;
  }

  .bfw-product h3 {
    margin: 0 0 9px;
    font-size: 21px;
    letter-spacing: -0.03em;
  }

  .bfw-product p {
    margin: 0;
    color: var(--muted);
    font-size: 15px;
    line-height: 1.6;
  }

  .bfw-quote {
    padding: 82px 0;
    background: var(--charcoal);
    color: #fff;
    text-align: center;
  }

  .bfw-quote blockquote {
    max-width: 870px;
    margin: 0 auto;
    font-size: clamp(32px, 4vw, 58px);
    line-height: 1.08;
    letter-spacing: -0.045em;
    font-weight: 500;
  }

  .bfw-quote p {
    max-width: 660px;
    margin: 22px auto 0;
    color: rgba(255,255,255,0.72);
    font-size: 17px;
    line-height: 1.65;
  }

  .bfw-cta {
    padding: 92px 0;
    background:
      radial-gradient(circle at 12% 20%, rgba(178, 58, 111, 0.12), transparent 24%),
      linear-gradient(135deg, #f7e3e8 0%, #fffaf7 100%);
  }

  .bfw-cta-box {
    max-width: 920px;
    margin: 0 auto;
    text-align: center;
    background: rgba(255,255,255,0.62);
    border: 1px solid rgba(255,255,255,0.9);
    border-radius: 36px;
    padding: 54px 34px;
    box-shadow: 0 24px 70px rgba(104, 52, 73, 0.12);
  }

  .bfw-cta-box h2 {
    margin: 0;
    font-size: clamp(36px, 4vw, 60px);
    line-height: 1.02;
    letter-spacing: -0.045em;
    font-weight: 500;
  }

  .bfw-cta-box p {
    max-width: 640px;
    margin: 18px auto 0;
    color: var(--muted);
    font-size: 18px;
    line-height: 1.65;
  }

  .bfw-disclaimer {
    max-width: 880px;
    margin: 34px auto 0;
    color: rgba(42,38,34,0.58);
    font-size: 12px;
    line-height: 1.55;
    text-align: center;
  }

  @media (max-width: 980px) {
    .bfw-hero-grid,
    .bfw-split {
      grid-template-columns: 1fr;
      gap: 36px;
    }

    .bfw-cards,
    .bfw-products {
      grid-template-columns: repeat(2, 1fr);
    }

    .bfw-visual {
      min-height: 440px;
    }
  }

  @media (max-width: 640px) {
    .bfw-container {
      width: min(100% - 24px, 1180px);
    }

    .bfw-hero {
      padding: 62px 0 52px;
    }

    .bfw-hero h1 {
      font-size: 43px;
    }

    .bfw-hero-text,
    .bfw-centered p,
    .bfw-split p,
    .bfw-cta-box p {
      font-size: 16px;
    }

    .bfw-section {
      padding: 62px 0;
    }

    .bfw-cards,
    .bfw-products {
      grid-template-columns: 1fr;
    }

    .bfw-card,
    .bfw-product,
    .bfw-highlight-box {
      padding: 24px;
      border-radius: 22px;
    }

    .bfw-actions {
      flex-direction: column;
    }

    .bfw-btn {
      width: 100%;
    }

    .bfw-visual {
      min-height: 520px;
    }

    .bfw-product-card {
      width: 150px;
      padding: 15px;
    }

    .bfw-product-card.one {
      top: 28px;
      left: 18px;
    }

    .bfw-product-card.two {
      top: 104px;
      right: 18px;
    }

    .bfw-product-card.three {
      bottom: 116px;
      left: 18px;
    }

    .bfw-product-card.four {
      bottom: 28px;
      right: 18px;
    }

    .bfw-center-mark {
      width: 150px;
      height: 150px;
      font-size: 23px;
    }

    .bfw-cta-box {
      padding: 42px 22px;
      border-radius: 28px;
    }
  }
</style>

