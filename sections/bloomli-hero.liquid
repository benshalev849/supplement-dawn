<section class="bloomli-hero bloomli-section color-{{ section.settings.color_scheme }} gradient" style="--hero-eyebrow-color: {{ section.settings.eyebrow_accent_color | default: '#8A6678' }}; {% if section.settings.use_brand_gradient %}background: var(--brand-gradient);{% endif %} min-height: {{ section.settings.min_height }}px; position: relative; overflow: hidden;">
  <div class="bloomli-hero__inner" style="max-width: 1280px; margin: 0 auto; padding: 96px 48px; display: grid; grid-template-columns: 55fr 45fr; gap: 48px; align-items: center; min-height: {{ section.settings.min_height }}px;">

    <!-- Left: copy -->
    <div class="bloomli-hero__copy" style="min-width: 0;">
      {%- if section.settings.eyebrow != blank -%}
        <div class="smallcaps" style="color: var(--hero-eyebrow-color); margin-bottom: 24px;">{{ section.settings.eyebrow }}</div>
      {%- endif -%}

      <h1 class="bloomli-hero__headline" style="font-family: 'Fraunces', serif; font-variation-settings: 'SOFT' 100, 'opsz' 144; font-size: 88px; line-height: 0.98; margin-bottom: 28px; letter-spacing: -0.02em; font-weight: 400; color: var(--bloomli-text); word-wrap: break-word;">
        {{ section.settings.headline_line1 }}<br>
        <span style="font-style: italic;">{{ section.settings.headline_line2 }}</span>
      </h1>

      {%- if section.settings.subtext != blank -%}
        <p class="bloomli-hero__subtext" style="font-size: 18px; color: var(--bloomli-text); max-width: 440px; margin-bottom: 36px; line-height: 1.55;">
          {{ section.settings.subtext }}
        </p>
      {%- endif -%}

      <div class="bloomli-hero__ctas color-{{ section.settings.button_color_scheme }}" style="display: flex; gap: 12px; flex-wrap: wrap; margin-bottom: 28px; background: transparent;">
        {%- if section.settings.cta_primary_label != blank -%}
          <a href="{{ section.settings.cta_primary_url }}" class="button button--primary">{{ section.settings.cta_primary_label }}</a>
        {%- endif -%}
        {%- if section.settings.cta_secondary_label != blank -%}
          <a href="{{ section.settings.cta_secondary_url }}" class="button button--secondary">{{ section.settings.cta_secondary_label }}</a>
        {%- endif -%}
      </div>

      {%- if section.settings.show_reviews -%}
        <div class="bloomli-hero__reviews" style="display: flex; gap: 10px; align-items: center; flex-wrap: wrap;">
          <span style="color: var(--hero-eyebrow-color); font-size: 16px; letter-spacing: -1px;" aria-hidden="true">★★★★★</span>
          <span style="font-size: 14px; color: var(--bloomli-text);">
            <strong style="font-weight: 500;">{{ section.settings.review_score }}</strong> from {{ section.settings.review_count }} reviews
          </span>
        </div>
      {%- endif -%}
    </div>

    <!-- Right: images -->
    <div class="bloomli-hero__media" style="position: relative; height: 540px;">
      {%- if section.settings.editorial_image != blank -%}
        <img
          class="bloomli-hero__editorial"
          src="{{ section.settings.editorial_image | image_url: width: 760 }}"
          alt="{{ section.settings.editorial_image.alt | default: 'bloomli hero' | escape }}"
          srcset="{{ section.settings.editorial_image | image_url: width: 380 }} 380w,
                  {{ section.settings.editorial_image | image_url: width: 760 }} 760w"
          sizes="(max-width: 749px) {{ section.settings.editorial_width_mobile }}vw, 380px"
          loading="eager"
          fetchpriority="high"
          width="380"
          height="520"
          style="position: absolute; right: 0; top: 0; width: 380px; height: 520px; border-radius: 220px; object-fit: cover; box-shadow: 0 24px 60px var(--bloomli-shadow-color);"
        >
      {%- else -%}
        <div class="bloomli-hero__editorial bloomli-hero__editorial--placeholder" style="position: absolute; right: 0; top: 0; width: 380px; height: 520px; border-radius: 220px; background: var(--bloomli-surface); display: flex; align-items: center; justify-content: center;">
          <span style="font-family: var(--font-commerce-ui, var(--font-body-family)); font-size: 11px; text-transform: uppercase; letter-spacing: 0.08em; color: var(--bloomli-text-soft);">Editorial photo</span>
        </div>
      {%- endif -%}

      {%- if section.settings.product_image != blank -%}
        <img
          class="bloomli-hero__bottle"
          src="{{ section.settings.product_image | image_url: width: 600 }}"
          srcset="{{ section.settings.product_image | image_url: width: 300 }} 300w,
                  {{ section.settings.product_image | image_url: width: 600 }} 600w,
                  {{ section.settings.product_image | image_url: width: 900 }} 900w"
          sizes="(max-width: 749px) {{ section.settings.bottle_width_mobile }}vw, {{ section.settings.bottle_width_desktop }}px"
          alt="{{ section.settings.product_image.alt | default: 'Root Ritual Gummies' | escape }}"
          loading="lazy"
          width="{{ section.settings.bottle_width_desktop }}"
          height="{{ section.settings.bottle_width_desktop | times: section.settings.product_image.height | divided_by: section.settings.product_image.width | round }}"
          style="position: absolute; left: {{ section.settings.bottle_x_desktop }}px; bottom: {{ section.settings.bottle_y_desktop }}px; transform: rotate({{ section.settings.bottle_rotation }}deg); width: {{ section.settings.bottle_width_desktop }}px; height: auto; max-width: none; object-fit: contain;"
        >
      {%- endif -%}

      <!-- Floating blur accent -->
      <div aria-hidden="true" style="position: absolute; right: -60px; top: 60px; width: 140px; height: 140px; border-radius: 50%; background: var(--bloomli-surface); opacity: 0.55; pointer-events: none;"></div>
    </div>

  </div>
</section>

<style>
  /* Make sure the wrapping color-scheme div doesn't paint a background over the gradient hero */
  .bloomli-hero__ctas { background: transparent !important; }

  /* Bottle: opt out of the global img max-width clamp so % widths can scale freely */
  .bloomli-hero__bottle { max-width: none !important; }

  @media (max-width: 749px) {
    .bloomli-hero { min-height: unset !important; }
    .bloomli-hero__inner {
      grid-template-columns: 1fr !important;
      padding: 40px 16px 48px !important;
      min-height: unset !important;
      gap: 24px !important;
    }
    .bloomli-hero__headline { font-size: 44px !important; line-height: 1.02 !important; margin-bottom: 16px !important; }
    .bloomli-hero__subtext { font-size: 15px !important; margin-bottom: 24px !important; max-width: 100% !important; }
    .bloomli-hero__ctas { gap: 8px !important; margin-bottom: 20px !important; }
    .bloomli-hero__ctas .button { padding: 12px 22px !important; font-size: 14px !important; }
    .bloomli-hero__media {
      height: {{ section.settings.media_height_mobile }}px !important;
      margin-top: 12px;
    }
    .bloomli-hero__editorial {
      width: {{ section.settings.editorial_width_mobile }}% !important;
      max-width: none !important;
      height: {{ section.settings.editorial_height_mobile }}px !important;
      border-radius: {{ section.settings.editorial_height_mobile | divided_by: 2 }}px !important;
      right: 0 !important;
    }
    .bloomli-hero__bottle {
      width: {{ section.settings.bottle_width_mobile }}% !important;
      left: {{ section.settings.bottle_x_mobile }}% !important;
      bottom: {{ section.settings.bottle_y_mobile }}px !important;
    }
  }
</style>

{% schema %}
{
  "name": "Bloomli — Hero",
  "tag": "div",
  "class": "bloomli-hero-wrapper",
  "settings": [
    { "type": "header", "content": "Copy" },
    { "type": "color_scheme", "id": "color_scheme", "label": "Color scheme", "default": "scheme-6d8ba907-aae6-4c49-9120-e1031d9cdb3f" },
    { "type": "checkbox", "id": "use_brand_gradient", "label": "Use Bloomli brand gradient", "default": true },
    { "type": "text",     "id": "eyebrow",        "label": "Eyebrow",                 "default": "Clinically-studied hair wellness" },
    { "type": "color",    "id": "eyebrow_accent_color", "label": "Eyebrow accent color", "default": "#8A6678" },
    { "type": "text",     "id": "headline_line1",  "label": "Headline line 1",         "default": "Quiet science," },
    { "type": "text",     "id": "headline_line2",  "label": "Headline line 2 (italic)", "default": "visible results." },
    { "type": "textarea", "id": "subtext",         "label": "Subtext",                 "default": "Gummies, capsules, or strips — clinically-formulated hair support in the form that fits your ritual. Backed by science, designed for real life." },
    { "type": "range",    "id": "min_height",      "label": "Min height (px)",         "min": 500, "max": 900, "step": 20, "default": 720 },
    { "type": "header", "content": "CTAs" },
    { "type": "color_scheme", "id": "button_color_scheme", "label": "Button color scheme", "default": "scheme-6d8ba907-aae6-4c49-9120-e1031d9cdb3f" },
    { "type": "text", "id": "cta_primary_label",   "label": "Primary button label",    "default": "Shop Hair" },
    { "type": "url",  "id": "cta_primary_url",     "label": "Primary button URL" },
    { "type": "text", "id": "cta_secondary_label", "label": "Secondary button label",  "default": "Take the 2-min Quiz" },
    { "type": "url",  "id": "cta_secondary_url",   "label": "Secondary button URL" },
    { "type": "header", "content": "Reviews badge" },
    { "type": "checkbox", "id": "show_reviews",  "label": "Show reviews badge", "default": true },
    { "type": "text",     "id": "review_score",  "label": "Score",              "default": "4.8" },
    { "type": "text",     "id": "review_count",  "label": "Count",              "default": "2,400+" },
    { "type": "header", "content": "Images" },
    { "type": "image_picker", "id": "editorial_image", "label": "Editorial image (tall pill crop)" },
    { "type": "image_picker", "id": "product_image",   "label": "Product image (transparent PNG)" },
    { "type": "header", "content": "Bottle — desktop" },
    { "type": "range", "id": "bottle_width_desktop", "label": "Bottle width", "min": 80, "max": 600, "step": 10, "default": 400, "unit": "px" },
    { "type": "range", "id": "bottle_x_desktop", "label": "Horizontal offset (from left edge of media)", "min": -250, "max": 250, "step": 5, "default": -120, "unit": "px" },
    { "type": "range", "id": "bottle_y_desktop", "label": "Vertical offset (from bottom of media)", "min": -50, "max": 200, "step": 5, "default": 40, "unit": "px" },
    { "type": "range", "id": "bottle_rotation", "label": "Rotation (applies to both)", "min": -45, "max": 45, "step": 1, "default": -8, "unit": "deg" },
    { "type": "header", "content": "Bottle — mobile" },
    { "type": "paragraph", "content": "Mobile sizes are percentages of the hero media area, so the bottle scales with screen width." },
    { "type": "range", "id": "bottle_width_mobile", "label": "Bottle width", "min": 30, "max": 130, "step": 2, "default": 90, "unit": "%" },
    { "type": "range", "id": "bottle_x_mobile", "label": "Horizontal offset (from left edge of media)", "min": -30, "max": 60, "step": 1, "default": -8, "unit": "%" },
    { "type": "range", "id": "bottle_y_mobile", "label": "Vertical offset (from bottom of media)", "min": -40, "max": 120, "step": 2, "default": 0, "unit": "px" },
    { "type": "header", "content": "Editorial image — mobile" },
    { "type": "range", "id": "editorial_width_mobile", "label": "Editorial image width", "min": 30, "max": 90, "step": 2, "default": 56, "unit": "%" },
    { "type": "range", "id": "editorial_height_mobile", "label": "Editorial image height", "min": 180, "max": 480, "step": 10, "default": 300, "unit": "px" },
    { "type": "range", "id": "media_height_mobile", "label": "Hero media area height", "min": 240, "max": 600, "step": 10, "default": 360, "unit": "px" }
  ],
  "presets": [{ "name": "Bloomli — Hero" }]
}
{% endschema %}
