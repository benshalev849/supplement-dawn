<section
  class="bloomli-bundle bloomli-section color-{{ section.settings.color_scheme }} gradient"
  style="--bloomli-padding-top: {{ section.settings.padding_top }}px; --bloomli-padding-bottom: {{ section.settings.padding_bottom }}px;"
>
  <div class="bloomli-bundle__inner">

    {%- if section.settings.eyebrow != blank -%}
      <div class="smallcaps bloomli-bundle__eyebrow">{{ section.settings.eyebrow }}</div>
    {%- endif -%}

    <h2 class="bloomli-bundle__heading">
      {{ section.settings.headline_line1 }}<br><span>{{ section.settings.headline_line2 }}</span>
    </h2>

    {%- if section.settings.description != blank -%}
      <p class="bloomli-bundle__copy">
        {{ section.settings.description }}
      </p>
    {%- endif -%}

    <div class="bloomli-bundle__products">
      {%- if section.settings.product_image_1 != blank -%}
        {{ section.settings.product_image_1 | image_url: width: 360 | image_tag: class: 'bloomli-bundle__product', widths: '180, 360', sizes: '(max-width: 749px) 44vw, 180px', loading: 'lazy', decoding: 'async' }}
      {%- else -%}
        <div class="bloomli-bundle__product bloomli-bundle__product--placeholder"><span>{{ section.settings.product_image_1_placeholder_label }}</span></div>
      {%- endif -%}
      {%- if section.settings.product_image_2 != blank -%}
        {{ section.settings.product_image_2 | image_url: width: 360 | image_tag: class: 'bloomli-bundle__product', widths: '180, 360', sizes: '(max-width: 749px) 44vw, 180px', loading: 'lazy', decoding: 'async' }}
      {%- else -%}
        <div class="bloomli-bundle__product bloomli-bundle__product--placeholder"><span>{{ section.settings.product_image_2_placeholder_label }}</span></div>
      {%- endif -%}
    </div>

    {%- if section.settings.cta_label != blank and section.settings.cta_url != blank -%}
      <div class="bloomli-bundle__cta-wrap color-{{ section.settings.button_color_scheme }}">
        <a href="{{ section.settings.cta_url }}" class="button button--primary">{{ section.settings.cta_label }}</a>
      </div>
    {%- endif -%}

  </div>
</section>

{% schema %}
{
  "name": "Bloomli — Bundle Promo",
  "tag": "div",
  "settings": [
    { "type": "color_scheme", "id": "color_scheme", "label": "Color scheme", "default": "scheme-6d8ba907-aae6-4c49-9120-e1031d9cdb3f" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "The complete ritual" },
    { "type": "text", "id": "headline_line1", "label": "Headline line 1", "default": "Inside & out." },
    { "type": "text", "id": "headline_line2", "label": "Headline line 2 (italic)", "default": "Save 20%." },
    { "type": "textarea", "id": "description", "label": "Description", "default": "The Root Ritual gummies that work from within, paired with our moisturizing & strengthening hair oil for visible shine day one." },
    { "type": "color_scheme", "id": "button_color_scheme", "label": "Button color scheme", "default": "scheme-6d8ba907-aae6-4c49-9120-e1031d9cdb3f" },
    { "type": "text", "id": "cta_label", "label": "CTA label", "default": "Shop the Duo — $74" },
    { "type": "url", "id": "cta_url", "label": "CTA URL" },
    { "type": "image_picker", "id": "product_image_1", "label": "Product image 1 (gummies)" },
    { "type": "text", "id": "product_image_1_placeholder_label", "label": "Product image 1 placeholder label", "default": "Gummies" },
    { "type": "image_picker", "id": "product_image_2", "label": "Product image 2 (oil)" },
    { "type": "text", "id": "product_image_2_placeholder_label", "label": "Product image 2 placeholder label", "default": "Hair Oil" },
    { "type": "range", "id": "padding_top", "label": "Padding top (px)", "min": 48, "max": 160, "step": 8, "default": 96 },
    { "type": "range", "id": "padding_bottom", "label": "Padding bottom (px)", "min": 48, "max": 160, "step": 8, "default": 96 }
  ],
  "presets": [{ "name": "Bloomli — Bundle Promo" }]
}
{% endschema %}
