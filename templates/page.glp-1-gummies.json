    "glp1_faq": {
      "type": "bloomli-faq",
      "blocks": {
        "q1": {
          "type": "question",
          "settings": {
            "question": "Why can hair shedding increase during rapid weight loss?",
            "answer": "<p>Rapid weight loss can temporarily shift more hairs into their natural resting-and-shedding phase. Eating less may also make it harder to consistently get the nutrients your hair relies on. </p>",
            "open_by_default": false
          }
        },
        "q2": {
          "type": "question",
          "settings": {
            "question": "How do Bloomli gummies support my hair?",
            "answer": "<p>Bloomli provides biotin, marine collagen, zinc, silicon, PABA, iodine, and essential vitamins in one daily formula. These nutrients support stronger, healthier-looking hair from within, but the gummies do not treat or stop hair loss.*</p>",
            "open_by_default": false
          }
        },
        "q3": {
          "type": "question",
          "settings": {
