{%- liquid
  assign default_idx = 0
  for block in section.blocks
    if block.settings.default_selected
      assign default_idx = forloop.index0
    endif
  endfor
-%}

<section class="bloomli-vt color-{{ section.settings.color_scheme }}"
         style="padding: {{ section.settings.padding_top }}px 0 {{ section.settings.padding_bottom }}px;"
         data-bloomli-vt-section>
  <div class="bloomli-vt__container">

    {%- if section.settings.eyebrow != blank -%}
      <div class="bloomli-vt__eyebrow">{{ section.settings.eyebrow }}</div>
    {%- endif -%}

    {%- if section.settings.heading != blank -%}
      <h3 class="bloomli-vt__title">{{ section.settings.heading }}</h3>
    {%- endif -%}

    <form action="{{ routes.cart_add_url }}"
          method="post"
          enctype="multipart/form-data"
          class="bloomli-vt__form"
          data-bloomli-vt-form>

      <input type="hidden" name="id" value="" data-bloomli-vt-variant>
      <input type="hidden" name="quantity" value="1" data-bloomli-vt-qty>

      <div class="bloomli-vt__cards">
        {%- for block in section.blocks -%}
          {%- liquid
            assign variant_pos = block.settings.variant_position | default: forloop.index
            assign variant_idx = variant_pos | minus: 1
            assign variant = product.variants[variant_idx]
            if variant == nil
              assign variant = product.selected_or_first_available_variant
            endif

            assign qty = block.settings.quantity | default: 1
            assign unit_price = variant.price
            assign unit_compare = variant.compare_at_price | default: variant.price
            assign line_price = unit_price | times: qty
            assign line_compare = unit_compare | times: qty

            assign discount_pct = 0
            if line_compare > line_price
              assign saved = line_compare | minus: line_price
              assign discount_pct = saved | times: 100 | divided_by: line_compare
            endif

            assign is_default = false
            if forloop.index0 == default_idx
              assign is_default = true
            endif
          -%}

          <label class="bloomli-vt__card{% if is_default %} is-selected{% endif %}"
                 {{ block.shopify_attributes }}
                 data-bloomli-vt-card
                 data-variant-id="{{ variant.id }}"
                 data-quantity="{{ qty }}"
                 data-price-html="{{ line_price | money }}"
                 data-compare-html="{{ line_compare | money }}"
                 data-discount="{{ discount_pct }}">

            <input type="radio"
                   name="bloomli-vt-tier"
                   value="{{ variant.id }}-{{ qty }}"
                   {% if is_default %}checked{% endif %}
                   class="bloomli-vt__radio"
                   tabindex="0">
            <span class="bloomli-vt__radio-visual" aria-hidden="true"></span>

            <div class="bloomli-vt__card-body">
              {%- if block.settings.badge_text != blank or block.settings.tag_text != blank or discount_pct > 0 -%}
                <div class="bloomli-vt__pills">
                  {%- if block.settings.badge_text != blank -%}
                    <span class="bloomli-vt__badge">{{ block.settings.badge_text }}</span>
                  {%- elsif discount_pct > 0 and section.settings.show_auto_discount -%}
                    <span class="bloomli-vt__badge">{{ discount_pct }}% OFF</span>
                  {%- endif -%}
                  {%- if block.settings.tag_text != blank -%}
                    <span class="bloomli-vt__tag">{{ block.settings.tag_text }}</span>
                  {%- endif -%}
                </div>
              {%- endif -%}

              <div class="bloomli-vt__name">
                {{ block.settings.label | default: variant.title }}
              </div>

              {%- if block.settings.description != blank -%}
                <div class="bloomli-vt__desc">{{ block.settings.description }}</div>
              {%- endif -%}
            </div>

            <div class="bloomli-vt__price">
              <span class="bloomli-vt__price-current">{{ line_price | money }}</span>
              {%- if line_compare > line_price -%}
                <span class="bloomli-vt__price-compare">{{ line_compare | money }}</span>
              {%- endif -%}
            </div>

            {%- if block.settings.show_shipping_pill -%}
              <div class="bloomli-vt__shipping">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <rect x="1" y="3" width="15" height="13"></rect>
                  <polygon points="16 8 20 8 23 11 23 16 16 16 16 8"></polygon>
                  <circle cx="5.5" cy="18.5" r="2.5"></circle>
                  <circle cx="18.5" cy="18.5" r="2.5"></circle>
                </svg>
                <span>{{ section.settings.shipping_text | default: 'Free shipping' }}</span>
              </div>
            {%- endif -%}
          </label>
        {%- endfor -%}
      </div>

      <div class="bloomli-vt__footer">
        <div class="bloomli-vt__total-row">
          <span class="bloomli-vt__total-label">{{ section.settings.total_label | default: 'Total price:' }}</span>
          <span class="bloomli-vt__total-amount">
            <span data-bloomli-vt-total></span>
            <span class="bloomli-vt__total-compare" data-bloomli-vt-compare></span>
          </span>
        </div>

        <button type="submit" class="bloomli-vt__cta" data-bloomli-vt-cta>
          <span data-bloomli-vt-cta-text>{{ section.settings.button_text | default: 'Add to cart' }}</span>
        </button>
      </div>

    </form>

  </div>
</section>

<style>
  .bloomli-vt {
    background: var(--cream, #F8F1E7);
    color: var(--charcoal, #2A2622);
  }
  .bloomli-vt__container {
    max-width: 560px;
    margin: 0 auto;
    padding: 24px;
    background: var(--cream, #F8F1E7);
    border: 1px solid rgba(110, 74, 99, 0.12);
    border-radius: 16px;
    font-family: 'DM Sans', sans-serif;
  }
  .bloomli-vt__eyebrow {
    font-family: 'DM Sans', sans-serif;
    text-transform: uppercase;
    font-size: 11px;
    letter-spacing: 0.08em;
    color: rgba(110, 74, 99, 0.7);
    text-align: center;
    margin: 0 0 8px;
    font-weight: 500;
  }
  .bloomli-vt__title {
    font-family: 'Fraunces', serif;
    font-variation-settings: "SOFT" 100, "opsz" 144;
    font-size: 28px;
    font-weight: 400;
    color: var(--charcoal, #2A2622);
    text-align: center;
    margin: 0 0 20px;
    letter-spacing: -0.01em;
    line-height: 1.15;
  }
  .bloomli-vt__form {
    margin: 0;
  }
  .bloomli-vt__cards {
    display: flex;
    flex-direction: column;
    gap: 10px;
    margin: 0 0 16px;
  }
  .bloomli-vt__card {
    position: relative;
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: center;
    gap: 14px;
    background: #fff;
    border: 1.5px solid rgba(110, 74, 99, 0.12);
    border-radius: 12px;
    padding: 14px 16px;
    cursor: pointer;
    transition: border-color 0.18s ease, box-shadow 0.18s ease;
  }
  .bloomli-vt__card:hover {
    border-color: rgba(110, 74, 99, 0.4);
    box-shadow: 0 2px 8px rgba(110, 74, 99, 0.08);
  }
  .bloomli-vt__card.is-selected {
    border-color: var(--aubergine, #6E4A63);
    background: rgba(110, 74, 99, 0.04);
  }
  .bloomli-vt__radio {
    position: absolute;
    opacity: 0;
    pointer-events: none;
  }
  .bloomli-vt__radio-visual {
    width: 18px;
    height: 18px;
    border-radius: 50%;
    border: 1.5px solid rgba(110, 74, 99, 0.35);
    flex-shrink: 0;
    position: relative;
    transition: border-color 0.15s ease;
  }
  .bloomli-vt__card.is-selected .bloomli-vt__radio-visual {
    border-color: var(--aubergine, #6E4A63);
  }
  .bloomli-vt__card.is-selected .bloomli-vt__radio-visual::after {
    content: "";
    position: absolute;
    inset: 3px;
    border-radius: 50%;
    background: var(--aubergine, #6E4A63);
  }
  .bloomli-vt__card-body {
    min-width: 0;
  }
  .bloomli-vt__pills {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 6px;
    margin: 0 0 6px;
  }
  .bloomli-vt__badge {
    background: var(--aubergine, #6E4A63);
    color: var(--cream, #F8F1E7);
    font-family: 'DM Sans', sans-serif;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.05em;
    padding: 4px 10px;
    border-radius: 999px;
    text-transform: uppercase;
    line-height: 1;
    white-space: nowrap;
  }
  .bloomli-vt__tag {
    background: rgba(110, 74, 99, 0.1);
    color: var(--aubergine, #6E4A63);
    font-family: 'DM Sans', sans-serif;
    font-size: 10px;
    font-weight: 500;
    letter-spacing: 0.06em;
    padding: 4px 9px;
    border-radius: 999px;
    text-transform: uppercase;
    line-height: 1;
    white-space: nowrap;
  }
  .bloomli-vt__name {
    font-family: 'Fraunces', serif;
    font-variation-settings: "SOFT" 100;
    font-size: 18px;
    font-weight: 400;
    color: var(--charcoal, #2A2622);
    line-height: 1.2;
    letter-spacing: -0.005em;
  }
  .bloomli-vt__desc {
    font-family: 'DM Sans', sans-serif;
    font-size: 12px;
    color: rgba(42, 38, 34, 0.55);
    margin: 3px 0 0;
    line-height: 1.4;
  }
  .bloomli-vt__price {
    text-align: right;
    flex-shrink: 0;
    line-height: 1.2;
  }
  .bloomli-vt__price-current {
    display: block;
    font-family: 'DM Sans', sans-serif;
    font-size: 17px;
    font-weight: 600;
    color: var(--charcoal, #2A2622);
    white-space: nowrap;
  }
  .bloomli-vt__price-compare {
    display: block;
    font-family: 'DM Sans', sans-serif;
    font-size: 13px;
    font-weight: 400;
    color: rgba(42, 38, 34, 0.4);
    text-decoration: line-through;
    white-space: nowrap;
  }
  .bloomli-vt__shipping {
    grid-column: 1 / -1;
    display: flex;
    align-items: center;
    gap: 6px;
    padding: 10px 0 0;
    margin: 6px 0 0;
    border-top: 1px dashed rgba(110, 74, 99, 0.18);
    color: var(--aubergine, #6E4A63);
    font-family: 'DM Sans', sans-serif;
    font-size: 11px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }
  .bloomli-vt__footer {
    border-top: 1px solid rgba(110, 74, 99, 0.1);
    padding: 16px 4px 0;
    margin: 8px 0 0;
  }
  .bloomli-vt__total-row {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    margin: 0 0 14px;
    font-family: 'DM Sans', sans-serif;
  }
  .bloomli-vt__total-label {
    font-size: 14px;
    font-weight: 500;
    color: var(--charcoal, #2A2622);
  }
  .bloomli-vt__total-amount {
    display: inline-flex;
    align-items: baseline;
    gap: 8px;
    font-size: 17px;
    font-weight: 600;
    color: var(--charcoal, #2A2622);
  }
  .bloomli-vt__total-compare {
    font-size: 13px;
    font-weight: 400;
    color: rgba(42, 38, 34, 0.4);
    text-decoration: line-through;
  }
  .bloomli-vt__total-compare:empty { display: none; }
  .bloomli-vt__cta {
    display: block;
    width: 100%;
    background: var(--aubergine, #6E4A63);
    color: var(--cream, #F8F1E7);
    border: none;
    border-radius: 999px;
    font-family: 'DM Sans', sans-serif;
    font-weight: 500;
    font-size: 15px;
    padding: 14px 28px;
    cursor: pointer;
    transition: opacity 0.18s ease, transform 0.18s ease;
    letter-spacing: 0;
  }
  .bloomli-vt__cta:hover {
    opacity: 0.92;
    transform: translateY(-1px);
  }
  .bloomli-vt__cta:disabled {
    opacity: 0.5;
    cursor: not-allowed;
    transform: none;
  }

  @media (max-width: 749px) {
    .bloomli-vt__container {
      padding: 16px;
      border-radius: 12px;
      max-width: 100%;
    }
    .bloomli-vt__title { font-size: 22px; }
    .bloomli-vt__name { font-size: 16px; }
    .bloomli-vt__price-current { font-size: 15px; }
    .bloomli-vt__cta { padding: 13px 22px; font-size: 14px; }
    .bloomli-vt__card { padding: 12px 14px; gap: 10px; }
  }
</style>

<script>
  (function () {
    const sections = document.querySelectorAll('[data-bloomli-vt-section]');
    sections.forEach(function (section) {
      const form = section.querySelector('[data-bloomli-vt-form]');
      if (!form) return;
      const variantInput = form.querySelector('[data-bloomli-vt-variant]');
      const qtyInput = form.querySelector('[data-bloomli-vt-qty]');
      const cards = form.querySelectorAll('[data-bloomli-vt-card]');
      const totalEl = form.querySelector('[data-bloomli-vt-total]');
      const compareEl = form.querySelector('[data-bloomli-vt-compare]');
      const ctaTextEl = form.querySelector('[data-bloomli-vt-cta-text]');
      const ctaBaseText = ctaTextEl ? ctaTextEl.textContent.trim() : '';

      function selectCard(card) {
        cards.forEach(function (c) {
          c.classList.remove('is-selected');
          const r = c.querySelector('.bloomli-vt__radio');
          if (r) r.checked = false;
        });
        card.classList.add('is-selected');
        const radio = card.querySelector('.bloomli-vt__radio');
        if (radio) radio.checked = true;

        variantInput.value = card.dataset.variantId;
        qtyInput.value = card.dataset.quantity || 1;

        if (totalEl) totalEl.innerHTML = card.dataset.priceHtml || '';
        if (compareEl) {
          const cmp = card.dataset.compareHtml || '';
          const cur = card.dataset.priceHtml || '';
          compareEl.innerHTML = (cmp && cmp !== cur) ? cmp : '';
        }

        if (ctaTextEl) {
          const pct = parseInt(card.dataset.discount, 10) || 0;
          ctaTextEl.textContent = pct > 0 ? ctaBaseText + ' (' + pct + '% OFF)' : ctaBaseText;
        }

        section.dispatchEvent(new CustomEvent('bloomli:variant-change', {
          bubbles: true,
          detail: { variantId: card.dataset.variantId, quantity: parseInt(card.dataset.quantity, 10) || 1 }
        }));
      }

      cards.forEach(function (card) {
        card.addEventListener('click', function (e) {
          if (e.target.tagName === 'A') return;
          selectCard(card);
        });
        card.addEventListener('keydown', function (e) {
          if (e.key === ' ' || e.key === 'Enter') {
            e.preventDefault();
            selectCard(card);
          }
        });
      });

      const initial = form.querySelector('[data-bloomli-vt-card].is-selected') || cards[0];
      if (initial) selectCard(initial);
    });
  })();
</script>

{% schema %}
{
  "name": "Bloomli — Volume Tier",
  "tag": "section",
  "class": "section",
  "max_blocks": 6,
  "settings": [
    { "type": "header", "content": "Heading" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Best Offers" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Save More!" },
    { "type": "header", "content": "Footer" },
    { "type": "text", "id": "total_label", "label": "Total label", "default": "Total price:" },
    { "type": "text", "id": "button_text", "label": "Button text", "default": "Add bundles to cart" },
    { "type": "checkbox", "id": "show_auto_discount", "label": "Auto-fill % OFF badge from compare-at price (when no badge text)", "default": true },
    { "type": "text", "id": "shipping_text", "label": "Shipping pill text", "default": "Free shipping" },
    { "type": "header", "content": "Color" },
    { "type": "color_scheme", "id": "color_scheme", "label": "Color scheme", "default": "scheme-1" },
    { "type": "header", "content": "Spacing" },
    { "type": "range", "id": "padding_top", "label": "Padding top", "min": 0, "max": 80, "step": 4, "default": 16, "unit": "px" },
    { "type": "range", "id": "padding_bottom", "label": "Padding bottom", "min": 0, "max": 80, "step": 4, "default": 16, "unit": "px" }
  ],
  "blocks": [
    {
      "type": "tier",
      "name": "Tier",
      "settings": [
        { "type": "header", "content": "Variant" },
        { "type": "paragraph", "content": "Pick which variant of the current product this tier sells, by position (1 = first variant, 2 = second, etc.). Set the variant's discounted price on the product itself, and add a compare-at price to show a strikethrough." },
        { "type": "number", "id": "variant_position", "label": "Variant position (1-based)", "default": 1 },
        { "type": "number", "id": "quantity", "label": "Quantity to add", "default": 1 },
        { "type": "header", "content": "Card content" },
        { "type": "text", "id": "label", "label": "Tier label (e.g. 'Two Months')" },
        { "type": "text", "id": "description", "label": "Short description" },
        { "type": "text", "id": "badge_text", "label": "Discount badge (e.g. '20% OFF')", "info": "Leave blank to auto-fill from compare-at price" },
        { "type": "text", "id": "tag_text", "label": "Side tag (e.g. 'Most popular')" },
        { "type": "checkbox", "id": "show_shipping_pill", "label": "Show free-shipping pill", "default": false },
        { "type": "checkbox", "id": "default_selected", "label": "Selected by default", "default": false }
      ]
    }
  ],
  "presets": [
    {
      "name": "Bloomli — Volume Tier",
      "blocks": [
        { "type": "tier", "settings": { "variant_position": 1, "quantity": 1, "label": "One Month", "description": "", "badge_text": "", "tag_text": "", "default_selected": false } },
        { "type": "tier", "settings": { "variant_position": 2, "quantity": 1, "label": "Two Months", "description": "Most subscribers choose this", "badge_text": "20% OFF", "tag_text": "Most popular", "default_selected": true } },
        { "type": "tier", "settings": { "variant_position": 3, "quantity": 1, "label": "Three Months", "description": "Best value over time", "badge_text": "30% OFF", "tag_text": "Best value", "default_selected": false } }
      ]
    }
  ]
}
{% endschema %}
