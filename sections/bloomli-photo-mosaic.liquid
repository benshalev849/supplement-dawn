<section class="bloomli-photo-mosaic bloomli-section color-{{ section.settings.color_scheme }} gradient" style="{% if section.settings.use_custom_background %}--bpm-bg: {{ section.settings.background_color }};{% else %}--bpm-bg: var(--bloomli-bg);{% endif %}{% case section.settings.placeholder_background %}{% when 'background' %}--bpm-placeholder-bg: var(--bloomli-bg);{% when 'surface_strong' %}--bpm-placeholder-bg: var(--bloomli-surface-strong);{% when 'accent_soft' %}--bpm-placeholder-bg: rgba(var(--color-button), 0.12);{% else %}--bpm-placeholder-bg: var(--bloomli-surface);{% endcase %} padding: {{ section.settings.padding_top }}px 48px {{ section.settings.padding_bottom }}px; background: var(--bpm-bg);">
  <div style="max-width: 1280px; margin: 0 auto;">
    <div class="bloomli-photo-mosaic__header" style="text-align: center; margin-bottom: 52px;">
      {%- if section.settings.eyebrow != blank -%}
        <div class="smallcaps" style="color: var(--bloomli-accent); margin-bottom: 16px;">{{ section.settings.eyebrow }}</div>
      {%- endif -%}
      <h2 class="bloomli-photo-mosaic__heading" style="font-family: 'Fraunces', serif; font-variation-settings: 'SOFT' 100; font-size: 46px; line-height: 1.08; font-weight: 400; margin: 0; color: var(--bloomli-text);">{{ section.settings.heading }}</h2>
    </div>

    <div class="bloomli-photo-mosaic__grid" style="display: grid; grid-template-columns: repeat({{ section.settings.columns_desktop }}, minmax(0, 1fr)); gap: {{ section.settings.gap }}px;">
      {%- for block in section.blocks -%}
        <div class="bloomli-photo-mosaic__tile" {{ block.shopify_attributes }} style="aspect-ratio: 1 / 1; border-radius: {{ section.settings.radius }}px; overflow: hidden; position: relative; background-color: {% if block.settings.use_custom_placeholder_color %}{{ block.settings.placeholder_color }}{% else %}var(--bpm-placeholder-bg){% endif %}; {% if block.settings.image == blank %}background-image: repeating-linear-gradient(135deg, var(--bloomli-line-soft) 0 1px, transparent 1px 18px);{% endif %}">
          {%- if block.settings.image != blank -%}
            {%- assign image_scale = block.settings.image_scale | divided_by: 100.0 -%}
            <img src="{{ block.settings.image | image_url: width: 520 }}" srcset="{{ block.settings.image | image_url: width: 240 }} 240w, {{ block.settings.image | image_url: width: 360 }} 360w, {{ block.settings.image | image_url: width: 520 }} 520w" sizes="(max-width: 749px) calc((100vw - 50px) / {{ section.settings.columns_mobile }}), calc((100vw - 160px) / {{ section.settings.columns_desktop }})" alt="{{ block.settings.image.alt | default: block.settings.label | escape }}" width="320" height="320" loading="lazy" draggable="false" style="width: 100%; height: 100%; object-fit: contain; transform: scale({{ image_scale }}); transform-origin: center; display: block;">
          {%- endif -%}
          {%- if block.settings.label != blank and block.settings.image == blank -%}
            <span class="smallcaps" style="position: absolute; left: 50%; top: 50%; transform: translate(-50%, -50%); background: var(--bloomli-label-bg); color: var(--bloomli-text-soft); padding: 7px 14px; border-radius: 4px; font-size: 9px; white-space: nowrap;">{{ block.settings.label }}</span>
          {%- endif -%}
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

<style>
  @media (max-width: 749px) {
    .bloomli-photo-mosaic { padding: 64px 20px !important; }
    .bloomli-photo-mosaic__header { margin-bottom: 32px !important; }
    .bloomli-photo-mosaic__heading { font-size: 34px !important; }
    .bloomli-photo-mosaic__grid { grid-template-columns: repeat({{ section.settings.columns_mobile }}, minmax(0, 1fr)) !important; gap: 10px !important; }
  }
</style>

{% schema %}
{
  "name": "Bloomli - Photo Mosaic",
  "tag": "div",
  "max_blocks": 16,
  "settings": [
    { "type": "color_scheme", "id": "color_scheme", "label": "Color scheme", "default": "scheme-6d8ba907-aae6-4c49-9120-e1031d9cdb3f" },
    { "type": "checkbox", "id": "use_custom_background", "label": "Use custom background color", "default": false },
    { "type": "color", "id": "background_color", "label": "Custom background color", "default": "#FDFAF7" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Verified buyers" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Photos from the ritual." },
    { "type": "select", "id": "placeholder_background", "label": "Tile placeholder background", "options": [
      { "value": "surface", "label": "Scheme soft surface" },
      { "value": "surface_strong", "label": "Scheme stronger surface" },
      { "value": "background", "label": "Scheme background" },
      { "value": "accent_soft", "label": "Soft accent" }
    ], "default": "surface" },
    { "type": "range", "id": "columns_desktop", "label": "Columns desktop", "min": 3, "max": 6, "step": 1, "default": 6 },
    { "type": "select", "id": "columns_mobile", "label": "Columns mobile", "options": [
      { "value": "2", "label": "2" },
      { "value": "3", "label": "3" }
    ], "default": "2" },
    { "type": "range", "id": "gap", "label": "Gap desktop", "min": 0, "max": 24, "step": 2, "default": 10, "unit": "px" },
    { "type": "range", "id": "radius", "label": "Corner radius", "min": 0, "max": 24, "step": 2, "default": 8, "unit": "px" },
    { "type": "range", "id": "padding_top", "label": "Padding top", "min": 48, "max": 176, "step": 8, "default": 96, "unit": "px" },
    { "type": "range", "id": "padding_bottom", "label": "Padding bottom", "min": 48, "max": 176, "step": 8, "default": 96, "unit": "px" }
  ],
  "blocks": [
    {
      "type": "photo",
      "name": "Photo",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Photo" },
        { "type": "range", "id": "image_scale", "label": "Uploaded image scale", "min": 70, "max": 140, "step": 5, "default": 100, "unit": "%" },
        { "type": "text", "id": "label", "label": "Placeholder label", "default": "Photo" },
        { "type": "checkbox", "id": "use_custom_placeholder_color", "label": "Override tile background", "default": false },
        { "type": "color", "id": "placeholder_color", "label": "Custom tile background", "default": "#F5EDE4" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Bloomli - Photo Mosaic",
      "blocks": [
        { "type": "photo", "settings": { "label": "Photo 1" } },
        { "type": "photo", "settings": { "label": "Photo 2" } },
        { "type": "photo", "settings": { "label": "Photo 3" } },
        { "type": "photo", "settings": { "label": "Photo 4" } },
        { "type": "photo", "settings": { "label": "Photo 5" } },
        { "type": "photo", "settings": { "label": "Photo 6" } },
        { "type": "photo", "settings": { "label": "Photo 7" } },
        { "type": "photo", "settings": { "label": "Photo 8" } },
        { "type": "photo", "settings": { "label": "Photo 9" } },
        { "type": "photo", "settings": { "label": "Photo 10" } },
        { "type": "photo", "settings": { "label": "Photo 11" } },
        { "type": "photo", "settings": { "label": "Photo 12" } }
      ]
    }
  ]
}
{% endschema %}
