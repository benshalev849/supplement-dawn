<section class="bloomli-proof-split" style="padding: {{ section.settings.padding_top }}px 48px {{ section.settings.padding_bottom }}px; background: {{ section.settings.background_color }};">
  <div class="bloomli-proof-split__inner" style="max-width: 1120px; margin: 0 auto; display: grid; grid-template-columns: minmax(0, 1fr) minmax(0, 0.9fr); gap: 72px; align-items: center;">
    <div class="bloomli-proof-split__media" style="aspect-ratio: 1 / 1.1; border-radius: {{ section.settings.image_radius }}px; overflow: hidden; position: relative; background-color: {{ section.settings.placeholder_color }}; background-image: repeating-linear-gradient(135deg, rgba(110,74,99,0.08) 0 1px, transparent 1px 18px);">
      {%- if section.settings.image != blank -%}
        <img src="{{ section.settings.image | image_url: width: 900 }}" alt="{{ section.settings.image.alt | default: section.settings.heading_line1 | escape }}" width="700" height="770" loading="lazy" style="width: 100%; height: 100%; object-fit: cover;">
      {%- endif -%}
      {%- if section.settings.image_label != blank -%}
        <span class="smallcaps" style="position: absolute; left: 50%; top: 50%; transform: translate(-50%, -50%); background: rgba(253,250,247,0.78); color: rgba(110,74,99,0.55); padding: 8px 16px; border-radius: 4px; font-size: 9px; white-space: nowrap;">{{ section.settings.image_label }}</span>
      {%- endif -%}
    </div>

    <div class="bloomli-proof-split__content">
      {%- if section.settings.eyebrow != blank -%}
        <div class="smallcaps" style="color: var(--aubergine); margin-bottom: 18px;">{{ section.settings.eyebrow }}</div>
      {%- endif -%}
      <h2 class="bloomli-proof-split__heading" style="font-family: 'Fraunces', serif; font-variation-settings: 'SOFT' 100; font-size: 52px; line-height: 1.05; font-weight: 400; margin: 0 0 26px; color: var(--charcoal);">
        {{ section.settings.heading_line1 }}<br>
        <span style="font-style: italic;">{{ section.settings.heading_line2 }}</span>
      </h2>
      {%- if section.settings.copy != blank -%}
        <div class="bloomli-proof-split__copy" style="font-size: 17px; line-height: 1.65; color: var(--charcoal); margin-bottom: 34px;">{{ section.settings.copy }}</div>
      {%- endif -%}
      <div style="display: grid; gap: 18px;">
        {%- for block in section.blocks -%}
          <div {{ block.shopify_attributes }} style="display: grid; grid-template-columns: 22px 1fr; gap: 14px; align-items: start;">
            <span style="width: 20px; height: 20px; border: 1px solid var(--aubergine); border-radius: 999px; display: inline-flex; align-items: center; justify-content: center; color: var(--aubergine); margin-top: 2px;">
              <svg width="11" height="11" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M3 8.5 6.5 12 13 4"/></svg>
            </span>
            <div style="font-size: 15px; line-height: 1.55; color: var(--charcoal);">{{ block.settings.text }}</div>
          </div>
        {%- endfor -%}
      </div>
    </div>
  </div>
</section>

<style>
  @media (max-width: 749px) {
    .bloomli-proof-split { padding: 64px 20px !important; }
    .bloomli-proof-split__inner { grid-template-columns: 1fr !important; gap: 36px !important; }
    .bloomli-proof-split__heading { font-size: 36px !important; }
  }
</style>

{% schema %}
{
  "name": "Bloomli - Proof Split",
  "tag": "div",
  "max_blocks": 6,
  "settings": [
    { "type": "color", "id": "background_color", "label": "Background color", "default": "#FDFAF7" },
    { "type": "image_picker", "id": "image", "label": "Image" },
    { "type": "color", "id": "placeholder_color", "label": "Placeholder color", "default": "#F2D4D0" },
    { "type": "text", "id": "image_label", "label": "Placeholder label", "default": "Editorial - morning ritual - natural light" },
    { "type": "range", "id": "image_radius", "label": "Image corner radius", "min": 0, "max": 40, "step": 2, "default": 16, "unit": "px" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Clinically dosed - gently made" },
    { "type": "text", "id": "heading_line1", "label": "Heading line 1", "default": "Every milligram," },
    { "type": "text", "id": "heading_line2", "label": "Heading line 2 (italic)", "default": "intentional." },
    { "type": "richtext", "id": "copy", "label": "Copy", "default": "<p>We formulate at clinical doses - the amounts used in peer-reviewed studies - not the sprinkle-doses you'll find in most gummies. Every batch is independently tested. Nothing added for color, nothing hidden in a proprietary blend.</p>" },
    { "type": "range", "id": "padding_top", "label": "Padding top", "min": 48, "max": 180, "step": 8, "default": 104, "unit": "px" },
    { "type": "range", "id": "padding_bottom", "label": "Padding bottom", "min": 48, "max": 180, "step": 8, "default": 104, "unit": "px" }
  ],
  "blocks": [
    {
      "type": "bullet",
      "name": "Checklist item",
      "settings": [
        { "type": "text", "id": "text", "label": "Text", "default": "Clinically-dosed actives. No fairy dust." }
      ]
    }
  ],
  "presets": [
    {
      "name": "Bloomli - Proof Split",
      "blocks": [
        { "type": "bullet", "settings": { "text": "Clinically-dosed actives. No fairy dust." } },
        { "type": "bullet", "settings": { "text": "Vegan pectin base. No gelatin, no artificial dyes." } },
        { "type": "bullet", "settings": { "text": "Third-party tested for purity and potency." } },
        { "type": "bullet", "settings": { "text": "Made in a GMP-certified facility in California." } }
      ]
    }
  ]
}
{% endschema %}
