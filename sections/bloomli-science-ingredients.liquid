{{ 'bloomli-science.css' | asset_url | stylesheet_tag }}

<section
  {% if section.settings.section_id != blank %}
    id="{{ section.settings.section_id | handleize }}"
  {% endif %}
  class="bloomli-science-section bloomli-science-ingredients color-{{ section.settings.color_scheme }} gradient"
  style="
    --section-padding-top: {{ section.settings.padding_top }}px;
    --section-padding-bottom: {{ section.settings.padding_bottom }}px;
    --section-padding-top-mobile: {{ section.settings.padding_top_mobile }}px;
    --section-padding-bottom-mobile: {{ section.settings.padding_bottom_mobile }}px;
    --bsi-bg: {% if section.settings.use_custom_background %}{{ section.settings.background_color }}{% else %}rgb(var(--color-background)){% endif %};
  "
>
  <div class="bloomli-science-section__inner">
    <div class="bloomli-science-ingredients__header">
      {%- if section.settings.heading != blank -%}
        <h2 class="bloomli-science-section__heading">{{ section.settings.heading | escape }}</h2>
      {%- endif -%}
      {%- if section.settings.copy != blank -%}
        <div class="bloomli-science-section__copy rte">{{ section.settings.copy }}</div>
      {%- endif -%}
    </div>

    <div class="bloomli-science-ingredients__grid">
      {%- for block in section.blocks -%}
        <article class="bloomli-science-ingredients__card" {{ block.shopify_attributes }}>
          <div class="bloomli-science-ingredients__meta">
            {%- if block.settings.label != blank -%}
              <span class="bloomli-science-ingredients__label">{{ block.settings.label | escape }}</span>
            {%- endif -%}
            {%- if block.settings.role != blank -%}
              <span class="bloomli-science-ingredients__role">{{ block.settings.role | escape }}</span>
            {%- endif -%}
          </div>

          {%- if block.settings.title != blank -%}
            <h3>{{ block.settings.title | escape }}</h3>
          {%- endif -%}

          {%- if block.settings.text != blank -%}
            <div class="bloomli-science-ingredients__text rte">{{ block.settings.text }}</div>
          {%- endif -%}
        </article>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Bloomli Sci Ingredients",
  "tag": "div",
  "enabled_on": {
    "templates": ["page"]
  },
  "max_blocks": 8,
  "settings": [
    { "type": "color_scheme", "id": "color_scheme", "label": "Color scheme", "default": "scheme-6d8ba907-aae6-4c49-9120-e1031d9cdb3f" },
    { "type": "text", "id": "section_id", "label": "Optional section anchor ID", "default": "ingredients" },
    { "type": "checkbox", "id": "use_custom_background", "label": "Use custom background color", "default": false },
    { "type": "color", "id": "background_color", "label": "Custom background color", "default": "#FAF5F3", "visible_if": "{{ section.settings.use_custom_background }}" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Six ingredients worth knowing by name." },
    { "type": "richtext", "id": "copy", "label": "Intro copy", "default": "<p>Not every ingredient list earns attention. These six have a specific role, a specific reason for being included, and research behind the way they&rsquo;re used in hair, skin, nail, or scalp wellness.</p>" },
    { "type": "range", "id": "padding_top", "label": "Padding top", "min": 0, "max": 176, "step": 8, "default": 104, "unit": "px" },
    { "type": "range", "id": "padding_bottom", "label": "Padding bottom", "min": 0, "max": 176, "step": 8, "default": 104, "unit": "px" },
    { "type": "range", "id": "padding_top_mobile", "label": "Padding top mobile", "min": 0, "max": 120, "step": 8, "default": 64, "unit": "px" },
    { "type": "range", "id": "padding_bottom_mobile", "label": "Padding bottom mobile", "min": 0, "max": 120, "step": 8, "default": 64, "unit": "px" }
  ],
  "blocks": [
    {
      "type": "ingredient",
      "name": "Ingredient",
      "settings": [
        { "type": "text", "id": "label", "label": "Small label", "default": "Inside support" },
        { "type": "text", "id": "role", "label": "Product role tag", "default": "Gummies" },
        { "type": "text", "id": "title", "label": "Ingredient name", "default": "Biotin" },
        { "type": "richtext", "id": "text", "label": "Short description", "default": "<p>Supports normal hair and nail wellness and helps the body metabolize fats and proteins. Bloomli gummies are formulated with 6,000 mcg Biotin per serving.</p>" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Bloomli Sci Ingredients",
      "blocks": [
        { "type": "ingredient" },
        { "type": "ingredient", "settings": { "label": "Mineral support", "role": "Inside + outside", "title": "Zinc", "text": "<p>A mineral involved in normal skin, hair, and nail health. Included to support the beauty-from-within side of the Bloomli ritual.</p>" } },
        { "type": "ingredient", "settings": { "label": "Daily metabolism", "role": "Capsules", "title": "Folate + B-vitamins", "text": "<p>B-vitamins help support normal nutrient metabolism and daily wellness. Bloomli formulas use B-vitamin support as part of a broader hair, skin, and nail routine.</p>" } },
        { "type": "ingredient", "settings": { "label": "Antioxidant support", "role": "Inside + outside", "title": "Vitamin C", "text": "<p>Supports normal collagen formation and antioxidant protection. In a hair wellness formula, Vitamin C belongs because healthy-looking hair starts with overall tissue and skin support.</p>" } },
        { "type": "ingredient", "settings": { "label": "Scalp ritual", "role": "Serum", "title": "Rosemary Extract", "text": "<p>A botanical used in Bloomli&rsquo;s topical serum to support a consistent scalp-care ritual and help the scalp feel refreshed.</p>" } },
        { "type": "ingredient", "settings": { "label": "Topical blend", "role": "Serum", "title": "Densidyl components", "text": "<p>A topical blend built around Chlorella and Spirulina extracts, included in the serum to help support the scalp environment.</p>" } }
      ]
    }
  ]
}
{% endschema %}
