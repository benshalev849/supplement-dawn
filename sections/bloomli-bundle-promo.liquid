<section class="bloomli-bundle bloomli-section color-{{ section.settings.color_scheme }} gradient" style="padding: {{ section.settings.padding_top }}px 48px {{ section.settings.padding_bottom }}px;">
  <div class="bloomli-bundle__inner" style="max-width: 900px; margin: 0 auto; text-align: center;">

    {%- if section.settings.eyebrow != blank -%}
      <div class="smallcaps" style="color: var(--bloomli-accent); margin-bottom: 20px;">{{ section.settings.eyebrow }}</div>
    {%- endif -%}

    <h2 class="bloomli-bundle__heading" style="font-family: 'Fraunces', serif; font-variation-settings: 'SOFT' 100; font-size: 64px; margin: 0 0 20px; font-weight: 400; color: var(--bloomli-text); line-height: 1.05;">
      {{ section.settings.headline_line1 }}<br><span style="font-style: italic;">{{ section.settings.headline_line2 }}</span>
    </h2>

    {%- if section.settings.description != blank -%}
      <p class="bloomli-bundle__copy" style="font-size: 18px; color: var(--bloomli-text); margin: 0 auto 36px; max-width: 560px; line-height: 1.6;">
        {{ section.settings.description }}
      </p>
    {%- endif -%}

    <div class="bloomli-bundle__products" style="display: flex; justify-content: center; gap: 24px; margin-bottom: 40px; flex-wrap: nowrap; align-items: flex-end;">
      {%- if section.settings.product_image_1 != blank -%}
        <img class="bloomli-bundle__product" src="{{ section.settings.product_image_1 | image_url: width: 360 }}" alt="{{ section.settings.product_image_1.alt | escape }}" width="180" height="240" loading="lazy" style="width: 180px; max-width: 45%; height: auto; filter: drop-shadow(0 12px 24px var(--bloomli-shadow-color));">
      {%- else -%}
        <div class="bloomli-bundle__product bloomli-bundle__product--placeholder" style="width: 180px; max-width: 45%; height: 240px; background: var(--bloomli-surface); border-radius: 12px; display: flex; align-items: center; justify-content: center;"><span style="font-size: 11px; text-transform: uppercase; letter-spacing: 0.08em; color: var(--bloomli-text-soft);">Gummies</span></div>
      {%- endif -%}
      {%- if section.settings.product_image_2 != blank -%}
        <img class="bloomli-bundle__product" src="{{ section.settings.product_image_2 | image_url: width: 360 }}" alt="{{ section.settings.product_image_2.alt | escape }}" width="180" height="240" loading="lazy" style="width: 180px; max-width: 45%; height: auto; filter: drop-shadow(0 12px 24px var(--bloomli-shadow-color));">
      {%- else -%}
        <div class="bloomli-bundle__product bloomli-bundle__product--placeholder" style="width: 180px; max-width: 45%; height: 240px; background: var(--bloomli-surface); border-radius: 12px; display: flex; align-items: center; justify-content: center;"><span style="font-size: 11px; text-transform: uppercase; letter-spacing: 0.08em; color: var(--bloomli-text-soft);">Hair Oil</span></div>
      {%- endif -%}
    </div>

    {%- if section.settings.cta_label != blank -%}
      <div class="bloomli-bundle__cta-wrap color-{{ section.settings.button_color_scheme }}" style="background: transparent; display: inline-block;">
        <a href="{{ section.settings.cta_url }}" class="button button--primary">{{ section.settings.cta_label }}</a>
      </div>
    {%- endif -%}

  </div>
</section>

<style>
  .bloomli-bundle__cta-wrap { background: transparent !important; }

  @media (max-width: 749px) {
    .bloomli-bundle {
      padding: 56px 16px !important;
    }
    .bloomli-bundle__heading { font-size: 36px !important; }
    .bloomli-bundle__copy { font-size: 15px !important; margin-bottom: 28px !important; }
    .bloomli-bundle__products {
      gap: 12px !important;
      margin-bottom: 28px !important;
      flex-wrap: nowrap !important;
    }
    .bloomli-bundle__product {
      width: 44% !important;
      max-width: 150px !important;
    }
    .bloomli-bundle__cta-wrap .button { padding: 12px 22px !important; font-size: 14px !important; }
  }
</style>

{% schema %}
{
  "name": "Bloomli — Bundle Promo",
  "tag": "div",
  "settings": [
    { "type": "color_scheme", "id": "color_scheme", "label": "Color scheme", "default": "scheme-6d8ba907-aae6-4c49-9120-e1031d9cdb3f" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "The complete ritual" },
    { "type": "text", "id": "headline_line1", "label": "Headline line 1", "default": "Inside & out." },
    { "type": "text", "id": "headline_line2", "label": "Headline line 2 (italic)", "default": "Save 20%." },
    { "type": "textarea", "id": "description", "label": "Description", "default": "The Root Ritual gummies that work from within, paired with our moisturizing & strengthening hair oil for visible shine day one." },
    { "type": "color_scheme", "id": "button_color_scheme", "label": "Button color scheme", "default": "scheme-6d8ba907-aae6-4c49-9120-e1031d9cdb3f" },
    { "type": "text", "id": "cta_label", "label": "CTA label", "default": "Shop the Duo — $74" },
    { "type": "url", "id": "cta_url", "label": "CTA URL" },
    { "type": "image_picker", "id": "product_image_1", "label": "Product image 1 (gummies)" },
    { "type": "image_picker", "id": "product_image_2", "label": "Product image 2 (oil)" },
    { "type": "range", "id": "padding_top", "label": "Padding top (px)", "min": 48, "max": 160, "step": 8, "default": 96 },
    { "type": "range", "id": "padding_bottom", "label": "Padding bottom (px)", "min": 48, "max": 160, "step": 8, "default": 96 }
  ],
  "presets": [{ "name": "Bloomli — Bundle Promo" }]
}
{% endschema %}
