            "what_text": "Hair follicles struggle to complete their natural growth cycle, leading to thinning, shedding, and strands that feel fragile.",
            "how_text": "Every Bloomli supplement is formulated to fill the nutritional gaps your hair actually needs. Consistently, daily, without the guesswork."
          }
        },
        "concern_shedding": {
          "type": "concern",
          "settings": {
            "image": "shopify://shop_images/Shedding.png",
            "icon": "droplets",
            "title": "Shedding",
            "subtitle": "When the drain tells a different story",
            "what_text": "Noticing more hair in the shower or on your brush is one of the first signs something is off. Shedding increases when the growth cycle is disrupted, long before visible thinning appears.",
            "how_text": "The nutrients in Bloomli's daily formula help support follicles through their natural growth cycle, encouraging strands to stay in the growth phase longer."
          }
        },
        "concern_breakage": {
          "type": "concern",
          "settings": {
            "image": "shopify://shop_images/Breakage.png",
            "icon": "scissors",
            "title": "Breakage",
            "subtitle": "When your hair breaks before it grows",
            "what_text": "Fragile strands break before they reach their full length. The result looks like slow growth — but the real issue is retention, not growth itself.",
            "how_text": "The nutrients in Bloomli's daily formula support keratin production and strand strength from within. Paired with the hair oil, you're nourishing your hair at every level."
          }
        },
        "concern_scalp": {
          "type": "concern",
          "settings": {
            "image": "shopify://shop_images/Scalp.png",
            "icon": "plant-2",
            "title": "Scalp environment",
            "subtitle": "Where healthy hair actually begins",
            "what_text": "When your scalp is out of balance, nothing else in your routine works as well as it should. Dryness, irritation and buildup are often the hidden reason hair looks and feels off.",
            "how_text": "Healthy hair starts with a healthy scalp. Bloomli nourishes it from both directions. Daily supplements from within, botanical oil from the outside."
          }
        },
        "concern_lifestyle": {
          "type": "concern",
          "settings": {
            "icon": "heartbeat",
            "title": "Lifestyle stress",
            "subtitle": "When life shows up in your hair",
            "what_text": "During periods of stress, the body redirects nutrients away from hair follicles toward more essential functions. The result shows up weeks or even months later as increased shedding, dullness, or slower growth.",
            "how_text": "Bloomli's daily formula gives your hair the nutritional consistency it needs, even when life isn't. Two gummies or capsules a day keeps your hair routine intact, regardless of what else is going on."
          }
        }
