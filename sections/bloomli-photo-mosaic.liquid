<section class="bloomli-photo-mosaic bloomli-section color-{{ section.settings.color_scheme }} gradient" style="{% if section.settings.use_custom_background %}--bpm-bg: {{ section.settings.background_color }};{% else %}--bpm-bg: var(--bloomli-bg);{% endif %}{% case section.settings.placeholder_background %}{% when 'background' %}--bpm-placeholder-bg: var(--bloomli-bg);{% when 'surface_strong' %}--bpm-placeholder-bg: var(--bloomli-surface-strong);{% when 'accent_soft' %}--bpm-placeholder-bg: rgba(var(--color-button), 0.12);{% else %}--bpm-placeholder-bg: var(--bloomli-surface);{% endcase %} --bloomli-padding-top: {{ section.settings.padding_top }}px; --bloomli-padding-bottom: {{ section.settings.padding_bottom }}px; --bpm-columns-desktop: {{ section.settings.columns_desktop }}; --bpm-columns-mobile: {{ section.settings.columns_mobile }}; --bpm-gap: {{ section.settings.gap }}px; --bpm-radius: {{ section.settings.radius }}px;">
  <div class="bloomli-section__inner">
    <div class="bloomli-photo-mosaic__header">
      {%- if section.settings.eyebrow != blank -%}
        <div class="smallcaps bloomli-photo-mosaic__eyebrow">{{ section.settings.eyebrow }}</div>
      {%- endif -%}
      <h2 class="bloomli-photo-mosaic__heading">{{ section.settings.heading }}</h2>
    </div>

    <div class="bloomli-photo-mosaic__grid">
      {%- for block in section.blocks -%}
        <div class="bloomli-photo-mosaic__tile" {{ block.shopify_attributes }} style="--bpm-tile-bg: {% if block.settings.use_custom_placeholder_color %}{{ block.settings.placeholder_color }}{% else %}var(--bpm-placeholder-bg){% endif %}; {% if block.settings.image == blank %}--bpm-placeholder-lines: repeating-linear-gradient(135deg, var(--bloomli-line-soft) 0 1px, transparent 1px 18px);{% endif %}">
          {%- if block.settings.image != blank -%}
            {%- assign image_scale = block.settings.image_scale | divided_by: 100.0 -%}
            {%- assign image_style = '--bpm-image-scale: ' | append: image_scale | append: ';' -%}
            {%- assign image_alt = block.settings.image.alt | default: block.settings.label -%}
            {{
              block.settings.image
              | image_url: width: 520
              | image_tag:
                class: 'bloomli-photo-mosaic__image',
                alt: image_alt,
                widths: '240, 360, 520',
                sizes: '(max-width: 749px) 50vw, 320px',
                loading: 'lazy', decoding: 'async',
                style: image_style
            }}
          {%- endif -%}
          {%- if block.settings.label != blank and block.settings.image == blank -%}
            <span class="smallcaps bloomli-section-placeholder-label">{{ block.settings.label }}</span>
          {%- endif -%}
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Bloomli - Photo Mosaic",
  "tag": "div",
  "max_blocks": 16,
  "settings": [
    { "type": "color_scheme", "id": "color_scheme", "label": "Color scheme", "default": "scheme-6d8ba907-aae6-4c49-9120-e1031d9cdb3f" },
    { "type": "checkbox", "id": "use_custom_background", "label": "Use custom background color", "default": false },
    { "type": "color", "id": "background_color", "label": "Custom background color", "default": "#FDFAF7" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Verified buyers" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Photos from the ritual." },
    { "type": "select", "id": "placeholder_background", "label": "Tile placeholder background", "options": [
      { "value": "surface", "label": "Scheme soft surface" },
      { "value": "surface_strong", "label": "Scheme stronger surface" },
      { "value": "background", "label": "Scheme background" },
      { "value": "accent_soft", "label": "Soft accent" }
    ], "default": "surface" },
    { "type": "range", "id": "columns_desktop", "label": "Columns desktop", "min": 3, "max": 6, "step": 1, "default": 6 },
    { "type": "select", "id": "columns_mobile", "label": "Columns mobile", "options": [
      { "value": "2", "label": "2" },
      { "value": "3", "label": "3" }
    ], "default": "2" },
    { "type": "range", "id": "gap", "label": "Gap desktop", "min": 0, "max": 24, "step": 2, "default": 10, "unit": "px" },
    { "type": "range", "id": "radius", "label": "Corner radius", "min": 0, "max": 24, "step": 2, "default": 8, "unit": "px" },
    { "type": "range", "id": "padding_top", "label": "Padding top", "min": 48, "max": 176, "step": 8, "default": 96, "unit": "px" },
    { "type": "range", "id": "padding_bottom", "label": "Padding bottom", "min": 48, "max": 176, "step": 8, "default": 96, "unit": "px" }
  ],
  "blocks": [
    {
      "type": "photo",
      "name": "Photo",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Photo" },
        { "type": "range", "id": "image_scale", "label": "Uploaded image scale", "min": 70, "max": 140, "step": 5, "default": 100, "unit": "%" },
        { "type": "text", "id": "label", "label": "Placeholder label", "default": "Photo" },
        { "type": "checkbox", "id": "use_custom_placeholder_color", "label": "Override tile background", "default": false },
        { "type": "color", "id": "placeholder_color", "label": "Custom tile background", "default": "#F5EDE4" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Bloomli - Photo Mosaic",
      "blocks": [
        { "type": "photo", "settings": { "label": "Photo 1" } },
        { "type": "photo", "settings": { "label": "Photo 2" } },
        { "type": "photo", "settings": { "label": "Photo 3" } },
        { "type": "photo", "settings": { "label": "Photo 4" } },
        { "type": "photo", "settings": { "label": "Photo 5" } },
        { "type": "photo", "settings": { "label": "Photo 6" } },
        { "type": "photo", "settings": { "label": "Photo 7" } },
        { "type": "photo", "settings": { "label": "Photo 8" } },
        { "type": "photo", "settings": { "label": "Photo 9" } },
        { "type": "photo", "settings": { "label": "Photo 10" } },
        { "type": "photo", "settings": { "label": "Photo 11" } },
        { "type": "photo", "settings": { "label": "Photo 12" } }
      ]
    }
  ]
}
{% endschema %}
