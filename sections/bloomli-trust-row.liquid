<section style="padding: {{ section.settings.padding_top }}px 48px {{ section.settings.padding_bottom }}px; background: var(--cream); border-top: 1px solid rgba(110,74,99,0.08); border-bottom: 1px solid rgba(110,74,99,0.08);">
  <div style="max-width: 1280px; margin: 0 auto; display: grid; grid-template-columns: repeat(4, 1fr); gap: 0;">

    {%- for block in section.blocks -%}
      <div {{ block.shopify_attributes }} style="display: flex; flex-direction: column; align-items: center; gap: 10px; {% unless forloop.first %}border-left: 1px solid rgba(110,74,99,0.1);{% endunless %} padding: 0 12px;">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#6E4A63" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
          {%- case block.settings.icon -%}
            {%- when 'flask' -%}
              <path d="M9 3h6M10 3v6l-5 10a2 2 0 0 0 1.8 3h10.4A2 2 0 0 0 19 19L14 9V3"/><path d="M7.5 14h9"/>
            {%- when 'shield' -%}
              <path d="M12 3l8 3v6c0 5-3.5 8.5-8 10-4.5-1.5-8-5-8-10V6l8-3z"/><path d="M9 12l2 2 4-4"/>
            {%- when 'leaf' -%}
              <path d="M5 19c0-8 6-14 14-14 0 8-6 14-14 14z"/><path d="M5 19c4-4 8-8 14-14"/>
            {%- when 'star' -%}
              <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/>
            {%- when 'check' -%}
              <circle cx="12" cy="12" r="9"/><path d="M9 12l2 2 4-4"/>
            {%- when 'globe' -%}
              <circle cx="12" cy="12" r="9"/><path d="M3 12h18M12 3v18M5 6h14M5 18h14"/>
          {%- endcase -%}
        </svg>
        <span class="smallcaps" style="color: var(--charcoal); text-align: center; font-size: 11px;">{{ block.settings.label }}</span>
      </div>
    {%- endfor -%}

  </div>
</section>

<style>
  @media (max-width: 749px) {
    section:has(.bloomli-trust-inner) > div {
      grid-template-columns: 1fr 1fr !important;
      gap: 24px !important;
    }
    section:has(.bloomli-trust-inner) > div > div {
      border-left: none !important;
      padding: 0 !important;
    }
  }
</style>

{% schema %}
{
  "name": "Bloomli — Trust Row",
  "tag": "div",
  "max_blocks": 4,
  "settings": [
    { "type": "range", "id": "padding_top", "label": "Padding top (px)", "min": 20, "max": 80, "step": 4, "default": 56 },
    { "type": "range", "id": "padding_bottom", "label": "Padding bottom (px)", "min": 20, "max": 80, "step": 4, "default": 56 }
  ],
  "blocks": [
    {
      "type": "trust_item",
      "name": "Trust item",
      "settings": [
        { "type": "select", "id": "icon", "label": "Icon", "options": [
          { "value": "flask", "label": "Flask" },
          { "value": "shield", "label": "Shield / Check" },
          { "value": "leaf", "label": "Leaf" },
          { "value": "star", "label": "Star" },
          { "value": "check", "label": "Circle check" },
          { "value": "globe", "label": "Globe / USA" }
        ], "default": "flask" },
        { "type": "text", "id": "label", "label": "Label", "default": "Clinically-studied ingredients" }
      ]
    }
  ],
  "presets": [{
    "name": "Bloomli — Trust Row",
    "blocks": [
      { "type": "trust_item", "settings": { "icon": "flask", "label": "Clinically-studied ingredients" } },
      { "type": "trust_item", "settings": { "icon": "shield", "label": "Dermatologist-approved" } },
      { "type": "trust_item", "settings": { "icon": "leaf", "label": "Cruelty-free & vegan" } },
      { "type": "trust_item", "settings": { "icon": "globe", "label": "Made in the USA" } }
    ]
  }]
}
{% endschema %}
