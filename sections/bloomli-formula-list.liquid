<section class="bloomli-formula-list bloomli-section color-{{ section.settings.color_scheme }} gradient" style="--bfl-eyebrow-color: {{ section.settings.eyebrow_accent_color | default: '#8A6678' }}; --bfl-icon-color: {{ section.settings.icon_accent_color | default: '#6F7A5A' }}; {% if section.settings.use_custom_background %}--bfl-bg: {{ section.settings.background_color }};{% else %}--bfl-bg: var(--bloomli-bg);{% endif %}{% case section.settings.icon_background_tone %}{% when 'background' %}--bfl-icon-bg: var(--bloomli-bg);{% when 'surface' %}--bfl-icon-bg: #F1EDE8;{% when 'surface_strong' %}--bfl-icon-bg: var(--bloomli-surface-strong);{% else %}--bfl-icon-bg: #F1EDE8;{% endcase %}{% case section.settings.proof_icon_background_tone %}{% when 'background' %}--bfl-proof-icon-bg: var(--bloomli-bg);{% when 'accent' %}--bfl-proof-icon-bg: #F1EDE8;{% when 'surface_strong' %}--bfl-proof-icon-bg: var(--bloomli-surface-strong);{% else %}--bfl-proof-icon-bg: var(--bloomli-surface);{% endcase %} padding: {{ section.settings.padding_top }}px 48px {{ section.settings.padding_bottom }}px; background: var(--bfl-bg);">
  <div class="bloomli-formula-list__inner" style="max-width: 1080px; margin: 0 auto;">
    <div class="bloomli-formula-list__header" style="max-width: 560px; margin-bottom: 64px;">
      {%- if section.settings.eyebrow != blank -%}
        <div class="smallcaps" style="color: var(--bfl-eyebrow-color); margin-bottom: 18px;">{{ section.settings.eyebrow }}</div>
      {%- endif -%}
      <h2 class="bloomli-formula-list__heading" style="font-family: 'Fraunces', serif; font-variation-settings: 'SOFT' 100; font-size: 52px; line-height: 1.05; font-weight: 400; margin: 0 0 24px; color: var(--bloomli-text);">
        {{ section.settings.heading_line1 }}<br>
        <span style="font-style: italic;">{{ section.settings.heading_line2 }}</span>
      </h2>
      {%- if section.settings.copy != blank -%}
        <div class="bloomli-formula-list__copy" style="font-size: 17px; line-height: 1.55; color: var(--bloomli-text);">{{ section.settings.copy }}</div>
      {%- endif -%}
    </div>

    <div class="bloomli-formula-list__grid" style="display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 0 56px;">
      {%- for block in section.blocks -%}
        {%- if block.settings.is_proof -%}
          {%- continue -%}
        {%- endif -%}
        <div class="bloomli-formula-list__item" {{ block.shopify_attributes }} style="display: grid; grid-template-columns: {{ section.settings.icon_size }}px 1fr; gap: 20px; align-items: center; padding: 30px 0; min-width: 0;">
          <div class="bloomli-formula-list__icon" style="width: {{ section.settings.icon_size }}px; height: {{ section.settings.icon_size }}px; border-radius: 999px; background: {% if block.settings.use_custom_icon_background %}{{ block.settings.icon_background }}{% else %}var(--bfl-icon-bg){% endif %}; color: {% if block.settings.use_custom_icon_color %}{{ block.settings.icon_color }}{% else %}var(--bfl-icon-color){% endif %}; display: flex; align-items: center; justify-content: center; overflow: clip; flex-shrink: 0;">
            {%- if block.settings.image != blank -%}
              {%- assign image_scale = block.settings.image_scale | default: 100 | divided_by: 100.0 -%}
              <img src="{{ block.settings.image | image_url: width: 240 }}" srcset="{{ block.settings.image | image_url: width: 120 }} 120w, {{ block.settings.image | image_url: width: 240 }} 240w" sizes="(max-width: 749px) {{ section.settings.icon_size_mobile }}px, {{ section.settings.icon_size }}px" alt="{{ block.settings.image.alt | default: block.settings.title | escape }}" width="{{ section.settings.icon_size }}" height="{{ section.settings.icon_size }}" loading="lazy" draggable="false" style="width: 100%; height: 100%; object-fit: contain; transform: scale({{ image_scale }}); transform-origin: center; display: block;">
            {%- else -%}
              <svg width="30" height="30" viewBox="0 0 80 80" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                {%- case block.settings.icon -%}
                  {%- when 'leaf' -%}<path d="M18 56c0-22 18-38 42-38 0 24-16 42-42 42"/><path d="M18 56c10-12 20-22 42-38"/>
                  {%- when 'palm' -%}<path d="M40 68V28"/><path d="M40 28c-10-11-20-10-28 0"/><path d="M40 28c10-11 20-10 28 0"/><path d="M40 34c-8-7-16-7-22 1"/><path d="M40 34c8-7 16-7 22 1"/>
                  {%- when 'drop' -%}<path d="M40 68c-12-8-18-18-18-30 0-12 8-22 18-30 10 8 18 18 18 30 0 12-6 22-18 30z"/><path d="M32 44c5-3 11-3 16 0"/>
                  {%- when 'root' -%}<path d="M40 64V34"/><path d="M40 42c-10-10-18-9-26 0"/><path d="M40 42c10-10 18-9 26 0"/><circle cx="24" cy="56" r="5"/><circle cx="56" cy="56" r="5"/>
                  {%- when 'zinc' -%}<circle cx="40" cy="40" r="24"/><path d="M28 36h24M28 44h24"/><text x="40" y="44" text-anchor="middle" font-size="11" fill="currentColor" stroke="none">Zn</text>
                  {%- when 'spark' -%}<path d="M40 12v18M40 50v18M12 40h18M50 40h18"/><path d="M24 24l10 10M46 46l10 10M56 24 46 34M34 46 24 56"/>
                  {%- when 'tested' -%}<rect x="18" y="12" width="44" height="56" rx="4"/><path d="M26 28h28M26 40h18M26 52h28"/><text x="40" y="62" text-anchor="middle" font-size="8" fill="currentColor" stroke="none">TESTED</text>
                {%- endcase -%}
              </svg>
            {%- endif -%}
          </div>
          <div>
            <div class="smallcaps" style="color: var(--bfl-eyebrow-color); font-size: 11px; margin-bottom: 10px;">{{ block.settings.title }}</div>
            <div style="font-size: 15px; line-height: 1.55; color: var(--bloomli-text);">{{ block.settings.text }}</div>
          </div>
        </div>
      {%- endfor -%}
    </div>

    {%- assign has_proof = false -%}
    {%- for block in section.blocks -%}
      {%- if block.settings.is_proof -%}
        {%- assign has_proof = true -%}
      {%- endif -%}
    {%- endfor -%}

    {%- if has_proof -%}
      <div class="bloomli-formula-list__proof-grid" style="display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 0 56px; margin-top: 58px; padding-top: 48px; border-top: 1px solid var(--bloomli-line);">
        {%- for block in section.blocks -%}
          {%- unless block.settings.is_proof -%}
            {%- continue -%}
          {%- endunless -%}
          <div class="bloomli-formula-list__item bloomli-formula-list__item--proof" {{ block.shopify_attributes }} style="display: grid; grid-template-columns: {{ section.settings.icon_size }}px 1fr; gap: 20px; align-items: center; padding: 0; min-width: 0;">
            <div class="bloomli-formula-list__icon" style="width: {{ section.settings.icon_size }}px; height: {{ section.settings.icon_size }}px; border-radius: 999px; background: {% if block.settings.use_custom_icon_background %}{{ block.settings.icon_background }}{% else %}var(--bfl-proof-icon-bg){% endif %}; color: {% if block.settings.use_custom_icon_color %}{{ block.settings.icon_color }}{% else %}var(--bfl-icon-color){% endif %}; display: flex; align-items: center; justify-content: center; overflow: clip; flex-shrink: 0;">
              {%- if block.settings.image != blank -%}
                {%- assign image_scale = block.settings.image_scale | default: 100 | divided_by: 100.0 -%}
                <img src="{{ block.settings.image | image_url: width: 240 }}" srcset="{{ block.settings.image | image_url: width: 120 }} 120w, {{ block.settings.image | image_url: width: 240 }} 240w" sizes="(max-width: 749px) {{ section.settings.icon_size_mobile }}px, {{ section.settings.icon_size }}px" alt="{{ block.settings.image.alt | default: block.settings.title | escape }}" width="{{ section.settings.icon_size }}" height="{{ section.settings.icon_size }}" loading="lazy" draggable="false" style="width: 100%; height: 100%; object-fit: contain; transform: scale({{ image_scale }}); transform-origin: center; display: block;">
              {%- else -%}
                <svg width="30" height="30" viewBox="0 0 80 80" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  {%- case block.settings.icon -%}
                    {%- when 'leaf' -%}<path d="M18 56c0-22 18-38 42-38 0 24-16 42-42 42"/><path d="M18 56c10-12 20-22 42-38"/>
                    {%- when 'palm' -%}<path d="M40 68V28"/><path d="M40 28c-10-11-20-10-28 0"/><path d="M40 28c10-11 20-10 28 0"/><path d="M40 34c-8-7-16-7-22 1"/><path d="M40 34c8-7 16-7 22 1"/>
                    {%- when 'drop' -%}<path d="M40 68c-12-8-18-18-18-30 0-12 8-22 18-30 10 8 18 18 18 30 0 12-6 22-18 30z"/><path d="M32 44c5-3 11-3 16 0"/>
                    {%- when 'root' -%}<path d="M40 64V34"/><path d="M40 42c-10-10-18-9-26 0"/><path d="M40 42c10-10 18-9 26 0"/><circle cx="24" cy="56" r="5"/><circle cx="56" cy="56" r="5"/>
                    {%- when 'zinc' -%}<circle cx="40" cy="40" r="24"/><path d="M28 36h24M28 44h24"/><text x="40" y="44" text-anchor="middle" font-size="11" fill="currentColor" stroke="none">Zn</text>
                    {%- when 'spark' -%}<path d="M40 12v18M40 50v18M12 40h18M50 40h18"/><path d="M24 24l10 10M46 46l10 10M56 24 46 34M34 46 24 56"/>
                    {%- when 'tested' -%}<rect x="18" y="12" width="44" height="56" rx="4"/><path d="M26 28h28M26 40h18M26 52h28"/><text x="40" y="62" text-anchor="middle" font-size="8" fill="currentColor" stroke="none">TESTED</text>
                  {%- endcase -%}
                </svg>
              {%- endif -%}
            </div>
            <div>
              <div class="smallcaps" style="color: var(--bfl-eyebrow-color); font-size: 11px; margin-bottom: 10px;">{{ block.settings.title }}</div>
              <div style="font-size: 15px; line-height: 1.55; color: var(--bloomli-text);">{{ block.settings.text }}</div>
            </div>
          </div>
        {%- endfor -%}
      </div>
    {%- endif -%}
  </div>
</section>

<style>
  @media (max-width: 749px) {
    .bloomli-formula-list { padding: 56px 20px !important; }
    .bloomli-formula-list__header { margin-bottom: 32px !important; }
    .bloomli-formula-list__heading { font-size: 36px !important; }
    .bloomli-formula-list__grid,
    .bloomli-formula-list__proof-grid { grid-template-columns: 1fr !important; gap: 0 !important; }
    .bloomli-formula-list__proof-grid { margin-top: 32px !important; padding-top: 24px !important; }
    .bloomli-formula-list__item { grid-template-columns: {{ section.settings.icon_size_mobile }}px 1fr !important; gap: 16px !important; padding: 22px 0 !important; }
    .bloomli-formula-list__icon { width: {{ section.settings.icon_size_mobile }}px !important; height: {{ section.settings.icon_size_mobile }}px !important; }
  }
</style>

{% schema %}
{
  "name": "Bloomli - Formula List",
  "tag": "div",
  "max_blocks": 8,
  "settings": [
    { "type": "color_scheme", "id": "color_scheme", "label": "Color scheme", "default": "scheme-6d8ba907-aae6-4c49-9120-e1031d9cdb3f" },
    { "type": "checkbox", "id": "use_custom_background", "label": "Use custom background color", "default": false },
    { "type": "color", "id": "background_color", "label": "Section background color", "default": "#F3E1E5" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "The goods inside" },
    { "type": "color", "id": "eyebrow_accent_color", "label": "Eyebrow accent color", "default": "#8A6678" },
    { "type": "color", "id": "icon_accent_color", "label": "Icon accent color", "default": "#6F7A5A" },
    { "type": "text", "id": "heading_line1", "label": "Heading line 1", "default": "Five ingredients," },
    { "type": "text", "id": "heading_line2", "label": "Heading line 2 (italic)", "default": "doing the quiet work." },
    { "type": "richtext", "id": "copy", "label": "Intro copy", "default": "<p>A daily blend that supports thicker, stronger hair from the inside - clinically dosed and easy on the stomach.</p>" },
    { "type": "select", "id": "icon_background_tone", "label": "Ingredient icon background", "options": [
      { "value": "accent", "label": "Scheme accent" },
      { "value": "surface", "label": "Scheme soft surface" },
      { "value": "surface_strong", "label": "Scheme stronger surface" },
      { "value": "background", "label": "Scheme background" }
    ], "default": "surface" },
    { "type": "select", "id": "proof_icon_background_tone", "label": "Proof icon background", "options": [
      { "value": "surface", "label": "Scheme soft surface" },
      { "value": "surface_strong", "label": "Scheme stronger surface" },
      { "value": "background", "label": "Scheme background" },
      { "value": "accent", "label": "Scheme accent" }
    ], "default": "surface" },
    { "type": "range", "id": "icon_size", "label": "Icon size desktop", "min": 44, "max": 96, "step": 4, "default": 64, "unit": "px" },
    { "type": "range", "id": "icon_size_mobile", "label": "Icon size mobile", "min": 40, "max": 80, "step": 4, "default": 56, "unit": "px" },
    { "type": "range", "id": "padding_top", "label": "Padding top", "min": 48, "max": 176, "step": 8, "default": 112, "unit": "px" },
    { "type": "range", "id": "padding_bottom", "label": "Padding bottom", "min": 48, "max": 176, "step": 8, "default": 112, "unit": "px" }
  ],
  "blocks": [
    {
      "type": "item",
      "name": "Ingredient / proof item",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Custom icon image" },
        { "type": "range", "id": "image_scale", "label": "Uploaded image scale", "min": 70, "max": 140, "step": 5, "default": 100, "unit": "%" },
        { "type": "checkbox", "id": "is_proof", "label": "Proof item", "default": false },
        { "type": "select", "id": "icon", "label": "Default SVG icon", "options": [
          { "value": "leaf", "label": "Leaf" },
          { "value": "palm", "label": "Palm" },
          { "value": "drop", "label": "Drop" },
          { "value": "root", "label": "Root" },
          { "value": "zinc", "label": "Zinc" },
          { "value": "spark", "label": "Spark" },
          { "value": "tested", "label": "Tested badge" }
        ], "default": "leaf" },
        { "type": "checkbox", "id": "use_custom_icon_background", "label": "Override icon background", "default": false },
        { "type": "color", "id": "icon_background", "label": "Custom icon background", "default": "#F1EDE8" },
        { "type": "checkbox", "id": "use_custom_icon_color", "label": "Override icon color", "default": false },
        { "type": "color", "id": "icon_color", "label": "Custom icon color", "default": "#6F7A5A" },
        { "type": "text", "id": "title", "label": "Title", "default": "Biotin" },
        { "type": "textarea", "id": "text", "label": "Text", "default": "The keratin building block - clinically dosed for strand strength you can actually feel." }
      ]
    }
  ],
  "presets": [
    {
      "name": "Bloomli - Formula List",
      "blocks": [
        { "type": "item", "settings": { "icon": "leaf", "title": "Biotin", "text": "The keratin building block - clinically dosed for strand strength you can actually feel." } },
        { "type": "item", "settings": { "icon": "palm", "title": "Saw Palmetto", "text": "A plant-based DHT balancer that keeps follicles happy at the root." } },
        { "type": "item", "settings": { "icon": "drop", "title": "Marine Collagen", "text": "Sustainably sourced amino acids for elasticity and shine." } },
        { "type": "item", "settings": { "icon": "root", "title": "Ashwagandha", "text": "Adaptogen that quiets stress-related shedding." } },
        { "type": "item", "settings": { "icon": "zinc", "title": "Zinc", "text": "Essential mineral that supports a calm, healthy scalp environment." } },
        { "type": "item", "settings": { "icon": "spark", "title": "Delightfully tasty", "text": "A natural strawberry-forward berry blend. Never chalky, never too sweet.", "is_proof": true } },
        { "type": "item", "settings": { "icon": "tested", "title": "Independently verified", "text": "Every batch tested by a third-party lab for purity, potency, and heavy metals.", "is_proof": true } }
      ]
    }
  ]
}
{% endschema %}
