eight: 500;\n    color: var(--charcoal);\n  }\n\n  .bq-cta-box p {\n    max-width: 640px;\n    margin: 18px auto 0;\n    color: var(--muted);\n    font-size: 18px;\n    line-height: 1.65;\n  }\n\n  .bq-disclaimer {\n    max-width: 880px;\n    margin: 34px auto 0;\n    color: rgba(42,38,34,0.58);\n    font-size: 12px;\n    line-height: 1.55;\n    text-align: center;\n  }\n\n  @media (max-width: 980px) {\n    .bq-hero-grid,\n    .bq-split {\n      grid-template-columns: 1fr;\n      gap: 36px;\n    }\n\n    .bq-cards,\n    .bq-process {\n      grid-template-columns: repeat(2, 1fr);\n    }\n  }\n\n  @media (max-width: 640px) {\n    .bq-container {\n      width: min(100% - 24px, 1180px);\n    }\n\n    .bq-hero {\n      padding: 50px 0 54px;\n    }\n\n    .bq-hero h1 {\n      font-size: 42px;\n      line-height: 1.04;\n    }\n\n    .bq-hero-text,\n    .bq-centered p,\n    .bq-split p,\n    .bq-cta-box p {\n      font-size: 16px;\n    }\n\n    .bq-section {\n      padding: 60px 0;\n    }\n\n    .bq-cards,\n    .bq-process {\n      grid-template-columns: 1fr;\n    }\n\n    .bq-card,\n    .bq-process-card,\n    .bq-highlight-box {\n      padding: 24px;\n      border-radius: 22px;\n    }\n\n    .bq-actions {\n      flex-direction: column;\n    }\n\n    .bq-btn {\n      width: 100%;\n    }\n\n    .bq-visual {\n      padding: 22px;\n      border-radius: 28px;\n    }\n\n    .bq-seal {\n      padding: 30px 22px;\n      border-radius: 24px;\n    }\n\n    .bq-cta-box {\n      padding: 42px 22px;\n      border-radius: 28px;\n    }\n  }\n</style>\n\n<div class=\"bloomli-quality\">\n\n  <section class=\"bq-hero\">\n    <div class=\"bq-container bq-hero-grid\">\n      <div>\n        <p class=\"bq-eyebrow\">Our Standards</p>\n        <h1>Made with care, clarity, and standards you can feel good about.</h1>\n\n        <p class=\"bq-hero-text\">\n          At Bloomli, quality is not just about what goes into a product. It is about how every formula is chosen, reviewed, presented, and made to fit into women’s real beauty routines.\n        </p>\n\n        <p class=\"bq-hero-text\">\n          Our goal is simple: create hair, beauty, and wellness products that feel trustworthy, easy to understand, and beautiful to use every day.\n        </p>\n\n        <div class=\"bq-actions\">\n          <a class=\"bq-btn bq-btn-primary\" href=\"/collections/all\">Shop Bloomli</a>\n          <a class=\"bq-btn bq-btn-secondary\" href=\"#bloomli-standards\">See Our Standards</a>\n        </div>\n      </div>\n\n      <div class=\"bq-visual\" aria-label=\"Bloomli quality standards\">\n        <div class=\"bq-seal\">\n          <div class=\"bq-seal-mark\">✓</div>\n          <h2>Thoughtful quality, start to finish.</h2>\n          <p>\n            From ingredient selection to clear product directions, Bloomli is built around beauty wellness that feels intentional, transparent, and consistent.\n          </p>\n        </div>\n      </div>\n    </div>\n  </section>\n\n  <section class=\"bq-section\" id=\"bloomli-standards\">\n    <div class=\"bq-container\">\n      <div class=\"bq-centered\">\n        <p class=\"bq-eyebrow\">The Bloomli Standard</p>\n        <h2>Beauty wellness should feel clear, not confusing.</h2>\n        <p>\n          We believe women deserve products that are easy to understand, simple to use, and made with a quality-first mindset.\n        </p>\n      </div>\n\n      <div class=\"bq-cards\">\n        <div class=\"bq-card\">\n          <div class=\"bq-icon\">✦</div>\n          <h3>Thoughtful formulas</h3>\n          <p>\n            We focus on ingredients that make sense for hair, beauty, and women’s wellness routines — without making the experience feel complicated.\n          </p>\n        </div>\n\n        <div class=\"bq-card\">\n          <div class=\"bq-icon\">♡</div>\n          <h3>Clear labels</h3>\n          <p>\n            We believe product information should be simple to read, easy to understand, and clear about what each product is made to support.\n          </p>\n        </div>\n\n        <div class=\"bq-card\">\n          <div class=\"bq-icon\">☼</div>\n          <h3>Consistency first</h3>\n          <p>\n            Every Bloomli product is designed to fit into real routines, helping beauty care feel easier to keep coming back to.\n          </p>\n        </div>\n      </div>\n    </div>\n  </section>\n\n  <section class=\"bq-section bq-soft\">\n    <div class=\"bq-container bq-split\">\n      <div>\n        <p class=\"bq-eyebrow\">How We Think About Quality</p>\n        <h2>Pretty on the outside. Considered on the inside.</h2>\n\n        <p>\n          Bloomli is built to feel feminine and premium, but the standard behind the brand is just as important as the look. We care about the details customers actually rely on: clear usage directions, responsible positioning, thoughtful ingredients, and products that are easy to trust.\n        </p>\n\n        <p>\n          As our product line grows across gummies, pills, strips, and hair oil, our goal is to keep the same quality mindset across every format.\n        </p>\n      </div>\n\n      <div class=\"bq-highlight-box\">\n        <div class=\"bq-highlight-list\">\n          <div class=\"bq-highlight-item\">\n            <div class=\"bq-check\">✓</div>\n            <div>\n              <strong>Ingredient intention</strong>\n              <span>Each product is built around a clear role in your hair, beauty, or wellness routine.</span>\n            </div>\n          </div>\n\n          <div class=\"bq-highlight-item\">\n            <div class=\"bq-check\">✓</div>\n            <div>\n              <strong>Responsible claims</strong>\n              <span>We aim to communicate benefits clearly without promising overnight fixes or unrealistic results.</span>\n            </div>\n          </div>\n\n          <div class=\"bq-highlight-item\">\n            <div class=\"bq-check\">✓</div>\n            <div>\n              <strong>Routine-friendly formats</strong>\n              <span>From supplements to topical care, our products are created to feel easy to use consistently.</span>\n            </div>\n          </div>\n\n          <div class=\"bq-highlight-item\">\n            <div class=\"bq-check\">✓</div>\n            <div>\n              <strong>Premium experience</strong>\n              <span>We care about how the product looks, feels, tastes, applies, and fits into your daily life.</span>\n            </div>\n          </div>\n        </div>\n      </div>\n    </div>\n  </section>\n\n  <section class=\"bq-section\">\n    <div class=\"bq-container\">\n      <div class=\"bq-centered\">\n        <p class=\"bq-eyebrow\">Our Quality Checklist</p>\n        <h2>The details we look for before a product becomes Bloomli.</h2>\n        <p>\n          Quality is a process. Before a product belongs in the Bloomli routine, we look at how it supports the customer, how clearly it can be explained, and how easy it is to use.\n        </p>\n      </div>\n\n      <div class=\"bq-process\">\n        <div class=\"bq-process-card\">\n          <div class=\"bq-number\">1</div>\n          <h3>Purpose</h3>\n          <p>\n            Every product needs a clear reason to exist within hair, beauty, or women’s wellness.\n          </p>\n        </div>\n\n        <div class=\"bq-process-card\">\n          <div class=\"bq-number\">2</div>\n          <h3>Formula fit</h3>\n          <p>\n            We look for ingredients and formats that make sense for real routines and daily consistency.\n          </p>\n        </div>\n\n        <div class=\"bq-process-card\">\n          <div class=\"bq-number\">3</div>\n          <h3>Customer clarity</h3>\n          <p>\n            The product should be easy to understand, with clear directions and simple benefit language.\n          </p>\n        </div>\n\n        <div class=\"bq-process-card\">\n          <div class=\"bq-number\">4</div>\n          <h3>Experience</h3>\n          <p>\n            We care about the full experience — packaging, texture, taste, feel, and how the product fits into your ritual.\n          </p>\n        </div>\n      </div>\n\n      <div class=\"bq-note\">\n        <strong>Important:</strong> If your final manufacturer provides specific certifications, you can add them here later — for example GMP manufacturing, third-party testing, allergen statements, non-GMO, vegan, cruelty-free, or made in USA. Only include claims that are true for the specific product.\n      </div>\n    </div>\n  </section>\n\n  <section class=\"bq-section bq-soft\">\n    <div class=\"bq-container bq-split\">\n      <div>\n        <p class=\"bq-eyebrow\">Transparency</p>\n        <h2>No mystery. No overcomplication.</h2>\n\n        <p>\n          We want Bloomli customers to feel confident about what they are buying. That means presenting products in a way that feels understandable, honest, and easy to compare.\n        </p>\n\n        <p>\n          We do not believe beauty wellness needs to feel intimidating. Our standards are built around giving customers enough clarity to make a confident choice.\n        </p>\n      </div>\n\n      <div class=\"bq-highlight-box\">\n        <div class=\"bq-highlight-list\">\n          <div class=\"bq-highlight-item\">\n            <div class=\"bq-check\">✓</div>\n            <div>\n              <strong>Clear product pages</strong>\n              <span>Ingredients, directions, and key product details should be easy to find before purchase.</span>\n            </div>\n          </div>\n\n          <div class=\"bq-highlight-item\">\n            <div class=\"bq-check\">✓</div>\n            <div>\n              <strong>Easy-to-read benefits</strong>\n              <span>We use simple language that helps customers understand what each product is designed to support.</span>\n            </div>\n          </div>\n\n          <div class=\"bq-highlight-item\">\n            <div class=\"bq-check\">✓</div>\n            <div>\n              <strong>Realistic expectations</strong>\n              <span>We believe in consistency over quick-fix promises, especially in hair and beauty routines.</span>\n            </div>\n          </div>\n\n          <div class=\"bq-highlight-item\">\n            <div class=\"bq-check\">✓</div>\n            <div>\n              <strong>Support-first messaging</strong>\n              <span>Bloomli products are positioned as part of a daily routine, not as medical treatments.</span>\n            </div>\n          </div>\n        </div>\n      </div>\n    </div>\n  </section>\n\n  <section class=\"bq-cta\">\n    <div class=\"bq-container\">\n      <div class=\"bq-cta-box\">\n        <p class=\"bq-eyebrow\">Our Promise</p>\n        <h2>Quality that feels beautiful, clear, and easy to trust.</h2>\n\n        <p>\n          Explore Bloomli’s growing collection of hair, beauty, and women’s wellness products designed with care, clarity, and daily consistency in mind.\n        </p>\n\n        <div class=\"bq-actions\" style=\"justify-content:center;\">\n          <a class=\"bq-btn bq-btn-primary\" href=\"/collections/all\">Shop Bloomli</a>\n          <a class=\"bq-btn bq-btn-secondary\" href=\"/pages/beauty-from-within\">Beauty From Within</a>\n        </div>\n      </div>\n\n      <p class=\"bq-disclaimer\">\n        *These statements have not been evaluated by the Food and Drug Administration. Bloomli supplement products are not intended to diagnose, treat, cure, or prevent any disease. Results may vary. Use all products as directed.\n      </p>\n    </div>\n  </section>\n\n</div>",
