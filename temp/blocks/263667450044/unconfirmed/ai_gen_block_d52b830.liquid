{% doc %}
  @prompt
    Create a comparison table section inspired by a wellness supplement brand. The table compares a featured product (highlighted with a dark forest green header column, #1a3a2a background, white text) against competitor categories: Multivitamins, Probiotics, Greens. Rows include: Vitamins, Minerals, Prebiotics, Probiotics, Greens & Superfoods, Antioxidants, Digestive Enzymes. Use green checkmark circle icons for supported features and grey X circle icons for unsupported ones. The featured product column has all green checkmarks. Style should feel premium, clean, and wellness-focused with a light background, subtle row dividers, and bold column headers. Make all text, icons, column headers, and the featured product label customizable via section settings. Add a footnote text field at the bottom. Fully responsive.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-comparison-table-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    margin: 0 auto;
    background-color: {{ block.settings.background_color }};
    padding: {{ block.settings.padding }}px;
    border-radius: {{ block.settings.border_radius }}px;
  }

  .ai-comparison-table__wrapper-{{ ai_gen_id }} {
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
  }

  .ai-comparison-table__table-{{ ai_gen_id }} {
    width: 100%;
    border-collapse: collapse;
    min-width: 600px;
  }

  .ai-comparison-table__header-{{ ai_gen_id }} {
    background-color: transparent;
  }

  .ai-comparison-table__header-cell-{{ ai_gen_id }} {
    padding: {{ block.settings.cell_padding }}px;
    text-align: center;
    font-weight: 700;
    font-size: {{ block.settings.header_font_size }}px;
    color: {{ block.settings.header_text_color }};
    border-bottom: {{ block.settings.divider_thickness }}px solid {{ block.settings.divider_color }};
  }

  .ai-comparison-table__header-cell-{{ ai_gen_id }}:first-child {
    text-align: left;
    color: {{ block.settings.row_label_color }};
    font-weight: 600;
  }

  .ai-comparison-table__featured-header-{{ ai_gen_id }} {
    background-color: {{ block.settings.featured_bg_color }};
    color: {{ block.settings.featured_text_color }};
    border-radius: {{ block.settings.featured_border_radius }}px {{ block.settings.featured_border_radius }}px 0 0;
    position: relative;
  }

  .ai-comparison-table__row-{{ ai_gen_id }} {
    border-bottom: {{ block.settings.divider_thickness }}px solid {{ block.settings.divider_color }};
  }

  .ai-comparison-table__row-{{ ai_gen_id }}:last-child {
    border-bottom: none;
  }

  .ai-comparison-table__cell-{{ ai_gen_id }} {
    padding: {{ block.settings.cell_padding }}px;
    text-align: center;
    font-size: {{ block.settings.body_font_size }}px;
    color: {{ block.settings.body_text_color }};
  }

  .ai-comparison-table__cell-{{ ai_gen_id }}:first-child {
    text-align: left;
    font-weight: 600;
    color: {{ block.settings.row_label_color }};
  }

  .ai-comparison-table__featured-cell-{{ ai_gen_id }} {
    background-color: {{ block.settings.featured_cell_bg_color }};
  }

  .ai-comparison-table__icon-{{ ai_gen_id }} {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: {{ block.settings.icon_size }}px;
    height: {{ block.settings.icon_size }}px;
  }

  .ai-comparison-table__icon-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
  }

  .ai-comparison-table__footnote-{{ ai_gen_id }} {
    margin-top: {{ block.settings.footnote_spacing }}px;
    font-size: {{ block.settings.footnote_font_size }}px;
    color: {{ block.settings.footnote_color }};
    text-align: {{ block.settings.footnote_alignment }};
  }

  @media screen and (max-width: 749px) {
    .ai-comparison-table-{{ ai_gen_id }} {
      padding: {{ block.settings.padding | times: 0.6 }}px;
    }

    .ai-comparison-table__header-cell-{{ ai_gen_id }} {
      font-size: {{ block.settings.header_font_size | times: 0.85 }}px;
      padding: {{ block.settings.cell_padding | times: 0.7 }}px;
    }

    .ai-comparison-table__cell-{{ ai_gen_id }} {
      font-size: {{ block.settings.body_font_size | times: 0.85 }}px;
      padding: {{ block.settings.cell_padding | times: 0.7 }}px;
    }

    .ai-comparison-table__icon-{{ ai_gen_id }} {
      width: {{ block.settings.icon_size | times: 0.8 }}px;
      height: {{ block.settings.icon_size | times: 0.8 }}px;
    }
  }
{% endstyle %}

