{{ 'bloomli-brand-difference.css' | asset_url | stylesheet_tag }}
<script src="{{ 'bloomli-brand-difference.js' | asset_url }}" defer="defer"></script>

{%- liquid
  assign custom_check_icon = section.settings.custom_check_icon
  assign bloomli_header_logo = section.settings.bloomli_header_logo
-%}

<section
  class="bloomli-brand-difference color-{{ section.settings.color_scheme }} gradient"
  data-padding-top-mobile="{{ section.settings.padding_top_mobile }}"
  data-padding-bottom-mobile="{{ section.settings.padding_bottom_mobile }}"
  data-padding-top-desktop="{{ section.settings.padding_top_desktop }}"
  data-padding-bottom-desktop="{{ section.settings.padding_bottom_desktop }}"
>
  <div class="page-width">
    <div class="bloomli-brand-difference__statement">
      {%- if section.settings.heading != blank -%}
        <h2 class="bloomli-brand-difference__heading h1">
          {{ section.settings.heading | escape }}
        </h2>
      {%- endif -%}

      {%- if section.settings.body != blank -%}
        <div class="bloomli-brand-difference__body rte">
          {{ section.settings.body }}
        </div>
      {%- endif -%}
    </div>

    {%- if section.blocks.size > 0 -%}
      <div class="bloomli-brand-difference__table-wrap">
        <table class="bloomli-brand-difference__table">
          <thead>
            <tr>
              <th scope="col" class="bloomli-brand-difference__feature-heading">
                {{ section.settings.feature_header | escape }}
              </th>
              <th scope="col" class="bloomli-brand-difference__column-heading bloomli-brand-difference__column-heading--bloomli">
                {%- if bloomli_header_logo != blank -%}
                  {{
                    bloomli_header_logo
                    | image_url: width: 240
                    | image_tag:
                      class: 'bloomli-brand-difference__header-logo',
                      widths: '120, 180, 240',
                      width: 120,
                      loading: 'lazy',
                      alt: section.settings.bloomli_header
                  }}
                {%- else -%}
                  {{ section.settings.bloomli_header | escape }}
                {%- endif -%}
              </th>
              <th scope="col" class="bloomli-brand-difference__column-heading">
                {{ section.settings.standard_header | escape }}
              </th>
              <th scope="col" class="bloomli-brand-difference__column-heading">
                {{ section.settings.biotin_header | escape }}
              </th>
            </tr>
          </thead>
          <tbody>
            {%- for block in section.blocks -%}
              <tr {{ block.shopify_attributes }}>
                <th scope="row" class="bloomli-brand-difference__feature">
                  {{ block.settings.feature_label | escape }}
                </th>
                <td class="bloomli-brand-difference__value-cell bloomli-brand-difference__value-cell--bloomli">
                  {%- case block.settings.bloomli_value -%}
                    {%- when 'cross' -%}
                      <span class="bloomli-brand-difference__value bloomli-brand-difference__value--cross" aria-label="Not included">
                        <i class="ti ti-circle-x" aria-hidden="true"></i>
                      </span>
                    {%- when 'partial' -%}
                      <span class="bloomli-brand-difference__value bloomli-brand-difference__value--partial" aria-label="Partial">
                        <i class="ti ti-minus" aria-hidden="true"></i>
                      </span>
                    {%- else -%}
                      <span class="bloomli-brand-difference__value bloomli-brand-difference__value--check" aria-label="Included">
                        {%- if custom_check_icon != blank -%}
                          {{
                            custom_check_icon
                            | image_url: width: 40
                            | image_tag:
                              class: 'bloomli-brand-difference__custom-check',
                              widths: '20, 40',
                              width: 20,
                              height: 20,
                              loading: 'lazy',
                              alt: 'Included'
                          }}
                        {%- else -%}
                          <i class="ti ti-check" aria-hidden="true"></i>
                        {%- endif -%}
                      </span>
                  {%- endcase -%}
                </td>
                <td class="bloomli-brand-difference__value-cell">
                  {%- case block.settings.standard_value -%}
                    {%- when 'check' -%}
                      <span class="bloomli-brand-difference__value bloomli-brand-difference__value--competitor-check" aria-label="Included">
                        <i class="ti ti-check" aria-hidden="true"></i>
                      </span>
                    {%- when 'partial' -%}
                      <span class="bloomli-brand-difference__value bloomli-brand-difference__value--competitor-partial" aria-label="Partial">
                        <i class="ti ti-minus" aria-hidden="true"></i>
                      </span>
                    {%- else -%}
                      <span class="bloomli-brand-difference__value bloomli-brand-difference__value--competitor-cross" aria-label="Not included">
                        <i class="ti ti-circle-x" aria-hidden="true"></i>
                      </span>
                  {%- endcase -%}
                </td>
                <td class="bloomli-brand-difference__value-cell">
                  {%- case block.settings.biotin_value -%}
                    {%- when 'check' -%}
                      <span class="bloomli-brand-difference__value bloomli-brand-difference__value--competitor-check" aria-label="Included">
                        <i class="ti ti-check" aria-hidden="true"></i>
                      </span>
                    {%- when 'partial' -%}
                      <span class="bloomli-brand-difference__value bloomli-brand-difference__value--competitor-partial" aria-label="Partial">
                        <i class="ti ti-minus" aria-hidden="true"></i>
                      </span>
                    {%- else -%}
                      <span class="bloomli-brand-difference__value bloomli-brand-difference__value--competitor-cross" aria-label="Not included">
                        <i class="ti ti-circle-x" aria-hidden="true"></i>
                      </span>
                  {%- endcase -%}
                </td>
              </tr>
            {%- endfor -%}
          </tbody>
        </table>
      </div>
    {%- endif -%}

    {%- if section.settings.footnote != blank -%}
      <p class="bloomli-brand-difference__footnote">
        {{ section.settings.footnote | escape }}
      </p>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Bloomli Brand Difference",
  "tag": "section",
  "class": "section",
  "enabled_on": {
    "templates": ["*"]
  },
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "How we stack up"
    },
    {
      "type": "richtext",
      "id": "body",
      "label": "Subheading",
      "default": "<p>Not all hair supplements are built the same.</p>"
    },
    {
      "type": "text",
      "id": "feature_header",
      "label": "Feature column header",
      "default": "Feature"
    },
    {
      "type": "text",
      "id": "bloomli_header",
      "label": "Bloomli column header",
      "default": "Complete Hair Ritual"
    },
    {
      "type": "image_picker",
      "id": "bloomli_header_logo",
      "label": "Bloomli column logo"
    },
    {
      "type": "text",
      "id": "biotin_header",
      "label": "Biotin-only column header",
      "default": "Biotin supplement"
    },
    {
      "type": "text",
      "id": "standard_header",
      "label": "Standard supplement column header",
      "default": "Standard hair supplement"
    },
    {
      "type": "image_picker",
      "id": "custom_check_icon",
      "label": "Custom Bloomli check icon"
    },
    {
      "type": "textarea",
      "id": "footnote",
      "label": "Footnote",
      "default": "† Botanical herbal blend available in capsules formula. ‡ Based on general market data for mass-market hair supplements. Individual products may vary."
    },
    {
      "type": "header",
      "content": "Desktop spacing"
    },
    {
      "type": "range",
      "id": "padding_top_desktop",
      "label": "Padding top",
      "min": 0,
      "max": 120,
      "step": 8,
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_bottom_desktop",
      "label": "Padding bottom",
      "min": 0,
      "max": 120,
      "step": 8,
      "default": 80
    },
    {
      "type": "header",
      "content": "Mobile spacing"
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "label": "Padding top",
      "min": 0,
      "max": 120,
      "step": 8,
      "default": 56
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "label": "Padding bottom",
      "min": 0,
      "max": 120,
      "step": 8,
      "default": 56
    }
  ],
  "blocks": [
    {
      "type": "card",
      "name": "Comparison row",
      "settings": [
        {
          "type": "text",
          "id": "feature_label",
          "label": "Feature label",
          "default": "High-dose Biotin"
        },
        {
          "type": "select",
          "id": "bloomli_value",
          "label": "Bloomli value",
          "options": [
            { "value": "check", "label": "Check" },
            { "value": "cross", "label": "Cross" },
            { "value": "partial", "label": "Partial" }
          ],
          "default": "check"
        },
        {
          "type": "select",
          "id": "biotin_value",
          "label": "Biotin-only value",
          "options": [
            { "value": "check", "label": "Check" },
            { "value": "cross", "label": "Cross" },
            { "value": "partial", "label": "Partial" }
          ],
          "default": "check"
        },
        {
          "type": "select",
          "id": "standard_value",
          "label": "Standard value",
          "options": [
            { "value": "check", "label": "Check" },
            { "value": "cross", "label": "Cross" },
            { "value": "partial", "label": "Partial" }
          ],
          "default": "check"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Bloomli Brand Difference",
      "blocks": [
        {
          "type": "card",
          "settings": {
            "feature_label": "High-dose Biotin",
            "bloomli_value": "check",
            "biotin_value": "check",
            "standard_value": "check"
          }
        },
        {
          "type": "card",
          "settings": {
            "feature_label": "Full B vitamin complex",
            "bloomli_value": "check",
            "biotin_value": "cross",
            "standard_value": "check"
          }
        },
        {
          "type": "card",
          "settings": {
            "feature_label": "Complete mineral blend",
            "bloomli_value": "check",
            "biotin_value": "cross",
            "standard_value": "partial"
          }
        },
        {
          "type": "card",
          "settings": {
            "feature_label": "Botanical herbal blend†",
            "bloomli_value": "check",
            "biotin_value": "cross",
            "standard_value": "cross"
          }
        },
        {
          "type": "card",
          "settings": {
            "feature_label": "Choice of format — gummies or capsules",
            "bloomli_value": "check",
            "biotin_value": "cross",
            "standard_value": "cross"
          }
        },
        {
          "type": "card",
          "settings": {
            "feature_label": "Botanical scalp serum",
            "bloomli_value": "check",
            "biotin_value": "cross",
            "standard_value": "cross"
          }
        },
        {
          "type": "card",
          "settings": {
            "feature_label": "Third-party tested",
            "bloomli_value": "check",
            "biotin_value": "cross",
            "standard_value": "cross"
          }
        },
        {
          "type": "card",
          "settings": {
            "feature_label": "Manufactured in NSF-certified facility",
            "bloomli_value": "check",
            "biotin_value": "cross",
            "standard_value": "cross"
          }
        },
        {
          "type": "card",
          "settings": {
            "feature_label": "Made in the USA",
            "bloomli_value": "check",
            "biotin_value": "partial",
            "standard_value": "partial"
          }
        },
        {
          "type": "card",
          "settings": {
            "feature_label": "Gluten-free",
            "bloomli_value": "check",
            "biotin_value": "partial",
            "standard_value": "partial"
          }
        }
      ]
    }
  ]
}
{% endschema %}
