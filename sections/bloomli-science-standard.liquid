{{ 'bloomli-science.css' | asset_url | stylesheet_tag }}

<section
  {% if section.settings.section_id != blank %}
    id="{{ section.settings.section_id | handleize }}"
  {% endif %}
  class="bloomli-science-section bloomli-science-standard{% if section.settings.show_numbers %} bloomli-science-standard--numbered{% endif %} color-{{ section.settings.color_scheme }} gradient"
  style="
    --section-padding-top: {{ section.settings.padding_top }}px;
    --section-padding-bottom: {{ section.settings.padding_bottom }}px;
    --section-padding-top-mobile: {{ section.settings.padding_top_mobile }}px;
    --section-padding-bottom-mobile: {{ section.settings.padding_bottom_mobile }}px;
    --bss-accent: {% if section.settings.use_custom_accent_color %}{{ section.settings.accent_color }}{% else %}var(--bloomli-primary-action, rgb(var(--color-button))){% endif %};
  "
>
  <div class="bloomli-science-section__inner">
    <div class="bloomli-science-standard__layout">
      <div class="bloomli-science-standard__thesis">
        {%- if section.settings.eyebrow != blank -%}
          <div class="bloomli-science-pill">{{ section.settings.eyebrow | escape }}</div>
        {%- endif -%}

        {%- if section.settings.heading != blank -%}
          <h2 class="bloomli-science-section__heading">{{ section.settings.heading | escape }}</h2>
        {%- endif -%}

        {%- if section.settings.copy != blank -%}
          <div class="bloomli-science-section__copy rte">{{ section.settings.copy }}</div>
        {%- endif -%}
      </div>

      <div class="bloomli-science-standard__items">
        {%- for block in section.blocks -%}
          <article class="bloomli-science-standard__item" {{ block.shopify_attributes }}>
            {%- if section.settings.show_numbers -%}
              <span class="bloomli-science-standard__number">{{ forloop.index }}</span>
            {%- endif -%}

            <div class="bloomli-science-standard__item-content">
              {%- if block.settings.title != blank -%}
                <h3>{{ block.settings.title | escape }}</h3>
              {%- endif -%}

              {%- if block.settings.text != blank -%}
                <p>{{ block.settings.text }}</p>
              {%- endif -%}
            </div>
          </article>
        {%- endfor -%}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Bloomli Science Standard",
  "tag": "div",
  "enabled_on": {
    "templates": ["page"]
  },
  "settings": [
    { "type": "color_scheme", "id": "color_scheme", "label": "Color scheme", "default": "scheme-db3fe7fd-8cb8-43cd-b413-f26d3fc92c5f" },
    { "type": "text", "id": "section_id", "label": "Optional section anchor ID" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Bloomli standard" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Science-backed should mean more than a trendy ingredient list." },
    { "type": "richtext", "id": "copy", "label": "Copy", "default": "<p>In beauty supplements, science-backed can mean many things. At Bloomli, it means every formula starts with a clear purpose, uses ingredients with a relevant role in hair, skin, nail, or scalp wellness, and avoids claims that sound bigger than the evidence behind them.</p>" },
    { "type": "checkbox", "id": "show_numbers", "label": "Show item numbers", "default": true },
    { "type": "checkbox", "id": "use_custom_accent_color", "label": "Use custom accent color", "default": false },
    { "type": "color", "id": "accent_color", "label": "Custom accent color", "default": "#6F7A5A" },
    { "type": "range", "id": "padding_top", "label": "Padding top", "min": 0, "max": 176, "step": 8, "default": 112, "unit": "px" },
    { "type": "range", "id": "padding_bottom", "label": "Padding bottom", "min": 0, "max": 176, "step": 8, "default": 88, "unit": "px" },
    { "type": "range", "id": "padding_top_mobile", "label": "Padding top mobile", "min": 0, "max": 120, "step": 8, "default": 56, "unit": "px" },
    { "type": "range", "id": "padding_bottom_mobile", "label": "Padding bottom mobile", "min": 0, "max": 120, "step": 8, "default": 56, "unit": "px" }
  ],
  "blocks": [
    {
      "type": "principle",
      "name": "Principle",
      "settings": [
        { "type": "text", "id": "title", "label": "Title", "default": "Purpose before hype" },
        { "type": "text", "id": "text", "label": "Text", "default": "We choose ingredients because they have a clear role in the formula - not because they are trending on TikTok." }
      ]
    }
  ],
  "presets": [
    {
      "name": "Bloomli Science Standard",
      "blocks": [
        { "type": "principle" },
        { "type": "principle", "settings": { "title": "Format matters", "text": "A gummy, capsule, and topical serum do different jobs. Bloomli treats each format as part of a ritual, not as interchangeable versions of the same product." } },
        { "type": "principle", "settings": { "title": "Consistency matters", "text": "Hair support is not instant. The most important part of any routine is choosing one you can actually stick with." } },
        { "type": "principle", "settings": { "title": "Claims stay honest", "text": "We use support language because Bloomli products are wellness products - not medical treatments." } }
      ]
    }
  ]
}
{% endschema %}
