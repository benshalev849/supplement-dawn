{{ 'bloomli-product-finder.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign cards = 'capsules,gummies,oil' | split: ','
-%}

<section
  class="bloomli-product-finder color-{{ section.settings.color_scheme }} gradient"
  style="--bpf-oil-card-background: {% if section.settings.oil_card_background != blank %}{{ section.settings.oil_card_background }}{% else %}rgb(var(--color-background)){% endif %};"
>
  <div class="page-width">
    <div class="bloomli-product-finder__header">
      {%- if section.settings.heading != blank -%}
        <h2 class="bloomli-product-finder__heading h1">{{ section.settings.heading | escape }}</h2>
      {%- endif -%}

      {%- if section.settings.subheading != blank -%}
        <div class="bloomli-product-finder__subheading rte">
          {{ section.settings.subheading }}
        </div>
      {%- endif -%}
    </div>

    <div class="bloomli-product-finder__grid">
      {%- for card in cards -%}
        {%- liquid
          assign card_modifier = card
          assign product_key = 'card_' | append: forloop.index | append: '_product'
          assign subhead_key = card | append: '_subhead'
          assign best_for_key = card | append: '_best_for'
          assign check_1_key = card | append: '_check_1'
          assign check_2_key = card | append: '_check_2'
          assign check_3_key = card | append: '_check_3'
          assign button_label_key = card | append: '_button_label'
          assign badge_key = card | append: '_badge'

          assign card_product = section.settings[product_key]
          assign card_heading = card_product.title
          assign card_subhead = section.settings[subhead_key]
          assign best_for = section.settings[best_for_key]
          assign check_1 = section.settings[check_1_key]
          assign check_2 = section.settings[check_2_key]
          assign check_3 = section.settings[check_3_key]
          assign button_label = section.settings[button_label_key]
          assign button_url = card_product.url
          assign badge_text = section.settings[badge_key]
        -%}

        <article class="bloomli-product-finder__card bloomli-product-finder__card--{{ card_modifier }}{% if card == 'gummies' %} bloomli-product-finder__card--featured{% endif %}">
          {%- if card == 'gummies' and section.settings.most_popular_badge != blank -%}
            <span class="bloomli-product-finder__floating-badge">
              {{ section.settings.most_popular_badge | escape }}
            </span>
          {%- endif -%}

          <div class="bloomli-product-finder__icon-row">
            <span class="bloomli-product-finder__icon" aria-hidden="true">
              {%- if card == 'capsules' -%}
                <i class="ti ti-pill"></i>
              {%- elsif card == 'gummies' -%}
                <i class="ti ti-candy"></i>
              {%- else -%}
                <i class="ti ti-droplet"></i>
              {%- endif -%}
            </span>

            {%- if card != 'oil' and badge_text != blank -%}
              <span class="bloomli-product-finder__pill">
                {{ badge_text | escape }}
              </span>
            {%- endif -%}
          </div>

          {%- if best_for != blank -%}
            <p class="bloomli-product-finder__best-for">
              {{ best_for | escape }}
            </p>
          {%- endif -%}

          {%- if card_heading != blank -%}
            <h3 class="bloomli-product-finder__title h3">
              {{ card_heading | escape }}
            </h3>
          {%- endif -%}

          {%- if card_subhead != blank -%}
            <p class="bloomli-product-finder__body">
              {{ card_subhead | escape }}
            </p>
          {%- endif -%}

          <div class="bloomli-proof-split__bullets bloomli-product-finder__checks" style="--bps-icon-color: rgb(var(--color-button));" role="list">
            {%- if check_1 != blank -%}
              <div class="bloomli-proof-split__bullet" role="listitem">
                <span class="bloomli-proof-split__check" aria-hidden="true"></span>
                <div class="bloomli-proof-split__bullet-text">{{ check_1 | escape }}</div>
              </div>
            {%- endif -%}
            {%- if check_2 != blank -%}
              <div class="bloomli-proof-split__bullet" role="listitem">
                <span class="bloomli-proof-split__check" aria-hidden="true"></span>
                <div class="bloomli-proof-split__bullet-text">{{ check_2 | escape }}</div>
              </div>
            {%- endif -%}
            {%- if check_3 != blank -%}
              <div class="bloomli-proof-split__bullet" role="listitem">
                <span class="bloomli-proof-split__check" aria-hidden="true"></span>
                <div class="bloomli-proof-split__bullet-text">{{ check_3 | escape }}</div>
              </div>
            {%- endif -%}
          </div>

          {%- if button_label != blank -%}
            <a
              class="button button--primary bloomli-product-finder__button"
              href="{{ button_url | default: '#' }}"
            >
              {{ button_label | escape }}
            </a>
          {%- endif -%}
        </article>
      {%- endfor -%}
    </div>
  </div>
</section>

