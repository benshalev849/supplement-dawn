{%- liquid
  assign stars_color = 'rgb(var(--color-button))'
  if section.settings.stars_color_source == 'custom' and section.settings.stars_custom_color != blank
    assign stars_color = section.settings.stars_custom_color
  endif
-%}

<section
  class="bloomli-product-picks bloomli-section color-{{ section.settings.color_scheme }} gradient"
  style="{% if section.settings.use_custom_background %}--bpp-bg: {{ section.settings.background_color }};{% else %}--bpp-bg: var(--bloomli-bg);{% endif %} --bloomli-padding-top: {{ section.settings.padding_top }}px; --bloomli-padding-bottom: {{ section.settings.padding_bottom }}px; --bpp-columns-desktop: {{ section.settings.columns_desktop }}; --bpp-columns-mobile: {{ section.settings.columns_mobile }}; --bpp-image-box-height: {{ section.settings.image_box_height }}px; --bpp-stars-color: {{ stars_color }};"
>
  <style>
    #shopify-section-{{ section.id }} .bloomli-product-picks__badge.badge {
      position: relative;
      top: auto;
      right: auto;
      bottom: auto;
      left: auto;
      z-index: 2;
      display: block;
      width: fit-content;
      margin: 0 auto 0.8rem;
    }

    #shopify-section-{{ section.id }} .bloomli-product-picks__media {
      display: flex;
      align-items: center;
      justify-content: center;
    }

    #shopify-section-{{ section.id }} .bloomli-product-picks__image,
    #shopify-section-{{ section.id }} .bloomli-product-picks__media > svg {
      width: var(--bpp-image-scale-percent, 70%);
      max-width: var(--bpp-image-scale-percent, 70%);
      max-height: var(--bpp-image-scale-percent, 70%);
      height: auto;
      object-fit: contain;
    }

    #shopify-section-{{ section.id }} .bloomli-product-picks__stars {
      display: inline-flex;
      align-items: center;
      gap: 0.6rem;
    }

    #shopify-section-{{ section.id }} .bloomli-product-picks__stars-meter {
      position: relative;
      display: inline-block;
      line-height: 1;
    }

    #shopify-section-{{ section.id }} .bloomli-product-picks__stars-base {
      color: rgba(var(--color-foreground), 0.22);
    }

    #shopify-section-{{ section.id }} .bloomli-product-picks__stars-fill {
      position: absolute;
      top: 0;
      left: 0;
      width: var(--bpp-rating-percent, 100%);
      overflow: hidden;
      color: var(--bpp-stars-color, rgb(var(--color-button)));
      white-space: nowrap;
    }

    #shopify-section-{{ section.id }} .bloomli-product-picks__stars--judgeme :is(
      .jdgm-star,
      .jdgm-prev-badge__stars,
      .jdgm-prev-badge__stars .jdgm-star
    ) {
      color: var(--bpp-stars-color, rgb(var(--color-button))) !important;
    }

    #shopify-section-{{ section.id }} .bloomli-product-picks__rating-text {
      font-size: 1.2rem;
      color: rgba(var(--color-foreground), 0.72);
      line-height: 1.2;
    }
  </style>

  <div class="bloomli-section__inner">
    <div class="bloomli-product-picks__header">
      <h2 class="bloomli-product-picks__heading">{{ section.settings.heading }}</h2>
      {%- if section.settings.subtext != blank -%}
        <div class="bloomli-product-picks__subtext">{{ section.settings.subtext }}</div>
      {%- endif -%}
    </div>

    <div class="bloomli-product-picks__grid">
      {%- for block in section.blocks -%}
        {%- assign picked_product = block.settings.product -%}
        {%- assign card_url = picked_product.url | default: block.settings.link -%}
        {%- assign image_scale = block.settings.image_scale | default: 70 -%}
        {%- assign image_scale_factor = image_scale | divided_by: 100.0 -%}
        {%- assign image_scale_percent = image_scale | append: '%' -%}
        {%- assign image_style = '--bpp-image-scale: ' | append: image_scale_factor | append: '; --bpp-image-scale-percent: ' | append: image_scale_percent | append: ';' -%}
        <div class="bloomli-product-picks__card" {{ block.shopify_attributes }}>
          {%- if block.settings.badge != blank -%}
            <span class="bloomli-product-picks__badge badge badge--top-left color-{{ settings.sale_badge_color_scheme | default: section.settings.color_scheme }}">
              {{- block.settings.badge -}}
            </span>
          {%- endif -%}

          {%- if card_url != blank -%}
            <a href="{{ card_url }}" class="bloomli-product-picks__link">
          {%- else -%}
            <div class="bloomli-product-picks__link">
          {%- endif -%}
            <div class="bloomli-product-picks__media" style="{{ image_style }}">
              {%- if block.settings.image != blank -%}
                {%- assign image_alt = block.settings.image.alt | default: block.settings.title -%}
                {{
                  block.settings.image
                  | image_url: width: 520
                  | image_tag:
                    class: 'bloomli-product-picks__image',
                    alt: image_alt,
                    widths: '240, 360, 520',
                    sizes: '(max-width: 749px) 50vw, 260px',
                    loading: 'lazy',
                    decoding: 'async'
                }}
              {%- elsif picked_product.featured_image != blank -%}
                {%- assign product_image_alt = picked_product.featured_image.alt | default: picked_product.title -%}
                {{
                  picked_product.featured_image
                  | image_url: width: 520
                  | image_tag:
                    class: 'bloomli-product-picks__image',
                    alt: product_image_alt,
                    widths: '240, 360, 520',
                    sizes: '(max-width: 749px) 50vw, 260px',
                    loading: 'lazy',
                    decoding: 'async'
                }}
              {%- else -%}
                <svg width="180" height="220" viewBox="0 0 180 220" fill="none" aria-hidden="true">
                  <rect x="58" y="18" width="64" height="24" rx="4" fill="rgb(var(--color-button))"/>
                  <rect x="68" y="42" width="44" height="22" fill="rgb(var(--color-button))" opacity="0.82"/>
                  <rect x="46" y="62" width="88" height="134" rx="14" fill="rgb(var(--color-background))" stroke="rgba(var(--color-foreground),0.14)"/>
                  <rect x="62" y="96" width="56" height="70" rx="4" fill="rgb(var(--color-button))"/>
                  <text x="90" y="125" text-anchor="middle" fill="rgb(var(--color-button-text))" font-size="13" font-family="serif">Root</text>
                  <text x="90" y="143" text-anchor="middle" fill="rgb(var(--color-button-text))" font-size="15" font-family="serif" font-style="italic">Ritual</text>
                </svg>
              {%- endif -%}
            </div>

            <div class="bloomli-product-picks__meta">
              <div>
                <h3 class="bloomli-product-picks__title">{{ block.settings.title | default: picked_product.title }}</h3>
                {%- if block.settings.show_stars -%}
                  {%- if block.settings.rating_source == 'judgeme' and picked_product != blank -%}
                    <div class="bloomli-product-picks__stars bloomli-product-picks__stars--judgeme">
                      <div class="jdgm-widget jdgm-preview-badge" data-id="{{ picked_product.id }}">
                        {{ picked_product.metafields.judgeme.badge }}
                      </div>
                    </div>
                  {%- else -%}
                    {%- assign custom_rating = block.settings.custom_star_rating | default: '5' | plus: 0 -%}
                    {%- assign rating_percent = custom_rating | times: 20 -%}
                    <div class="bloomli-product-picks__stars" aria-label="{{ custom_rating }} out of 5 star rating">
                      <span class="bloomli-product-picks__stars-meter" style="--bpp-rating-percent: {{ rating_percent }}%;">
                        <span class="bloomli-product-picks__stars-base" aria-hidden="true">&#9733;&#9733;&#9733;&#9733;&#9733;</span>
                        <span class="bloomli-product-picks__stars-fill" aria-hidden="true">&#9733;&#9733;&#9733;&#9733;&#9733;</span>
                      </span>
                      {%- if block.settings.rating_text != blank -%}
                        <span class="bloomli-product-picks__rating-text">{{ block.settings.rating_text }}</span>
                      {%- endif -%}
                    </div>
                  {%- endif -%}
                {%- endif -%}
              </div>
              <div class="bloomli-product-picks__price">
                {%- if block.settings.price != blank -%}
                  {{ block.settings.price }}
                {%- elsif picked_product.price != blank -%}
                  {{ picked_product.price | money_without_trailing_zeros }}
                {%- endif -%}
              </div>
            </div>
          {%- if card_url != blank -%}
            </a>
          {%- else -%}
            </div>
          {%- endif -%}
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Bloomli - Product Picks",
  "tag": "div",
  "max_blocks": 8,
  "settings": [
    { "type": "color_scheme", "id": "color_scheme", "label": "Color scheme", "default": "scheme-6d8ba907-aae6-4c49-9120-e1031d9cdb3f" },
    { "type": "select", "id": "stars_color_source", "label": "Stars color", "options": [
      { "value": "scheme_button", "label": "Scheme button color" },
      { "value": "custom", "label": "Custom color" }
    ], "default": "scheme_button" },
    { "type": "color", "id": "stars_custom_color", "label": "Custom stars color", "default": "#B23A6F" },
    { "type": "checkbox", "id": "use_custom_background", "label": "Use custom background color", "default": false },
    { "type": "color", "id": "background_color", "label": "Custom background color", "default": "#F5EDE4" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "You may also like" },
    { "type": "richtext", "id": "subtext", "label": "Subtext", "default": "<p>Complete your routine with a few Bloomli favorites.</p>" },
    { "type": "range", "id": "columns_desktop", "label": "Columns desktop", "min": 2, "max": 4, "step": 1, "default": 4 },
    { "type": "select", "id": "columns_mobile", "label": "Columns mobile", "options": [
      { "value": "1", "label": "1" },
      { "value": "2", "label": "2" }
    ], "default": "2" },
    { "type": "range", "id": "image_box_height", "label": "Image box height", "min": 160, "max": 320, "step": 10, "default": 240, "unit": "px" },
    { "type": "range", "id": "padding_top", "label": "Padding top", "min": 48, "max": 176, "step": 8, "default": 88, "unit": "px" },
    { "type": "range", "id": "padding_bottom", "label": "Padding bottom", "min": 48, "max": 176, "step": 8, "default": 88, "unit": "px" }
  ],
  "blocks": [
    {
      "type": "product",
      "name": "Product card",
      "settings": [
        { "type": "product", "id": "product", "label": "Product" },
        { "type": "image_picker", "id": "image", "label": "Custom image override" },
        { "type": "range", "id": "image_scale", "label": "Image scale", "min": 70, "max": 140, "step": 5, "default": 70, "unit": "%" },
        { "type": "text", "id": "title", "label": "Custom title" },
        { "type": "url", "id": "link", "label": "Fallback link if no product selected" },
        { "type": "text", "id": "price", "label": "Custom price" },
        { "type": "text", "id": "badge", "label": "Badge" },
        { "type": "checkbox", "id": "show_stars", "label": "Show rating", "default": true },
        { "type": "select", "id": "rating_source", "label": "Rating source", "options": [
          { "value": "custom", "label": "Custom stars" },
          { "value": "judgeme", "label": "Judge.me product rating" }
        ], "default": "custom" },
        { "type": "select", "id": "custom_star_rating", "label": "Custom star rating", "options": [
          { "value": "0", "label": "0" },
          { "value": "0.5", "label": "0.5" },
          { "value": "1", "label": "1" },
          { "value": "1.5", "label": "1.5" },
          { "value": "2", "label": "2" },
          { "value": "2.5", "label": "2.5" },
          { "value": "3", "label": "3" },
          { "value": "3.5", "label": "3.5" },
          { "value": "4", "label": "4" },
          { "value": "4.5", "label": "4.5" },
          { "value": "5", "label": "5" }
        ], "default": "5" },
        { "type": "text", "id": "rating_text", "label": "Optional rating text" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Bloomli - Product Picks",
      "blocks": [
        { "type": "product", "settings": { "title": "Root Ritual Capsules", "price": "$48" } },
        { "type": "product", "settings": { "title": "Root Ritual Strips", "price": "$36" } },
        { "type": "product", "settings": { "title": "Scalp Serum", "price": "$58", "badge": "Coming soon" } },
        { "type": "product", "settings": { "title": "Starter Duo", "price": "$68" } }
      ]
    }
  ]
}
{% endschema %}
