{% doc %}
  Renders a cart routine upsell card at the bottom of the drawer's scrolling content.
  State 1: supplement in cart but no add-on → upsell the add-on product.
  State 2: add-on in cart but no supplement → upsell the supplement product.
  State 3/4: both or neither → nothing renders.
  Subscription mode: if any cart item has a selling plan, swaps to "Add to subscription"
  with a one-time purchase fallback link below.
{% enddoc %}

{%- liquid
  assign routine_upsell_enabled = settings.bloomli_routine_upsell_enabled
  if routine_upsell_enabled == nil
    assign routine_upsell_enabled = false
  endif

  assign supplement_product = settings.bloomli_routine_upsell_supplement_product
  assign addon_product      = settings.bloomli_routine_upsell_addon_product

  assign supplement_tag = settings.bloomli_routine_upsell_supplement_tag | default: 'supplement' | downcase | strip
  assign addon_tag      = settings.bloomli_routine_upsell_addon_tag | default: 'add-on' | downcase | strip

  assign cart_has_supplement   = false
  assign cart_has_addon        = false
  assign cart_has_subscription = false

  for item in cart.items
    for product_tag in item.product.tags
      assign normalized_tag = product_tag | downcase | strip
      if normalized_tag == supplement_tag
        assign cart_has_supplement = true
      endif
      if normalized_tag == addon_tag
        assign cart_has_addon = true
      endif
    endfor
    if item.selling_plan_allocation != blank and cart_has_subscription == false
      assign cart_has_subscription = true
    endif
  endfor

  assign upsell_state = 0
  if cart_has_supplement and cart_has_addon == false
    assign upsell_state = 1
  elsif cart_has_addon and cart_has_supplement == false
    assign upsell_state = 2
  endif
-%}

{%- if routine_upsell_enabled
    and supplement_product != blank
    and addon_product != blank
    and upsell_state > 0
-%}
  {%- liquid
    if upsell_state == 1
      assign upsell_product      = addon_product
      assign upsell_heading      = settings.bloomli_routine_upsell_state1_heading | default: 'Complete your routine'
      assign upsell_text_template = settings.bloomli_routine_upsell_state1_text    | default: 'Add Hair Serum and unlock Pair & Save.'
      assign upsell_button       = settings.bloomli_routine_upsell_state1_button  | default: 'Add Hair Serum'
      assign upsell_has_bundle_discount = true
    else
      assign upsell_product      = supplement_product
      assign upsell_heading      = settings.bloomli_routine_upsell_state2_heading | default: 'Unlock your pairing offer'
      assign upsell_text_template = settings.bloomli_routine_upsell_state2_text    | default: 'Add Gummies to activate Pair & Save on your Hair Serum.'
      assign upsell_button       = settings.bloomli_routine_upsell_state2_button  | default: 'Add Gummies'
      assign upsell_has_bundle_discount = false
    endif

    assign upsell_variant = upsell_product.first_available_variant
    assign upsell_image   = upsell_product.featured_image

    assign upsell_compare_price = upsell_variant.compare_at_price
    if upsell_compare_price == blank or upsell_compare_price <= upsell_variant.price
      assign upsell_compare_price = 0
    endif

    assign upsell_sub_btn   = settings.bloomli_routine_upsell_sub_button | default: 'Add to subscription'
    assign upsell_otp_label = settings.bloomli_routine_upsell_otp_label  | default: 'One Time Purchase'
    assign upsell_quantity = 1

    assign upsell_selling_plan_id = nil
    if cart_has_subscription
      assign plan_filter = upsell_quantity | append: '-pack'
      assign frequency_filter = upsell_quantity | append: 'mo'
      assign frequency_filter_spaced = upsell_quantity | append: ' mo'
      assign frequency_filter_dash = upsell_quantity | append: '-mo'
      assign frequency_filter_month = upsell_quantity | append: ' month'
      assign frequency_filter_every = 'every ' | append: upsell_quantity
      assign frequency_filter_appstle = upsell_quantity | append: 'month'
      assign fallback_plan_id = nil
      for spg in upsell_product.selling_plan_groups
        assign spg_name_lower = spg.name | downcase
        if spg_name_lower contains plan_filter
          assign first_plan = spg.selling_plans | first
          if first_plan and fallback_plan_id == nil
            assign fallback_plan_id = first_plan.id
          endif

          for plan in spg.selling_plans
            assign frequency_source = spg.name | append: ' ' | append: plan.name | downcase
            for option in plan.options
              assign frequency_source = frequency_source | append: ' ' | append: option.value | downcase
            endfor

            if frequency_source contains frequency_filter or frequency_source contains frequency_filter_spaced or frequency_source contains frequency_filter_dash or frequency_source contains frequency_filter_month or frequency_source contains frequency_filter_every or frequency_source contains frequency_filter_appstle
              assign upsell_selling_plan_id = plan.id
              break
            endif
          endfor

          if upsell_selling_plan_id != nil
            break
          endif
        endif
      endfor
      if upsell_selling_plan_id == nil
        assign upsell_selling_plan_id = fallback_plan_id
      endif
    endif

    if upsell_product.metafields.bloomli.subscription_discount_pct != blank
      assign upsell_subscription_discount_pct = upsell_product.metafields.bloomli.subscription_discount_pct | plus: 0
    elsif settings.bloomli_subscription_discount_pct != blank
      assign upsell_subscription_discount_pct = settings.bloomli_subscription_discount_pct | plus: 0
    elsif settings.bloomli_routine_upsell_subscription_discount_pct != blank
      assign upsell_subscription_discount_pct = settings.bloomli_routine_upsell_subscription_discount_pct | plus: 0
    else
      assign upsell_subscription_discount_pct = 20
    endif

    if upsell_product.metafields.bloomli.bundle_add_on_discount_pct != blank
      assign upsell_bundle_discount_pct = upsell_product.metafields.bloomli.bundle_add_on_discount_pct | plus: 0
    elsif settings.bloomli_routine_upsell_addon_discount_pct != blank
      assign upsell_bundle_discount_pct = settings.bloomli_routine_upsell_addon_discount_pct | plus: 0
    elsif settings.bloomli_bundle_add_on_discount_pct != blank
      assign upsell_bundle_discount_pct = settings.bloomli_bundle_add_on_discount_pct | plus: 0
    else
      assign upsell_bundle_discount_pct = 15
    endif

    assign upsell_volume_discount_pct = 0
    assign upsell_bundle_factor = 100.0
    if upsell_has_bundle_discount
      assign upsell_bundle_factor = 100.0 | minus: upsell_bundle_discount_pct
    endif
    assign upsell_sale_unit_price = upsell_variant.price
    if upsell_has_bundle_discount
      assign upsell_sale_unit_price = upsell_sale_unit_price | times: upsell_bundle_factor | divided_by: 100.0 | round
    endif
    assign upsell_sale_price = upsell_sale_unit_price | times: upsell_quantity
    assign upsell_sale_discount_pct = upsell_variant.price | minus: upsell_sale_unit_price | times: 100.0 | divided_by: upsell_variant.price | floor

    if cart_has_subscription and upsell_selling_plan_id != nil
      assign upsell_subscription_factor = 100.0 | minus: upsell_subscription_discount_pct
      if upsell_has_bundle_discount
        assign upsell_sub_unit_price = upsell_variant.price | times: upsell_subscription_factor | times: upsell_bundle_factor | divided_by: 10000.0 | round
      else
        assign upsell_sub_unit_price = upsell_variant.price | times: upsell_subscription_factor | divided_by: 100.0 | round
      endif
      assign upsell_sub_price = upsell_sub_unit_price | times: upsell_quantity
      assign upsell_sub_discount_pct = upsell_variant.price | minus: upsell_sub_unit_price | times: 100.0 | divided_by: upsell_variant.price | floor
    else
      assign upsell_sub_price = 0
      assign upsell_sub_discount_pct = 0
    endif
  -%}

  {%- if upsell_variant != blank -%}
    {%- assign show_subscription = false -%}
    {%- if cart_has_subscription and upsell_selling_plan_id and upsell_sub_price > 0 -%}
      {%- assign show_subscription = true -%}
    {%- endif -%}
    {%- liquid
      if show_subscription
        assign upsell_display_discount_pct = upsell_sub_discount_pct
      else
        assign upsell_display_discount_pct = upsell_sale_discount_pct
      endif
      assign upsell_text = upsell_text_template

      assign upsell_display_compare_price = upsell_compare_price
      if upsell_display_compare_price > 0
        assign upsell_display_compare_price = upsell_display_compare_price | times: upsell_quantity
      endif
      assign upsell_base_total_price = upsell_variant.price | times: upsell_quantity
      if show_subscription and upsell_sub_price < upsell_base_total_price
        assign upsell_display_compare_price = upsell_base_total_price
      elsif show_subscription == false and upsell_sale_price < upsell_base_total_price
        assign upsell_display_compare_price = upsell_base_total_price
      endif
    -%}
    <div
      class="bloomli-routine-upsell"
      data-bloomli-routine-upsell
      data-state="{{ upsell_state }}"
      data-discount-pct="{{ upsell_display_discount_pct }}"
      data-discount-price-cents="{% if show_subscription %}{{ upsell_sub_price }}{% else %}{{ upsell_sale_price }}{% endif %}"
      data-subscription-discount-pct="{{ upsell_subscription_discount_pct }}"
      data-volume-discount-pct="{{ upsell_volume_discount_pct }}"
      data-bundle-discount-pct="{% if upsell_has_bundle_discount %}{{ upsell_bundle_discount_pct }}{% else %}0{% endif %}"
    >
      <div class="bloomli-routine-upsell__inner">
        {%- if upsell_image != blank -%}
          <div class="bloomli-routine-upsell__image-wrap">
            {{
              upsell_image
              | image_url: width: 248
              | image_tag:
                class: 'bloomli-routine-upsell__image',
                loading: 'lazy',
                alt: upsell_image.alt | default: upsell_product.title,
                width: 124,
                height: 124,
                widths: '124, 248'
            }}
          </div>
        {%- endif -%}
        <div class="bloomli-routine-upsell__content">
          <p class="bloomli-routine-upsell__heading">{{ upsell_heading | escape }}</p>
          <p class="bloomli-routine-upsell__title">{{ upsell_product.title | escape }}</p>
          <p class="bloomli-routine-upsell__text">{{ upsell_text | escape }}</p>
          <div class="bloomli-routine-upsell__prices">
            {%- if show_subscription -%}
              {%- if upsell_display_compare_price > upsell_sub_price -%}
                <s class="bloomli-routine-upsell__compare-price">{{ upsell_display_compare_price | money }}</s>
              {%- endif -%}
              <span class="bloomli-routine-upsell__price">{{ upsell_sub_price | money }}</span>
            {%- else -%}
              {%- if upsell_display_compare_price > upsell_sale_price -%}
                <s class="bloomli-routine-upsell__compare-price">{{ upsell_display_compare_price | money }}</s>
              {%- endif -%}
              <span class="bloomli-routine-upsell__price">{{ upsell_sale_price | money }}</span>
            {%- endif -%}
          </div>
        </div>
      </div>
      {%- if show_subscription -%}
        <button
          type="button"
          class="bloomli-routine-upsell__btn"
          data-bloomli-routine-upsell-btn
          data-variant-id="{{ upsell_variant.id }}"
          data-selling-plan-id="{{ upsell_selling_plan_id }}"
          data-quantity="{{ upsell_quantity }}"
          aria-label="{{ upsell_sub_btn | escape }}: {{ upsell_product.title | escape }}"
        >
          <span class="bloomli-routine-upsell__btn-text">{{ upsell_sub_btn | escape }}</span>
        </button>
        <div class="bloomli-routine-upsell__otp">
          <button
            type="button"
            class="bloomli-routine-upsell__otp-btn"
            data-bloomli-routine-upsell-otp-btn
            data-variant-id="{{ upsell_variant.id }}"
            data-quantity="{{ upsell_quantity }}"
            aria-label="{{ upsell_otp_label | escape }}: {{ upsell_product.title | escape }}"
          >
            <span>{{- upsell_otp_label | escape -}} · {{ upsell_sale_price | money }}</span>
          </button>
        </div>
      {%- else -%}
        <button
          type="button"
          class="bloomli-routine-upsell__btn"
          data-bloomli-routine-upsell-btn
          data-variant-id="{{ upsell_variant.id }}"
          data-quantity="{{ upsell_quantity }}"
          aria-label="{{ upsell_button | escape }}: {{ upsell_product.title | escape }}"
        >
          <span class="bloomli-routine-upsell__btn-text">{{ upsell_button | escape }}</span>
        </button>
      {%- endif -%}
    </div>
  {%- endif -%}
{%- endif -%}
