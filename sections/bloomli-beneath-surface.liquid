{{ 'bloomli-faq.css' | asset_url | stylesheet_tag }}
{{ 'bloomli-beneath-surface.css' | asset_url | stylesheet_tag }}
<script src="{{ 'bloomli-beneath-surface.js' | asset_url }}" defer="defer"></script>
<script src="{{ 'bloomli-faq.js' | asset_url }}" defer="defer"></script>

{%- liquid
  assign section_id = 'BloomliBeneathSurface-' | append: section.id
  assign row_background_color = section.settings.row_background_color | default: '#FAF5F3'
  assign content_card_background_color = section.settings.content_card_background_color | default: '#FAF5F3'
-%}

<section
  id="{{ section_id }}"
  class="bloomli-beneath-surface color-{{ section.settings.color_scheme }} gradient"
  style="
    --section-padding-top: {{ section.settings.padding_top }}px;
    --section-padding-bottom: {{ section.settings.padding_bottom }}px;
    --section-padding-top-mobile: {{ section.settings.padding_top_mobile }}px;
    --section-padding-bottom-mobile: {{ section.settings.padding_bottom_mobile }}px;
  "
  style="--bloomli-beneath-row-background: {{ row_background_color }}; --bloomli-beneath-content-card-background: {{ content_card_background_color }};"
  data-bloomli-beneath-surface
>
  <div class="page-width">
    <div class="bloomli-beneath-surface__header">
      {%- if section.settings.heading != blank -%}
        <h2 class="bloomli-beneath-surface__heading h1">
          {{ section.settings.heading | escape }}
        </h2>
      {%- endif -%}

      {%- if section.settings.subtext != blank -%}
        <div class="bloomli-beneath-surface__subtext rte">
          {{ section.settings.subtext }}
        </div>
      {%- endif -%}
    </div>

    {%- if section.blocks.size > 0 -%}
      <div class="bloomli-beneath-surface__desktop" data-bbs-desktop>
        <div class="bloomli-beneath-surface__tabs" role="tablist" aria-label="Hair concerns">
          {%- for block in section.blocks -%}
            {%- liquid
              assign tab_id = section_id | append: '-tab-' | append: forloop.index
              assign panel_id = section_id | append: '-panel-' | append: forloop.index
            -%}
            <button
              id="{{ tab_id }}"
              class="bloomli-beneath-surface__tab{% if forloop.first %} is-active{% endif %}"
              type="button"
              role="tab"
              aria-selected="{% if forloop.first %}true{% else %}false{% endif %}"
              aria-controls="{{ panel_id }}"
              tabindex="{% if forloop.first %}0{% else %}-1{% endif %}"
              data-bbs-tab
              data-bbs-index="{{ forloop.index0 }}"
              {{ block.shopify_attributes }}
            >
              <span class="bloomli-beneath-surface__tab-copy">
                <span class="bloomli-beneath-surface__tab-title">{{ block.settings.title | escape }}</span>
                {%- if block.settings.subtitle != blank -%}
                  <span class="bloomli-beneath-surface__tab-subtitle">{{ block.settings.subtitle | escape }}</span>
                {%- endif -%}
              </span>
              <span class="bloomli-beneath-surface__tab-arrow" aria-hidden="true">
                <i class="ti ti-chevron-right"></i>
              </span>
            </button>
          {%- endfor -%}
        </div>

        <div class="bloomli-beneath-surface__panels">
          {%- for block in section.blocks -%}
            {%- liquid
              assign tab_id = section_id | append: '-tab-' | append: forloop.index
              assign panel_id = section_id | append: '-panel-' | append: forloop.index
            -%}
            <article
              id="{{ panel_id }}"
              class="bloomli-beneath-surface__panel{% if forloop.first %} is-active{% endif %}"
              role="tabpanel"
              aria-labelledby="{{ tab_id }}"
              data-bbs-panel
              data-bbs-index="{{ forloop.index0 }}"
              {% unless forloop.first %}
                hidden
              {% endunless %}
            >
              <div class="bloomli-beneath-surface__panel-copy">
                <h3 class="bloomli-beneath-surface__panel-title h2">{{ block.settings.title | escape }}</h3>
                <p class="bloomli-beneath-surface__eyebrow">{{ block.settings.subtitle | escape }}</p>

                <div class="bloomli-beneath-surface__explain-grid">
                  <div class="bloomli-beneath-surface__explain">
                    <h4 class="bloomli-beneath-surface__explain-heading">What may be happening</h4>
                    <p>{{ block.settings.what_text | escape }}</p>
                  </div>
                  <div class="bloomli-beneath-surface__explain">
                    <h4 class="bloomli-beneath-surface__explain-heading">How Bloomli supports it</h4>
                    <p>{{ block.settings.how_text | escape }}</p>
                  </div>
                </div>
              </div>
            </article>
          {%- endfor -%}
        </div>
      </div>

      <div class="bloomli-beneath-surface__mobile bloomli-faq__items" data-bbs-mobile data-bloomli-faq>
        {%- for block in section.blocks -%}
          {%- liquid
            assign mobile_button_id = section_id | append: '-mobile-button-' | append: forloop.index
            assign mobile_panel_id = section_id | append: '-mobile-panel-' | append: forloop.index
          -%}
          <article class="bloomli-faq__item bloomli-beneath-surface__mobile-item" {{ block.shopify_attributes }}>
            <button
              id="{{ mobile_button_id }}"
              class="bloomli-faq__question bloomli-beneath-surface__mobile-question"
              type="button"
              aria-expanded="{% if forloop.first %}true{% else %}false{% endif %}"
              aria-controls="{{ mobile_panel_id }}"
              data-bloomli-faq-button
            >
              <span class="bloomli-beneath-surface__accordion-copy">
                <span class="bloomli-beneath-surface__tab-title">{{ block.settings.title | escape }}</span>
                {%- if block.settings.subtitle != blank -%}
                  <span class="bloomli-beneath-surface__tab-subtitle">{{ block.settings.subtitle | escape }}</span>
                {%- endif -%}
              </span>
              <span class="bloomli-faq__plus" aria-hidden="true"></span>
            </button>

            <div
              id="{{ mobile_panel_id }}"
              class="bloomli-faq__panel"
              role="region"
              aria-labelledby="{{ mobile_button_id }}"
              {% unless forloop.first %}
                hidden
              {% endunless %}
            >
              <div class="bloomli-faq__panel-inner bloomli-beneath-surface__mobile-panel-inner">
                <div class="bloomli-beneath-surface__explain">
                  <h4 class="bloomli-beneath-surface__explain-heading">What may be happening</h4>
                  <p>{{ block.settings.what_text | escape }}</p>
                </div>
                <div class="bloomli-beneath-surface__explain">
                  <h4 class="bloomli-beneath-surface__explain-heading">How Bloomli supports it</h4>
                  <p>{{ block.settings.how_text | escape }}</p>
                </div>
              </div>
            </div>
          </article>
        {%- endfor -%}
      </div>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Bloomli - Beneath Surface",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-6d8ba907-aae6-4c49-9120-e1031d9cdb3f"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "What’s happening to your hair starts beneath the surface."
    },
    {
      "type": "richtext",
      "id": "subtext",
      "label": "Subtext",
      "default": "<p>Tap each concern to see what may be affecting your hair — and how Bloomli supports your routine from the inside out.</p>"
    },
    {
      "type": "color",
      "id": "row_background_color",
      "label": "Concern row background",
      "default": "#FAF5F3"
    },
    {
      "type": "color",
      "id": "content_card_background_color",
      "label": "Content card background",
      "default": "#FAF5F3"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "min": 0,
      "max": 120,
      "step": 8,
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "min": 0,
      "max": 120,
      "step": 8,
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "label": "Padding top mobile",
      "min": 0,
      "max": 120,
      "step": 8,
      "default": 56
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "label": "Padding bottom mobile",
      "min": 0,
      "max": 120,
      "step": 8,
      "default": 56
    }
  ],
  "blocks": [
    {
      "type": "concern",
      "name": "Concern",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Nutrient gaps"
        },
        {
          "type": "text",
          "id": "subtitle",
          "label": "Subtitle",
          "default": "Daily support from within"
        },
        {
          "type": "textarea",
          "id": "what_text",
          "label": "What may be happening",
          "default": "Hair follicles rely on steady nutrients to support the normal growth cycle. When your routine is inconsistent, hair can look weaker, thinner, or more fragile."
        },
        {
          "type": "textarea",
          "id": "how_text",
          "label": "How Bloomli supports it",
          "default": "Bloomli gummies provide daily beauty nutrients chosen to support hair from within - helping your routine stay simple and consistent."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Bloomli - Beneath Surface",
      "blocks": [
        {
          "type": "concern",
          "settings": {
            "title": "Nutrient gaps",
            "subtitle": "Daily support from within",
            "what_text": "Hair follicles rely on steady nutrients to support the normal growth cycle. When your routine is inconsistent, hair can look weaker, thinner, or more fragile.",
            "how_text": "Bloomli gummies provide daily beauty nutrients chosen to support hair from within - helping your routine stay simple and consistent."
          }
        },
        {
          "type": "concern",
          "settings": {
            "title": "Shedding",
            "subtitle": "When hair feels less full",
            "what_text": "Shedding can make hair feel thinner before visible density changes. Consistency matters because hair changes slowly over time.",
            "how_text": "Bloomli supports your daily hair wellness routine with nutrients that help nourish follicles from within."
          }
        },
        {
          "type": "concern",
          "settings": {
            "title": "Breakage",
            "subtitle": "When strands feel fragile",
            "what_text": "When strands become dry or fragile, hair can look thinner through the lengths even when growth is still happening at the root.",
            "how_text": "Bloomli supports stronger-feeling strands from within, while hair serum helps nourish lengths and ends from the outside."
          }
        },
        {
          "type": "concern",
          "settings": {
            "title": "Scalp environment",
            "subtitle": "The foundation of the ritual",
            "what_text": "Your scalp is the foundation for fuller-looking hair. Dryness, buildup, and imbalance can make your routine feel less effective.",
            "how_text": "Pair daily nutrients with botanical scalp care to support the full inside-out and outside-in ritual."
          }
        },
        {
          "type": "concern",
          "settings": {
            "title": "Lifestyle stress",
            "subtitle": "When life shows up in your hair",
            "what_text": "Busy seasons, stress, styling, and inconsistent routines can all affect how your hair looks and feels over time.",
            "how_text": "Bloomli keeps hair wellness simple with an easy daily ritual designed to fit into real life."
          }
        }
      ]
    }
  ]
}
{% endschema %}
