{% doc %}
Renders a Bloomli trust icon.

@param {string} icon - The icon to render.

@example
{% render 'icon-bloomli-trust', icon: 'shield' %}
{% enddoc %}

{%- case icon -%}
  {%- when 'truck' -%}
    <svg
      class="bloomli-trust-icons__svg"
      xmlns="http://www.w3.org/2000/svg"
      width="64"
      height="64"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="1.55"
      stroke-linecap="round"
      stroke-linejoin="round"
      aria-hidden="true"
      focusable="false"
    >
      <path d="M3.75 6.75A1.25 1.25 0 0 1 5 5.5h9.25v12.25H9.7" />
      <path d="M14.25 9.25h3.95c.42 0 .81.21 1.05.56l1.9 2.78c.14.21.22.45.22.7v4.46H19.3" />
      <path d="M14.25 17.75h-4.5" />
      <path d="M5.55 17.75h-1.8v-4.5" />
      <path d="M16.75 11.35h3.15" />
      <circle cx="7.55" cy="17.75" r="1.9" />
      <circle cx="17.45" cy="17.75" r="1.9" />
    </svg>
  {%- when 'cancel' -%}
    <svg
      class="bloomli-trust-icons__svg"
      xmlns="http://www.w3.org/2000/svg"
      width="64"
      height="64"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="1.55"
      stroke-linecap="round"
      stroke-linejoin="round"
      aria-hidden="true"
      focusable="false"
    >
      <circle cx="12" cy="12" r="8.65" />
      <path d="M9.75 9.35v5.3" />
      <path d="M14.25 9.35v5.3" />
    </svg>
  {%- else -%}
    <svg
      class="bloomli-trust-icons__svg"
      xmlns="http://www.w3.org/2000/svg"
      width="64"
      height="64"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="1.55"
      stroke-linecap="round"
      stroke-linejoin="round"
      aria-hidden="true"
      focusable="false"
    >
      <path d="M12 3.35 18.65 6v5.1c0 4.1-2.43 7.15-6.65 9.05-4.22-1.9-6.65-4.95-6.65-9.05V6L12 3.35Z" />
      <path d="m9.05 12.1 1.9 1.9 4.15-4.35" />
    </svg>
{%- endcase -%}
