{% doc %}
  Renders a repeated product image stack for bundle and quantity visuals.

  @param {image} [image] - Preferred image object.
  @param {product} [product] - Fallback product object.
  @param {number} [count] - Number of items to visualize, capped at 3.
  @param {string} [alt] - Optional alt text.
  @param {string} [class] - Optional additional class.
  @param {number} [width] - Optional image request width.

  @example
  {% render 'bloomli-product-image-stack', product: product, count: 3 %}
{% enddoc %}

{%- liquid
  assign stack_count = count | default: 1 | plus: 0
  if stack_count < 1
    assign stack_count = 1
  endif
  if stack_count > 3
    assign stack_count = 3
  endif

  assign stack_image = image
  if stack_image == blank and product != blank
    assign stack_image = product.featured_image
  endif

  assign image_width = width | default: 420
  assign stack_alt = alt
  if stack_alt == blank and stack_image != blank
    assign stack_alt = stack_image.alt
  endif
  if stack_alt == blank and product != blank
    assign stack_alt = product.title
  endif
-%}

<div class="bloomli-product-stack bloomli-product-stack--{{ stack_count }}{% if class != blank %} {{ class }}{% endif %}">
  {%- if stack_image != blank -%}
    {%- for image_index in (1..stack_count) -%}
      {{
        stack_image
        | image_url: width: image_width
        | image_tag:
          class: 'bloomli-product-stack__image',
          alt: stack_alt,
          loading: 'lazy', decoding: 'async',
          widths: '180, 280, 420',
          sizes: '(max-width: 749px) 42vw, 180px'
      }}
    {%- endfor -%}
  {%- else -%}
    <span class="bloomli-product-stack__placeholder" aria-hidden="true"></span>
  {%- endif -%}
</div>
