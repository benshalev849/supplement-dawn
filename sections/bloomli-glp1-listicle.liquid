{{ 'bloomli-glp1-editorial.css' | asset_url | stylesheet_tag }}

<section
  id="glp1-why"
  class="bloomli-glp1-listicle bloomli-glp1-listicle--{{ section.settings.first_media_side }} color-{{ section.settings.color_scheme }} gradient"
  data-bloomli-glp1-listicle
  style="
    --glp1-accent: {{ section.settings.accent_color }};
    --glp1-emphasis: {{ section.settings.emphasis_color }};
    --glp1-media: {{ section.settings.media_background }};
    --glp1-callout: {{ section.settings.callout_background }};
    --glp1-radius: {{ section.settings.media_radius }}px;
    --glp1-max-width: {{ section.settings.max_width }}rem;
    --glp1-heading: {{ section.settings.heading_size }}px;
    --glp1-heading-mobile: {{ section.settings.heading_size_mobile }}px;
    --glp1-padding-top: {{ section.settings.padding_top }}px;
    --glp1-padding-bottom: {{ section.settings.padding_bottom }}px;
    --glp1-padding-top-mobile: {{ section.settings.padding_top_mobile }}px;
    --glp1-padding-bottom-mobile: {{ section.settings.padding_bottom_mobile }}px;
  "
>
  <div class="bloomli-glp1-listicle__inner">
    {%- if section.settings.heading != blank or section.settings.intro != blank -%}
      <header class="bloomli-glp1-listicle__header">
        {%- if section.settings.heading != blank -%}
          <h2 class="bloomli-glp1-listicle__title">{{ section.settings.heading }}</h2>
        {%- endif -%}
        {%- if section.settings.intro != blank -%}
          <p class="bloomli-glp1-listicle__intro">{{ section.settings.intro }}</p>
        {%- endif -%}
      </header>
    {%- endif -%}

    <div class="bloomli-glp1-listicle__items">
      {%- assign reason_index = 0 -%}
      {%- for block in section.blocks -%}
        {%- case block.type -%}
          {%- when 'reason' -%}
            {%- assign reason_index = reason_index | plus: 1 -%}
            {%- assign reason_number = block.settings.number -%}
            {%- if reason_number == blank -%}
              {%- if reason_index < 10 -%}
                {%- assign reason_number = reason_index | prepend: '0' -%}
              {%- else -%}
                {%- assign reason_number = reason_index -%}
              {%- endif -%}
            {%- endif -%}
            <article class="bloomli-glp1-listicle__reason" data-bloomli-reveal {{ block.shopify_attributes }}>
              <div class="bloomli-glp1-listicle__media bloomli-glp1-listicle__media--{{ section.settings.media_ratio }}">
                {%- if block.settings.image != blank -%}
                  {{
                    block.settings.image
                    | image_url: width: 1400
                    | image_tag:
                      widths: '420, 640, 840, 1100, 1400',
                      sizes: '(min-width: 990px) 48vw, (min-width: 750px) 50vw, 100vw',
                      loading: 'lazy',
                      alt: block.settings.image.alt | default: block.settings.title
                  }}
                {%- else -%}
                  <div class="bloomli-glp1-listicle__placeholder" aria-hidden="true">
                    <span class="bloomli-glp1-listicle__placeholder-number">{{ reason_number }}</span>
                  </div>
                {%- endif -%}
              </div>
              <div class="bloomli-glp1-listicle__copy">
                <span class="bloomli-glp1-listicle__index" aria-hidden="true">{{ reason_number }}</span>
                {%- if block.settings.title != blank -%}
                  <h3 class="bloomli-glp1-listicle__reason-title">{{ block.settings.title }}</h3>
                {%- endif -%}
                {%- if block.settings.body != blank -%}
                  <div class="bloomli-glp1-listicle__body rte">{{ block.settings.body }}</div>
                {%- endif -%}
              </div>
            </article>

          {%- when 'callout' -%}
            <aside class="bloomli-glp1-listicle__callout" data-bloomli-reveal {{ block.shopify_attributes }}>
              {%- if block.settings.show_icon -%}
                <span class="bloomli-glp1-listicle__callout-icon" aria-hidden="true">
                  <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M12 3l8 3v6c0 5-3.5 8.5-8 10-4.5-1.5-8-5-8-10V6l8-3z"/>
                    <path d="M9 12l2 2 4-4"/>
                  </svg>
                </span>
              {%- endif -%}
              <div>
                {%- if block.settings.heading != blank -%}
                  <h3 class="bloomli-glp1-listicle__callout-title">{{ block.settings.heading }}</h3>
                {%- endif -%}
                {%- if block.settings.body != blank -%}
                  <div class="bloomli-glp1-listicle__callout-body rte">{{ block.settings.body }}</div>
                {%- endif -%}
              </div>
            </aside>
        {%- endcase -%}
      {%- endfor -%}
    </div>
  </div>
</section>

{%- if section.settings.enable_reveal -%}
  <script src="{{ 'bloomli-glp1-reveal.js' | asset_url }}" defer="defer"></script>
{%- endif -%}

{% schema %}
{
  "name": "Bloomli GLP-1 listicle",
  "tag": "section",
  "class": "section",
  "enabled_on": { "templates": ["page", "product"] },
  "max_blocks": 6,
  "settings": [
    { "type": "color_scheme", "id": "color_scheme", "label": "Color scheme", "default": "scheme-1" },
    { "type": "inline_richtext", "id": "heading", "label": "Heading", "default": "Why women on a GLP-1 add Bloomli <em>to their routine.</em>" },
    { "type": "textarea", "id": "intro", "label": "Introduction", "default": "Five clear reasons, without fear tactics or overnight promises." },
    { "type": "select", "id": "first_media_side", "label": "First image side", "options": [
      { "value": "media-first", "label": "Left" },
      { "value": "reverse", "label": "Right" }
    ], "default": "media-first" },
    { "type": "select", "id": "media_ratio", "label": "Image ratio", "options": [
      { "value": "portrait", "label": "Portrait" },
      { "value": "landscape", "label": "Landscape" }
    ], "default": "landscape" },
    { "type": "range", "id": "media_radius", "label": "Image corner radius", "min": 12, "max": 36, "step": 2, "default": 28, "unit": "px" },
    { "type": "range", "id": "max_width", "label": "Content width", "min": 88, "max": 120, "step": 4, "default": 112, "unit": "rem" },
    { "type": "checkbox", "id": "enable_reveal", "label": "Enable subtle scroll reveal", "default": true },
    { "type": "header", "content": "Optional custom colors" },
    { "type": "color", "id": "accent_color", "label": "Numbers and accent", "default": "#B23A6F" },
    { "type": "color", "id": "emphasis_color", "label": "Emphasis", "default": "#7B2151" },
    { "type": "color", "id": "media_background", "label": "Empty image background", "default": "#F5EDE4" },
    { "type": "color", "id": "callout_background", "label": "Callout background", "default": "#F3E1E5" },
    { "type": "header", "content": "Typography" },
    { "type": "range", "id": "heading_size", "label": "Heading size desktop", "min": 36, "max": 72, "step": 2, "default": 56, "unit": "px" },
    { "type": "range", "id": "heading_size_mobile", "label": "Heading size mobile", "min": 30, "max": 46, "step": 2, "default": 38, "unit": "px" },
    { "type": "header", "content": "Spacing" },
    { "type": "range", "id": "padding_top", "min": 0, "max": 160, "step": 8, "unit": "px", "label": "Padding top", "default": 96 },
    { "type": "range", "id": "padding_bottom", "min": 0, "max": 160, "step": 8, "unit": "px", "label": "Padding bottom", "default": 112 },
    { "type": "range", "id": "padding_top_mobile", "min": 0, "max": 120, "step": 8, "unit": "px", "label": "Padding top mobile", "default": 64 },
    { "type": "range", "id": "padding_bottom_mobile", "min": 0, "max": 120, "step": 8, "unit": "px", "label": "Padding bottom mobile", "default": 72 }
  ],
  "blocks": [
    {
      "type": "reason",
      "name": "Reason",
      "limit": 5,
      "settings": [
        { "type": "text", "id": "number", "label": "Number override" },
        { "type": "image_picker", "id": "image", "label": "Image" },
        { "type": "text", "id": "title", "label": "Title", "default": "Reason title" },
        { "type": "richtext", "id": "body", "label": "Body", "default": "<p>Describe this reason in clear, measured language.</p>" }
      ]
    },
    {
      "type": "callout",
      "name": "Provider reassurance",
      "limit": 1,
      "settings": [
        { "type": "checkbox", "id": "show_icon", "label": "Show icon", "default": true },
        { "type": "text", "id": "heading", "label": "Heading", "default": "Keep your provider in the loop." },
        { "type": "richtext", "id": "body", "label": "Body", "default": "<p>If shedding concerns you, talk to your healthcare provider. Bloomli is a nutritional supplement, not medical advice.</p>" }
      ]
    }
  ],
  "presets": [{
    "name": "Bloomli GLP-1 listicle",
    "blocks": [
      { "type": "reason" },
      { "type": "reason" },
      { "type": "reason" },
      { "type": "reason" },
      { "type": "reason" },
      { "type": "callout" }
    ]
  }]
}
{% endschema %}
