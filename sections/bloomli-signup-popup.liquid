{%- liquid
  assign popup_visible = false
  if section.settings.enabled and request.page_type != 'checkout'
    assign popup_visible = true
  endif

  assign form_id = 'BloomliSignupPopupForm-' | append: section.id
  assign email_id = 'BloomliSignupPopupEmail-' | append: section.id
  assign title_id = 'BloomliSignupPopupTitle-' | append: section.id
  assign error_id = 'BloomliSignupPopupError-' | append: section.id
  assign success_id = 'BloomliSignupPopupSuccess-' | append: section.id
  assign popup_logo = section.settings.logo_image | default: settings.logo
  assign primary_image = section.settings.image_desktop | default: section.settings.image_mobile
-%}

{%- if popup_visible -%}
  {{ 'bloomli-signup-popup.css' | asset_url | stylesheet_tag }}
  <script src="{{ 'bloomli-signup-popup.js' | asset_url }}" defer="defer"></script>

  <div
    class="bloomli-signup-popup color-{{ section.settings.color_scheme }} gradient"
    data-bloomli-signup-popup
    data-delay-seconds="{{ section.settings.delay_seconds }}"
    data-close-cooldown-days="{{ section.settings.close_cooldown_days }}"
    data-submit-cooldown-days="{{ section.settings.submit_cooldown_days }}"
    data-show-launcher="{{ section.settings.show_launcher_after_close }}"
    data-customer-marketing="{% if customer and customer.accepts_marketing %}true{% else %}false{% endif %}"
    data-custom-colors="{{ section.settings.enable_custom_colors }}"
    data-popup-background="{{ section.settings.popup_background_color }}"
    data-popup-text="{{ section.settings.popup_text_color }}"
    data-option-background="{{ section.settings.option_button_background_color }}"
    data-option-text="{{ section.settings.option_button_text_color }}"
    data-padding-mobile="{{ section.settings.content_padding_mobile }}"
    data-padding-desktop="{{ section.settings.content_padding_desktop }}"
  >
    <div class="bloomli-signup-popup__modal" data-bloomli-popup-modal hidden>
      <div
        class="bloomli-signup-popup__dialog bloomli-signup-popup__dialog--media-{{ section.settings.image_position_desktop }}{% unless section.settings.show_image %} bloomli-signup-popup__dialog--no-media{% endunless %}"
        role="dialog"
        aria-modal="true"
        aria-labelledby="{{ title_id }}"
        tabindex="-1"
      >
        <button
          class="bloomli-signup-popup__close"
          type="button"
          aria-label="{{ section.settings.close_button_label | escape }}"
          data-bloomli-popup-close
        >
          {{- 'icon-close.svg' | inline_asset_content -}}
        </button>

        <div class="bloomli-signup-popup__content">
          <div class="bloomli-signup-popup__logo">
            {%- if popup_logo != blank -%}
              {{
                popup_logo
                | image_url: width: 360
                | image_tag:
                  class: 'bloomli-signup-popup__logo-image',
                  loading: 'lazy',
                  widths: '120, 180, 240, 360',
                  sizes: '(max-width: 749px) 150px, 180px'
              }}
            {%- elsif section.settings.logo_text != blank -%}
              <span class="bloomli-signup-popup__logo-text">{{ section.settings.logo_text | escape }}</span>
            {%- endif -%}
          </div>

          <h2
            class="bloomli-signup-popup__title"
            id="{{ title_id }}"
          >
            <span
              data-bloomli-popup-title-line
              data-title-step-one="{{ section.settings.headline_step_1 | escape }}"
              data-title-step-two="{{ section.settings.headline_step_2 | escape }}"
            >
              {{- section.settings.headline_step_1 | escape -}}
            </span>
            <span
              data-bloomli-popup-title-line
              data-title-step-one="{{ section.settings.discount_line_step_1 | escape }}"
              data-title-step-two="{{ section.settings.discount_line_step_2 | escape }}"
            >
              {{- section.settings.discount_line_step_1 | escape -}}
            </span>
          </h2>

          <div class="bloomli-signup-popup__steps" data-bloomli-popup-steps>
            <div class="bloomli-signup-popup__step bloomli-signup-popup__step--one" data-bloomli-popup-step="1">
              <p class="bloomli-signup-popup__text">{{ section.settings.subheading_step_1 | escape }}</p>

              <div class="bloomli-signup-popup__options" aria-label="{{ section.settings.options_group_label | escape }}">
                <button type="button" class="bloomli-signup-popup__option" data-bloomli-popup-option data-concern-handle="{{ section.settings.problem_option_1_handle | handle | escape }}">
                  {{ section.settings.problem_option_1_label | escape }}
                </button>
                <button type="button" class="bloomli-signup-popup__option" data-bloomli-popup-option data-concern-handle="{{ section.settings.problem_option_2_handle | handle | escape }}">
                  {{ section.settings.problem_option_2_label | escape }}
                </button>
                <button type="button" class="bloomli-signup-popup__option" data-bloomli-popup-option data-concern-handle="{{ section.settings.problem_option_3_handle | handle | escape }}">
                  {{ section.settings.problem_option_3_label | escape }}
                </button>
                <button type="button" class="bloomli-signup-popup__option" data-bloomli-popup-option data-concern-handle="{{ section.settings.problem_option_4_handle | handle | escape }}">
                  {{ section.settings.problem_option_4_label | escape }}
                </button>
              </div>

              <button class="bloomli-signup-popup__decline" type="button" data-bloomli-popup-decline>
                {{ section.settings.no_thanks_text | escape }}
              </button>
            </div>

            <div
              class="bloomli-signup-popup__step bloomli-signup-popup__step--two"
              data-bloomli-popup-step="2"
              aria-hidden="true"
            >
              <p class="bloomli-signup-popup__text">{{ section.settings.body_step_2 | escape }}</p>

              {%- form 'customer', id: form_id, class: 'bloomli-signup-popup__form' -%}
                <div
                  data-bloomli-popup-form-state="{% if form.posted_successfully? %}success{% elsif form.errors %}error{% else %}idle{% endif %}"
                >
                  <input type="hidden" name="contact[tags]" value="newsletter,bloomli-popup" data-bloomli-popup-tags>
                  <label class="visually-hidden" for="{{ email_id }}">{{ section.settings.email_placeholder | escape }}</label>
                  <input
                    class="bloomli-signup-popup__email"
                    id="{{ email_id }}"
                    type="email"
                    name="contact[email]"
                    value="{{ form.email }}"
                    autocorrect="off"
                    autocapitalize="off"
                    autocomplete="email"
                    aria-required="true"
                    {% if form.errors %}
                      aria-invalid="true"
                      aria-describedby="{{ error_id }}"
                    {% endif %}
                    placeholder="{{ section.settings.email_placeholder | escape }}"
                    required
                    data-bloomli-popup-email
                  >
                  <button class="bloomli-signup-popup__submit" type="submit" name="commit">
                    {{ section.settings.submit_button_label | escape }}
                  </button>

                  {%- if form.errors -%}
                    <small class="bloomli-signup-popup__message bloomli-signup-popup__message--error" id="{{ error_id }}">
                      {{- form.errors.translated_fields.email | capitalize }} {{ form.errors.messages.email -}}
                    </small>
                  {%- endif -%}
                </div>
              {%- endform -%}
            </div>
          </div>
        </div>

        {%- if section.settings.show_image -%}
          <div class="bloomli-signup-popup__media">
            {%- if primary_image != blank -%}
              <picture>
                {%- if section.settings.image_mobile != blank -%}
                  <source
                    media="(max-width: 749px)"
                    srcset="
                      {{ section.settings.image_mobile | image_url: width: 480 }} 480w,
                      {{ section.settings.image_mobile | image_url: width: 750 }} 750w,
                      {{ section.settings.image_mobile | image_url: width: 1100 }} 1100w
                    "
                    sizes="100vw"
                  >
                {%- endif -%}
                {{
                  primary_image
                  | image_url: width: 1800
                  | image_tag:
                    class: 'bloomli-signup-popup__image',
                    loading: 'lazy',
                    widths: '480, 750, 1100, 1500, 1800',
                    sizes: '(min-width: 750px) 50vw, 100vw'
                }}
              </picture>
            {%- else -%}
              <div class="bloomli-signup-popup__image-placeholder" aria-hidden="true"></div>
            {%- endif -%}
          </div>
        {%- endif -%}
      </div>
    </div>

    <div class="bloomli-signup-popup__launcher" data-bloomli-popup-launcher hidden>
      <button
        class="bloomli-signup-popup__launcher-close"
        type="button"
        aria-label="{{ section.settings.launcher_close_button_label | escape }}"
        data-bloomli-popup-launcher-close
      >
        {{- 'icon-close.svg' | inline_asset_content -}}
      </button>
      <button class="bloomli-signup-popup__launcher-open" type="button" data-bloomli-popup-reopen>
        {{ section.settings.launcher_label | escape }}
      </button>
    </div>

    <p
      class="bloomli-signup-popup__success"
      id="{{ success_id }}"
      role="status"
      data-bloomli-popup-success
      hidden
    >
      {{ section.settings.success_message | escape }}
    </p>
  </div>
{%- endif -%}

{% schema %}
{
  "name": "Bloomli signup popup",
  "settings": [
    {
      "type": "checkbox",
      "id": "enabled",
      "label": "Enable popup",
      "default": true
    },
    {
      "type": "header",
      "content": "Brand and imagery"
    },
    {
      "type": "image_picker",
      "id": "logo_image",
      "label": "Popup logo override",
      "info": "Leave blank to use the same logo as the header."
    },
    {
      "type": "text",
      "id": "logo_text",
      "label": "Logo text if no header logo exists",
      "default": "Bloomli"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "checkbox",
      "id": "enable_custom_colors",
      "label": "Override color scheme colors",
      "default": false
    },
    {
      "type": "color",
      "id": "popup_background_color",
      "label": "Popup background color",
      "default": "#f6eee8",
      "visible_if": "{{ section.settings.enable_custom_colors }}"
    },
    {
      "type": "color",
      "id": "popup_text_color",
      "label": "Popup text color",
      "default": "#322922",
      "visible_if": "{{ section.settings.enable_custom_colors }}"
    },
    {
      "type": "color",
      "id": "option_button_background_color",
      "label": "Option button background color",
      "default": "#d56d78",
      "visible_if": "{{ section.settings.enable_custom_colors }}"
    },
    {
      "type": "color",
      "id": "option_button_text_color",
      "label": "Option button text color",
      "default": "#fff9f4",
      "visible_if": "{{ section.settings.enable_custom_colors }}"
    },
    {
      "type": "checkbox",
      "id": "show_image",
      "label": "Show image panel",
      "default": true
    },
    {
      "type": "image_picker",
      "id": "image_desktop",
      "label": "Desktop image",
      "visible_if": "{{ section.settings.show_image }}"
    },
    {
      "type": "image_picker",
      "id": "image_mobile",
      "label": "Mobile image",
      "visible_if": "{{ section.settings.show_image }}"
    },
    {
      "type": "select",
      "id": "image_position_desktop",
      "label": "Desktop image position",
      "default": "right",
      "options": [
        {
          "value": "right",
          "label": "Right"
        },
        {
          "value": "left",
          "label": "Left"
        }
      ],
      "visible_if": "{{ section.settings.show_image }}"
    },
    {
      "type": "header",
      "content": "Step 1"
    },
    {
      "type": "text",
      "id": "headline_step_1",
      "label": "Headline line 1",
      "default": "Unlock Your"
    },
    {
      "type": "text",
      "id": "discount_line_step_1",
      "label": "Headline line 2",
      "default": "47% off"
    },
    {
      "type": "textarea",
      "id": "subheading_step_1",
      "label": "Subheading",
      "default": "To claim, share what problem you're trying to solve:"
    },
    {
      "type": "text",
      "id": "problem_option_1_label",
      "label": "Problem option 1 label",
      "default": "Shedding"
    },
    {
      "type": "text",
      "id": "problem_option_1_handle",
      "label": "Problem option 1 tag handle",
      "default": "shedding"
    },
    {
      "type": "text",
      "id": "problem_option_2_label",
      "label": "Problem option 2 label",
      "default": "Breakage"
    },
    {
      "type": "text",
      "id": "problem_option_2_handle",
      "label": "Problem option 2 tag handle",
      "default": "breakage"
    },
    {
      "type": "text",
      "id": "problem_option_3_label",
      "label": "Problem option 3 label",
      "default": "Slow growth"
    },
    {
      "type": "text",
      "id": "problem_option_3_handle",
      "label": "Problem option 3 tag handle",
      "default": "slow-growth"
    },
    {
      "type": "text",
      "id": "problem_option_4_label",
      "label": "Problem option 4 label",
      "default": "Dry scalp"
    },
    {
      "type": "text",
      "id": "problem_option_4_handle",
      "label": "Problem option 4 tag handle",
      "default": "dry-scalp"
    },
    {
      "type": "text",
      "id": "no_thanks_text",
      "label": "No thanks text",
      "default": "No thanks, I don't like savings"
    },
    {
      "type": "text",
      "id": "options_group_label",
      "label": "Options accessible label",
      "default": "Select your hair concern"
    },
    {
      "type": "header",
      "content": "Step 2"
    },
    {
      "type": "text",
      "id": "headline_step_2",
      "label": "Headline step 2 line 1",
      "default": "Unlock Your",
      "info": "Keep this the same as Step 1 for the smoothest transition."
    },
    {
      "type": "text",
      "id": "discount_line_step_2",
      "label": "Headline step 2 line 2",
      "default": "47% off"
    },
    {
      "type": "textarea",
      "id": "body_step_2",
      "label": "Body text",
      "default": "Sign up for email to receive your discount!"
    },
    {
      "type": "text",
      "id": "email_placeholder",
      "label": "Email placeholder",
      "default": "Enter your email"
    },
    {
      "type": "text",
      "id": "submit_button_label",
      "label": "Submit button label",
      "default": "Get My 47% Off"
    },
    {
      "type": "text",
      "id": "success_message",
      "label": "Success message",
      "default": "Check your email for your Bloomli offer."
    },
    {
      "type": "header",
      "content": "Behavior"
    },
    {
      "type": "range",
      "id": "delay_seconds",
      "label": "Open delay",
      "unit": "s",
      "min": 0,
      "max": 30,
      "step": 1,
      "default": 7
    },
    {
      "type": "range",
      "id": "close_cooldown_days",
      "label": "Close cooldown",
      "unit": "day",
      "min": 1,
      "max": 30,
      "step": 1,
      "default": 7
    },
    {
      "type": "range",
      "id": "submit_cooldown_days",
      "label": "Submit cooldown",
      "unit": "day",
      "min": 30,
      "max": 365,
      "step": 5,
      "default": 180
    },
    {
      "type": "checkbox",
      "id": "show_launcher_after_close",
      "label": "Show launcher after close",
      "default": true
    },
    {
      "type": "text",
      "id": "close_button_label",
      "label": "Popup close accessible label",
      "default": "Close signup offer"
    },
    {
      "type": "text",
      "id": "launcher_label",
      "label": "Launcher label",
      "default": "Get 47% Off",
      "visible_if": "{{ section.settings.show_launcher_after_close }}"
    },
    {
      "type": "text",
      "id": "launcher_close_button_label",
      "label": "Launcher close accessible label",
      "default": "Dismiss signup offer",
      "visible_if": "{{ section.settings.show_launcher_after_close }}"
    },
    {
      "type": "header",
      "content": "Layout spacing"
    },
    {
      "type": "range",
      "id": "content_padding_mobile",
      "label": "Mobile content padding",
      "unit": "px",
      "min": 16,
      "max": 56,
      "step": 2,
      "default": 28
    },
    {
      "type": "range",
      "id": "content_padding_desktop",
      "label": "Desktop content padding",
      "unit": "px",
      "min": 32,
      "max": 120,
      "step": 4,
      "default": 64
    }
  ]
}
{% endschema %}
