{{ 'bloomli-product-finder.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign capsules_product = section.settings.card_1_product
  assign gummies_product = section.settings.card_2_product
  assign oil_product = section.settings.card_3_product

  assign capsules_title_override = section.settings.capsules_title | strip
  assign gummies_title_override = section.settings.gummies_title | strip
  assign oil_title_override = section.settings.oil_title | strip

  assign capsules_title = 'Daily Hair Support Capsules'
  if capsules_title_override != blank
    assign capsules_title = capsules_title_override
  elsif capsules_product != blank and capsules_product.handle != gummies_product.handle
    assign capsules_title = capsules_product.title
  endif

  assign gummies_title = 'Ultra Strength Hair Gummies'
  if gummies_title_override != blank
    assign gummies_title = gummies_title_override
  elsif gummies_product != blank
    assign gummies_title = gummies_product.title
  endif

  assign oil_title = 'Botanical Hair Oil'
  if oil_title_override != blank
    assign oil_title = oil_title_override
  elsif oil_product != blank
    assign oil_title = oil_product.title
  endif

  assign capsules_description = section.settings.capsules_short_description | default: section.settings.capsules_subhead | default: 'Daily hair support in an easy capsule.'
  assign gummies_description = section.settings.gummies_short_description | default: section.settings.gummies_subhead | default: 'Daily beauty nutrients in a flavorful gummy.'
  assign oil_description = section.settings.oil_short_description | default: section.settings.oil_subhead | default: 'Outside-in scalp + strand care for the full Bloomli ritual.'

  assign capsules_image = section.settings.capsules_image_override | default: capsules_product.featured_image
  assign gummies_image = section.settings.gummies_image_override | default: gummies_product.featured_image
  assign oil_image = section.settings.oil_image_override | default: oil_product.featured_image

  assign capsules_url = section.settings.capsules_button_link | default: capsules_product.url
  assign gummies_url = section.settings.gummies_button_link | default: gummies_product.url
  assign oil_url = section.settings.oil_button_link | default: oil_product.url

  assign capsules_rating = section.settings.capsules_manual_rating
  assign capsules_review_text = section.settings.capsules_manual_review_text
  if section.settings.capsules_rating_source == 'product_reviews' and capsules_product != blank
    assign capsules_product_rating = capsules_product.metafields.reviews.rating.value
    assign capsules_product_rating_number = capsules_product_rating.rating | default: capsules_product_rating
    assign capsules_product_rating_count = capsules_product.metafields.reviews.rating_count.value | default: capsules_product.metafields.reviews.rating_count
    if capsules_product_rating_number != blank
      assign capsules_rating = capsules_product_rating_number
    endif
    if capsules_product_rating_count != blank
      assign capsules_review_text = capsules_product_rating_count | append: ' reviews'
    endif
  endif

  assign gummies_rating = section.settings.gummies_manual_rating
  assign gummies_review_text = section.settings.gummies_manual_review_text
  if section.settings.gummies_rating_source == 'product_reviews' and gummies_product != blank
    assign gummies_product_rating = gummies_product.metafields.reviews.rating.value
    assign gummies_product_rating_number = gummies_product_rating.rating | default: gummies_product_rating
    assign gummies_product_rating_count = gummies_product.metafields.reviews.rating_count.value | default: gummies_product.metafields.reviews.rating_count
    if gummies_product_rating_number != blank
      assign gummies_rating = gummies_product_rating_number
    endif
    if gummies_product_rating_count != blank
      assign gummies_review_text = gummies_product_rating_count | append: ' reviews'
    endif
  endif

  assign image_fit_class = 'bloomli-product-finder--image-cover'
  if section.settings.image_fit == 'contain'
    assign image_fit_class = 'bloomli-product-finder--image-contain'
  endif
-%}

<section
  id="bloomli-product-finder"
  class="bloomli-product-finder {{ image_fit_class }} color-{{ section.settings.color_scheme }} gradient"
  style="
    --section-padding-top: {{ section.settings.padding_top }}px;
    --section-padding-bottom: {{ section.settings.padding_bottom }}px;
    --section-padding-top-mobile: {{ section.settings.padding_top_mobile }}px;
    --section-padding-bottom-mobile: {{ section.settings.padding_bottom_mobile }}px;
  "
>
  <div class="page-width">
    <div class="bloomli-product-finder__header">
      {%- if section.settings.heading != blank -%}
        <h2 class="bloomli-product-finder__heading h1">{{ section.settings.heading | escape }}</h2>
      {%- endif -%}

      {%- if section.settings.subheading != blank -%}
        <div class="bloomli-product-finder__subheading rte">
          {{ section.settings.subheading }}
        </div>
      {%- endif -%}
    </div>

    <div class="bloomli-product-finder__main-grid">
      <article class="bloomli-product-finder__card bloomli-product-finder__card--gummies bloomli-product-finder__card--featured">
        {%- if section.settings.most_popular_badge != blank -%}
          <span class="bloomli-product-finder__badge">
            {{ section.settings.most_popular_badge | escape }}
          </span>
        {%- endif -%}

        <div class="bloomli-product-finder__media">
            {%- if gummies_image != blank -%}
              {{
                gummies_image
                | image_url: width: 1100
                | image_tag:
                  loading: 'lazy',
                  widths: '320, 480, 640, 820, 1100',
                  sizes: '(min-width: 990px) 560px, 82vw',
                  class: 'bloomli-product-finder__image',
                  alt: gummies_title
              }}
            {%- else -%}
              <span class="bloomli-product-finder__media-icon" aria-hidden="true">
                <i class="ti ti-candy"></i>
              </span>
            {%- endif -%}
        </div>

        <div class="bloomli-product-finder__content">
            {%- if section.settings.gummies_rating_source != 'hide' and gummies_rating != blank -%}
              <p class="bloomli-product-finder__rating">
                <span class="bloomli-product-finder__stars" aria-hidden="true">★★★★★</span>
                <span>{{ gummies_rating | escape }}</span>
                {%- if gummies_review_text != blank -%}
                  <span class="bloomli-product-finder__rating-divider" aria-hidden="true">·</span>
                  <span>{{ gummies_review_text | escape }}</span>
                {%- endif -%}
              </p>
            {%- endif -%}

            <h3 class="bloomli-product-finder__title h3">{{ gummies_title | escape }}</h3>

            {%- if gummies_description != blank -%}
              <p class="bloomli-product-finder__body">{{ gummies_description | escape }}</p>
            {%- endif -%}

            {%- if section.settings.gummies_price_text != blank -%}
              <p class="bloomli-product-finder__price">{{ section.settings.gummies_price_text | escape }}</p>
            {%- endif -%}

            {%- if section.settings.gummies_button_label != blank -%}
              <a class="button button--primary bloomli-product-finder__button" href="{{ gummies_url | default: '#' }}">
                {{ section.settings.gummies_button_label | escape }}
              </a>
            {%- endif -%}
        </div>
      </article>

      <article class="bloomli-product-finder__card bloomli-product-finder__card--capsules">
        <div class="bloomli-product-finder__media">
            {%- if capsules_image != blank -%}
              {{
                capsules_image
                | image_url: width: 1100
                | image_tag:
                  loading: 'lazy',
                  widths: '320, 480, 640, 820, 1100',
                  sizes: '(min-width: 990px) 560px, 82vw',
                  class: 'bloomli-product-finder__image',
                  alt: capsules_title
              }}
            {%- else -%}
              <span class="bloomli-product-finder__media-icon" aria-hidden="true">
                <i class="ti ti-pill"></i>
              </span>
            {%- endif -%}
        </div>

        <div class="bloomli-product-finder__content">
            {%- if section.settings.capsules_rating_source != 'hide' and capsules_rating != blank -%}
              <p class="bloomli-product-finder__rating">
                <span class="bloomli-product-finder__stars" aria-hidden="true">★★★★★</span>
                <span>{{ capsules_rating | escape }}</span>
                {%- if capsules_review_text != blank -%}
                  <span class="bloomli-product-finder__rating-divider" aria-hidden="true">·</span>
                  <span>{{ capsules_review_text | escape }}</span>
                {%- endif -%}
              </p>
            {%- endif -%}

            <h3 class="bloomli-product-finder__title h3">{{ capsules_title | escape }}</h3>

            {%- if capsules_description != blank -%}
              <p class="bloomli-product-finder__body">{{ capsules_description | escape }}</p>
            {%- endif -%}

            {%- if section.settings.capsules_price_text != blank -%}
              <p class="bloomli-product-finder__price">{{ section.settings.capsules_price_text | escape }}</p>
            {%- endif -%}

            {%- if section.settings.capsules_button_label != blank -%}
              <a class="button button--primary bloomli-product-finder__button" href="{{ capsules_url | default: '#' }}">
                {{ section.settings.capsules_button_label | escape }}
              </a>
            {%- endif -%}
        </div>
      </article>
    </div>

    <aside class="bloomli-product-finder__addon" aria-label="{{ oil_title | escape }}">
      <div class="bloomli-product-finder__addon-media">
        {%- if oil_image != blank -%}
          {{
            oil_image
            | image_url: width: 640
            | image_tag:
              loading: 'lazy',
              widths: '180, 260, 360, 520, 640',
              sizes: '(min-width: 990px) 220px, 32vw',
              class: 'bloomli-product-finder__addon-image',
              alt: oil_title
          }}
        {%- else -%}
          <span class="bloomli-product-finder__media-icon" aria-hidden="true">
            <i class="ti ti-droplet"></i>
          </span>
        {%- endif -%}
      </div>

      <div class="bloomli-product-finder__addon-content">
        {%- if section.settings.oil_badge != blank -%}
          <p class="bloomli-product-finder__addon-label">{{ section.settings.oil_badge | escape }}</p>
        {%- endif -%}

        <h3 class="bloomli-product-finder__addon-title h3">{{ oil_title | escape }}</h3>

        {%- if oil_description != blank -%}
          <p class="bloomli-product-finder__addon-body">{{ oil_description | escape }}</p>
        {%- endif -%}

        {%- if section.settings.oil_price_text != blank -%}
          <p class="bloomli-product-finder__addon-price">{{ section.settings.oil_price_text | escape }}</p>
        {%- endif -%}
      </div>

      {%- if section.settings.oil_button_label != blank -%}
        <a class="button button--secondary bloomli-product-finder__addon-button" href="{{ oil_url | default: '#' }}">
          {{ section.settings.oil_button_label | escape }}
        </a>
      {%- endif -%}
    </aside>
  </div>
</section>

