{{ 'bloomli-science.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign image_alt = section.settings.hero_image.alt | default: section.settings.heading
-%}

<section
  class="bloomli-science-section bloomli-science-hero color-{{ section.settings.color_scheme }} gradient"
  style="--section-padding-top: {{ section.settings.padding_top }}px; --section-padding-bottom: {{ section.settings.padding_bottom }}px; --section-padding-top-mobile: {{ section.settings.padding_top_mobile }}px; --section-padding-bottom-mobile: {{ section.settings.padding_bottom_mobile }}px;"
>
  <div class="bloomli-science-section__inner">
    <div class="bloomli-science-grid bloomli-science-hero__grid">
      <div class="bloomli-science-hero__content">
        {%- if section.settings.eyebrow != blank -%}
          <div class="bloomli-science-section__eyebrow">{{ section.settings.eyebrow | escape }}</div>
        {%- endif -%}
        {%- if section.settings.heading != blank -%}
          <h1 class="bloomli-science-section__heading">{{ section.settings.heading | escape }}</h1>
        {%- endif -%}
        {%- if section.settings.body != blank -%}
          <div class="bloomli-science-section__copy rte">{{ section.settings.body }}</div>
        {%- endif -%}

        <div class="bloomli-science-actions">
          {%- if section.settings.primary_label != blank -%}
            <a class="button" href="{{ section.settings.primary_link }}">{{ section.settings.primary_label | escape }}</a>
          {%- endif -%}
          {%- if section.settings.secondary_label != blank -%}
            <a class="button button--secondary" href="{{ section.settings.secondary_link }}">{{ section.settings.secondary_label | escape }}</a>
          {%- endif -%}
        </div>

        {%- if section.settings.trust_line != blank -%}
          <div class="bloomli-science-hero__trust">{{ section.settings.trust_line | escape }}</div>
        {%- endif -%}
        {%- if section.settings.disclaimer != blank -%}
          <div class="bloomli-science-disclaimer">{{ section.settings.disclaimer }}</div>
        {%- endif -%}
      </div>

      <div class="bloomli-science-media bloomli-science-hero__media">
        {%- if section.settings.hero_image != blank -%}
          {{
            section.settings.hero_image
            | image_url: width: 1400
            | image_tag:
              widths: '500, 700, 900, 1100, 1400',
              sizes: '(min-width: 990px) 48vw, 100vw',
              fetchpriority: 'high',
              decoding: 'async',
              alt: image_alt
          }}
        {%- else -%}
          <div class="bloomli-science-media__placeholder">{{ section.settings.placeholder_label | escape }}</div>
        {%- endif -%}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Bloomli - Science Hero",
  "tag": "div",
  "settings": [
    { "type": "color_scheme", "id": "color_scheme", "label": "Color scheme", "default": "scheme-db3fe7fd-8cb8-43cd-b413-f26d3fc92c5f" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "The Bloomli Science Standard" },
    { "type": "text", "id": "heading", "label": "Headline", "default": "The science behind fuller-looking hair starts at the root." },
    { "type": "richtext", "id": "body", "label": "Body", "default": "<p>Healthy-looking hair is built over time - through consistent nutrition, strand support, and care for the scalp environment. Bloomli brings all three together in a simple daily ritual designed to support hair wellness from the inside and outside.*</p>" },
    { "type": "text", "id": "primary_label", "label": "Primary button label", "default": "Shop the Ritual" },
    { "type": "url", "id": "primary_link", "label": "Primary button link", "default": "/collections/all" },
    { "type": "text", "id": "secondary_label", "label": "Secondary button label", "default": "Explore the Science" },
    { "type": "url", "id": "secondary_link", "label": "Secondary button link", "default": "#hair-biology" },
    { "type": "text", "id": "trust_line", "label": "Trust line", "default": "Daily hair wellness - Scalp care - Documented quality" },
    { "type": "richtext", "id": "disclaimer", "label": "FDA disclaimer", "default": "<p>*These statements have not been evaluated by the Food and Drug Administration. This product is not intended to diagnose, treat, cure, or prevent any disease.</p>" },
    { "type": "image_picker", "id": "hero_image", "label": "Hero image - healthy hair / beauty science visual" },
    { "type": "text", "id": "placeholder_label", "label": "Placeholder label", "default": "Hero image - healthy hair / beauty science visual" },
    { "type": "range", "id": "padding_top", "label": "Padding top", "min": 0, "max": 160, "step": 8, "default": 88, "unit": "px" },
    { "type": "range", "id": "padding_bottom", "label": "Padding bottom", "min": 0, "max": 160, "step": 8, "default": 88, "unit": "px" },
    { "type": "range", "id": "padding_top_mobile", "label": "Padding top mobile", "min": 0, "max": 120, "step": 8, "default": 56, "unit": "px" },
    { "type": "range", "id": "padding_bottom_mobile", "label": "Padding bottom mobile", "min": 0, "max": 120, "step": 8, "default": 56, "unit": "px" }
  ],
  "presets": [{ "name": "Bloomli - Science Hero" }]
}
{% endschema %}
