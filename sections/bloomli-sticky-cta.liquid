{%- if section.settings.enabled -%}
<div
  class="bloomli-sticky-cta{% if section.settings.compact %} bloomli-sticky-cta--compact{% endif %}"
  id="bloomli-sticky-cta-{{ section.id }}"
  data-scroll-target="{{ section.settings.scroll_target }}"
  data-proximity-margin="{{ section.settings.proximity_margin }}"
  data-suppress-selector="{{ section.settings.suppress_selector | escape }}"
  aria-hidden="true"
  style="
    --bscta-bar-bg: {{ section.settings.bar_bg }};
    --bscta-btn-bg: {{ section.settings.btn_fill }};
    --bscta-btn-text: {{ section.settings.btn_label }};
    --bscta-badge-bg: {{ section.settings.badge_fill }};
    --bscta-badge-text: {{ section.settings.badge_label }};
    --bscta-social-text: {{ section.settings.social_color }};
    --bscta-star: {{ section.settings.star_fill }};
  "
>
  <div class="bloomli-sticky-cta__inner">
    {%- if section.settings.social_proof != blank -%}
      <p class="bloomli-sticky-cta__social">
        {%- if section.settings.show_stars -%}
          <span class="bloomli-sticky-cta__stars" aria-hidden="true">{%- for i in (1..5) -%}★{%- endfor -%}</span>
        {%- endif -%}
        <span class="bloomli-sticky-cta__social-text">{{ section.settings.social_proof }}</span>
      </p>
    {%- endif -%}
    <button
      class="bloomli-sticky-cta__btn"
      type="button"
      aria-label="{{ section.settings.main_text | escape }}"
    >
      {%- if section.settings.badge_text != blank -%}
        <span class="bloomli-sticky-cta__badge">{{ section.settings.badge_text }}</span>
      {%- endif -%}
      <span class="bloomli-sticky-cta__main">{{ section.settings.main_text }}</span>
    </button>
  </div>
</div>

<script>
  (function () {
    var el = document.getElementById('bloomli-sticky-cta-{{ section.id }}');
    if (!el) return;

    var margin = parseInt(el.dataset.proximityMargin, 10);
    if (isNaN(margin)) margin = 250;
    var selector = el.dataset.scrollTarget;
    var suppressSelector = el.dataset.suppressSelector;
    var visible = false;
    var ticking = false;

    function targetEl() {
      return selector ? document.querySelector(selector) : null;
    }

    function suppressElVisible() {
      if (!suppressSelector) return false;
      var node = document.querySelector(suppressSelector);
      if (!node) return false;
      var rect = node.getBoundingClientRect();
      var vh = window.innerHeight || document.documentElement.clientHeight;
      return rect.bottom > 0 && rect.top < vh;
    }

    function update() {
      ticking = false;
      var dest = targetEl();
      var shouldShow;

      if (dest) {
        // Distance the target sits outside the viewport, in either direction.
        var rect = dest.getBoundingClientRect();
        var vh = window.innerHeight || document.documentElement.clientHeight;
        var below = rect.top - vh; // > 0 → target is below the fold
        var above = -rect.bottom;  // > 0 → target is above the top of the screen
        var offscreenBy = Math.max(below, above, 0);
        // Show once the target is more than `margin` px out of view (above or below).
        shouldShow = offscreenBy > margin;
      } else {
        // No target on this page → fall back to a simple scroll distance.
        shouldShow = (window.scrollY || window.pageYOffset) > margin;
      }

      if (shouldShow && suppressElVisible()) shouldShow = false;

      if (shouldShow === visible) return;
      visible = shouldShow;
      el.setAttribute('aria-hidden', String(!visible));
      el.classList.toggle('bloomli-sticky-cta--visible', visible);
    }

    function onScroll() {
      if (ticking) return;
      ticking = true;
      window.requestAnimationFrame(update);
    }

    window.addEventListener('scroll', onScroll, { passive: true });
    window.addEventListener('resize', onScroll, { passive: true });
    update();

    el.querySelector('.bloomli-sticky-cta__btn').addEventListener('click', function () {
      var dest = targetEl();
      if (dest) {
        dest.scrollIntoView({ behavior: 'smooth', block: 'start' });
      } else {
        window.scrollTo({ top: 0, behavior: 'smooth' });
      }
    });
  })();
</script>
{%- endif -%}

{% schema %}
{
  "name": "Sticky CTA bar",
  "tag": "div",
  "class": "bloomli-sticky-cta-section",
  "enabled_on": {
    "templates": ["page", "index", "product", "collection"]
  },
  "settings": [
    {
      "type": "checkbox",
      "id": "enabled",
      "label": "Enable sticky CTA",
      "default": true
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "badge_text",
      "label": "Badge text",
      "default": "100M+ Gummies Sold",
      "info": "Small pill badge above the button. Leave blank to hide."
    },
    {
      "type": "text",
      "id": "main_text",
      "label": "Button text",
      "default": "Save 61% + Free Gifts"
    },
    {
      "type": "text",
      "id": "social_proof",
      "label": "Social proof text",
      "default": "4.8 stars | 100K+ reviews | 1M+ members",
      "info": "Shown to the left on desktop, below the button on mobile. Leave blank to hide."
    },
    {
      "type": "checkbox",
      "id": "show_stars",
      "label": "Show star icons",
      "default": true
    },
    {
      "type": "header",
      "content": "Behaviour"
    },
    {
      "type": "text",
      "id": "scroll_target",
      "label": "Scroll-to anchor",
      "default": "#glp1-offers",
      "info": "CSS selector for the element to scroll to when the button is clicked. e.g. #glp1-offers"
    },
    {
      "type": "text",
      "id": "suppress_selector",
      "label": "Hide while this element is visible",
      "info": "Optional CSS selector. The bar stays hidden while this element is on screen, e.g. .bloomli-hero__ctas keeps it away from the hero button. Leave blank for the original behavior."
    },
    {
      "type": "checkbox",
      "id": "compact",
      "label": "Compact bar",
      "default": false,
      "info": "Slimmer paddings and button, closer to a thin bottom bar on mobile."
    },
    {
      "type": "range",
      "id": "proximity_margin",
      "label": "Show when target is off-screen by (px)",
      "min": 0,
      "max": 1200,
      "step": 50,
      "default": 250,
      "info": "The bar appears once the target section is this far above or below the viewport, and hides while the target is in view."
    },
    {
      "type": "header",
      "content": "Colors",
      "info": "Bloomli brand defaults: charcoal bar, pink button, cream text."
    },
    {
      "type": "color",
      "id": "bar_bg",
      "label": "Bar background (full-width)",
      "default": "#2a2622"
    },
    {
      "type": "color",
      "id": "btn_fill",
      "label": "Button background",
      "default": "#b23a6f"
    },
    {
      "type": "color",
      "id": "btn_label",
      "label": "Button text",
      "default": "#fdfaf7"
    },
    {
      "type": "color",
      "id": "badge_fill",
      "label": "Badge background",
      "default": "#fdfaf7"
    },
    {
      "type": "color",
      "id": "badge_label",
      "label": "Badge text",
      "default": "#b23a6f"
    },
    {
      "type": "color",
      "id": "social_color",
      "label": "Social proof text",
      "default": "#fdfaf7"
    },
    {
      "type": "color",
      "id": "star_fill",
      "label": "Star color",
      "default": "#f0b429"
    }
  ],
  "presets": [
    {
      "name": "Sticky CTA bar"
    }
  ]
}
{% endschema %}
