<script src="{{ 'bloomli-timeline.js' | asset_url }}" defer="defer"></script>

<section class="bloomli-timeline bloomli-journey bloomli-section color-{{ section.settings.color_scheme }} gradient" data-bloomli-journey style="--journey-progress: 0%; --journey-progress-color: var(--bloomli-accent, #B23A6F); --timeline-eyebrow-color: {{ section.settings.eyebrow_accent_color | default: '#8A6678' }}; --timeline-icon-color: {{ section.settings.timeline_icon_color | default: '#6F7A5A' }}; {% case section.settings.circle_background %}{% when 'background' %}--timeline-circle-bg: var(--bloomli-bg);{% when 'surface_strong' %}--timeline-circle-bg: #F1EDE8;{% when 'accent_soft' %}--timeline-circle-bg: var(--bloomli-soft-blush);{% else %}--timeline-circle-bg: var(--bloomli-surface);{% endcase %} --bloomli-padding-top: {{ section.settings.padding_top }}px; --bloomli-padding-bottom: {{ section.settings.padding_bottom }}px;">
  <div class="bloomli-section__inner">

    <div class="bloomli-timeline__header">
      {%- if section.settings.eyebrow != blank -%}
        <div class="smallcaps bloomli-timeline__eyebrow">{{ section.settings.eyebrow }}</div>
      {%- endif -%}
      <h2 class="bloomli-timeline__heading">
        {{ section.settings.heading }}
      </h2>
    </div>

    {%- assign circle_size = section.settings.circle_size | default: 280 -%}
    {%- if circle_size < 280 -%}
      {%- assign circle_size = 280 -%}
    {%- elsif circle_size > 330 -%}
      {%- assign circle_size = 330 -%}
    {%- endif -%}
    {%- assign icon_size = section.settings.icon_size | default: 64 -%}
    {%- assign line_top = circle_size | times: 2 | divided_by: 3 -%}
    {%- assign connector_color = 'var(--bloomli-line)' -%}
    {%- assign connector_style = section.settings.connector_style | default: 'dashed' -%}
    {%- assign connector_width = section.settings.connector_width | default: 1 -%}

    <div class="bloomli-timeline__wrap bloomli-journey__wrap{% unless section.settings.show_connector %} bloomli-timeline__wrap--no-line{% endunless %}" style="--timeline-circle-size: {{ circle_size }}px; --timeline-line-top: {{ line_top }}px; --timeline-gap: 32px; --timeline-line-color: {{ connector_color }}; --timeline-line-width: {{ connector_width }}px; --timeline-line-style: {{ connector_style }};">
      {%- if section.settings.show_connector -%}
        <div class="bloomli-timeline__track bloomli-journey__track" aria-hidden="true">
          <span class="bloomli-timeline__progress bloomli-journey__progress"></span>
        </div>
      {%- endif -%}
      <div class="bloomli-timeline__grid">
        {%- for block in section.blocks -%}
          <div class="bloomli-timeline__step bloomli-journey__step" {{ block.shopify_attributes }}>
            <div class="bloomli-timeline__circle{% if block.settings.image != blank %} bloomli-timeline__circle--has-image{% endif %}">
              {%- if block.settings.image != blank -%}
                {%- assign image_scale = block.settings.image_scale | default: 100 | divided_by: 100.0 -%}
                {%- assign image_style = '--timeline-image-scale: ' | append: image_scale | append: ';' -%}
                {%- assign image_alt = block.settings.image.alt | default: block.settings.title -%}
                {{
                  block.settings.image
                  | image_url: width: 660
                  | image_tag:
                    class: 'bloomli-timeline__icon-img',
                    alt: image_alt,
                    widths: '220, 330, 660',
                    sizes: '(max-width: 749px) 220px, 330px',
                    loading: 'lazy', decoding: 'async',
                    style: image_style
                }}
              {%- else -%}
                <svg class="bloomli-timeline__icon-svg" width="{{ icon_size }}" height="{{ icon_size }}" viewBox="0 0 80 80" fill="none" stroke="currentColor" color="var(--timeline-icon-color)" stroke-width="1.25" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false">
                  {%- case block.settings.icon -%}
                    {%- when 'seed' -%}
                      <ellipse cx="40" cy="44" rx="12" ry="18"/><path d="M40 26 Q 48 22, 56 26"/><path d="M40 44 L40 60"/>
                    {%- when 'sprout' -%}
                      <path d="M40 70 L40 40"/><path d="M40 40 Q 28 34, 24 22 Q 36 24, 40 40Z"/><path d="M40 46 Q 52 40, 56 28 Q 44 30, 40 46Z"/>
                    {%- when 'bloom' -%}
                      <circle cx="40" cy="40" r="6"/><ellipse cx="40" cy="24" rx="7" ry="11"/><ellipse cx="56" cy="40" rx="11" ry="7"/><ellipse cx="40" cy="56" rx="7" ry="11"/><ellipse cx="24" cy="40" rx="11" ry="7"/><path d="M40 60 L40 72"/>
                  {%- endcase -%}
                </svg>
              {%- endif -%}
            </div>
            <div class="smallcaps bloomli-timeline__range">{{ block.settings.range }}</div>
            <h3 class="bloomli-timeline__title">{{ block.settings.title }}</h3>
            <p class="bloomli-timeline__copy">{{ block.settings.description }}</p>
          </div>
        {%- endfor -%}
      </div>
    </div>

  </div>
</section>

{% schema %}
{
  "name": "Bloomli — Timeline",
  "tag": "div",
  "max_blocks": 3,
  "settings": [
    { "type": "color_scheme", "id": "color_scheme", "label": "Color scheme", "default": "scheme-6d8ba907-aae6-4c49-9120-e1031d9cdb3f" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Your 6-month journey" },
    { "type": "color", "id": "eyebrow_accent_color", "label": "Eyebrow accent color", "default": "#8A6678" },
    { "type": "color", "id": "timeline_icon_color", "label": "Timeline icon color", "default": "#6F7A5A" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Your ritual, over time." },
    { "type": "select", "id": "circle_background", "label": "Icon circle background", "options": [
      { "value": "surface", "label": "Scheme soft surface" },
      { "value": "surface_strong", "label": "Scheme stronger surface" },
      { "value": "background", "label": "Scheme background" },
      { "value": "accent_soft", "label": "Soft accent" }
    ], "default": "surface" },
    { "type": "header", "content": "Image / icon sizing" },
    { "type": "range", "id": "circle_size", "label": "Image card size", "min": 60, "max": 340, "step": 4, "default": 280, "unit": "px" },
    { "type": "range", "id": "icon_size", "label": "Icon size inside card (SVG fallback)", "min": 24, "max": 280, "step": 4, "default": 160, "unit": "px" },
    { "type": "header", "content": "Connector line" },
    { "type": "checkbox", "id": "show_connector", "label": "Show connector line", "default": true },
    { "type": "select", "id": "connector_style", "label": "Connector style", "options": [
      { "value": "dashed", "label": "Dashed" },
      { "value": "dotted", "label": "Dotted" },
      { "value": "solid", "label": "Solid" }
    ], "default": "dashed" },
    { "type": "range", "id": "connector_width", "label": "Connector width", "min": 1, "max": 4, "step": 1, "default": 1, "unit": "px" },
    { "type": "header", "content": "Spacing" },
    { "type": "range", "id": "padding_top", "label": "Padding top (px)", "min": 48, "max": 160, "step": 8, "default": 128 },
    { "type": "range", "id": "padding_bottom", "label": "Padding bottom (px)", "min": 48, "max": 160, "step": 8, "default": 128 }
  ],
  "blocks": [
    {
      "type": "step",
      "name": "Step",
      "settings": [
        { "type": "header", "content": "Icon" },
        { "type": "paragraph", "content": "Upload a transparent PNG/SVG to override the default icon. The image is centered inside the circle and scales to fit." },
        { "type": "image_picker", "id": "image", "label": "Custom icon (optional)" },
        { "type": "range", "id": "image_scale", "label": "Uploaded image scale", "min": 70, "max": 140, "step": 5, "default": 100, "unit": "%" },
        { "type": "select", "id": "icon", "label": "Default icon (used if no image)", "options": [
          { "value": "seed", "label": "Seed" },
          { "value": "sprout", "label": "Sprout" },
          { "value": "bloom", "label": "Bloom" }
        ], "default": "seed" },
        { "type": "header", "content": "Text" },
        { "type": "text", "id": "range", "label": "Month range", "default": "Month 1–3" },
        { "type": "text", "id": "title", "label": "Title", "default": "Foundation" },
        { "type": "textarea", "id": "description", "label": "Description", "default": "Nourishment reaches the follicle. Expect less shedding and a healthier scalp feel." }
      ]
    }
  ],
  "presets": [{
    "name": "Bloomli — Timeline",
    "settings": { "circle_size": 280, "icon_size": 160 },
    "blocks": [
      { "type": "step", "settings": { "icon": "seed", "range": "Month 1–3", "title": "Foundation", "description": "Nourishment reaches the follicle. Expect less shedding and a healthier scalp feel." } },
      { "type": "step", "settings": { "icon": "sprout", "range": "Month 3–6", "title": "Visible Shift", "description": "New growth begins. Many see fuller density at the part line and temples." } },
      { "type": "step", "settings": { "icon": "bloom", "range": "Month 6+", "title": "Full Bloom", "description": "Thicker, stronger, shinier hair. Results consolidate with consistent use." } }
    ]
  }]
}
{% endschema %}
