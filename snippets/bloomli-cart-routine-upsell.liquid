{% doc %}
  Renders a cart routine upsell card in the drawer footer, just above subtotals.
  State 1: supplement in cart but no add-on → upsell the add-on product.
  State 2: add-on in cart but no supplement → upsell the supplement product.
  State 3/4: both or neither → nothing renders.
  Subscription mode: if any cart item has a selling plan, swaps to "Add to subscription"
  with a one-time purchase fallback link below.
{% enddoc %}

{%- liquid
  assign routine_upsell_enabled = settings.bloomli_routine_upsell_enabled
  if routine_upsell_enabled == nil
    assign routine_upsell_enabled = false
  endif

  assign supplement_product = settings.bloomli_routine_upsell_supplement_product
  assign addon_product      = settings.bloomli_routine_upsell_addon_product

  assign supplement_tag = settings.bloomli_routine_upsell_supplement_tag | default: 'supplement' | downcase | strip
  assign addon_tag      = settings.bloomli_routine_upsell_addon_tag | default: 'add-on' | downcase | strip

  assign cart_has_supplement   = false
  assign cart_has_addon        = false
  assign cart_has_subscription = false
  assign cart_sub_interval     = nil

  for item in cart.items
    for product_tag in item.product.tags
      assign normalized_tag = product_tag | downcase | strip
      if normalized_tag == supplement_tag
        assign cart_has_supplement = true
      endif
      if normalized_tag == addon_tag
        assign cart_has_addon = true
      endif
    endfor
    if item.selling_plan_allocation != blank and cart_has_subscription == false
      assign cart_has_subscription = true
      for opt in item.selling_plan_allocation.selling_plan.options
        assign cart_sub_interval = opt.value
        break
      endfor
    endif
  endfor

  assign upsell_state = 0
  if cart_has_supplement and cart_has_addon == false
    assign upsell_state = 1
  elsif cart_has_addon and cart_has_supplement == false
    assign upsell_state = 2
  endif
-%}

{%- if routine_upsell_enabled
    and supplement_product != blank
    and addon_product != blank
    and upsell_state > 0
-%}
  {%- liquid
    if upsell_state == 1
      assign upsell_product      = addon_product
      assign upsell_heading      = settings.bloomli_routine_upsell_state1_heading | default: 'Complete your routine'
      assign upsell_text         = settings.bloomli_routine_upsell_state1_text    | default: 'Add Hair Oil and unlock Pair & Save.'
      assign upsell_button       = settings.bloomli_routine_upsell_state1_button  | default: 'Add Hair Oil'
      assign upsell_discount_pct = settings.bloomli_routine_upsell_addon_discount_pct | default: 20 | plus: 0
    else
      assign upsell_product      = supplement_product
      assign upsell_heading      = settings.bloomli_routine_upsell_state2_heading | default: 'Unlock your pairing offer'
      assign upsell_text         = settings.bloomli_routine_upsell_state2_text    | default: 'Add Gummies to activate Pair & Save on your Hair Oil.'
      assign upsell_button       = settings.bloomli_routine_upsell_state2_button  | default: 'Add Gummies'
      assign upsell_discount_pct = 0
    endif

    assign upsell_variant = upsell_product.first_available_variant
    assign upsell_image   = upsell_product.featured_image

    assign upsell_sale_price = upsell_variant.price
    if upsell_discount_pct > 0
      assign discount_multiplier = 100 | minus: upsell_discount_pct
      assign upsell_sale_price = upsell_variant.price | times: discount_multiplier | divided_by: 100.0 | ceil
    endif

    assign upsell_compare_price = upsell_variant.compare_at_price
    if upsell_compare_price == blank or upsell_compare_price <= upsell_sale_price
      assign upsell_compare_price = 0
    endif

    assign sub_discount_pct = settings.bloomli_routine_upsell_subscription_discount_pct | default: 15 | plus: 0
    assign upsell_sub_btn   = settings.bloomli_routine_upsell_sub_button | default: 'Add to subscription'
    assign upsell_otp_label = settings.bloomli_routine_upsell_otp_label  | default: 'One Time Purchase'

    assign upsell_selling_plan_id = nil
    if cart_has_subscription
      for spg in upsell_product.selling_plan_groups
        for plan in spg.selling_plans
          for opt in plan.options
            if opt.value == cart_sub_interval
              assign upsell_selling_plan_id = plan.id
              break
            endif
          endfor
          if upsell_selling_plan_id != nil
            break
          endif
        endfor
        if upsell_selling_plan_id != nil
          break
        endif
      endfor
      if upsell_selling_plan_id == nil
        for spg in upsell_product.selling_plan_groups
          for plan in spg.selling_plans
            assign upsell_selling_plan_id = plan.id
            break
          endfor
          if upsell_selling_plan_id != nil
            break
          endif
        endfor
      endif
    endif

    assign upsell_sub_price = 0
    if cart_has_subscription and upsell_selling_plan_id != nil
      assign sub_mult = 100 | minus: sub_discount_pct
      assign upsell_sub_price = upsell_variant.price | times: sub_mult | divided_by: 100.0
      if upsell_discount_pct > 0
        assign addon_mult = 100 | minus: upsell_discount_pct
        assign upsell_sub_price = upsell_sub_price | times: addon_mult | divided_by: 100.0 | ceil
      else
        assign upsell_sub_price = upsell_sub_price | ceil
      endif
    endif
  -%}

  {%- if upsell_variant != blank -%}
    {%- assign show_subscription = false -%}
    {%- if cart_has_subscription and upsell_selling_plan_id and upsell_sub_price > 0 -%}
      {%- assign show_subscription = true -%}
    {%- endif -%}
    <div
      class="bloomli-routine-upsell"
      data-bloomli-routine-upsell
      data-state="{{ upsell_state }}"
    >
      <div class="bloomli-routine-upsell__inner">
        {%- if upsell_image != blank -%}
          <div class="bloomli-routine-upsell__image-wrap">
            {{
              upsell_image
              | image_url: width: 248
              | image_tag:
                class: 'bloomli-routine-upsell__image',
                loading: 'lazy',
                alt: upsell_image.alt | default: upsell_product.title,
                width: 124,
                height: 124,
                widths: '124, 248'
            }}
          </div>
        {%- endif -%}
        <div class="bloomli-routine-upsell__content">
          <p class="bloomli-routine-upsell__heading">{{ upsell_heading | escape }}</p>
          <p class="bloomli-routine-upsell__title">{{ upsell_product.title | escape }}</p>
          <p class="bloomli-routine-upsell__text">{{ upsell_text | escape }}</p>
          <div class="bloomli-routine-upsell__prices">
            {%- if show_subscription -%}
              {%- if upsell_compare_price > 0 -%}
                <s class="bloomli-routine-upsell__compare-price">{{ upsell_compare_price | money }}</s>
              {%- endif -%}
              <span class="bloomli-routine-upsell__price">{{ upsell_sub_price | money }}</span>
            {%- else -%}
              {%- if upsell_compare_price > 0 -%}
                <s class="bloomli-routine-upsell__compare-price">{{ upsell_compare_price | money }}</s>
              {%- endif -%}
              <span class="bloomli-routine-upsell__price">{{ upsell_sale_price | money }}</span>
            {%- endif -%}
          </div>
        </div>
      </div>
      {%- if show_subscription -%}
        <button
          type="button"
          class="bloomli-routine-upsell__btn"
          data-bloomli-routine-upsell-btn
          data-variant-id="{{ upsell_variant.id }}"
          data-selling-plan-id="{{ upsell_selling_plan_id }}"
          aria-label="{{ upsell_sub_btn | escape }}: {{ upsell_product.title | escape }}"
        >
          <span class="bloomli-routine-upsell__btn-text">{{ upsell_sub_btn | escape }}</span>
          <span class="bloomli-routine-upsell__spinner loading__spinner hidden">
            {{- 'loading-spinner.svg' | inline_asset_content -}}
          </span>
        </button>
        <div class="bloomli-routine-upsell__otp">
          <button
            type="button"
            class="bloomli-routine-upsell__otp-btn"
            data-bloomli-routine-upsell-otp-btn
            data-variant-id="{{ upsell_variant.id }}"
            aria-label="{{ upsell_otp_label | escape }}: {{ upsell_product.title | escape }}"
          >
            {{- upsell_otp_label | escape -}} &middot;
            <span class="bloomli-routine-upsell__otp-price">{{ upsell_sale_price | money }}</span>
          </button>
        </div>
      {%- else -%}
        <button
          type="button"
          class="bloomli-routine-upsell__btn"
          data-bloomli-routine-upsell-btn
          data-variant-id="{{ upsell_variant.id }}"
          aria-label="{{ upsell_button | escape }}: {{ upsell_product.title | escape }}"
        >
          <span class="bloomli-routine-upsell__btn-text">{{ upsell_button | escape }}</span>
          <span class="bloomli-routine-upsell__spinner loading__spinner hidden">
            {{- 'loading-spinner.svg' | inline_asset_content -}}
          </span>
        </button>
      {%- endif -%}
    </div>
  {%- endif -%}
{%- endif -%}
