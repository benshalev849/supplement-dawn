{{ 'bloomli-what-to-expect.css' | asset_url | stylesheet_tag }}
<script src="{{ 'bloomli-what-to-expect.js' | asset_url }}" defer="defer"></script>

<section
  class="bloomli-wte color-{{ section.settings.color_scheme }} gradient{% if section.settings.layout == 'grid' %} bloomli-wte--grid{% endif %}"
  data-wte-animate="{{ section.settings.enable_animation }}"
  data-padding-top-mobile="{{ section.settings.padding_top_mobile }}"
  data-padding-bottom-mobile="{{ section.settings.padding_bottom_mobile }}"
  data-padding-top-desktop="{{ section.settings.padding_top_desktop }}"
  data-padding-bottom-desktop="{{ section.settings.padding_bottom_desktop }}"
>
  {%- liquid
    assign stat_blocks = section.blocks | where: 'type', 'stat'
    assign quality_blocks = section.blocks | where: 'type', 'quality'
  -%}
  <div class="page-width">
    <div class="bloomli-wte__inner">
      <div class="bloomli-wte__card">
        {%- if section.settings.heading != blank or section.settings.subheading != blank -%}
          <div class="bloomli-wte__head">
            {%- if section.settings.heading != blank -%}
              <h2 class="bloomli-wte__heading h1">{{ section.settings.heading | escape }}</h2>
            {%- endif -%}
            {%- if section.settings.subheading != blank -%}
              <div class="bloomli-wte__subheading rte">{{ section.settings.subheading }}</div>
            {%- endif -%}
          </div>
        {%- endif -%}

        {%- if stat_blocks.size > 0 -%}
          <div
            class="bloomli-wte__stats"
            {% if section.settings.layout == 'grid' %}
              style="--wte-cols: {{ section.settings.grid_columns }};"
            {% endif %}
          >
            {%- for block in stat_blocks -%}
              <div class="bloomli-wte__row" {{ block.shopify_attributes }}>
                {%- if block.settings.icon != 'none' -%}
                  <span class="bloomli-wte__icon" aria-hidden="true">
                    <i class="ti ti-{{ block.settings.icon }}"></i>
                  </span>
                {%- endif -%}
                <div class="bloomli-wte__copy">
                  {%- if block.settings.label != blank -%}
                    <h3 class="bloomli-wte__label">{{ block.settings.label | escape }}</h3>
                  {%- endif -%}
                  {%- if block.settings.description != blank -%}
                    <p class="bloomli-wte__description">{{ block.settings.description | escape }}</p>
                  {%- endif -%}
                </div>
                {%- if block.settings.stat != blank -%}
                  <span class="bloomli-wte__stat" data-wte-count>{{ block.settings.stat | escape }}</span>
                {%- endif -%}
              </div>
            {%- endfor -%}
          </div>
        {%- endif -%}

        {%- if section.settings.footnote != blank -%}
          <p class="bloomli-wte__footnote">{{ section.settings.footnote | escape }}</p>
        {%- endif -%}

        {%- if section.settings.show_quality and quality_blocks.size > 0 -%}
          <hr class="bloomli-wte__divider" aria-hidden="true">
          <div class="bloomli-wte__quality">
            {%- if section.settings.quality_heading != blank -%}
              <h3 class="bloomli-wte__quality-heading">{{ section.settings.quality_heading | escape }}</h3>
            {%- endif -%}
            {%- if section.settings.quality_text != blank -%}
              <div class="bloomli-wte__quality-text rte">{{ section.settings.quality_text }}</div>
            {%- endif -%}
            <ul class="bloomli-wte__quality-list" role="list">
              {%- for block in quality_blocks -%}
                <li class="bloomli-wte__quality-item" {{ block.shopify_attributes }}>
                  <i class="ti ti-{{ block.settings.icon }}" aria-hidden="true"></i>
                  <span>{{ block.settings.text | escape }}</span>
                </li>
              {%- endfor -%}
            </ul>
          </div>
        {%- endif -%}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Bloomli What To Expect",
  "tag": "section",
  "class": "section",
  "enabled_on": {
    "templates": ["*"]
  },
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "What To Expect"
    },
    {
      "type": "richtext",
      "id": "subheading",
      "label": "Subheading"
    },
    {
      "type": "select",
      "id": "layout",
      "label": "Layout",
      "options": [
        { "value": "grid", "label": "Big number grid" },
        { "value": "card", "label": "Compact card (rows)" }
      ],
      "default": "grid",
      "info": "Big number grid shows 2 columns on mobile and up to 4 on desktop. Compact card shows icon rows."
    },
    {
      "type": "range",
      "id": "grid_columns",
      "label": "Grid columns on desktop",
      "min": 2,
      "max": 4,
      "step": 1,
      "default": 4,
      "visible_if": "{{ section.settings.layout == 'grid' }}"
    },
    {
      "type": "checkbox",
      "id": "enable_animation",
      "label": "Animate numbers on scroll",
      "default": true,
      "info": "Counts each stat up when it enters the viewport. Automatically disabled for visitors who prefer reduced motion."
    },
    {
      "type": "textarea",
      "id": "footnote",
      "label": "Footnote",
      "default": "* Based on verified Bloomli customer reviews mentioning each topic. Review insights are not clinical results. Individual experiences may vary."
    },
    {
      "type": "header",
      "content": "Quality strip"
    },
    {
      "type": "checkbox",
      "id": "show_quality",
      "label": "Show quality strip",
      "default": true,
      "info": "Shows below a divider inside the same card. Add \"Quality point\" blocks for the checklist."
    },
    {
      "type": "text",
      "id": "quality_heading",
      "label": "Quality heading",
      "default": "Quality You Can Trust",
      "visible_if": "{{ section.settings.show_quality }}"
    },
    {
      "type": "richtext",
      "id": "quality_text",
      "label": "Quality text",
      "default": "<p>Every bottle is made with ingredients you can read and understand:</p>",
      "visible_if": "{{ section.settings.show_quality }}"
    },
    {
      "type": "header",
      "content": "Desktop spacing"
    },
    {
      "type": "range",
      "id": "padding_top_desktop",
      "label": "Padding top",
      "min": 0,
      "max": 120,
      "step": 8,
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_bottom_desktop",
      "label": "Padding bottom",
      "min": 0,
      "max": 120,
      "step": 8,
      "default": 80
    },
    {
      "type": "header",
      "content": "Mobile spacing"
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "label": "Padding top",
      "min": 0,
      "max": 120,
      "step": 8,
      "default": 56
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "label": "Padding bottom",
      "min": 0,
      "max": 120,
      "step": 8,
      "default": 56
    }
  ],
  "blocks": [
    {
      "type": "stat",
      "name": "Stat row",
      "limit": 6,
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "Icon",
          "options": [
            { "value": "flower", "label": "Flower" },
            { "value": "sparkles", "label": "Sparkles" },
            { "value": "barbell", "label": "Barbell" },
            { "value": "seeding", "label": "Seedling" },
            { "value": "leaf", "label": "Leaf" },
            { "value": "heart", "label": "Heart" },
            { "value": "shield-check", "label": "Shield check" },
            { "value": "droplet", "label": "Droplet" },
            { "value": "bolt", "label": "Bolt" },
            { "value": "star", "label": "Star" },
            { "value": "none", "label": "No icon" }
          ],
          "default": "flower"
        },
        {
          "type": "text",
          "id": "stat",
          "label": "Stat",
          "default": "95%",
          "info": "The big number, e.g. 95% or 15K+."
        },
        {
          "type": "text",
          "id": "label",
          "label": "Label",
          "default": "Fuller Hair"
        },
        {
          "type": "text",
          "id": "description",
          "label": "Description",
          "default": "said their hair looked thicker*"
        }
      ]
    },
    {
      "type": "quality",
      "name": "Quality point",
      "limit": 6,
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "Icon",
          "options": [
            { "value": "circle-check", "label": "Check" },
            { "value": "rosette-discount-check", "label": "Verified badge" },
            { "value": "circle-x", "label": "X (free from)" },
            { "value": "leaf", "label": "Leaf" },
            { "value": "shield-check", "label": "Shield check" }
          ],
          "default": "circle-x"
        },
        {
          "type": "text",
          "id": "text",
          "label": "Text",
          "default": "Biotin + marine collagen in every serving"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Bloomli What To Expect",
      "blocks": [
        {
          "type": "stat",
          "settings": {
            "icon": "flower",
            "stat": "95%",
            "label": "Fuller Hair",
            "description": "said their hair looked thicker*"
          }
        },
        {
          "type": "stat",
          "settings": {
            "icon": "sparkles",
            "stat": "88%",
            "label": "Less Shedding",
            "description": "experienced reduced shedding*"
          }
        },
        {
          "type": "stat",
          "settings": {
            "icon": "barbell",
            "stat": "82%",
            "label": "Stronger Strands",
            "description": "reported less breakage*"
          }
        },
        {
          "type": "stat",
          "settings": {
            "icon": "seeding",
            "stat": "75%",
            "label": "Visible Growth",
            "description": "noticed new growth*"
          }
        },
        {
          "type": "quality",
          "settings": {
            "icon": "circle-x",
            "text": "Biotin + marine collagen in every serving"
          }
        },
        {
          "type": "quality",
          "settings": {
            "icon": "circle-x",
            "text": "Vitamins A, C, D, E + full B-complex"
          }
        },
        {
          "type": "quality",
          "settings": {
            "icon": "circle-x",
            "text": "Gluten-free, passion fruit flavor"
          }
        },
        {
          "type": "quality",
          "settings": {
            "icon": "circle-x",
            "text": "Just 2 gummies a day"
          }
        }
      ]
    }
  ]
}
{% endschema %}
