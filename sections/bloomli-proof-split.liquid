{% comment %}
/* PROOF SPLIT ORIGINAL - REVERT HERE IF NEEDED */
<section class="bloomli-proof-split bloomli-proof-split--image-{{ section.settings.image_side | default: 'left' }} bloomli-section color-{{ section.settings.color_scheme }} gradient" style="--bps-icon-color: {{ section.settings.icon_accent_color | default: '#6F7A5A' }}; {% if section.settings.use_custom_background %}--bps-bg: {{ section.settings.background_color }};{% else %}--bps-bg: var(--bloomli-bg);{% endif %}{% case section.settings.media_background %}{% when 'background' %}--bps-media-bg: var(--bloomli-bg);{% when 'surface_strong' %}--bps-media-bg: var(--bloomli-surface-strong);{% when 'accent_soft' %}--bps-media-bg: var(--bloomli-soft-blush);{% else %}--bps-media-bg: var(--bloomli-surface);{% endcase %} --bloomli-padding-top: {{ section.settings.padding_top }}px; --bloomli-padding-bottom: {{ section.settings.padding_bottom }}px; --bps-image-width: {{ section.settings.image_width | default: 620 }}px; --bps-image-radius: {{ section.settings.image_radius | default: 16 }}px; --bps-image-position: {{ section.settings.image_position }};">
  <div class="bloomli-proof-split__inner">
    <div class="bloomli-proof-split__media" style="{% if section.settings.image == blank %}--bps-placeholder-lines: repeating-linear-gradient(135deg, var(--bloomli-line-soft) 0 1px, transparent 1px 18px);{% endif %}">
      {%- if section.settings.image != blank -%}
        {%- assign image_scale = section.settings.image_scale | divided_by: 100.0 -%}
        {%- assign image_style = '--bps-image-scale: ' | append: image_scale | append: ';' -%}
        {%- assign image_alt = section.settings.image.alt | default: section.settings.heading_line1 -%}
        {{
          section.settings.image
          | image_url: width: 1200
          | image_tag:
            class: 'bloomli-proof-split__image',
            alt: image_alt,
            widths: '500, 700, 900, 1200',
            sizes: '(max-width: 749px) calc(100vw - 40px), 50vw',
            loading: 'lazy', decoding: 'async',
            style: image_style
        }}
      {%- endif -%}
      {%- if section.settings.image_label != blank and section.settings.image == blank -%}
        <span class="smallcaps bloomli-section-placeholder-label">{{ section.settings.image_label }}</span>
      {%- endif -%}
    </div>

    <div class="bloomli-proof-split__content">
      <h2 class="bloomli-proof-split__heading">
        {{ section.settings.heading_line1 }}<br>
        <span>{{ section.settings.heading_line2 }}</span>
      </h2>
      {%- if section.settings.copy != blank -%}
        <div class="bloomli-proof-split__copy">{{ section.settings.copy }}</div>
      {%- endif -%}
      <div class="bloomli-proof-split__bullets">
        {%- for block in section.blocks -%}
          <div class="bloomli-proof-split__bullet" {{ block.shopify_attributes }}>
            {%- if block.settings.bullet_title != blank -%}
              <div class="bloomli-proof-split__bullet-content">
                <strong class="bloomli-proof-split__bullet-title">{{ block.settings.bullet_title | escape }}</strong>
                <div class="bloomli-proof-split__bullet-text">{{ block.settings.text }}</div>
              </div>
            {%- else -%}
              <div class="bloomli-proof-split__bullet-text">{{ block.settings.text }}</div>
            {%- endif -%}
          </div>
        {%- endfor -%}
      </div>
    </div>
  </div>
</section>
{% endcomment %}

{%- liquid
  assign image_scale = section.settings.image_scale | divided_by: 100.0
  assign image_alt = section.settings.image.alt | default: section.settings.heading_line1
  assign image_style = 'object-position: ' | append: section.settings.image_position | append: ';'
  assign icon_accent_color = section.settings.icon_accent_color | downcase
-%}

<section
  class="bloomli-proof-panel bloomli-proof-panel--image-{{ section.settings.image_side | default: 'left' }} bloomli-section color-{{ section.settings.color_scheme }} gradient"
  style="
    --bpp-bg: {% if section.settings.use_custom_background %}{{ section.settings.background_color }}{% else %}rgb(var(--color-background)){% endif %};
    --bpp-accent: {% if icon_accent_color == '#6f7a5a' %}var(--bloomli-primary-action){% else %}{{ section.settings.icon_accent_color | default: 'var(--bloomli-primary-action)' }}{% endif %};
    --bloomli-padding-top: {{ section.settings.padding_top }}px;
    --bloomli-padding-bottom: {{ section.settings.padding_bottom }}px;
    --bpp-image-width: {{ section.settings.image_width | default: 620 }}px;
    --bpp-image-radius: {{ section.settings.image_radius | default: 16 }}px;
    --bpp-image-scale: {{ image_scale }};
    --bpp-card-border: {% if section.settings.show_card_borders %}1px solid color-mix(in srgb, var(--bloomli-editorial-accent) 18%, transparent){% else %}0{% endif %};
  "
>
  <div class="bloomli-proof-panel__inner">
    <div class="bloomli-proof-panel__header">
      <h2>
        {{ section.settings.heading_line1 | escape }}
      </h2>
      {%- if section.settings.copy != blank -%}
        <div class="bloomli-proof-panel__copy">{{ section.settings.copy }}</div>
      {%- endif -%}
    </div>

    <div class="bloomli-proof-panel__grid">
      <div class="bloomli-proof-panel__visual">
        {%- if section.settings.image != blank -%}
          {{
            section.settings.image
            | image_url: width: 1400
            | image_tag:
              class: 'bloomli-proof-panel__image',
              alt: image_alt,
              widths: '500, 700, 900, 1200, 1400',
              sizes: '(max-width: 899px) calc(100vw - 84px), min(42vw, 560px)',
              loading: 'lazy',
              decoding: 'async',
              style: image_style
          }}
        {%- elsif section.settings.image_label != blank -%}
          <span class="smallcaps bloomli-section-placeholder-label">{{ section.settings.image_label }}</span>
        {%- endif -%}

        {%- if section.settings.image_caption != blank -%}
          <div class="bloomli-proof-panel__image-caption">{{ section.settings.image_caption }}</div>
        {%- endif -%}
      </div>

      <div class="bloomli-proof-panel__proof-list">
        {%- for block in section.blocks -%}
          <article class="bloomli-proof-panel__proof-item" {{ block.shopify_attributes }}>
            <span class="bloomli-proof-panel__number">
              {%- if forloop.index < 10 -%}0{%- endif -%}{{ forloop.index }}
            </span>
            <div>
              {%- if block.settings.bullet_title != blank -%}
                <h3>{{ block.settings.bullet_title | escape }}</h3>
                {%- if block.settings.text != blank -%}
                  <p>{{ block.settings.text }}</p>
                {%- endif -%}
              {%- elsif block.settings.text != blank -%}
                <h3>{{ block.settings.text }}</h3>
              {%- endif -%}
            </div>
          </article>
        {%- endfor -%}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Bloomli - Proof Split",
  "tag": "div",
  "max_blocks": 6,
  "settings": [
    { "type": "color_scheme", "id": "color_scheme", "label": "Color scheme", "default": "scheme-6d8ba907-aae6-4c49-9120-e1031d9cdb3f" },
    { "type": "checkbox", "id": "use_custom_background", "label": "Use custom background color", "default": false },
    { "type": "color", "id": "background_color", "label": "Custom background color", "default": "#FDFAF7" },
    { "type": "color", "id": "icon_accent_color", "label": "Icon accent color", "default": "#6F7A5A" },
    { "type": "image_picker", "id": "image", "label": "Image" },
    { "type": "select", "id": "image_side", "label": "Image position on desktop", "options": [
      { "value": "left", "label": "Left" },
      { "value": "right", "label": "Right" }
    ], "default": "left" },
    { "type": "select", "id": "media_background", "label": "Image placeholder background", "options": [
      { "value": "surface", "label": "Scheme soft surface" },
      { "value": "surface_strong", "label": "Scheme stronger surface" },
      { "value": "background", "label": "Scheme background" },
      { "value": "accent_soft", "label": "Soft accent" }
    ], "default": "surface" },
    { "type": "text", "id": "image_label", "label": "Placeholder label", "default": "Editorial - morning ritual - natural light" },
    { "type": "richtext", "id": "image_caption", "label": "Text below image" },
    { "type": "range", "id": "image_scale", "label": "Uploaded image zoom", "min": 100, "max": 140, "step": 5, "default": 100, "unit": "%" },
    { "type": "select", "id": "image_position", "label": "Image crop position", "options": [
      { "value": "center center", "label": "Center" },
      { "value": "center top", "label": "Top" },
      { "value": "center bottom", "label": "Bottom" },
      { "value": "left center", "label": "Left" },
      { "value": "right center", "label": "Right" }
    ], "default": "center center" },
    { "type": "range", "id": "image_width", "label": "Image width", "min": 320, "max": 760, "step": 20, "default": 620, "unit": "px" },
    { "type": "range", "id": "image_radius", "label": "Image corner radius", "min": 0, "max": 40, "step": 2, "default": 16, "unit": "px" },
    { "type": "checkbox", "id": "show_card_borders", "label": "Show card borders", "default": true },
    { "type": "text", "id": "heading_line1", "label": "Heading", "default": "Every milligram, intentional." },
    { "type": "richtext", "id": "copy", "label": "Copy", "default": "<p>We formulate at clinical doses - the amounts used in peer-reviewed studies - not the sprinkle-doses you'll find in most gummies. Every batch is independently tested. Nothing added for color, nothing hidden in a proprietary blend.</p>" },
    { "type": "range", "id": "padding_top", "label": "Padding top", "min": 48, "max": 176, "step": 8, "default": 104, "unit": "px" },
    { "type": "range", "id": "padding_bottom", "label": "Padding bottom", "min": 48, "max": 176, "step": 8, "default": 104, "unit": "px" }
  ],
  "blocks": [
    {
      "type": "bullet",
      "name": "Checklist item",
      "settings": [
        { "type": "text", "id": "bullet_title", "label": "Bullet title" },
        { "type": "text", "id": "text", "label": "Text", "default": "Clinically-dosed actives. No fairy dust." }
      ]
    }
  ],
  "presets": [
    {
      "name": "Bloomli - Proof Split",
      "blocks": [
        { "type": "bullet", "settings": { "text": "Clinically-dosed actives. No fairy dust." } },
        { "type": "bullet", "settings": { "text": "Vegan pectin base. No gelatin, no artificial dyes." } },
        { "type": "bullet", "settings": { "text": "Third-party tested for purity and potency." } },
        { "type": "bullet", "settings": { "text": "Made in a GMP-certified facility in California." } }
      ]
    }
  ]
}
{% endschema %}
