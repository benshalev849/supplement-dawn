{{ 'bloomli-product-finder.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign capsules_product = section.settings.card_1_product
  assign gummies_product = section.settings.card_2_product
  assign oil_product = section.settings.card_3_product

  assign capsules_title = section.settings.capsules_title | default: capsules_product.title | default: 'Daily Hair Support Capsules'
  assign gummies_title = section.settings.gummies_title | default: gummies_product.title | default: 'Ultra Strength Hair Gummies'
  assign oil_title = section.settings.oil_title | default: oil_product.title | default: 'Add Hair Oil for outside-in care.'

  assign capsules_image = section.settings.capsules_image_override | default: capsules_product.featured_image
  assign gummies_image = section.settings.gummies_image_override | default: gummies_product.featured_image
  assign oil_image = section.settings.oil_image_override | default: oil_product.featured_image

  assign capsules_url = section.settings.capsules_button_link | default: capsules_product.url
  assign gummies_url = section.settings.gummies_button_link | default: gummies_product.url
  assign oil_url = section.settings.oil_button_link | default: oil_product.url
-%}

<section class="bloomli-product-finder color-{{ section.settings.color_scheme }} gradient">
  <div class="page-width">
    <div class="bloomli-product-finder__header">
      {%- if section.settings.heading != blank -%}
        <h2 class="bloomli-product-finder__heading h1">{{ section.settings.heading | escape }}</h2>
      {%- endif -%}

      {%- if section.settings.subheading != blank -%}
        <div class="bloomli-product-finder__subheading rte">
          {{ section.settings.subheading }}
        </div>
      {%- endif -%}
    </div>

    <div class="bloomli-product-finder__main-grid">
      <article class="bloomli-product-finder__card bloomli-product-finder__card--capsules">
        <div class="bloomli-product-finder__media">
          {%- if capsules_image != blank -%}
            {{
              capsules_image
              | image_url: width: 900
              | image_tag:
                loading: 'lazy',
                widths: '240, 360, 480, 720, 900',
                sizes: '(min-width: 990px) 420px, 100vw',
                class: 'bloomli-product-finder__image',
                alt: capsules_title
            }}
          {%- else -%}
            <span class="bloomli-product-finder__media-icon" aria-hidden="true">
              <i class="ti ti-pill"></i>
            </span>
          {%- endif -%}
        </div>

        <div class="bloomli-product-finder__content">
          <div class="bloomli-product-finder__meta-row">
            {%- if section.settings.capsules_badge != blank -%}
              <span class="bloomli-product-finder__pill">{{ section.settings.capsules_badge | escape }}</span>
            {%- endif -%}

            {%- if section.settings.capsules_price_text != blank -%}
              <span class="bloomli-product-finder__price">{{ section.settings.capsules_price_text | escape }}</span>
            {%- endif -%}
          </div>

          {%- if section.settings.capsules_best_for != blank -%}
            <p class="bloomli-product-finder__best-for">{{ section.settings.capsules_best_for | escape }}</p>
          {%- endif -%}

          <h3 class="bloomli-product-finder__title h3">{{ capsules_title | escape }}</h3>

          {%- if section.settings.capsules_subhead != blank -%}
            <p class="bloomli-product-finder__body">{{ section.settings.capsules_subhead | escape }}</p>
          {%- endif -%}

          <div class="bloomli-product-finder__checks" role="list">
            {%- if section.settings.capsules_check_1 != blank -%}
              <div class="bloomli-product-finder__check" role="listitem">
                <span class="bloomli-product-finder__check-icon" aria-hidden="true">
                  <svg viewBox="0 0 20 20" focusable="false">
                    <path d="M4 10.5 8 14 16 6" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                </span>
                <span>{{ section.settings.capsules_check_1 | escape }}</span>
              </div>
            {%- endif -%}
            {%- if section.settings.capsules_check_2 != blank -%}
              <div class="bloomli-product-finder__check" role="listitem">
                <span class="bloomli-product-finder__check-icon" aria-hidden="true">
                  <svg viewBox="0 0 20 20" focusable="false">
                    <path d="M4 10.5 8 14 16 6" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                </span>
                <span>{{ section.settings.capsules_check_2 | escape }}</span>
              </div>
            {%- endif -%}
            {%- if section.settings.capsules_check_3 != blank -%}
              <div class="bloomli-product-finder__check" role="listitem">
                <span class="bloomli-product-finder__check-icon" aria-hidden="true">
                  <svg viewBox="0 0 20 20" focusable="false">
                    <path d="M4 10.5 8 14 16 6" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                </span>
                <span>{{ section.settings.capsules_check_3 | escape }}</span>
              </div>
            {%- endif -%}
          </div>

          {%- if section.settings.capsules_button_label != blank -%}
            <a class="button button--primary bloomli-product-finder__button" href="{{ capsules_url | default: '#' }}">
              {{ section.settings.capsules_button_label | escape }}
            </a>
          {%- endif -%}
        </div>
      </article>

      <article class="bloomli-product-finder__card bloomli-product-finder__card--gummies bloomli-product-finder__card--featured">
        {%- if section.settings.most_popular_badge != blank -%}
          <span class="bloomli-product-finder__floating-badge">
            {{ section.settings.most_popular_badge | escape }}
          </span>
        {%- endif -%}

        <div class="bloomli-product-finder__media">
          {%- if gummies_image != blank -%}
            {{
              gummies_image
              | image_url: width: 900
              | image_tag:
                loading: 'lazy',
                widths: '240, 360, 480, 720, 900',
                sizes: '(min-width: 990px) 420px, 100vw',
                class: 'bloomli-product-finder__image',
                alt: gummies_title
            }}
          {%- else -%}
            <span class="bloomli-product-finder__media-icon" aria-hidden="true">
              <i class="ti ti-candy"></i>
            </span>
          {%- endif -%}
        </div>

        <div class="bloomli-product-finder__content">
          <div class="bloomli-product-finder__meta-row">
            {%- if section.settings.gummies_badge != blank -%}
              <span class="bloomli-product-finder__pill">{{ section.settings.gummies_badge | escape }}</span>
            {%- endif -%}

            {%- if section.settings.gummies_price_text != blank -%}
              <span class="bloomli-product-finder__price">{{ section.settings.gummies_price_text | escape }}</span>
            {%- endif -%}
          </div>

          {%- if section.settings.gummies_best_for != blank -%}
            <p class="bloomli-product-finder__best-for">{{ section.settings.gummies_best_for | escape }}</p>
          {%- endif -%}

          <h3 class="bloomli-product-finder__title h3">{{ gummies_title | escape }}</h3>

          {%- if section.settings.gummies_subhead != blank -%}
            <p class="bloomli-product-finder__body">{{ section.settings.gummies_subhead | escape }}</p>
          {%- endif -%}

          <div class="bloomli-product-finder__checks" role="list">
            {%- if section.settings.gummies_check_1 != blank -%}
              <div class="bloomli-product-finder__check" role="listitem">
                <span class="bloomli-product-finder__check-icon" aria-hidden="true">
                  <svg viewBox="0 0 20 20" focusable="false">
                    <path d="M4 10.5 8 14 16 6" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                </span>
                <span>{{ section.settings.gummies_check_1 | escape }}</span>
              </div>
            {%- endif -%}
            {%- if section.settings.gummies_check_2 != blank -%}
              <div class="bloomli-product-finder__check" role="listitem">
                <span class="bloomli-product-finder__check-icon" aria-hidden="true">
                  <svg viewBox="0 0 20 20" focusable="false">
                    <path d="M4 10.5 8 14 16 6" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                </span>
                <span>{{ section.settings.gummies_check_2 | escape }}</span>
              </div>
            {%- endif -%}
            {%- if section.settings.gummies_check_3 != blank -%}
              <div class="bloomli-product-finder__check" role="listitem">
                <span class="bloomli-product-finder__check-icon" aria-hidden="true">
                  <svg viewBox="0 0 20 20" focusable="false">
                    <path d="M4 10.5 8 14 16 6" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                </span>
                <span>{{ section.settings.gummies_check_3 | escape }}</span>
              </div>
            {%- endif -%}
          </div>

          {%- if section.settings.gummies_button_label != blank -%}
            <a class="button button--primary bloomli-product-finder__button" href="{{ gummies_url | default: '#' }}">
              {{ section.settings.gummies_button_label | escape }}
            </a>
          {%- endif -%}
        </div>
      </article>
    </div>

    <aside class="bloomli-product-finder__addon" aria-label="{{ oil_title | escape }}">
      <div class="bloomli-product-finder__addon-media">
        {%- if oil_image != blank -%}
          {{
            oil_image
            | image_url: width: 520
            | image_tag:
              loading: 'lazy',
              widths: '160, 240, 360, 520',
              sizes: '(min-width: 990px) 180px, 34vw',
              class: 'bloomli-product-finder__addon-image',
              alt: oil_title
          }}
        {%- else -%}
          <span class="bloomli-product-finder__media-icon" aria-hidden="true">
            <i class="ti ti-droplet"></i>
          </span>
        {%- endif -%}
      </div>

      <div class="bloomli-product-finder__addon-content">
        <div class="bloomli-product-finder__meta-row bloomli-product-finder__meta-row--addon">
          {%- if section.settings.oil_badge != blank -%}
            <span class="bloomli-product-finder__pill">{{ section.settings.oil_badge | escape }}</span>
          {%- endif -%}

          {%- if section.settings.oil_price_text != blank -%}
            <span class="bloomli-product-finder__price">{{ section.settings.oil_price_text | escape }}</span>
          {%- endif -%}
        </div>

        <h3 class="bloomli-product-finder__addon-title h3">{{ oil_title | escape }}</h3>

        {%- if section.settings.oil_subhead != blank -%}
          <p class="bloomli-product-finder__addon-body">{{ section.settings.oil_subhead | escape }}</p>
        {%- endif -%}

        <div class="bloomli-product-finder__addon-checks" role="list">
          {%- if section.settings.oil_check_1 != blank -%}
            <span role="listitem">{{ section.settings.oil_check_1 | escape }}</span>
          {%- endif -%}
          {%- if section.settings.oil_check_2 != blank -%}
            <span role="listitem">{{ section.settings.oil_check_2 | escape }}</span>
          {%- endif -%}
          {%- if section.settings.oil_check_3 != blank -%}
            <span role="listitem">{{ section.settings.oil_check_3 | escape }}</span>
          {%- endif -%}
        </div>
      </div>

      {%- if section.settings.oil_button_label != blank -%}
        <a class="button button--secondary bloomli-product-finder__addon-button" href="{{ oil_url | default: '#' }}">
          {{ section.settings.oil_button_label | escape }}
        </a>
      {%- endif -%}
    </aside>
  </div>
</section>

