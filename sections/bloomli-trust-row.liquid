<section
  class="bloomli-trust bloomli-section color-{{ section.settings.color_scheme }} gradient"
  style="--bloomli-trust-icon-color: {{ section.settings.icon_accent_color | default: '#6F7A5A' }}; --bloomli-padding-top: {{ section.settings.padding_top }}px; --bloomli-padding-bottom: {{ section.settings.padding_bottom }}px;"
>
  <div class="bloomli-trust__grid">

    {%- for block in section.blocks -%}
      <div class="bloomli-trust__item" {{ block.shopify_attributes }}>
        {%- render 'bloomli-icon', icon: block.settings.icon, class: 'bloomli-trust__icon', size: 24 -%}
        <span class="bloomli-trust__label smallcaps">{{ block.settings.label }}</span>
      </div>
    {%- endfor -%}

  </div>
</section>

{% schema %}
{
  "name": "Bloomli — Trust Row",
  "tag": "div",
  "max_blocks": 4,
  "settings": [
    { "type": "color_scheme", "id": "color_scheme", "label": "Color scheme", "default": "scheme-6d8ba907-aae6-4c49-9120-e1031d9cdb3f" },
    { "type": "color", "id": "icon_accent_color", "label": "Icon accent color", "default": "#6F7A5A" },
    { "type": "range", "id": "padding_top", "label": "Padding top (px)", "min": 20, "max": 80, "step": 4, "default": 56 },
    { "type": "range", "id": "padding_bottom", "label": "Padding bottom (px)", "min": 20, "max": 80, "step": 4, "default": 56 }
  ],
  "blocks": [
    {
      "type": "trust_item",
      "name": "Trust item",
      "settings": [
        { "type": "select", "id": "icon", "label": "Icon", "options": [
          { "value": "flask", "label": "Flask" },
          { "value": "shield", "label": "Shield / Check" },
          { "value": "leaf", "label": "Leaf" },
          { "value": "star", "label": "Star" },
          { "value": "check", "label": "Circle check" },
          { "value": "globe", "label": "Globe / USA" }
        ], "default": "flask" },
        { "type": "text", "id": "label", "label": "Label", "default": "Clinically-studied ingredients" }
      ]
    }
  ],
  "presets": [{
    "name": "Bloomli — Trust Row",
    "blocks": [
      { "type": "trust_item", "settings": { "icon": "flask", "label": "Clinically-studied ingredients" } },
      { "type": "trust_item", "settings": { "icon": "shield", "label": "Dermatologist-approved" } },
      { "type": "trust_item", "settings": { "icon": "leaf", "label": "Cruelty-free & vegan" } },
      { "type": "trust_item", "settings": { "icon": "globe", "label": "Made in the USA" } }
    ]
  }]
}
{% endschema %}
