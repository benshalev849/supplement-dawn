{{ 'bloomli-faq.css' | asset_url | stylesheet_tag }}
<script src="{{ 'bloomli-faq.js' | asset_url }}" defer="defer"></script>

<section
  class="bloomli-faq bloomli-collapsible-row color-{{ section.settings.color_scheme }} gradient"
  data-bloomli-faq
  style="
    --bf-border: {{ section.settings.border_color }};
    --bf-content-width: {{ section.settings.content_width }}px;
    --bf-image-width: 0px;
    --bf-radius: {{ section.settings.corner_radius }}px;
    --bf-heading-size: {{ section.settings.heading_size }}px;
    --bf-question-size: {{ section.settings.question_size }}px;
    --bf-body-size: {{ section.settings.body_size }}px;
    --bf-padding-top: {{ section.settings.padding_top }}px;
    --bf-padding-bottom: {{ section.settings.padding_bottom }}px;
  "
>
  <div class="bloomli-faq__inner" style="grid-template-columns: minmax(0, 1fr);">
    <div class="bloomli-faq__content">
      {%- if section.settings.heading != blank -%}
        <h2 class="bloomli-faq__heading">{{ section.settings.heading }}</h2>
      {%- endif -%}

      {%- if section.blocks.size > 0 -%}
        <div class="bloomli-faq__items">
          {%- for block in section.blocks -%}
            {%- liquid
              assign button_id = 'BloomliCollapsibleRowButton-' | append: section.id | append: '-' | append: block.id
              assign panel_id = 'BloomliCollapsibleRowPanel-' | append: section.id | append: '-' | append: block.id
              assign icon_alt = block.settings.title | escape
            -%}
            <div class="bloomli-faq__item color-{{ section.settings.container_color_scheme }} gradient" {{ block.shopify_attributes }}>
              <button
                id="{{ button_id }}"
                class="bloomli-faq__question"
                type="button"
                aria-expanded="false"
                aria-controls="{{ panel_id }}"
                data-bloomli-faq-button
              >
                <span style="display: inline-flex; align-items: center; gap: 12px; min-width: 0;">
                  {%- if block.settings.icon != blank -%}
                    {{
                      block.settings.icon
                      | image_url: width: 48
                      | image_tag:
                        widths: '24, 48',
                        sizes: '24px',
                        loading: 'lazy',
                        decoding: 'async',
                        alt: icon_alt,
                        width: 24,
                        height: 24
                    }}
                  {%- endif -%}
                  <span>{{ block.settings.title | escape }}</span>
                </span>
                <span class="bloomli-faq__plus" aria-hidden="true"></span>
              </button>

              <div
                id="{{ panel_id }}"
                class="bloomli-faq__panel"
                role="region"
                aria-labelledby="{{ button_id }}"
                hidden
              >
                <div class="bloomli-faq__panel-inner rte">
                  {{ block.settings.content }}
                </div>
              </div>
            </div>
          {%- endfor -%}
        </div>
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Bloomli - Collapsible row",
  "tag": "div",
  "max_blocks": 8,
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading"
    },
    {
      "type": "header",
      "content": "Color schemes"
    },
    {
      "type": "color_scheme",
      "id": "container_color_scheme",
      "label": "Container color scheme",
      "default": "scheme-4"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Section color scheme",
      "default": "scheme-1"
    },
    {
      "type": "color",
      "id": "border_color",
      "label": "Divider",
      "default": "#E8DED8"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "content_width",
      "label": "Content width",
      "min": 900,
      "max": 1400,
      "step": 20,
      "default": 1180,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "corner_radius",
      "label": "Corner radius",
      "min": 0,
      "max": 28,
      "step": 2,
      "default": 16,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "heading_size",
      "label": "Heading size",
      "min": 32,
      "max": 72,
      "step": 2,
      "default": 48,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "question_size",
      "label": "Row title size",
      "min": 14,
      "max": 24,
      "step": 1,
      "default": 17,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "body_size",
      "label": "Content text size",
      "min": 13,
      "max": 20,
      "step": 1,
      "default": 15,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "min": 40,
      "max": 160,
      "step": 8,
      "default": 88,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "min": 40,
      "max": 160,
      "step": 8,
      "default": 88,
      "unit": "px"
    }
  ],
  "blocks": [
    {
      "type": "row",
      "name": "Row",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Row title",
          "default": "Collapsible row title"
        },
        {
          "type": "richtext",
          "id": "content",
          "label": "Row content",
          "default": "<p>Add details, links, or formatted content for this row.</p>"
        },
        {
          "type": "image_picker",
          "id": "icon",
          "label": "Icon"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Bloomli - Collapsible row",
      "blocks": [
        {
          "type": "row"
        },
        {
          "type": "row",
          "settings": {
            "title": "Materials",
            "content": "<p>Add rich text content for this row.</p>"
          }
        },
        {
          "type": "row",
          "settings": {
            "title": "How to use",
            "content": "<p>Add instructions, links, or formatted copy here.</p>"
          }
        }
      ]
    }
  ]
}
{% endschema %}
