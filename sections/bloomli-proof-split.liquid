<section class="bloomli-proof-split bloomli-section color-{{ section.settings.color_scheme }} gradient" style="{% if section.settings.use_custom_background %}--bps-bg: {{ section.settings.background_color }};{% else %}--bps-bg: var(--bloomli-bg);{% endif %}{% case section.settings.media_background %}{% when 'background' %}--bps-media-bg: var(--bloomli-bg);{% when 'surface_strong' %}--bps-media-bg: var(--bloomli-surface-strong);{% when 'accent_soft' %}--bps-media-bg: rgba(var(--color-button), 0.12);{% else %}--bps-media-bg: var(--bloomli-surface);{% endcase %} padding: {{ section.settings.padding_top }}px 48px {{ section.settings.padding_bottom }}px; background: var(--bps-bg);">
  <div class="bloomli-proof-split__inner" style="max-width: 1120px; margin: 0 auto; display: grid; grid-template-columns: minmax(0, 1fr) minmax(0, 0.9fr); gap: 72px; align-items: center;">
    <div class="bloomli-proof-split__media" style="aspect-ratio: 2 / 3; border-radius: {{ section.settings.image_radius }}px; overflow: hidden; position: relative; background-color: var(--bps-media-bg); {% if section.settings.image == blank %}background-image: repeating-linear-gradient(135deg, var(--bloomli-line-soft) 0 1px, transparent 1px 18px);{% endif %}">
      {%- if section.settings.image != blank -%}
        {%- assign image_scale = section.settings.image_scale | divided_by: 100.0 -%}
        <img src="{{ section.settings.image | image_url: width: 900 }}" srcset="{{ section.settings.image | image_url: width: 500 }} 500w, {{ section.settings.image | image_url: width: 700 }} 700w, {{ section.settings.image | image_url: width: 900 }} 900w, {{ section.settings.image | image_url: width: 1200 }} 1200w" sizes="(max-width: 749px) calc(100vw - 40px), 50vw" alt="{{ section.settings.image.alt | default: section.settings.heading_line1 | escape }}" width="700" height="1050" loading="lazy" style="width: 100%; height: 100%; object-fit: cover; object-position: {{ section.settings.image_position }}; transform: scale({{ image_scale }}); transform-origin: center; display: block;">
      {%- endif -%}
      {%- if section.settings.image_label != blank and section.settings.image == blank -%}
        <span class="smallcaps" style="position: absolute; left: 50%; top: 50%; transform: translate(-50%, -50%); background: var(--bloomli-label-bg); color: var(--bloomli-text-soft); padding: 8px 16px; border-radius: 4px; font-size: 9px; white-space: nowrap;">{{ section.settings.image_label }}</span>
      {%- endif -%}
    </div>

    <div class="bloomli-proof-split__content">
      {%- if section.settings.eyebrow != blank -%}
        <div class="smallcaps" style="color: var(--bloomli-accent); margin-bottom: 18px;">{{ section.settings.eyebrow }}</div>
      {%- endif -%}
      <h2 class="bloomli-proof-split__heading" style="font-family: 'Fraunces', serif; font-variation-settings: 'SOFT' 100; font-size: 52px; line-height: 1.05; font-weight: 400; margin: 0 0 26px; color: var(--bloomli-text);">
        {{ section.settings.heading_line1 }}<br>
        <span style="font-style: italic;">{{ section.settings.heading_line2 }}</span>
      </h2>
      {%- if section.settings.copy != blank -%}
        <div class="bloomli-proof-split__copy" style="font-size: 17px; line-height: 1.65; color: var(--bloomli-text); margin-bottom: 34px;">{{ section.settings.copy }}</div>
      {%- endif -%}
      <div style="display: grid; gap: 18px;">
        {%- for block in section.blocks -%}
          <div {{ block.shopify_attributes }} style="display: grid; grid-template-columns: 22px 1fr; gap: 14px; align-items: start;">
            <span style="width: 20px; height: 20px; border: 1px solid var(--bloomli-accent); border-radius: 999px; display: inline-flex; align-items: center; justify-content: center; color: var(--bloomli-accent); margin-top: 2px;">
              <svg width="11" height="11" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M3 8.5 6.5 12 13 4"/></svg>
            </span>
            <div style="font-size: 15px; line-height: 1.55; color: var(--bloomli-text);">{{ block.settings.text }}</div>
          </div>
        {%- endfor -%}
      </div>
    </div>
  </div>
</section>

<style>
  @media (max-width: 749px) {
    .bloomli-proof-split { padding: 64px 20px !important; }
    .bloomli-proof-split__inner { grid-template-columns: 1fr !important; gap: 36px !important; }
    .bloomli-proof-split__heading { font-size: 36px !important; }
  }
</style>

{% schema %}
{
  "name": "Bloomli - Proof Split",
  "tag": "div",
  "max_blocks": 6,
  "settings": [
    { "type": "color_scheme", "id": "color_scheme", "label": "Color scheme", "default": "scheme-6d8ba907-aae6-4c49-9120-e1031d9cdb3f" },
    { "type": "checkbox", "id": "use_custom_background", "label": "Use custom background color", "default": false },
    { "type": "color", "id": "background_color", "label": "Custom background color", "default": "#FDFAF7" },
    { "type": "image_picker", "id": "image", "label": "Image" },
    { "type": "select", "id": "media_background", "label": "Image placeholder background", "options": [
      { "value": "surface", "label": "Scheme soft surface" },
      { "value": "surface_strong", "label": "Scheme stronger surface" },
      { "value": "background", "label": "Scheme background" },
      { "value": "accent_soft", "label": "Soft accent" }
    ], "default": "surface" },
    { "type": "text", "id": "image_label", "label": "Placeholder label", "default": "Editorial - morning ritual - natural light" },
    { "type": "range", "id": "image_scale", "label": "Uploaded image zoom", "min": 100, "max": 140, "step": 5, "default": 100, "unit": "%" },
    { "type": "select", "id": "image_position", "label": "Image crop position", "options": [
      { "value": "center center", "label": "Center" },
      { "value": "center top", "label": "Top" },
      { "value": "center bottom", "label": "Bottom" },
      { "value": "left center", "label": "Left" },
      { "value": "right center", "label": "Right" }
    ], "default": "center center" },
    { "type": "range", "id": "image_radius", "label": "Image corner radius", "min": 0, "max": 40, "step": 2, "default": 16, "unit": "px" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Clinically dosed - gently made" },
    { "type": "text", "id": "heading_line1", "label": "Heading line 1", "default": "Every milligram," },
    { "type": "text", "id": "heading_line2", "label": "Heading line 2 (italic)", "default": "intentional." },
    { "type": "richtext", "id": "copy", "label": "Copy", "default": "<p>We formulate at clinical doses - the amounts used in peer-reviewed studies - not the sprinkle-doses you'll find in most gummies. Every batch is independently tested. Nothing added for color, nothing hidden in a proprietary blend.</p>" },
    { "type": "range", "id": "padding_top", "label": "Padding top", "min": 48, "max": 176, "step": 8, "default": 104, "unit": "px" },
    { "type": "range", "id": "padding_bottom", "label": "Padding bottom", "min": 48, "max": 176, "step": 8, "default": 104, "unit": "px" }
  ],
  "blocks": [
    {
      "type": "bullet",
      "name": "Checklist item",
      "settings": [
        { "type": "text", "id": "text", "label": "Text", "default": "Clinically-dosed actives. No fairy dust." }
      ]
    }
  ],
  "presets": [
    {
      "name": "Bloomli - Proof Split",
      "blocks": [
        { "type": "bullet", "settings": { "text": "Clinically-dosed actives. No fairy dust." } },
        { "type": "bullet", "settings": { "text": "Vegan pectin base. No gelatin, no artificial dyes." } },
        { "type": "bullet", "settings": { "text": "Third-party tested for purity and potency." } },
        { "type": "bullet", "settings": { "text": "Made in a GMP-certified facility in California." } }
      ]
    }
  ]
}
{% endschema %}
