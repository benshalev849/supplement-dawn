{{ 'bloomli-faq.css' | asset_url | stylesheet_tag }}
<script src="{{ 'bloomli-faq.js' | asset_url }}" defer="defer"></script>

{%- liquid
  assign image_alt = section.settings.image_alt | default: section.settings.image.alt | escape
-%}

<section
  class="bloomli-faq bloomli-faq--image-{{ section.settings.image_position }}"
  data-bloomli-faq
  style="
    --bf-background: {{ section.settings.background_color }};
    --bf-media-background: {{ section.settings.media_background_color }};
    --bf-text: {{ section.settings.text_color }};
    --bf-muted: {{ section.settings.muted_color }};
    --bf-accent: {{ section.settings.accent_color }};
    --bf-border: {{ section.settings.border_color }};
    --bf-content-width: {{ section.settings.content_width }}px;
    --bf-image-width: {{ section.settings.image_width }}px;
    --bf-radius: {{ section.settings.corner_radius }}px;
    --bf-heading-size: {{ section.settings.heading_size }}px;
    --bf-question-size: {{ section.settings.question_size }}px;
    --bf-body-size: {{ section.settings.body_size }}px;
    --bf-padding-top: {{ section.settings.padding_top }}px;
    --bf-padding-bottom: {{ section.settings.padding_bottom }}px;
  "
>
  <div class="bloomli-faq__inner">
    <div class="bloomli-faq__content">
      {%- if section.settings.eyebrow != blank -%}
        <p class="smallcaps bloomli-faq__eyebrow">{{ section.settings.eyebrow }}</p>
      {%- endif -%}

      {%- if section.settings.heading != blank -%}
        <h2 class="bloomli-faq__heading">{{ section.settings.heading }}</h2>
      {%- endif -%}

      {%- if section.settings.intro != blank -%}
        <div class="bloomli-faq__intro rte">
          {{ section.settings.intro }}
        </div>
      {%- endif -%}

      {%- if section.blocks.size > 0 -%}
        <div class="bloomli-faq__items">
          {%- for block in section.blocks -%}
            {%- liquid
              assign button_id = 'BloomliFaqButton-' | append: section.id | append: '-' | append: block.id
              assign panel_id = 'BloomliFaqPanel-' | append: section.id | append: '-' | append: block.id
              assign is_open = block.settings.open_by_default
            -%}
            <div class="bloomli-faq__item" {{ block.shopify_attributes }}>
              <button
                id="{{ button_id }}"
                class="bloomli-faq__question"
                type="button"
                aria-expanded="{% if is_open %}true{% else %}false{% endif %}"
                aria-controls="{{ panel_id }}"
                data-bloomli-faq-button
              >
                <span>{{ block.settings.question | escape }}</span>
                <span class="bloomli-faq__plus" aria-hidden="true"></span>
              </button>

              <div
                id="{{ panel_id }}"
                class="bloomli-faq__panel"
                role="region"
                aria-labelledby="{{ button_id }}"
                {% unless is_open %}
                  hidden
                {% endunless %}
              >
                <div class="bloomli-faq__panel-inner rte">
                  {{ block.settings.answer }}
                </div>
              </div>
            </div>
          {%- endfor -%}
        </div>
      {%- endif -%}
    </div>

    {%- if section.settings.image != blank or section.settings.show_placeholder -%}
      <div class="bloomli-faq__media">
        {%- if section.settings.image != blank -%}
          {{
            section.settings.image
            | image_url: width: 1200
            | image_tag:
              widths: '360, 540, 720, 900, 1080, 1200',
              sizes: '(min-width: 990px) 40vw, 100vw',
              loading: 'lazy',
              decoding: 'async',
              alt: image_alt,
              class: 'bloomli-faq__image'
          }}
        {%- else -%}
          <div class="bloomli-faq__placeholder" aria-hidden="true"></div>
        {%- endif -%}
      </div>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Bloomli - FAQ",
  "tag": "div",
  "max_blocks": 12,
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "FAQ"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Questions, answered."
    },
    {
      "type": "richtext",
      "id": "intro",
      "label": "Intro text",
      "default": "<p>Everything you need to know before making Bloomli part of your routine.</p>"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    },
    {
      "type": "text",
      "id": "image_alt",
      "label": "Image alt text"
    },
    {
      "type": "checkbox",
      "id": "show_placeholder",
      "label": "Show placeholder when no image is selected",
      "default": true
    },
    {
      "type": "select",
      "id": "image_position",
      "label": "Image position on desktop",
      "options": [
        {
          "value": "right",
          "label": "Right"
        },
        {
          "value": "left",
          "label": "Left"
        }
      ],
      "default": "right"
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background",
      "default": "#FDFAF7"
    },
    {
      "type": "color",
      "id": "media_background_color",
      "label": "Image background",
      "default": "#F3E1E5"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text",
      "default": "#2A2622"
    },
    {
      "type": "color",
      "id": "muted_color",
      "label": "Body text",
      "default": "#7C7169"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent",
      "default": "#8A6678"
    },
    {
      "type": "color",
      "id": "border_color",
      "label": "Divider",
      "default": "#E8DED8"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "content_width",
      "label": "Content width",
      "min": 900,
      "max": 1400,
      "step": 20,
      "default": 1180,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "image_width",
      "label": "Image width",
      "min": 280,
      "max": 560,
      "step": 20,
      "default": 460,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "corner_radius",
      "label": "Image corner radius",
      "min": 0,
      "max": 28,
      "step": 2,
      "default": 16,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "heading_size",
      "label": "Heading size",
      "min": 32,
      "max": 72,
      "step": 2,
      "default": 48,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "question_size",
      "label": "Question text size",
      "min": 14,
      "max": 24,
      "step": 1,
      "default": 17,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "body_size",
      "label": "Body text size",
      "min": 13,
      "max": 20,
      "step": 1,
      "default": 15,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "min": 40,
      "max": 160,
      "step": 8,
      "default": 88,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "min": 40,
      "max": 160,
      "step": 8,
      "default": 88,
      "unit": "px"
    }
  ],
  "blocks": [
    {
      "type": "question",
      "name": "Question",
      "settings": [
        {
          "type": "text",
          "id": "question",
          "label": "Question",
          "default": "How long does Bloomli take to work?"
        },
        {
          "type": "richtext",
          "id": "answer",
          "label": "Answer",
          "default": "<p>Hair wellness is gradual. Most customers build a consistent routine for at least 3 to 6 months.</p>"
        },
        {
          "type": "checkbox",
          "id": "open_by_default",
          "label": "Open by default",
          "default": false
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Bloomli - FAQ",
      "blocks": [
        {
          "type": "question"
        },
        {
          "type": "question",
          "settings": {
            "question": "Can I take it every day?",
            "answer": "<p>Yes. Bloomli is designed as a daily ritual. Always follow the product directions and your clinician's guidance if you have a specific concern.</p>"
          }
        },
        {
          "type": "question",
          "settings": {
            "question": "Is this section editable?",
            "answer": "<p>Yes. You can edit each question, answer, colors, typography, spacing, and the image from the Shopify theme editor.</p>"
          }
        }
      ]
    }
  ]
}
{% endschema %}
