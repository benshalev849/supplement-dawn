{{ 'bloomli-science.css' | asset_url | stylesheet_tag }}

<section
  class="bloomli-science-section bloomli-science-standard color-{{ section.settings.color_scheme }} gradient"
  style="--section-padding-top: {{ section.settings.padding_top }}px; --section-padding-bottom: {{ section.settings.padding_bottom }}px; --section-padding-top-mobile: {{ section.settings.padding_top_mobile }}px; --section-padding-bottom-mobile: {{ section.settings.padding_bottom_mobile }}px;"
>
  <div class="bloomli-science-section__inner">
    <div class="bloomli-science-standard__header">
      {%- if section.settings.heading != blank -%}
        <h2 class="bloomli-science-section__heading">{{ section.settings.heading | escape }}</h2>
      {%- endif -%}
      {%- if section.settings.body != blank -%}
        <div class="bloomli-science-section__copy rte">{{ section.settings.body }}</div>
      {%- endif -%}
    </div>

    <div class="bloomli-science-grid bloomli-science-standard__grid">
      {%- for block in section.blocks -%}
        <article class="bloomli-science-card" {{ block.shopify_attributes }}>
          <span class="bloomli-science-card__number">{%- if forloop.index < 10 -%}0{%- endif -%}{{ forloop.index }}</span>
          <h3>{{ block.settings.title | escape }}</h3>
          <p>{{ block.settings.text | escape }}</p>
        </article>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Bloomli - Science Std",
  "tag": "div",
  "max_blocks": 4,
  "settings": [
    { "type": "color_scheme", "id": "color_scheme", "label": "Color scheme", "default": "scheme-c080e6f6-81c2-4466-90ab-623088a7219d" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Science-backed should mean more than a trendy ingredient list." },
    { "type": "richtext", "id": "body", "label": "Body", "default": "<p>In beauty supplements, \"science-backed\" can mean many things. At Bloomli, it means every formula starts with a clear purpose, uses ingredients with a relevant role in hair, skin, nail, or scalp wellness, and avoids claims that sound bigger than the evidence behind them.</p>" },
    { "type": "range", "id": "padding_top", "label": "Padding top", "min": 0, "max": 160, "step": 8, "default": 88, "unit": "px" },
    { "type": "range", "id": "padding_bottom", "label": "Padding bottom", "min": 0, "max": 160, "step": 8, "default": 88, "unit": "px" },
    { "type": "range", "id": "padding_top_mobile", "label": "Padding top mobile", "min": 0, "max": 120, "step": 8, "default": 56, "unit": "px" },
    { "type": "range", "id": "padding_bottom_mobile", "label": "Padding bottom mobile", "min": 0, "max": 120, "step": 8, "default": 56, "unit": "px" }
  ],
  "blocks": [
    {
      "type": "standard",
      "name": "Standard",
      "settings": [
        { "type": "text", "id": "title", "label": "Title", "default": "Purpose before hype" },
        { "type": "textarea", "id": "text", "label": "Text", "default": "We choose ingredients because they have a clear role in the formula - not because they are trending on TikTok." }
      ]
    }
  ],
  "presets": [{ "name": "Bloomli - Science Standard" }]
}
{% endschema %}
