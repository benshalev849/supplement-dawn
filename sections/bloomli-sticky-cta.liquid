{%- if section.settings.enabled -%}
<div
  class="bloomli-sticky-cta"
  id="bloomli-sticky-cta-{{ section.id }}"
  data-scroll-target="{{ section.settings.scroll_target }}"
  data-proximity-margin="{{ section.settings.proximity_margin }}"
  aria-hidden="true"
  style="
    --bscta-bg: {{ section.settings.bg_color }};
    --bscta-text: {{ section.settings.text_color }};
    --bscta-badge-bg: {{ section.settings.badge_bg }};
    --bscta-badge-text: {{ section.settings.badge_text_color }};
    --bscta-star: {{ section.settings.star_color }};
    --bscta-scrim: {{ section.settings.scrim_color }};
  "
>
  <div class="bloomli-sticky-cta__scrim" aria-hidden="true"></div>
  <button
    class="bloomli-sticky-cta__btn"
    type="button"
    aria-label="{{ section.settings.main_text | escape }}"
  >
    {%- if section.settings.badge_text != blank -%}
      <span class="bloomli-sticky-cta__badge">{{ section.settings.badge_text }}</span>
    {%- endif -%}
    <span class="bloomli-sticky-cta__main">{{ section.settings.main_text }}</span>
    {%- if section.settings.social_proof != blank -%}
      <span class="bloomli-sticky-cta__social">
        {%- if section.settings.show_stars -%}
          <span class="bloomli-sticky-cta__stars" aria-hidden="true">
            {%- for i in (1..5) -%}★{%- endfor -%}
          </span>
        {%- endif -%}
        {{ section.settings.social_proof }}
      </span>
    {%- endif -%}
  </button>
</div>

<script>
  (function () {
    var el = document.getElementById('bloomli-sticky-cta-{{ section.id }}');
    if (!el) return;

    var margin = parseInt(el.dataset.proximityMargin, 10);
    if (isNaN(margin)) margin = 250;
    var selector = el.dataset.scrollTarget;
    var visible = false;
    var ticking = false;

    function targetEl() {
      return selector ? document.querySelector(selector) : null;
    }

    function update() {
      ticking = false;
      var dest = targetEl();
      var shouldShow;

      if (dest) {
        // Distance the target sits outside the viewport, in either direction.
        var rect = dest.getBoundingClientRect();
        var vh = window.innerHeight || document.documentElement.clientHeight;
        var below = rect.top - vh; // > 0 → target is below the fold
        var above = -rect.bottom;  // > 0 → target is above the top of the screen
        var offscreenBy = Math.max(below, above, 0);
        // Show once the target is more than `margin` px out of view (above or below).
        shouldShow = offscreenBy > margin;
      } else {
        // No target on this page → fall back to a simple scroll distance.
        shouldShow = (window.scrollY || window.pageYOffset) > margin;
      }

      if (shouldShow === visible) return;
      visible = shouldShow;
      el.setAttribute('aria-hidden', String(!visible));
      el.classList.toggle('bloomli-sticky-cta--visible', visible);
    }

    function onScroll() {
      if (ticking) return;
      ticking = true;
      window.requestAnimationFrame(update);
    }

    window.addEventListener('scroll', onScroll, { passive: true });
    window.addEventListener('resize', onScroll, { passive: true });
    update();

    el.querySelector('.bloomli-sticky-cta__btn').addEventListener('click', function () {
      var dest = targetEl();
      if (dest) {
        dest.scrollIntoView({ behavior: 'smooth', block: 'start' });
      } else {
        window.scrollTo({ top: 0, behavior: 'smooth' });
      }
    });
  })();
</script>
{%- endif -%}

{% schema %}
{
  "name": "Sticky CTA bar",
  "tag": "div",
  "class": "bloomli-sticky-cta-section",
  "enabled_on": {
    "templates": ["page", "index", "product", "collection"]
  },
  "settings": [
    {
      "type": "checkbox",
      "id": "enabled",
      "label": "Enable sticky CTA",
      "default": true
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "badge_text",
      "label": "Badge text",
      "default": "100M+ Gummies Sold",
      "info": "Small pill badge above the main text. Leave blank to hide."
    },
    {
      "type": "text",
      "id": "main_text",
      "label": "Main CTA text",
      "default": "Save 61% + Free Gifts"
    },
    {
      "type": "text",
      "id": "social_proof",
      "label": "Social proof text",
      "default": "4.8 stars | 100K+ reviews | 1M+ members",
      "info": "Leave blank to hide the social proof row."
    },
    {
      "type": "checkbox",
      "id": "show_stars",
      "label": "Show star icons",
      "default": true
    },
    {
      "type": "header",
      "content": "Behaviour"
    },
    {
      "type": "text",
      "id": "scroll_target",
      "label": "Scroll-to anchor",
      "default": "#glp1-offers",
      "info": "CSS selector for the element to scroll to when the button is clicked. e.g. #glp1-offers"
    },
    {
      "type": "range",
      "id": "proximity_margin",
      "label": "Show when target is off-screen by (px)",
      "min": 0,
      "max": 1200,
      "step": 50,
      "default": 250,
      "info": "The bar appears once the target section is this far above or below the viewport, and hides while the target is in view."
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Button background",
      "default": "#b23a6f"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Button text",
      "default": "#fdfaf7"
    },
    {
      "type": "color",
      "id": "badge_bg",
      "label": "Badge background",
      "default": "#fdfaf7"
    },
    {
      "type": "color",
      "id": "badge_text_color",
      "label": "Badge text color",
      "default": "#b23a6f"
    },
    {
      "type": "color",
      "id": "star_color",
      "label": "Star color",
      "default": "#fdfaf7"
    },
    {
      "type": "color",
      "id": "scrim_color",
      "label": "Fade background color",
      "default": "#fdfaf7",
      "info": "The page content fades into this color behind the bar. Set it to match the page background where the bar appears."
    }
  ],
  "presets": [
    {
      "name": "Sticky CTA bar"
    }
  ]
}
{% endschema %}
