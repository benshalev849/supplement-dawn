{%- liquid
  assign product_1 = section.settings.product_1
  assign product_2 = section.settings.product_2
  assign current_product = product

  assign first_product = product_1
  assign second_product = product_2
  assign first_image = section.settings.product_1_image
  assign second_image = section.settings.product_2_image

  if current_product != blank
    if product_2 != blank and current_product.id == product_2.id
      assign first_product = product_2
      assign second_product = product_1
      assign first_image = section.settings.product_2_image
      assign second_image = section.settings.product_1_image
    elsif product_1 != blank and current_product.id == product_1.id
      assign first_product = product_1
      assign second_product = product_2
      assign first_image = section.settings.product_1_image
      assign second_image = section.settings.product_2_image
    else
      assign first_product = current_product
      if product_2 != blank and current_product.id != product_2.id
        assign second_product = product_2
        assign second_image = section.settings.product_2_image
      else
        assign second_product = product_1
        assign second_image = section.settings.product_1_image
      endif
    endif
  endif

  assign first_variant = first_product.selected_or_first_available_variant
  assign second_variant = second_product.selected_or_first_available_variant

  assign first_in_cart = false
  assign second_in_cart = false
  for item in cart.items
    if first_product != blank and item.product.id == first_product.id
      assign first_in_cart = true
    endif
    if second_product != blank and item.product.id == second_product.id
      assign second_in_cart = true
    endif
  endfor

  assign add_both_label = section.settings.add_both_label | default: 'Add Both & Save'
  assign view_routine_label = section.settings.view_routine_label | default: 'View My Routine'
  assign add_missing_template = section.settings.add_missing_label | default: 'Add [product] & Save'

  assign button_label = add_both_label
  assign first_missing = false
  assign second_missing = false
  if first_product != blank and first_in_cart == false
    assign first_missing = true
  endif
  if second_product != blank and second_in_cart == false
    assign second_missing = true
  endif

  if first_missing and second_missing
    assign button_label = add_both_label
  elsif first_missing
    assign missing_title = first_product.title
    assign button_label = add_missing_template | replace: '[product]', missing_title
  elsif second_missing
    assign missing_title = second_product.title
    assign button_label = add_missing_template | replace: '[product]', missing_title
  else
    assign button_label = view_routine_label
  endif
-%}

<section
  class="bloomli-bundle bloomli-section"
  style="--bloomli-padding-top: {{ section.settings.padding_top }}px; --bloomli-padding-bottom: {{ section.settings.padding_bottom }}px; background-color: {{ section.settings.background_color }};"
>
  <div class="bloomli-bundle__inner">
    {%- if section.settings.heading != blank -%}
      <h2 class="bloomli-bundle__heading">
        {{ section.settings.heading | escape | newline_to_br }}
      </h2>
    {%- endif -%}

    {%- if section.settings.body_text != blank -%}
      <p class="bloomli-bundle__copy">
        {{ section.settings.body_text | escape }}
      </p>
    {%- endif -%}

    <div class="bloomli-bundle__products">
      {%- if first_image != blank -%}
        {{
          first_image
          | image_url: width: 520
          | image_tag:
            class: 'bloomli-bundle__product',
            widths: '180, 260, 360, 520',
            sizes: '(max-width: 749px) 44vw, 180px',
            loading: 'lazy',
            decoding: 'async',
            alt: first_image.alt | default: first_product.title
        }}
      {%- elsif first_product.featured_image != blank -%}
        {{
          first_product.featured_image
          | image_url: width: 520
          | image_tag:
            class: 'bloomli-bundle__product',
            widths: '180, 260, 360, 520',
            sizes: '(max-width: 749px) 44vw, 180px',
            loading: 'lazy',
            decoding: 'async',
            alt: first_product.featured_image.alt | default: first_product.title
        }}
      {%- endif -%}

      {%- if second_image != blank -%}
        {{
          second_image
          | image_url: width: 520
          | image_tag:
            class: 'bloomli-bundle__product',
            widths: '180, 260, 360, 520',
            sizes: '(max-width: 749px) 44vw, 180px',
            loading: 'lazy',
            decoding: 'async',
            alt: second_image.alt | default: second_product.title
        }}
      {%- elsif second_product.featured_image != blank -%}
        {{
          second_product.featured_image
          | image_url: width: 520
          | image_tag:
            class: 'bloomli-bundle__product',
            widths: '180, 260, 360, 520',
            sizes: '(max-width: 749px) 44vw, 180px',
            loading: 'lazy',
            decoding: 'async',
            alt: second_product.featured_image.alt | default: second_product.title
        }}
      {%- endif -%}
    </div>

    <div class="bloomli-bundle__cta-wrap">
      <button
        type="button"
        class="button button--primary"
        data-bloomli-bundle-promo-button
        data-first-variant-id="{{ first_variant.id }}"
        data-second-variant-id="{{ second_variant.id }}"
        data-first-in-cart="{{ first_in_cart }}"
        data-second-in-cart="{{ second_in_cart }}"
        data-view-routine-label="{{ view_routine_label | escape }}"
        {% if first_variant == blank and second_variant == blank %}disabled{% endif %}
      >
        {{ button_label | escape }}
      </button>
    </div>
  </div>
</section>

<script>
  (() => {
    const section = document.currentScript.closest('.shopify-section');
    const button = section && section.querySelector('[data-bloomli-bundle-promo-button]');
    if (!button || button.dataset.initialized === 'true') return;
    button.dataset.initialized = 'true';

    const getSections = () => {
      const sections = ['cart-icon-bubble'];
      if (document.getElementById('CartDrawer')) sections.push('cart-drawer');
      return sections;
    };

    const openCartDrawer = () => {
      const cartDrawer = document.querySelector('cart-drawer');
      if (cartDrawer && typeof cartDrawer.open === 'function') {
        cartDrawer.open(button);
        return;
      }
      const cartLink = document.getElementById('cart-icon-bubble');
      if (cartLink) cartLink.click();
    };

    button.addEventListener('click', () => {
      const items = [];
      const firstVariantId = parseInt(button.dataset.firstVariantId, 10);
      const secondVariantId = parseInt(button.dataset.secondVariantId, 10);

      if (button.dataset.firstInCart !== 'true' && firstVariantId) items.push({ id: firstVariantId, quantity: 1 });
      if (button.dataset.secondInCart !== 'true' && secondVariantId) items.push({ id: secondVariantId, quantity: 1 });

      if (!items.length) {
        openCartDrawer();
        return;
      }

      button.disabled = true;

      fetch(routes.cart_add_url, {
        ...fetchConfig(),
        body: JSON.stringify({
          items,
          sections: getSections(),
          sections_url: window.location.pathname,
        }),
      })
        .then((response) => response.json())
        .then((parsedState) => {
          const cartDrawer = document.querySelector('cart-drawer');
          if (cartDrawer && typeof cartDrawer.renderContents === 'function' && parsedState.sections) {
            cartDrawer.renderContents(parsedState);
          } else {
            openCartDrawer();
          }
          button.dataset.firstInCart = 'true';
          button.dataset.secondInCart = 'true';
          button.textContent = button.dataset.viewRoutineLabel || 'View My Routine';
          button.disabled = false;
        })
        .catch(() => {
          button.disabled = false;
        });
    });
  })();
</script>

{% schema %}
{
  "name": "Bloomli — Bundle Promo",
  "tag": "div",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Section heading text",
      "default": "Inside & out. Save 20%."
    },
    {
      "type": "textarea",
      "id": "body_text",
      "label": "Body text",
      "default": "The Root Ritual gummies that work from within, paired with our moisturizing & strengthening hair oil for visible shine day one."
    },
    {
      "type": "product",
      "id": "product_1",
      "label": "Product 1"
    },
    {
      "type": "product",
      "id": "product_2",
      "label": "Product 2"
    },
    {
      "type": "image_picker",
      "id": "product_1_image",
      "label": "Product 1 image"
    },
    {
      "type": "image_picker",
      "id": "product_2_image",
      "label": "Product 2 image"
    },
    {
      "type": "text",
      "id": "add_both_label",
      "label": "Add both button label",
      "placeholder": "Add Both & Save"
    },
    {
      "type": "text",
      "id": "add_missing_label",
      "label": "Add missing product button label",
      "placeholder": "Add [product] & Save",
      "info": "Use [product] to insert the missing product title."
    },
    {
      "type": "text",
      "id": "view_routine_label",
      "label": "View routine button label",
      "placeholder": "View My Routine"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Section background color",
      "default": "#FDF7F1"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top (px)",
      "min": 48,
      "max": 160,
      "step": 8,
      "default": 96
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom (px)",
      "min": 48,
      "max": 160,
      "step": 8,
      "default": 96
    }
  ],
  "presets": [{ "name": "Bloomli — Bundle Promo" }]
}
{% endschema %}
