{%- assign has_bg_image = false -%}
{%- if section.settings.desktop_image != blank -%}{%- assign has_bg_image = true -%}{%- endif -%}

<section
  class="bloomli-hero bloomli-section color-{{ section.settings.color_scheme }} gradient{% unless has_bg_image %}{% if section.settings.use_brand_gradient %} bloomli-hero--brand-gradient{% endif %}{% endunless %}{% if has_bg_image %} bloomli-hero--has-bg-image{% if section.settings.desktop_image_layout == 'image_ratio_16_9' %} bloomli-hero--fit-16-9{% endif %}{% endif %}"
  style="
    --hero-min-height: {{ section.settings.min_height }}px;
    --hero-overlay-opacity: {{ section.settings.overlay_opacity | divided_by: 100.0 }};
    --section-padding-top: {{ section.settings.padding_top }}px;
    --section-padding-bottom: {{ section.settings.padding_bottom }}px;
    --section-padding-top-mobile: {{ section.settings.padding_top_mobile }}px;
    --section-padding-bottom-mobile: {{ section.settings.padding_bottom_mobile }}px;
    --hero-desktop-image-fit: {{ section.settings.desktop_image_fit | default: 'contain' }};
    --hero-desktop-image-position: {{ section.settings.desktop_image_position | default: 'center' }};
    --hero-mobile-image-fit: {{ section.settings.mobile_image_fit | default: 'contain' }};
    --hero-mobile-image-position: {{ section.settings.mobile_image_position | default: 'center bottom' }};
    {%- if section.settings.use_custom_text_color -%}
      --hero-text-color: {{ section.settings.text_color }};
    {%- endif -%}
    {%- if section.settings.use_custom_accent_color -%}
      --hero-accent-color: {{ section.settings.accent_color }};
    {%- endif -%}
  "
>
  {%- if has_bg_image -%}
    <div class="bloomli-hero__bg{% if section.settings.mobile_image != blank %} bloomli-hero__bg--has-mobile{% endif %}" aria-hidden="true">
      {{
        section.settings.desktop_image
        | image_url: width: 1920
        | image_tag:
          class: 'bloomli-hero__bg-img bloomli-hero__bg-img--desktop',
          alt: '',
          widths: '960, 1440, 1920',
          sizes: '100vw',
          loading: 'eager',
          fetchpriority: 'high',
          decoding: 'async'
      }}
      {%- if section.settings.mobile_image != blank -%}
        {{
          section.settings.mobile_image
          | image_url: width: 900
          | image_tag:
            class: 'bloomli-hero__bg-img bloomli-hero__bg-img--mobile',
            alt: '',
            widths: '400, 600, 900',
            sizes: '100vw',
            loading: 'eager',
            fetchpriority: 'high',
            decoding: 'async'
        }}
      {%- endif -%}
      <div class="bloomli-hero__overlay"></div>
    </div>
  {%- endif -%}

  <div class="bloomli-hero__inner bloomli-hero__inner--mobile-{{ section.settings.content_position_mobile }}">
    <div class="bloomli-hero__copy">
      {%- if section.settings.show_reviews -%}
        <div class="bloomli-hero__reviews">
          <span class="bloomli-hero__stars" aria-hidden="true">&#9733;&#9733;&#9733;&#9733;&#9733;</span>
          <span class="bloomli-hero__review-text">
            {{ section.settings.star_rating_text | default: '4.8 Stars · 2,400+ Reviews' }}
          </span>
        </div>
      {%- endif -%}

      <h1 class="bloomli-hero__headline">
        {{ section.settings.headline_line1 }}<br>
        <span>{{ section.settings.headline_line2 }}</span>
      </h1>

      {%- if section.settings.subtext != blank -%}
        <p class="bloomli-hero__subtext">
          {{ section.settings.subtext }}
        </p>
      {%- endif -%}

      <div class="bloomli-hero__ctas color-{{ section.settings.button_color_scheme }}">
        {%- if section.settings.cta_primary_label != blank -%}
          {%- assign cta_primary_href = section.settings.cta_primary_url | default: routes.all_products_collection_url -%}
          <a href="{{ cta_primary_href }}" class="button button--primary">{{ section.settings.cta_primary_label }}</a>
        {%- endif -%}
        {%- if section.settings.cta_secondary_label != blank and section.settings.cta_secondary_url != blank -%}
          <a href="{{ section.settings.cta_secondary_url }}" class="button button--secondary">{{ section.settings.cta_secondary_label }}</a>
        {%- endif -%}
      </div>

      {%- if section.settings.trust_badge_1 != blank or section.settings.trust_badge_2 != blank or section.settings.trust_badge_3 != blank -%}
        <div class="bloomli-hero__trust-badges" aria-label="Trust badges">
          {%- if section.settings.trust_badge_1 != blank -%}
            <span class="bloomli-hero__trust-badge">
              <i class="ti ti-shield-check" aria-hidden="true"></i>
              <span>{{ section.settings.trust_badge_1 }}</span>
            </span>
          {%- endif -%}
          {%- if section.settings.trust_badge_2 != blank -%}
            <span class="bloomli-hero__trust-badge">
              <i class="ti ti-shield-check" aria-hidden="true"></i>
              <span>{{ section.settings.trust_badge_2 }}</span>
            </span>
          {%- endif -%}
          {%- if section.settings.trust_badge_3 != blank -%}
            <span class="bloomli-hero__trust-badge">
              <i class="ti ti-shield-check" aria-hidden="true"></i>
              <span>{{ section.settings.trust_badge_3 }}</span>
            </span>
          {%- endif -%}
        </div>
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Bloomli — Hero",
  "tag": "div",
  "class": "bloomli-hero-wrapper",
  "settings": [
    { "type": "header", "content": "Copy" },
    { "type": "color_scheme", "id": "color_scheme", "label": "Color scheme", "default": "scheme-6d8ba907-aae6-4c49-9120-e1031d9cdb3f" },
    { "type": "checkbox", "id": "use_brand_gradient", "label": "Use Bloomli brand gradient", "default": true },
    { "type": "text",     "id": "headline_line1",  "label": "Headline line 1",         "default": "Quiet science," },
    { "type": "text",     "id": "headline_line2",  "label": "Headline line 2 (italic)", "default": "visible results." },
    { "type": "textarea", "id": "subtext",         "label": "Subtext",                 "default": "Gummies, capsules, or strips — clinically-formulated hair support in the form that fits your ritual. Backed by science, designed for real life." },
    { "type": "range",    "id": "min_height",      "label": "Min height (px)",         "min": 500, "max": 900, "step": 20, "default": 720 },
    { "type": "range",    "id": "padding_top",     "label": "Padding top",             "min": 0, "max": 176, "step": 8, "default": 80, "unit": "px" },
    { "type": "range",    "id": "padding_bottom",  "label": "Padding bottom",          "min": 0, "max": 176, "step": 8, "default": 80, "unit": "px" },
    { "type": "range",    "id": "padding_top_mobile", "label": "Padding top mobile",   "min": 0, "max": 176, "step": 8, "default": 56, "unit": "px" },
    { "type": "range",    "id": "padding_bottom_mobile", "label": "Padding bottom mobile", "min": 0, "max": 176, "step": 8, "default": 56, "unit": "px" },
    { "type": "header", "content": "CTAs" },
    { "type": "color_scheme", "id": "button_color_scheme", "label": "Button color scheme", "default": "scheme-6d8ba907-aae6-4c49-9120-e1031d9cdb3f" },
    { "type": "text", "id": "cta_primary_label",   "label": "CTA button label",    "default": "Start Your Ritual" },
    { "type": "url",  "id": "cta_primary_url",     "label": "CTA button URL" },
    { "type": "text", "id": "cta_secondary_label", "label": "Secondary button label",  "default": "Take the 2-min Quiz" },
    { "type": "url",  "id": "cta_secondary_url",   "label": "Secondary button URL" },
    { "type": "header", "content": "Reviews badge" },
    { "type": "checkbox", "id": "show_reviews",    "label": "Show reviews badge", "default": true },
    { "type": "text",     "id": "star_rating_text", "label": "Star rating text",  "default": "4.8 Stars · 2,400+ Reviews" },
    { "type": "header", "content": "Trust badges" },
    { "type": "text", "id": "trust_badge_1", "label": "Badge 1 text", "default": "Third-Party Tested" },
    { "type": "text", "id": "trust_badge_2", "label": "Badge 2 text", "default": "NSF-Certified Facility" },
    { "type": "text", "id": "trust_badge_3", "label": "Badge 3 text", "default": "Made in the USA" },
    { "type": "header", "content": "Background image" },
    { "type": "image_picker", "id": "desktop_image", "label": "Desktop background (16:9 landscape)" },
    {
      "type": "select",
      "id": "desktop_image_layout",
      "label": "Desktop image layout",
      "default": "fixed_height_background",
      "options": [
        { "value": "fixed_height_background", "label": "Background fill (fixed height)" },
        { "value": "image_ratio_16_9",        "label": "16:9 — show full image" }
      ]
    },
    {
      "type": "select",
      "id": "desktop_image_fit",
      "label": "Desktop image fit",
      "default": "contain",
      "options": [
        { "value": "contain", "label": "Contain (show full image)" },
        { "value": "cover",   "label": "Cover (crop to fill)" }
      ]
    },
    {
      "type": "select",
      "id": "desktop_image_position",
      "label": "Desktop image position",
      "default": "center",
      "options": [
        { "value": "center",        "label": "Center" },
        { "value": "center top",    "label": "Top" },
        { "value": "center bottom", "label": "Bottom" },
        { "value": "left center",   "label": "Left" },
        { "value": "right center",  "label": "Right" }
      ]
    },
    { "type": "image_picker", "id": "mobile_image",  "label": "Mobile background (3:4 portrait, optional — falls back to desktop)" },
    {
      "type": "select",
      "id": "mobile_image_fit",
      "label": "Mobile image fit",
      "default": "contain",
      "options": [
        { "value": "contain", "label": "Contain (show full image)" },
        { "value": "cover",   "label": "Cover (crop to fill)" }
      ]
    },
    {
      "type": "select",
      "id": "mobile_image_position",
      "label": "Mobile image position",
      "default": "center bottom",
      "options": [
        { "value": "center",        "label": "Center" },
        { "value": "center top",    "label": "Top" },
        { "value": "center bottom", "label": "Bottom" },
        { "value": "left center",   "label": "Left" },
        { "value": "right center",  "label": "Right" }
      ]
    },
    { "type": "range",  "id": "overlay_opacity", "label": "Overlay opacity", "min": 0, "max": 80, "step": 5, "default": 45 },
    { "type": "checkbox", "id": "use_custom_text_color", "label": "Override hero text color", "default": false },
    { "type": "color",  "id": "text_color", "label": "Text color override", "default": "#2a2622" },
    { "type": "checkbox", "id": "use_custom_accent_color", "label": "Override hero accent color", "default": false },
    { "type": "color",  "id": "accent_color", "label": "Accent color override", "default": "#b23a6f" },
    {
      "type": "select",
      "id": "content_position_mobile",
      "label": "Content position — mobile",
      "default": "top",
      "options": [
        { "value": "top",    "label": "Top" },
        { "value": "center", "label": "Center" },
        { "value": "bottom", "label": "Bottom" }
      ]
    }
  ],
  "presets": [{ "name": "Bloomli — Hero" }]
}
{% endschema %}
