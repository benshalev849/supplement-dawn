{{ 'bloomli-glp1-compare.css' | asset_url | stylesheet_tag }}

<section
  class="bloomli-glp1-compare color-{{ section.settings.color_scheme }} gradient"
  style="
    --glp1-compare-accent: {{ section.settings.accent_color }};
    --glp1-compare-emphasis: {{ section.settings.emphasis_color }};
    --glp1-compare-card: {{ section.settings.column_background }};
    --glp1-compare-featured: {{ section.settings.featured_background }};
    --glp1-compare-muted: {{ section.settings.muted_color }};
    --glp1-compare-badge-text: {{ section.settings.badge_text_color }};
    --glp1-compare-radius: {{ section.settings.column_radius }}px;
    --glp1-compare-columns: {{ section.blocks.size }};
    --glp1-compare-heading: {{ section.settings.heading_size }}px;
    --glp1-compare-heading-mobile: {{ section.settings.heading_size_mobile }}px;
    --glp1-compare-padding-top: {{ section.settings.padding_top }}px;
    --glp1-compare-padding-bottom: {{ section.settings.padding_bottom }}px;
    --glp1-compare-padding-top-mobile: {{ section.settings.padding_top_mobile }}px;
    --glp1-compare-padding-bottom-mobile: {{ section.settings.padding_bottom_mobile }}px;
  "
>
  <div class="bloomli-glp1-compare__inner">
    <header class="bloomli-glp1-compare__header">
      {%- if section.settings.heading != blank -%}
        <h2 class="bloomli-glp1-compare__title">{{ section.settings.heading }}</h2>
      {%- endif -%}
      {%- if section.settings.intro != blank -%}
        <p class="bloomli-glp1-compare__intro">{{ section.settings.intro }}</p>
      {%- endif -%}
    </header>

    <div class="bloomli-glp1-compare__grid">
      {%- for block in section.blocks -%}
        <article
          class="bloomli-glp1-compare__column{% if block.settings.featured %} bloomli-glp1-compare__column--featured{% endif %}"
          {{ block.shopify_attributes }}
        >
          <header class="bloomli-glp1-compare__column-header">
            {%- if block.settings.featured and block.settings.badge != blank -%}
              <span class="bloomli-glp1-compare__badge">{{ block.settings.badge }}</span>
            {%- endif -%}
            <h3 class="bloomli-glp1-compare__column-title">{{ block.settings.title }}</h3>
          </header>

          <div class="bloomli-glp1-compare__rows">
            {%- assign rows = block.settings.rows | newline_to_br | split: '<br />' -%}
            {%- for row in rows -%}
              {%- assign row_text = row | strip_html | strip -%}
              {%- if row_text != blank -%}
                <div class="bloomli-glp1-compare__row bloomli-glp1-compare__row--{% if block.settings.positive %}positive{% else %}muted{% endif %}">
                  <span class="bloomli-glp1-compare__icon" aria-hidden="true">
                    {%- if block.settings.positive -%}
                      <svg viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 10.5 8 14 16 6"/></svg>
                    {%- else -%}
                      <svg viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"><path d="M5 10h10"/></svg>
                    {%- endif -%}
                  </span>
                  <span class="bloomli-glp1-compare__row-text">{{ row_text }}</span>
                </div>
              {%- endif -%}
            {%- endfor -%}
          </div>
        </article>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Bloomli GLP-1 compare",
  "tag": "section",
  "class": "section",
  "enabled_on": { "templates": ["page", "product"] },
  "max_blocks": 3,
  "settings": [
    { "type": "color_scheme", "id": "color_scheme", "label": "Color scheme", "default": "scheme-1" },
    { "type": "inline_richtext", "id": "heading", "label": "Heading", "default": "A fuller routine, <em>not just biotin.</em>" },
    { "type": "textarea", "id": "intro", "label": "Introduction", "default": "The difference is not a louder promise. It is a more complete daily formula and a routine you can keep." },
    { "type": "header", "content": "Optional custom colors" },
    { "type": "color", "id": "accent_color", "label": "Checks and badge", "default": "#B23A6F" },
    { "type": "color", "id": "emphasis_color", "label": "Featured heading", "default": "#7B2151" },
    { "type": "color", "id": "column_background", "label": "Standard column", "default": "#FFFDFC" },
    { "type": "color", "id": "featured_background", "label": "Featured column", "default": "#F3E1E5" },
    { "type": "color", "id": "muted_color", "label": "Dash color", "default": "#9A8F89" },
    { "type": "color", "id": "badge_text_color", "label": "Badge text", "default": "#FDFAF7" },
    { "type": "range", "id": "column_radius", "label": "Column corner radius", "min": 16, "max": 36, "step": 2, "default": 28, "unit": "px" },
    { "type": "range", "id": "heading_size", "label": "Heading size desktop", "min": 36, "max": 68, "step": 2, "default": 54, "unit": "px" },
    { "type": "range", "id": "heading_size_mobile", "label": "Heading size mobile", "min": 30, "max": 46, "step": 2, "default": 38, "unit": "px" },
    { "type": "header", "content": "Spacing" },
    { "type": "range", "id": "padding_top", "min": 0, "max": 160, "step": 8, "unit": "px", "label": "Padding top", "default": 112 },
    { "type": "range", "id": "padding_bottom", "min": 0, "max": 160, "step": 8, "unit": "px", "label": "Padding bottom", "default": 112 },
    { "type": "range", "id": "padding_top_mobile", "min": 0, "max": 120, "step": 8, "unit": "px", "label": "Padding top mobile", "default": 72 },
    { "type": "range", "id": "padding_bottom_mobile", "min": 0, "max": 120, "step": 8, "unit": "px", "label": "Padding bottom mobile", "default": 72 }
  ],
  "blocks": [{
    "type": "column",
    "name": "Comparison column",
    "settings": [
      { "type": "checkbox", "id": "featured", "label": "Featured column", "default": false },
      { "type": "text", "id": "badge", "label": "Featured badge", "default": "The fuller routine" },
      { "type": "text", "id": "title", "label": "Column title", "default": "Column title" },
      { "type": "checkbox", "id": "positive", "label": "Show checks", "default": false },
      { "type": "textarea", "id": "rows", "label": "Rows", "info": "Enter one row per line.", "default": "First point\nSecond point\nThird point\nFourth point" }
    ]
  }],
  "presets": [{
    "name": "Bloomli GLP-1 compare",
    "blocks": [
      { "type": "column", "settings": { "featured": true, "positive": true, "title": "Bloomli Hair Gummies" } },
      { "type": "column", "settings": { "title": "Plain biotin" } },
      { "type": "column", "settings": { "title": "Doing nothing" } }
    ]
  }]
}
{% endschema %}
