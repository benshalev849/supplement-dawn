<section
  class="bloomli-reviews"
  style="
    --br-bg: {{ section.settings.background_color }};
    --br-card-bg: {{ section.settings.card_background }};
    --br-text: {{ section.settings.text_color }};
    --br-accent: {{ section.settings.accent_color }};
    --br-muted: {{ section.settings.muted_color }};
    --br-placeholder: {{ section.settings.placeholder_color }};
    --br-radius: {{ section.settings.card_radius }}px;
    padding: {{ section.settings.padding_top }}px 48px {{ section.settings.padding_bottom }}px;
    background: var(--br-bg);
  "
>
  <div class="bloomli-reviews__inner">
    <div class="bloomli-reviews__header">
      <div>
        {%- if section.settings.eyebrow != blank -%}
          <div class="smallcaps bloomli-reviews__eyebrow">{{ section.settings.eyebrow }}</div>
        {%- endif -%}

        {%- if section.settings.heading != blank -%}
          <h2 class="bloomli-reviews__heading">{{ section.settings.heading }}</h2>
        {%- endif -%}
      </div>

      {%- if section.settings.show_arrows and section.blocks.size > 1 -%}
        <div class="bloomli-reviews__controls" aria-hidden="false">
          <button class="bloomli-reviews__arrow" type="button" data-bloomli-reviews-prev aria-label="Previous review">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m15 18-6-6 6-6"/></svg>
          </button>
          <button class="bloomli-reviews__arrow bloomli-reviews__arrow--next" type="button" data-bloomli-reviews-next aria-label="Next review">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m9 18 6-6-6-6"/></svg>
          </button>
        </div>
      {%- endif -%}
    </div>

    <div class="bloomli-reviews__track" data-bloomli-reviews-track>
      {%- for block in section.blocks -%}
        <article class="bloomli-reviews__card" {{ block.shopify_attributes }}>
          <div class="bloomli-reviews__media">
            {%- if block.settings.image != blank -%}
              {%- assign image_scale = block.settings.image_scale | divided_by: 100.0 -%}
              <img
                src="{{ block.settings.image | image_url: width: 760 }}"
                alt="{{ block.settings.image.alt | default: block.settings.name | escape }}"
                width="680"
                height="680"
                loading="lazy"
                style="--br-image-scale: {{ image_scale }};"
              >
            {%- endif -%}

            {%- if block.settings.image == blank and block.settings.photo_label != blank -%}
              <span class="smallcaps bloomli-reviews__photo-label">{{ block.settings.photo_label }}</span>
            {%- endif -%}
          </div>

          <div class="bloomli-reviews__stars" aria-label="{{ block.settings.rating }} out of 5 stars">
            {%- for index in (1..5) -%}
              {%- if index <= block.settings.rating -%}
                <span aria-hidden="true">★</span>
              {%- else -%}
                <span class="bloomli-reviews__star-empty" aria-hidden="true">★</span>
              {%- endif -%}
            {%- endfor -%}
          </div>

          {%- if block.settings.quote != blank -%}
            <blockquote class="bloomli-reviews__quote">{{ block.settings.quote }}</blockquote>
          {%- endif -%}

          <div class="bloomli-reviews__footer">
            <div>
              {%- if block.settings.name != blank -%}
                <div class="bloomli-reviews__name">{{ block.settings.name }}</div>
              {%- endif -%}
              {%- if block.settings.meta != blank -%}
                <div class="bloomli-reviews__meta">{{ block.settings.meta }}</div>
              {%- endif -%}
            </div>

            {%- if block.settings.verified_label != blank -%}
              <div class="smallcaps bloomli-reviews__verified">
                <svg width="11" height="11" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M3 8.5 6.5 12 13 4"/></svg>
                {{ block.settings.verified_label }}
              </div>
            {%- endif -%}
          </div>
        </article>
      {%- endfor -%}
    </div>
  </div>
</section>

<style>
  .bloomli-reviews__inner {
    max-width: {{ section.settings.content_width }}px;
    margin: 0 auto;
  }

  .bloomli-reviews__header {
    display: flex;
    align-items: end;
    justify-content: space-between;
    gap: 32px;
    margin-bottom: 54px;
  }

  .bloomli-reviews__eyebrow {
    color: var(--br-accent);
    margin-bottom: 18px;
  }

  .bloomli-reviews__heading {
    font-family: 'Fraunces', serif;
    font-variation-settings: 'SOFT' 100;
    font-size: {{ section.settings.heading_size }}px;
    line-height: 1.06;
    font-weight: 400;
    color: var(--br-text);
    margin: 0;
  }

  .bloomli-reviews__controls {
    display: flex;
    align-items: center;
    gap: 10px;
    flex-shrink: 0;
  }

  .bloomli-reviews__arrow {
    width: 44px;
    height: 44px;
    border-radius: 999px;
    border: 1px solid var(--br-accent);
    background: transparent;
    color: var(--br-accent);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: background 0.2s ease, color 0.2s ease, transform 0.2s ease;
  }

  .bloomli-reviews__arrow--next,
  .bloomli-reviews__arrow:hover {
    background: var(--br-accent);
    color: var(--br-card-bg);
  }

  .bloomli-reviews__arrow:hover {
    transform: translateY(-1px);
  }

  .bloomli-reviews__track {
    display: grid;
    grid-auto-flow: column;
    grid-auto-columns: calc((100% - ({{ section.settings.card_gap }}px * 2)) / 3);
    gap: {{ section.settings.card_gap }}px;
    overflow-x: auto;
    overflow-y: hidden;
    scroll-snap-type: x mandatory;
    scroll-behavior: smooth;
    scrollbar-width: none;
    padding-bottom: 2px;
  }

  .bloomli-reviews__track::-webkit-scrollbar {
    display: none;
  }

  .bloomli-reviews__card {
    scroll-snap-align: start;
    background: var(--br-card-bg);
    border-radius: var(--br-radius);
    padding: 20px;
    min-width: 0;
    box-shadow: 0 18px 48px rgba(110, 74, 99, 0.08);
  }

  .bloomli-reviews__media {
    aspect-ratio: 1 / 1;
    border-radius: calc(var(--br-radius) - 2px);
    overflow: hidden;
    position: relative;
    background-color: var(--br-placeholder);
    background-image: repeating-linear-gradient(135deg, rgba(110, 74, 99, 0.06) 0 1px, transparent 1px 18px);
    margin-bottom: 24px;
  }

  .bloomli-reviews__media img {
    width: 100%;
    height: 100%;
    max-width: none;
    object-fit: cover;
    transform: scale(var(--br-image-scale, 1));
    transform-origin: center;
    display: block;
  }

  .bloomli-reviews__media:has(img) {
    background-image: none;
  }

  .bloomli-reviews__photo-label {
    position: absolute;
    left: 50%;
    top: 50%;
    transform: translate(-50%, -50%);
    background: rgba(253, 250, 247, 0.78);
    color: rgba(110, 74, 99, 0.5);
    padding: 7px 14px;
    border-radius: 4px;
    font-size: 9px;
    white-space: nowrap;
  }

  .bloomli-reviews__stars {
    color: var(--br-accent);
    font-size: 13px;
    letter-spacing: 1px;
    margin-bottom: 18px;
  }

  .bloomli-reviews__star-empty {
    opacity: 0.22;
  }

  .bloomli-reviews__quote {
    font-size: 15px;
    line-height: 1.5;
    color: var(--br-text);
    margin: 0 0 24px;
  }

  .bloomli-reviews__footer {
    display: flex;
    align-items: end;
    justify-content: space-between;
    gap: 14px;
  }

  .bloomli-reviews__name {
    font-size: 14px;
    font-weight: 600;
    color: var(--br-text);
    margin-bottom: 4px;
  }

  .bloomli-reviews__meta {
    font-size: 12px;
    color: var(--br-muted);
  }

  .bloomli-reviews__verified {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    border-radius: 999px;
    background: rgba(110, 74, 99, 0.06);
    color: var(--br-accent);
    padding: 6px 10px;
    font-size: 9px;
    white-space: nowrap;
  }

  @media (max-width: 989px) {
    .bloomli-reviews__track {
      grid-auto-columns: calc((100% - {{ section.settings.card_gap }}px) / 2);
    }
  }

  @media (max-width: 749px) {
    .bloomli-reviews {
      padding: 64px 20px !important;
    }

    .bloomli-reviews__header {
      align-items: start;
      margin-bottom: 34px;
    }

    .bloomli-reviews__heading {
      font-size: {{ section.settings.heading_size_mobile }}px !important;
    }

    .bloomli-reviews__controls {
      display: none;
    }

    .bloomli-reviews__track {
      grid-auto-columns: minmax(280px, 86%);
      gap: 16px;
      margin-left: -2px;
      padding-left: 2px;
      padding-right: 20px;
    }

    .bloomli-reviews__card {
      padding: 16px;
    }
  }
</style>

<script>
  (() => {
    const section = document.currentScript.closest('.shopify-section');
    if (!section) return;

    const track = section.querySelector('[data-bloomli-reviews-track]');
    const prev = section.querySelector('[data-bloomli-reviews-prev]');
    const next = section.querySelector('[data-bloomli-reviews-next]');
    if (!track || !prev || !next) return;

    const scrollByCard = (direction) => {
      const firstCard = track.querySelector('.bloomli-reviews__card');
      const gap = parseFloat(getComputedStyle(track).columnGap || 0);
      const distance = firstCard ? firstCard.getBoundingClientRect().width + gap : track.clientWidth;
      track.scrollBy({ left: distance * direction, behavior: 'smooth' });
    };

    prev.addEventListener('click', () => scrollByCard(-1));
    next.addEventListener('click', () => scrollByCard(1));
  })();
</script>

{% schema %}
{
  "name": "Bloomli - Reviews",
  "tag": "div",
  "max_blocks": 8,
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Verified reviews" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Real women. Real results." },
    { "type": "checkbox", "id": "show_arrows", "label": "Show desktop arrows", "default": true },
    { "type": "color", "id": "background_color", "label": "Background color", "default": "#F2E7E4" },
    { "type": "color", "id": "card_background", "label": "Card background", "default": "#FDFAF7" },
    { "type": "color", "id": "placeholder_color", "label": "Photo placeholder color", "default": "#F7F0E9" },
    { "type": "color", "id": "text_color", "label": "Text color", "default": "#2A2622" },
    { "type": "color", "id": "accent_color", "label": "Accent color", "default": "#6E4A63" },
    { "type": "color", "id": "muted_color", "label": "Muted text color", "default": "#7C7169" },
    { "type": "range", "id": "content_width", "label": "Content width", "min": 960, "max": 1440, "step": 40, "default": 1200, "unit": "px" },
    { "type": "range", "id": "heading_size", "label": "Heading size desktop", "min": 34, "max": 64, "step": 2, "default": 46, "unit": "px" },
    { "type": "range", "id": "heading_size_mobile", "label": "Heading size mobile", "min": 30, "max": 46, "step": 2, "default": 36, "unit": "px" },
    { "type": "range", "id": "card_gap", "label": "Card gap desktop", "min": 16, "max": 40, "step": 4, "default": 20, "unit": "px" },
    { "type": "range", "id": "card_radius", "label": "Card corner radius", "min": 4, "max": 20, "step": 2, "default": 10, "unit": "px" },
    { "type": "range", "id": "padding_top", "label": "Padding top", "min": 56, "max": 160, "step": 8, "default": 96, "unit": "px" },
    { "type": "range", "id": "padding_bottom", "label": "Padding bottom", "min": 56, "max": 160, "step": 8, "default": 96, "unit": "px" }
  ],
  "blocks": [
    {
      "type": "review",
      "name": "Review",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Customer photo" },
        { "type": "range", "id": "image_scale", "label": "Uploaded image zoom", "min": 100, "max": 140, "step": 5, "default": 100, "unit": "%" },
        { "type": "text", "id": "photo_label", "label": "Placeholder label", "default": "Customer photo - natural light" },
        { "type": "range", "id": "rating", "label": "Rating", "min": 1, "max": 5, "step": 1, "default": 5 },
        { "type": "textarea", "id": "quote", "label": "Quote", "default": "\"My part line filled in noticeably at month four. The gummies feel like a real ritual.\"" },
        { "type": "text", "id": "name", "label": "Customer name", "default": "Priya K." },
        { "type": "text", "id": "meta", "label": "Meta", "default": "Gummies - 6 months" },
        { "type": "text", "id": "verified_label", "label": "Verified label", "default": "Verified" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Bloomli - Reviews",
      "blocks": [
        { "type": "review", "settings": { "name": "Priya K.", "meta": "Gummies - 6 months", "quote": "\"My part line filled in noticeably at month four. The gummies feel like a real ritual.\"" } },
        { "type": "review", "settings": { "name": "Leah M.", "meta": "Capsules - 4 months", "quote": "\"Less shedding within weeks. I was skeptical - I'm not anymore.\"" } },
        { "type": "review", "settings": { "name": "Marisol R.", "meta": "Strips - 3 months", "quote": "\"The strips are my travel secret. I keep them in my bag.\"" } }
      ]
    }
  ]
}
{% endschema %}
