{% doc %}
  Bloomli Volume Tier - block snippet rendered inside main-product.liquid.

  Renders 1-3 horizontal size cards (Create-Wellness style) plus an optional
  One-Time / Subscribe toggle. Sets the buy-buttons form's variant, quantity,
  and optional `selling_plan` through normal form inputs.

  Tier-to-plan mapping: each tier can optionally submit a separate bundle
  product. If present, the tier uses that product's selected/default variant
  and first matching selling plan allocation. If no bundle product is selected,
  it falls back to the current product and the legacy quantity behavior.

  @param {block} block - Block object with all settings.
  @param {product} product - Current product.
  @param {string} section_id - Parent section ID for unique element IDs.

  @example
  {% render 'bloomli-volume-tier', block: block, product: product, section_id: section.id %}
{% enddoc %}

{{ 'bloomli-volume-tier.css' | asset_url | stylesheet_tag }}
{{ 'bloomli-product-stack.css' | asset_url | stylesheet_tag }}
<script src="{{ 'bloomli-volume-tier.js' | asset_url }}" defer="defer"></script>

{%- liquid
  assign uid = section_id | append: '-' | append: block.id
  assign bloomli_product_form_id = 'bloomli-product-form-' | append: uid

  assign unit_price   = product.selected_or_first_available_variant.price
  assign unit_compare = product.selected_or_first_available_variant.compare_at_price | default: unit_price

  assign default_idx = -1
  assign default_qty = 1
  assign subscribe_enabled = block.settings.subscribe_enabled
  assign default_mode = block.settings.default_mode | default: 'onetime'
  assign mf_sub_pct = product.metafields.bloomli.subscription_discount_pct
  assign g_sub_pct  = settings.bloomli_subscription_discount_pct
  if mf_sub_pct != blank
    assign subscription_discount_pct = mf_sub_pct | plus: 0
  elsif g_sub_pct != blank
    assign subscription_discount_pct = g_sub_pct | plus: 0
  else
    assign subscription_discount_pct = block.settings.subscription_discount_pct | default: 20 | plus: 0
  endif
  assign tier_1_qty_for_discount = block.settings.tier_1_qty | default: 1 | plus: 0
  assign tier_2_qty_for_discount = block.settings.tier_2_qty | default: 2 | plus: 0
  assign tier_3_qty_for_discount = block.settings.tier_3_qty | default: 3 | plus: 0
  if product.metafields.bloomli.volume_discount_1_pct != blank
    assign volume_discount_1_pct = product.metafields.bloomli.volume_discount_1_pct | plus: 0
  elsif settings.bloomli_volume_discount_1_pct != blank
    assign volume_discount_1_pct = settings.bloomli_volume_discount_1_pct | plus: 0
  elsif block.settings.tier_1_discount_pct != blank and tier_1_qty_for_discount == 1
    assign volume_discount_1_pct = block.settings.tier_1_discount_pct | plus: 0
  else
    assign volume_discount_1_pct = 0
  endif
  if product.metafields.bloomli.volume_discount_2_pct != blank
    assign volume_discount_2_pct = product.metafields.bloomli.volume_discount_2_pct | plus: 0
  elsif settings.bloomli_volume_discount_2_pct != blank
    assign volume_discount_2_pct = settings.bloomli_volume_discount_2_pct | plus: 0
  elsif block.settings.tier_2_discount_pct != blank and tier_2_qty_for_discount == 2
    assign volume_discount_2_pct = block.settings.tier_2_discount_pct | plus: 0
  else
    assign volume_discount_2_pct = 10
  endif
  if product.metafields.bloomli.volume_discount_3_pct != blank
    assign volume_discount_3_pct = product.metafields.bloomli.volume_discount_3_pct | plus: 0
  elsif settings.bloomli_volume_discount_3_pct != blank
    assign volume_discount_3_pct = settings.bloomli_volume_discount_3_pct | plus: 0
  elsif block.settings.tier_3_discount_pct != blank and tier_3_qty_for_discount == 3
    assign volume_discount_3_pct = block.settings.tier_3_discount_pct | plus: 0
  else
    assign volume_discount_3_pct = 15
  endif
  if product.metafields.bloomli.volume_discount_4_pct != blank
    assign volume_discount_4_pct = product.metafields.bloomli.volume_discount_4_pct | plus: 0
  elsif settings.bloomli_volume_discount_4_pct != blank
    assign volume_discount_4_pct = settings.bloomli_volume_discount_4_pct | plus: 0
  else
    assign volume_discount_4_pct = 18
  endif
  if product.metafields.bloomli.volume_discount_5_pct != blank
    assign volume_discount_5_pct = product.metafields.bloomli.volume_discount_5_pct | plus: 0
  elsif settings.bloomli_volume_discount_5_pct != blank
    assign volume_discount_5_pct = settings.bloomli_volume_discount_5_pct | plus: 0
  else
    assign volume_discount_5_pct = 20
  endif
  assign discount_badge_template = block.settings.discount_badge_template | default: 'SAVE [percent]%'
  assign add_to_cart_label = block.settings.add_to_cart_label | default: 'Add to cart'
  assign sold_out_label = block.settings.sold_out_label | default: 'Sold out'
  assign unit_price_money = unit_price | money_without_currency | prepend: '$'
-%}

<div class="bloomli-vt"
     data-bloomli-vt
     data-uid="{{ uid }}"
     data-form-id="{{ bloomli_product_form_id }}"
     data-discount-badge-template="{{ discount_badge_template | escape }}"
     data-savings-prefix="{{ block.settings.savings_label_prefix | default: "You're saving " | escape }}"
     data-savings-suffix="{{ block.settings.savings_label_suffix | escape }}"
     data-add-to-cart-label="{{ add_to_cart_label | escape }}"
     data-sold-out-label="{{ sold_out_label | escape }}"
     data-money-format="{{ shop.money_format | escape }}"
     style="
       --bloomli-vt-save-badge-bg: {{ block.settings.save_badge_background | default: '#B23A6F' }};
       --bloomli-vt-save-badge-text: {{ block.settings.save_badge_text_color | default: '#FDFAF7' }};
       --bloomli-vt-tier-tag-bg: {{ block.settings.tier_tag_background | default: '#8A6678' }};
       --bloomli-vt-tier-tag-text: {{ block.settings.tier_tag_text_color | default: '#FDFAF7' }};
       --bloomli-vt-desktop-title-size: {{ block.settings.desktop_tier_title_size | default: 11 }}px;
       --bloomli-vt-desktop-count-size: {{ block.settings.desktop_tier_count_size | default: 9 }}px;
       --bloomli-vt-desktop-daily-size: {{ block.settings.desktop_tier_daily_size | default: 9 }}px;
       --bloomli-vt-button-radius: var(--buttons-radius, 6px);
     "
     {{ block.shopify_attributes }}>

  {%- if block.settings.heading != blank -%}
    <p class="bloomli-vt__section-label bloomli-vt__section-label--size">{{ block.settings.heading }}</p>
  {%- endif -%}

  <div class="bloomli-vt__delivery-tiers" role="radiogroup" aria-label="{{ block.settings.heading | default: 'Delivery plan' | escape }}">
    {%- for i in (1..3) -%}
      {%- liquid
        case i
          when 1
            assign show = block.settings.tier_1_show
            assign qty = block.settings.tier_1_qty | default: 1
            assign bundle_product = block.settings.tier_1_bundle_product
            assign bundle_product_handle = block.settings.tier_1_bundle_product_handle
            assign inferred_bundle_handle = ''
            assign alternate_inferred_bundle_handle = ''
            assign label = block.settings.tier_1_label
            assign count_text = block.settings.tier_1_count_text
            assign daily_text = block.settings.tier_1_daily_text
            assign image = block.settings.tier_1_image
            assign badge = block.settings.tier_1_badge
            assign tag = block.settings.tier_1_tag
            assign sub_discount_pct = subscription_discount_pct
            assign configured_discount_pct = block.settings.tier_1_discount_pct
            assign plan_filter = block.settings.tier_1_plan_filter
            assign is_default = block.settings.tier_1_default
          when 2
            assign show = block.settings.tier_2_show
            assign qty = block.settings.tier_2_qty | default: 3
            assign bundle_product = block.settings.tier_2_bundle_product
            assign bundle_product_handle = block.settings.tier_2_bundle_product_handle
            assign inferred_bundle_handle = product.handle | append: '-3-months-supply'
            assign alternate_inferred_bundle_handle = product.title | append: ' 3 Months Supply' | handleize
            assign label = block.settings.tier_2_label
            assign count_text = block.settings.tier_2_count_text
            assign daily_text = block.settings.tier_2_daily_text
            assign image = block.settings.tier_2_image
            assign badge = block.settings.tier_2_badge
            assign tag = block.settings.tier_2_tag
            assign sub_discount_pct = subscription_discount_pct
            assign configured_discount_pct = block.settings.tier_2_discount_pct
            assign plan_filter = block.settings.tier_2_plan_filter
            assign is_default = block.settings.tier_2_default
          when 3
            assign show = block.settings.tier_3_show
            assign qty = block.settings.tier_3_qty | default: 6
            assign bundle_product = block.settings.tier_3_bundle_product
            assign bundle_product_handle = block.settings.tier_3_bundle_product_handle
            assign inferred_bundle_handle = product.handle | append: '-6-month-supply'
            assign alternate_inferred_bundle_handle = product.title | append: ' 6 Month Supply' | handleize
            assign label = block.settings.tier_3_label
            assign count_text = block.settings.tier_3_count_text
            assign daily_text = block.settings.tier_3_daily_text
            assign image = block.settings.tier_3_image
            assign badge = block.settings.tier_3_badge
            assign tag = block.settings.tier_3_tag
            assign sub_discount_pct = subscription_discount_pct
            assign configured_discount_pct = block.settings.tier_3_discount_pct
            assign plan_filter = block.settings.tier_3_plan_filter
            assign is_default = block.settings.tier_3_default
        endcase

        if image == blank
          assign image = block.settings.override_product_image
        endif

        if qty >= 5
          assign discount_pct = volume_discount_5_pct
        elsif qty == 4
          assign discount_pct = volume_discount_4_pct
        elsif qty == 3
          assign discount_pct = volume_discount_3_pct
        elsif qty == 2
          assign discount_pct = volume_discount_2_pct
        else
          assign discount_pct = volume_discount_1_pct
        endif
        if configured_discount_pct != blank
          assign discount_pct = configured_discount_pct | plus: 0
        endif

        if bundle_product == blank and bundle_product_handle != blank
          assign bundle_product = all_products[bundle_product_handle]
        endif
        if bundle_product == blank and inferred_bundle_handle != blank
          assign bundle_product = all_products[inferred_bundle_handle]
        endif
        if bundle_product == blank and alternate_inferred_bundle_handle != blank
          assign bundle_product = all_products[alternate_inferred_bundle_handle]
        endif

        assign tier_product = product
        assign tier_cart_quantity = qty
        assign tier_has_bundle_product = false
        if bundle_product != blank
          assign tier_product = bundle_product
          assign tier_cart_quantity = 1
          assign tier_has_bundle_product = true
        endif

        assign tier_variant = tier_product.selected_or_first_available_variant
        if tier_variant == blank
          assign tier_variant = product.selected_or_first_available_variant
        endif
        assign tier_variant_id = tier_variant.id
        assign tier_available = tier_variant.available
        assign tier_price = tier_variant.price | default: unit_price
        assign tier_compare = tier_variant.compare_at_price | default: tier_price

        if show and is_default and default_idx == -1
          assign default_idx = forloop.index0
          assign default_qty = tier_cart_quantity
        endif

        if plan_filter == blank
          assign plan_filter = qty | append: '-pack'
        endif

        assign frequency_qty = qty
        assign frequency_filter = frequency_qty | append: 'mo'
        assign tier_plan_id = ''
        assign tier_plan_price = 0
        assign tier_plan_compare = 0
        assign first_allocation_id = ''
        assign first_allocation_price = 0
        assign first_allocation_compare = 0
        assign plan_filter_lower = plan_filter | downcase
        for allocation in tier_variant.selling_plan_allocations
          if first_allocation_id == blank
            assign first_allocation_id = allocation.selling_plan.id
            assign first_allocation_price = allocation.price
            assign first_allocation_compare = allocation.compare_at_price | default: allocation.price
          endif

          assign allocation_source = allocation.selling_plan.name | downcase
          for option in allocation.selling_plan.options
            assign allocation_source = allocation_source | append: ' ' | append: option.value | downcase
          endfor
          assign frequency_filter_spaced = frequency_qty | append: ' mo'
          assign frequency_filter_dash = frequency_qty | append: '-mo'
          assign frequency_filter_month = frequency_qty | append: ' month'
          assign frequency_filter_every = 'every ' | append: frequency_qty
          assign frequency_filter_appstle = frequency_qty | append: 'month'
          if allocation_source contains plan_filter_lower or allocation_source contains frequency_filter or allocation_source contains frequency_filter_spaced or allocation_source contains frequency_filter_dash or allocation_source contains frequency_filter_month or allocation_source contains frequency_filter_every or allocation_source contains frequency_filter_appstle
            assign tier_plan_id = allocation.selling_plan.id
            assign tier_plan_price = allocation.price
            assign tier_plan_compare = allocation.compare_at_price | default: allocation.price
            break
          endif
        endfor
        if tier_plan_id == blank and first_allocation_id != blank
          assign tier_plan_id = first_allocation_id
          assign tier_plan_price = first_allocation_price
          assign tier_plan_compare = first_allocation_compare
        endif

        assign fallback_plan_id = ''
        for grp in tier_product.selling_plan_groups
          assign grp_name_lower = grp.name | downcase
          if tier_plan_id == blank and grp_name_lower contains plan_filter_lower
            assign first_plan = grp.selling_plans | first
            if first_plan
              if fallback_plan_id == blank
                assign fallback_plan_id = first_plan.id
              endif

              for selling_plan in grp.selling_plans
                assign frequency_source = grp.name | append: ' ' | append: selling_plan.name | downcase
                for option in selling_plan.options
                  assign frequency_source = frequency_source | append: ' ' | append: option.value | downcase
                endfor
                assign frequency_filter_spaced = frequency_qty | append: ' mo'
                assign frequency_filter_dash = frequency_qty | append: '-mo'
                assign frequency_filter_month = frequency_qty | append: ' month'
                assign frequency_filter_every = 'every ' | append: frequency_qty
                assign frequency_filter_appstle = frequency_qty | append: 'month'
                if frequency_source contains frequency_filter or frequency_source contains frequency_filter_spaced or frequency_source contains frequency_filter_dash or frequency_source contains frequency_filter_month or frequency_source contains frequency_filter_every or frequency_source contains frequency_filter_appstle
                  assign tier_plan_id = selling_plan.id
                  break
                endif
              endfor
              if tier_plan_id != blank
                break
              endif
            endif
          endif
        endfor
        if tier_plan_id == blank
          assign tier_plan_id = fallback_plan_id
        endif

        if tier_has_bundle_product
          assign line_compare = tier_price
          if tier_compare > tier_price
            assign line_compare = tier_compare
          endif
          if tier_plan_compare > line_compare
            assign line_compare = tier_plan_compare
          endif
          assign one_time_pct_factor = 100.0 | minus: discount_pct
          if one_time_pct_factor > 0
            assign one_time_total_cents = tier_price | times: one_time_pct_factor | divided_by: 100.0 | round
          else
            assign one_time_total_cents = tier_price
          endif
        else
          assign line_compare = unit_price | times: qty
          if unit_compare > unit_price
            assign line_compare = unit_compare | times: qty
          endif
          assign one_time_pct_factor = 100.0 | minus: discount_pct
          assign one_time_unit_cents = unit_price | times: one_time_pct_factor | divided_by: 100.0 | round
          assign one_time_total_cents = one_time_unit_cents | times: qty
        endif
        assign one_time_pct_factor = 100.0 | minus: discount_pct

        assign subscription_pct_factor = 100.0 | minus: sub_discount_pct
        assign compounded_pct_factor = one_time_pct_factor | times: subscription_pct_factor | divided_by: 100.0
        if tier_plan_price > 0
          if tier_has_bundle_product
            assign subscribe_total_cents = tier_plan_price | times: one_time_pct_factor | divided_by: 100.0 | round
          else
            assign subscribe_total_cents = tier_plan_price
          endif
        elsif tier_has_bundle_product
          assign subscribe_total_cents = tier_price | times: compounded_pct_factor | divided_by: 100.0 | round
        else
          assign subscribe_unit_cents = unit_price | times: compounded_pct_factor | divided_by: 100.0 | round
          assign subscribe_total_cents = subscribe_unit_cents | times: qty
        endif
        assign rounded_discount_pct = discount_pct | floor
        assign dynamic_badge = discount_badge_template | replace: '[percent]', rounded_discount_pct | replace: '[qty]', qty

        assign daily_cents = one_time_total_cents | divided_by: qty | divided_by: 30
        assign subscribe_daily_cents = subscribe_total_cents | divided_by: qty | divided_by: 30
        assign auto_daily = daily_cents | money_without_currency | prepend: '$'
        assign auto_subscribe_daily = subscribe_daily_cents | money_without_currency | prepend: '$'
        if daily_text == blank
          assign daily_text = '(' | append: auto_daily | append: ' / Day)'
        endif
        assign subscribe_daily_text = '(' | append: auto_subscribe_daily | append: ' / Day)'

        comment
          IM8-style per-card pricing: monthly = subscribe total / months,
          delivery frequency in weeks (4 weeks per month), per-day = monthly / 30.
        endcomment
        assign monthly_cents = subscribe_total_cents | times: 1.0 | divided_by: qty | round
        assign monthly_compare_cents = line_compare | times: 1.0 | divided_by: qty | round
        assign delivery_weeks = qty | times: 4

        assign auto_count = qty | times: 60 | append: ' Count'
        if count_text == blank
          assign count_text = auto_count
        endif

        assign display_label = label
        if display_label == blank
          assign display_label = qty | append: ' Month'
        endif
      -%}

      {%- if show -%}
        <label class="bloomli-vt__size bloomli-vt__size--delivery{% if forloop.index0 == default_idx %} is-selected{% endif %}{% if tag != blank %} bloomli-vt__size--tagged{% endif %}"
               data-vt-size
               data-tier-index="{{ forloop.index0 }}"
               data-quantity="{{ qty }}"
               data-display-supply-count="{{ qty }}"
               data-cart-quantity="{{ tier_cart_quantity }}"
               data-variant-id="{{ tier_variant_id }}"
               data-available="{{ tier_available }}"
               data-discount-pct="{{ discount_pct }}"
               data-sub-discount-pct="{{ sub_discount_pct }}"
               data-plan-id="{{ tier_plan_id }}"
               data-one-time-cents="{{ one_time_total_cents }}"
               data-subscribe-cents="{{ subscribe_total_cents }}"
               data-line-compare-cents="{{ line_compare }}"
               data-size-label="{{ display_label | escape }}"
               data-size-count="{{ count_text | escape }}"
               data-product-title="{{ tier_product.title | escape }}"
               data-vt-default-mode="subscribe">

          <input type="radio"
                 name="bloomli-vt-size-{{ uid }}"
                 value="{{ qty }}"
                 class="bloomli-vt__radio-native"
                 {% if forloop.index0 == default_idx %}checked{% endif %}>

          <div class="bloomli-vt__delivery-row">
            <span class="bloomli-vt__radio-visual" aria-hidden="true"></span>
            <span class="bloomli-vt__delivery-label">{{ display_label }}</span>
            {%- if discount_pct > 0 or badge != blank -%}
              <span
                class="bloomli-vt__size-badge bloomli-vt__size-badge--inline"
                data-vt-discount-badge
                data-manual-badge="{{ badge | escape }}"
              >
                {%- if discount_pct > 0 -%}
                  {{ dynamic_badge }}
                {%- else -%}
                  {{ badge }}
                {%- endif -%}
              </span>
            {%- endif -%}
          </div>

          <div class="bloomli-vt__delivery-pricing">
            <div class="bloomli-vt__delivery-monthly">
              <span class="bloomli-vt__delivery-monthly-price">{{ monthly_cents | money }}</span>
              <span class="bloomli-vt__delivery-monthly-suffix">/mo</span>
              {%- if monthly_compare_cents > monthly_cents -%}
                <span class="bloomli-vt__delivery-monthly-compare">{{ monthly_compare_cents | money }}</span>
              {%- endif -%}
            </div>

            <div class="bloomli-vt__delivery-totalrow">
              <span class="bloomli-vt__delivery-total">
                <span class="bloomli-vt__delivery-total-amount">{{ subscribe_total_cents | money }}</span>
                <span class="bloomli-vt__delivery-total-freq">every {{ delivery_weeks }} weeks</span>
              </span>
              <span class="bloomli-vt__delivery-perday">{{ subscribe_daily_cents | money }} / day</span>
            </div>
          </div>

          {%- if block.settings.subscribe_show_perks != false -%}
            {%- liquid
              assign perk_1 = block.settings.subscribe_perk_1 | default: '30-day money-back guarantee'
              assign perk_2 = block.settings.subscribe_perk_2 | default: 'Complimentary shipping on every delivery'
              assign perk_3 = block.settings.subscribe_perk_3 | default: 'Pause or cancel anytime, no fees'
            -%}
            <div class="bloomli-vt__delivery-accordion">
              <div class="bloomli-vt__delivery-accordion-inner">
                <ul class="bloomli-vt__delivery-perks">
                  {%- if perk_1 != blank -%}
                    <li class="bloomli-vt__mode-perk">
                      <span class="bloomli-checkmark bloomli-checkmark--svg bloomli-proof-split__check" aria-hidden="true">
                        <svg viewBox="0 0 20 20" focusable="false">
                          <path d="M4 10.5 8 14 16 6" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                        </svg>
                      </span>
                      <span>{{ perk_1 }}</span>
                    </li>
                  {%- endif -%}
                  {%- if perk_2 != blank -%}
                    <li class="bloomli-vt__mode-perk">
                      <span class="bloomli-checkmark bloomli-checkmark--svg bloomli-proof-split__check" aria-hidden="true">
                        <svg viewBox="0 0 20 20" focusable="false">
                          <path d="M4 10.5 8 14 16 6" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                        </svg>
                      </span>
                      <span>{{ perk_2 }}</span>
                    </li>
                  {%- endif -%}
                  {%- if perk_3 != blank -%}
                    <li class="bloomli-vt__mode-perk">
                      <span class="bloomli-checkmark bloomli-checkmark--svg bloomli-proof-split__check" aria-hidden="true">
                        <svg viewBox="0 0 20 20" focusable="false">
                          <path d="M4 10.5 8 14 16 6" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                        </svg>
                      </span>
                      <span>{{ perk_3 }}</span>
                    </li>
                  {%- endif -%}
                </ul>
              </div>
            </div>
          {%- endif -%}

          {%- if tag != blank -%}
            {%- liquid
              assign tag_lower = tag | downcase
              assign tag_modifier = ''
              if tag_lower contains 'popular'
                assign tag_modifier = ' bloomli-vt__size-tag--popular'
              elsif tag_lower contains 'value' or tag_lower contains 'best'
                assign tag_modifier = ' bloomli-vt__size-tag--value'
              endif
            -%}
            <span class="bloomli-vt__size-tag bloomli-vt__size-tag--delivery{{ tag_modifier }}">{{ tag }}</span>
          {%- endif -%}

        </label>
      {%- endif -%}
    {%- endfor -%}
  </div><!-- /.bloomli-vt__delivery-tiers -->

  {%- if subscribe_enabled -%}
    {%- liquid
      assign subscribe_popular_bar = block.settings.subscribe_popular_pill | default: 'Subscribe & Save'
    -%}

    {%- comment -%}Hidden subscribe mode — keeps JS in subscribe mode without visible UI{%- endcomment -%}
    <span class="bloomli-vt__mode bloomli-vt__mode--subscribe bloomli-vt__mode--hidden{% if default_mode == 'subscribe' %} is-selected{% endif %}"
          data-vt-mode
          data-mode="subscribe"
          aria-hidden="true">
      <input type="radio"
             name="bloomli-vt-mode-{{ uid }}"
             value="subscribe"
             class="bloomli-vt__radio-native"
             {% if default_mode == 'subscribe' %}checked{% endif %}>
      <span data-vt-mode-bar data-bar-template="{{ subscribe_popular_bar | escape }}"></span>
      <span data-vt-subscribe-price></span>
      <span data-vt-mode-subscribe-compare></span>
      <span data-vt-mode-subscribe-savings></span>
      <span data-vt-mode-sub-info></span>
    </span>

  {%- endif -%}

  <div class="bloomli-vt__footer">
    <div class="bloomli-vt__total-row">
      <span class="bloomli-vt__total-label">{{ block.settings.total_label | default: 'Total price:' }}</span>
      <span class="bloomli-vt__total-amount">
        <span data-vt-total>{{ unit_price_money }}</span>
        <span class="bloomli-vt__total-compare" data-vt-compare></span>
      </span>
    </div>
  </div>

  <div class="bloomli-vt__atc-home" data-vt-atc-home></div>
  <product-form
    class="product-form bloomli-vt__product-form"
    data-hide-errors="false"
    data-section-id="{{ section_id }}"
    data-vt-atc
  >
    <div class="product-form__error-message-wrapper" role="alert" hidden>
      <span class="svg-wrapper">
        {{- 'icon-error.svg' | inline_asset_content -}}
      </span>
      <span class="product-form__error-message"></span>
    </div>

    {%- form 'product',
      product,
      id: bloomli_product_form_id,
      class: 'form',
      novalidate: 'novalidate',
      data-type: 'add-to-cart-form'
    -%}
      <input
        type="hidden"
        name="id"
        value="{{ product.selected_or_first_available_variant.id }}"
        {% if product.selected_or_first_available_variant.available == false
          or product.selected_or_first_available_variant == null
        %}
          disabled
        {% endif %}
        class="product-variant-id"
      >
      <input
        type="hidden"
        name="quantity"
        value="{{ default_qty }}"
        data-vt-qty-input
      >
      <input
        type="hidden"
        name="selling_plan"
        value=""
        data-vt-sp-input
        disabled
      >
      <button
        id="ProductSubmitButton-{{ section_id }}"
        type="submit"
        name="add"
        class="bloomli-vt__custom-submit product-form__submit"
        data-vt-submit-button
        {% unless product.selected_or_first_available_variant.available %}
          disabled
        {% endunless %}
      >
        <span data-vt-submit-text>
          {%- if product.selected_or_first_available_variant.available -%}
            {{ add_to_cart_label }}
          {%- else -%}
            {{ sold_out_label }}
          {%- endif -%}
        </span>
        {%- render 'loading-spinner' -%}
      </button>
    {%- endform -%}
  </product-form>

  {%- if subscribe_enabled -%}
    <button
      type="button"
      class="bloomli-vt__onetime-direct"
      data-vt-onetime-direct
    >
      <span class="bloomli-vt__onetime-direct-label">{{ block.settings.label_one_time | default: 'One-Time Purchase' }}</span>
      <span class="bloomli-vt__onetime-direct-sep"> — </span>
      <span class="bloomli-vt__onetime-direct-price" data-vt-onetime-price></span>
      <span class="bloomli-vt__onetime-direct-daily" data-vt-onetime-daily></span>
    </button>
  {%- endif -%}
</div>
