{% doc %}
Renders the Benefit stats card product information block.

@param {block} block - The What You'll Feel block.

@example
{% render 'what-youll-feel', block: block %}
{% enddoc %}

{%- liquid
  assign heading_size = block.settings.heading_size | default: 20
-%}

<div
  class="what-youll-feel"
  style="
    --wyf-heading-size: {{ heading_size }}px;
    --wyf-title-size: {{ block.settings.title_size | default: 13 }}px;
    --wyf-descriptor-size: {{ block.settings.descriptor_size | default: 12 }}px;
    --wyf-percentage-size: {{ block.settings.percentage_size | default: 24 }}px;
    --wyf-fine-print-size: {{ block.settings.fine_print_size | default: 10 }}px;
    --wyf-icon-size: {{ block.settings.icon_size | default: 20 }}px;
    {%- if block.settings.card_background_color != blank -%}
      --wyf-card-background: {{ block.settings.card_background_color }};
    {%- endif -%}
    {%- if block.settings.heading_color != blank -%}
      --wyf-heading-color: {{ block.settings.heading_color }};
    {%- endif -%}
    {%- if block.settings.title_color != blank -%}
      --wyf-title-color: {{ block.settings.title_color }};
    {%- endif -%}
    {%- if block.settings.descriptor_color != blank -%}
      --wyf-descriptor-color: {{ block.settings.descriptor_color }};
    {%- endif -%}
    {%- if block.settings.percentage_color != blank -%}
      --wyf-percentage-color: {{ block.settings.percentage_color }};
    {%- endif -%}
    {%- if block.settings.fine_print_color != blank -%}
      --wyf-fine-print-color: {{ block.settings.fine_print_color }};
    {%- endif -%}
    {%- if block.settings.icon_color != blank -%}
      --wyf-icon-color-default: {{ block.settings.icon_color }};
    {%- endif -%}
  "
  {{ block.shopify_attributes }}
>
  <div class="what-youll-feel__card">
    {%- if block.settings.heading != blank -%}
      <h2
        class="what-youll-feel__heading"
        style="--wyf-heading-size: {{ heading_size }}px; font-size: {{ heading_size }}px !important;"
      >
        {{ block.settings.heading | escape }}
      </h2>
    {%- endif -%}

    <div class="what-youll-feel__rows">
      {%- if block.settings.show_benefit_1 -%}
        <div
          class="what-youll-feel__row what-youll-feel__row--1"
          {%- if block.settings.icon_tint_1 != blank or block.settings.icon_color_1 != blank -%}
            style="
              {%- if block.settings.icon_tint_1 != blank -%}
                --wyf-icon-tint: {{ block.settings.icon_tint_1 }};
              {%- endif -%}
              {%- if block.settings.icon_color_1 != blank -%}
                --wyf-icon-color: {{ block.settings.icon_color_1 }};
              {%- endif -%}
            "
          {%- endif -%}
        >
          <div class="what-youll-feel__icon-tile" aria-hidden="true">
            {%- if block.settings.image_1 != blank -%}
              {{
                block.settings.image_1
                | image_url: width: 88
                | image_tag:
                  class: 'what-youll-feel__image',
                  loading: 'lazy',
                  width: 44,
                  height: 44,
                  alt: ''
              }}
            {%- else -%}
              <i class="ti {{ block.settings.icon_class_1 | escape }}"></i>
            {%- endif -%}
          </div>
          <div class="what-youll-feel__copy">
            <p class="what-youll-feel__title">{{ block.settings.title_1 | escape }}</p>
            <p class="what-youll-feel__descriptor">{{ block.settings.descriptor_1 | escape }}</p>
          </div>
          <div class="what-youll-feel__stat">
            <span class="what-youll-feel__percent">{{ block.settings.percentage_1 | escape }}</span>
          </div>
        </div>
      {%- endif -%}

      {%- if block.settings.show_benefit_2 -%}
        <div
          class="what-youll-feel__row what-youll-feel__row--2"
          {%- if block.settings.icon_tint_2 != blank or block.settings.icon_color_2 != blank -%}
            style="
              {%- if block.settings.icon_tint_2 != blank -%}
                --wyf-icon-tint: {{ block.settings.icon_tint_2 }};
              {%- endif -%}
              {%- if block.settings.icon_color_2 != blank -%}
                --wyf-icon-color: {{ block.settings.icon_color_2 }};
              {%- endif -%}
            "
          {%- endif -%}
        >
          <div class="what-youll-feel__icon-tile" aria-hidden="true">
            {%- if block.settings.image_2 != blank -%}
              {{
                block.settings.image_2
                | image_url: width: 88
                | image_tag:
                  class: 'what-youll-feel__image',
                  loading: 'lazy',
                  width: 44,
                  height: 44,
                  alt: ''
              }}
            {%- else -%}
              <i class="ti {{ block.settings.icon_class_2 | escape }}"></i>
            {%- endif -%}
          </div>
          <div class="what-youll-feel__copy">
            <p class="what-youll-feel__title">{{ block.settings.title_2 | escape }}</p>
            <p class="what-youll-feel__descriptor">{{ block.settings.descriptor_2 | escape }}</p>
          </div>
          <div class="what-youll-feel__stat">
            <span class="what-youll-feel__percent">{{ block.settings.percentage_2 | escape }}</span>
          </div>
        </div>
      {%- endif -%}

      {%- if block.settings.show_benefit_3 -%}
        <div
          class="what-youll-feel__row what-youll-feel__row--3"
          {%- if block.settings.icon_tint_3 != blank or block.settings.icon_color_3 != blank -%}
            style="
              {%- if block.settings.icon_tint_3 != blank -%}
                --wyf-icon-tint: {{ block.settings.icon_tint_3 }};
              {%- endif -%}
              {%- if block.settings.icon_color_3 != blank -%}
                --wyf-icon-color: {{ block.settings.icon_color_3 }};
              {%- endif -%}
            "
          {%- endif -%}
        >
          <div class="what-youll-feel__icon-tile" aria-hidden="true">
            {%- if block.settings.image_3 != blank -%}
              {{
                block.settings.image_3
                | image_url: width: 88
                | image_tag:
                  class: 'what-youll-feel__image',
                  loading: 'lazy',
                  width: 44,
                  height: 44,
                  alt: ''
              }}
            {%- else -%}
              <i class="ti {{ block.settings.icon_class_3 | escape }}"></i>
            {%- endif -%}
          </div>
          <div class="what-youll-feel__copy">
            <p class="what-youll-feel__title">{{ block.settings.title_3 | escape }}</p>
            <p class="what-youll-feel__descriptor">{{ block.settings.descriptor_3 | escape }}</p>
          </div>
          <div class="what-youll-feel__stat">
            <span class="what-youll-feel__percent">{{ block.settings.percentage_3 | escape }}</span>
          </div>
        </div>
      {%- endif -%}

      {%- if block.settings.show_benefit_4 -%}
        <div
          class="what-youll-feel__row what-youll-feel__row--4"
          {%- if block.settings.icon_tint_4 != blank or block.settings.icon_color_4 != blank -%}
            style="
              {%- if block.settings.icon_tint_4 != blank -%}
                --wyf-icon-tint: {{ block.settings.icon_tint_4 }};
              {%- endif -%}
              {%- if block.settings.icon_color_4 != blank -%}
                --wyf-icon-color: {{ block.settings.icon_color_4 }};
              {%- endif -%}
            "
          {%- endif -%}
        >
          <div class="what-youll-feel__icon-tile" aria-hidden="true">
            {%- if block.settings.image_4 != blank -%}
              {{
                block.settings.image_4
                | image_url: width: 88
                | image_tag:
                  class: 'what-youll-feel__image',
                  loading: 'lazy',
                  width: 44,
                  height: 44,
                  alt: ''
              }}
            {%- else -%}
              <i class="ti {{ block.settings.icon_class_4 | escape }}"></i>
            {%- endif -%}
          </div>
          <div class="what-youll-feel__copy">
            <p class="what-youll-feel__title">{{ block.settings.title_4 | escape }}</p>
            <p class="what-youll-feel__descriptor">{{ block.settings.descriptor_4 | escape }}</p>
          </div>
          <div class="what-youll-feel__stat">
            <span class="what-youll-feel__percent">{{ block.settings.percentage_4 | escape }}</span>
          </div>
        </div>
      {%- endif -%}

      {%- if block.settings.show_benefit_5 -%}
        <div
          class="what-youll-feel__row what-youll-feel__row--5"
          {%- if block.settings.icon_tint_5 != blank or block.settings.icon_color_5 != blank -%}
            style="
              {%- if block.settings.icon_tint_5 != blank -%}
                --wyf-icon-tint: {{ block.settings.icon_tint_5 }};
              {%- endif -%}
              {%- if block.settings.icon_color_5 != blank -%}
                --wyf-icon-color: {{ block.settings.icon_color_5 }};
              {%- endif -%}
            "
          {%- endif -%}
        >
          <div class="what-youll-feel__icon-tile" aria-hidden="true">
            {%- if block.settings.image_5 != blank -%}
              {{
                block.settings.image_5
                | image_url: width: 88
                | image_tag:
                  class: 'what-youll-feel__image',
                  loading: 'lazy',
                  width: 44,
                  height: 44,
                  alt: ''
              }}
            {%- else -%}
              <i class="ti {{ block.settings.icon_class_5 | escape }}"></i>
            {%- endif -%}
          </div>
          <div class="what-youll-feel__copy">
            <p class="what-youll-feel__title">{{ block.settings.title_5 | escape }}</p>
            <p class="what-youll-feel__descriptor">{{ block.settings.descriptor_5 | escape }}</p>
          </div>
          <div class="what-youll-feel__stat">
            <span class="what-youll-feel__percent">{{ block.settings.percentage_5 | escape }}</span>
          </div>
        </div>
      {%- endif -%}
    </div>

    <div class="what-youll-feel__fine-print">
      {%- if block.settings.survey_source != blank -%}
        <p>{{ block.settings.survey_source | escape }}</p>
      {%- endif -%}
      {%- if block.settings.disclaimer != blank -%}
        <div class="what-youll-feel__disclaimer rte">{{ block.settings.disclaimer }}</div>
      {%- endif -%}
    </div>
  </div>
</div>
