{% doc %}
  Renders a cart-line Subscribe & Save upsell for one-time purchase cart lines.

  @param {line_item} item - Cart line item.
  @param {string} context - Rendering context, e.g. 'drawer' or 'main'.
  @param {boolean} line_has_bundle - Whether the line should include Pair & Save in displayed target savings.
  @param {number} resolved_subscription_discount_pct
  @param {number} resolved_bundle_discount_pct
  @param {number} resolved_volume_discount_1_pct
  @param {number} resolved_volume_discount_2_pct
  @param {number} resolved_volume_discount_3_pct
  @param {number} resolved_volume_discount_4_pct
  @param {number} resolved_volume_discount_5_pct
{% enddoc %}

{%- liquid
  assign upsell_context = context | default: 'cart'
  assign upsell_enabled = settings.cart_line_subscription_upsell_enabled
  if upsell_enabled == nil
    assign upsell_enabled = true
  endif
  assign can_update_line = true
  if item.instructions and item.instructions.can_update_quantity == false
    assign can_update_line = false
  endif

  assign target_plan_id = ''
  assign upsell_line_has_bundle = line_has_bundle | default: false
-%}

{%- if upsell_enabled and item.selling_plan_allocation == null and can_update_line -%}
  {%- liquid
    assign target_qty = item.quantity | default: 1
    if target_qty < 1
      assign target_qty = 1
    endif
    if target_qty > 5
      assign target_qty = 5
    endif

    assign plan_filter = target_qty | append: '-pack'
    assign frequency_filter = target_qty | append: 'mo'
    assign frequency_filter_spaced = target_qty | append: ' mo'
    assign frequency_filter_dash = target_qty | append: '-mo'
    assign frequency_filter_month = target_qty | append: ' month'
    assign frequency_filter_every = 'every ' | append: target_qty
    assign frequency_filter_appstle = target_qty | append: 'month'
    assign fallback_plan_id = ''

    for selling_plan_group in item.product.selling_plan_groups
      assign group_name_lower = selling_plan_group.name | downcase
      if group_name_lower contains plan_filter
        assign first_plan = selling_plan_group.selling_plans | first
        if first_plan and fallback_plan_id == blank
          assign fallback_plan_id = first_plan.id
        endif

        for selling_plan in selling_plan_group.selling_plans
          assign frequency_source = selling_plan_group.name | append: ' ' | append: selling_plan.name | downcase
          for option in selling_plan.options
            assign frequency_source = frequency_source | append: ' ' | append: option.value | downcase
          endfor

          if frequency_source contains frequency_filter or frequency_source contains frequency_filter_spaced or frequency_source contains frequency_filter_dash or frequency_source contains frequency_filter_month or frequency_source contains frequency_filter_every or frequency_source contains frequency_filter_appstle
            assign target_plan_id = selling_plan.id
            break
          endif
        endfor

        if target_plan_id != blank
          break
        endif
      endif
    endfor

    if target_plan_id == blank
      assign target_plan_id = fallback_plan_id
    endif

    if resolved_subscription_discount_pct != blank
      assign subscription_discount_pct = resolved_subscription_discount_pct | plus: 0
    elsif item.product.metafields.bloomli.subscription_discount_pct != blank
      assign subscription_discount_pct = item.product.metafields.bloomli.subscription_discount_pct | plus: 0
    elsif settings.bloomli_subscription_discount_pct != blank
      assign subscription_discount_pct = settings.bloomli_subscription_discount_pct | plus: 0
    elsif settings.cart_line_subscription_upsell_discount_pct != blank
      assign subscription_discount_pct = settings.cart_line_subscription_upsell_discount_pct | plus: 0
    elsif settings.cart_drawer_subscription_discount_pct != blank
      assign subscription_discount_pct = settings.cart_drawer_subscription_discount_pct | plus: 0
    else
      assign subscription_discount_pct = 15
    endif

    if resolved_bundle_discount_pct != blank
      assign bundle_discount_pct = resolved_bundle_discount_pct | plus: 0
    elsif item.product.metafields.bloomli.bundle_add_on_discount_pct != blank
      assign bundle_discount_pct = item.product.metafields.bloomli.bundle_add_on_discount_pct | plus: 0
    elsif settings.bloomli_bundle_add_on_discount_pct != blank
      assign bundle_discount_pct = settings.bloomli_bundle_add_on_discount_pct | plus: 0
    elsif settings.cart_drawer_addon_bundle_discount_pct != blank
      assign bundle_discount_pct = settings.cart_drawer_addon_bundle_discount_pct | plus: 0
    else
      assign bundle_discount_pct = 20
    endif

    if target_qty >= 5
      if resolved_volume_discount_5_pct != blank
        assign volume_discount_pct = resolved_volume_discount_5_pct | plus: 0
      elsif item.product.metafields.bloomli.volume_discount_5_pct != blank
        assign volume_discount_pct = item.product.metafields.bloomli.volume_discount_5_pct | plus: 0
      elsif settings.bloomli_volume_discount_5_pct != blank
        assign volume_discount_pct = settings.bloomli_volume_discount_5_pct | plus: 0
      elsif settings.cart_drawer_quantity_offer_5_savings != blank
        assign volume_discount_pct = settings.cart_drawer_quantity_offer_5_savings | plus: 0
      else
        assign volume_discount_pct = 20
      endif
    elsif target_qty == 4
      if resolved_volume_discount_4_pct != blank
        assign volume_discount_pct = resolved_volume_discount_4_pct | plus: 0
      elsif item.product.metafields.bloomli.volume_discount_4_pct != blank
        assign volume_discount_pct = item.product.metafields.bloomli.volume_discount_4_pct | plus: 0
      elsif settings.bloomli_volume_discount_4_pct != blank
        assign volume_discount_pct = settings.bloomli_volume_discount_4_pct | plus: 0
      elsif settings.cart_drawer_quantity_offer_4_savings != blank
        assign volume_discount_pct = settings.cart_drawer_quantity_offer_4_savings | plus: 0
      else
        assign volume_discount_pct = 18
      endif
    elsif target_qty == 3
      if resolved_volume_discount_3_pct != blank
        assign volume_discount_pct = resolved_volume_discount_3_pct | plus: 0
      elsif item.product.metafields.bloomli.volume_discount_3_pct != blank
        assign volume_discount_pct = item.product.metafields.bloomli.volume_discount_3_pct | plus: 0
      elsif settings.bloomli_volume_discount_3_pct != blank
        assign volume_discount_pct = settings.bloomli_volume_discount_3_pct | plus: 0
      elsif settings.cart_drawer_quantity_offer_3_savings != blank
        assign volume_discount_pct = settings.cart_drawer_quantity_offer_3_savings | plus: 0
      else
        assign volume_discount_pct = 15
      endif
    elsif target_qty == 2
      if resolved_volume_discount_2_pct != blank
        assign volume_discount_pct = resolved_volume_discount_2_pct | plus: 0
      elsif item.product.metafields.bloomli.volume_discount_2_pct != blank
        assign volume_discount_pct = item.product.metafields.bloomli.volume_discount_2_pct | plus: 0
      elsif settings.bloomli_volume_discount_2_pct != blank
        assign volume_discount_pct = settings.bloomli_volume_discount_2_pct | plus: 0
      else
        assign volume_discount_pct = 10
      endif
    else
      if resolved_volume_discount_1_pct != blank
        assign volume_discount_pct = resolved_volume_discount_1_pct | plus: 0
      elsif item.product.metafields.bloomli.volume_discount_1_pct != blank
        assign volume_discount_pct = item.product.metafields.bloomli.volume_discount_1_pct | plus: 0
      elsif settings.bloomli_volume_discount_1_pct != blank
        assign volume_discount_pct = settings.bloomli_volume_discount_1_pct | plus: 0
      else
        assign volume_discount_pct = 0
      endif
    endif

    assign bundle_factor = 100.0
    if upsell_line_has_bundle
      assign bundle_factor = 100.0 | minus: bundle_discount_pct
    endif
    assign volume_factor = 100.0 | minus: volume_discount_pct
    assign subscription_factor = 100.0 | minus: subscription_discount_pct
    assign combined_factor = volume_factor | times: subscription_factor | divided_by: 100.0 | times: bundle_factor | divided_by: 100.0
    assign discount_percent = 100.0 | minus: combined_factor | floor

    assign badge_text = settings.cart_line_subscription_upsell_badge_text | default: 'MOST POPULAR'
    assign discount_label = discount_percent
    assign heading_template = settings.cart_line_subscription_upsell_heading | default: 'Subscribe & Save [X]%'
    if heading_template contains '[X]' or heading_template contains '[percent]'
      assign heading_text = heading_template | replace: '[X]', discount_label | replace: '[percent]', discount_label
    elsif heading_template contains '%'
      assign heading_text = 'Subscribe & Save ' | append: discount_label | append: '%'
    else
      assign heading_text = heading_template
    endif
    assign benefit_1 = settings.cart_line_subscription_upsell_benefit_1 | default: 'Save more on every order'
    assign benefit_2 = settings.cart_line_subscription_upsell_benefit_2 | default: 'Free shipping on every delivery'
    assign benefit_3 = settings.cart_line_subscription_upsell_benefit_3 | default: 'Pause, skip, or cancel anytime'
    assign benefit_4 = settings.cart_line_subscription_upsell_benefit_4 | default: 'Backed by our 30-day guarantee'
    if upsell_context == 'drawer'
      assign benefit_icon_1 = settings.cart_line_subscription_upsell_benefit_icon_1
      assign benefit_icon_2 = settings.cart_line_subscription_upsell_benefit_icon_2
      assign benefit_icon_3 = settings.cart_line_subscription_upsell_benefit_icon_3
      assign benefit_icon_4 = settings.cart_line_subscription_upsell_benefit_icon_4
    endif
    assign cta_template = settings.cart_line_subscription_upsell_cta_text | default: 'Upgrade to Subscription & SAVE [X]%'
    if cta_template contains '[X]' or cta_template contains '[percent]'
      assign cta_text = cta_template | replace: '[X]', discount_label | replace: '[percent]', discount_label
    elsif cta_template contains '%'
      assign cta_text = 'Upgrade to Subscription & SAVE ' | append: discount_label | append: '%'
    else
      assign cta_text = cta_template
    endif
  -%}

  {%- if target_plan_id != blank -%}
    <div
      class="bloomli-cart-subscription-upsell bloomli-cart-subscription-upsell--{{ upsell_context }}"
      data-bloomli-cart-subscription-upsell
      style="
        --bloomli-cart-upsell-bg: {{ settings.cart_line_subscription_upsell_card_bg | default: '#DFF1E8' }};
        --bloomli-cart-upsell-border: {{ settings.cart_line_subscription_upsell_border_color | default: '#BBDCCB' }};
        --bloomli-cart-upsell-heading: {{ settings.cart_line_subscription_upsell_heading_color | default: '#2A2622' }};
        --bloomli-cart-upsell-body: {{ settings.cart_line_subscription_upsell_body_color | default: '#2A2622' }};
        --bloomli-cart-upsell-icon: {{ settings.cart_line_subscription_upsell_icon_color | default: '#B23A6F' }};
        --bloomli-cart-upsell-badge-bg: {{ settings.cart_line_subscription_upsell_badge_bg | default: '#B23A6F' }};
        --bloomli-cart-upsell-badge-text: {{ settings.cart_line_subscription_upsell_badge_text_color | default: '#FDFAF7' }};
        --bloomli-cart-upsell-cta-bg: {{ settings.cart_line_subscription_upsell_cta_bg | default: '#B23A6F' }};
        --bloomli-cart-upsell-cta-text: {{ settings.cart_line_subscription_upsell_cta_text_color | default: '#FDFAF7' }};
        --bloomli-cart-upsell-radius: {{ settings.cart_line_subscription_upsell_radius | default: 10 }}px;
        --bloomli-cart-upsell-padding: {{ settings.cart_line_subscription_upsell_padding | default: 18 }}px;
        --bloomli-cart-upsell-spacing: {{ settings.cart_line_subscription_upsell_spacing | default: 10 }}px;
      "
    >
      {%- if badge_text != blank -%}
        <span class="bloomli-cart-subscription-upsell__badge">{{ badge_text | escape }}</span>
      {%- endif -%}
      {%- if heading_text != blank -%}
        <h3 class="bloomli-cart-subscription-upsell__heading">{{ heading_text | escape }}</h3>
      {%- endif -%}
      <ul class="bloomli-cart-subscription-upsell__benefits" role="list">
        {%- if benefit_1 != blank -%}
          <li class="bloomli-cart-subscription-upsell__benefit">
            <span class="bloomli-cart-subscription-upsell__benefit-icon{% if benefit_icon_1 != blank %} has-custom-icon{% endif %}" aria-hidden="true">
              {%- if benefit_icon_1 != blank -%}
                {{ benefit_icon_1 | image_url: width: 48 | image_tag: loading: 'lazy', alt: '', widths: '24, 48' }}
              {%- endif -%}
            </span>
            <span>{{ benefit_1 | escape }}</span>
          </li>
        {%- endif -%}
        {%- if benefit_2 != blank -%}
          <li class="bloomli-cart-subscription-upsell__benefit">
            <span class="bloomli-cart-subscription-upsell__benefit-icon{% if benefit_icon_2 != blank %} has-custom-icon{% endif %}" aria-hidden="true">
              {%- if benefit_icon_2 != blank -%}
                {{ benefit_icon_2 | image_url: width: 48 | image_tag: loading: 'lazy', alt: '', widths: '24, 48' }}
              {%- endif -%}
            </span>
            <span>{{ benefit_2 | escape }}</span>
          </li>
        {%- endif -%}
        {%- if benefit_3 != blank -%}
          <li class="bloomli-cart-subscription-upsell__benefit">
            <span class="bloomli-cart-subscription-upsell__benefit-icon{% if benefit_icon_3 != blank %} has-custom-icon{% endif %}" aria-hidden="true">
              {%- if benefit_icon_3 != blank -%}
                {{ benefit_icon_3 | image_url: width: 48 | image_tag: loading: 'lazy', alt: '', widths: '24, 48' }}
              {%- endif -%}
            </span>
            <span>{{ benefit_3 | escape }}</span>
          </li>
        {%- endif -%}
        {%- if benefit_4 != blank -%}
          <li class="bloomli-cart-subscription-upsell__benefit">
            <span class="bloomli-cart-subscription-upsell__benefit-icon{% if benefit_icon_4 != blank %} has-custom-icon{% endif %}" aria-hidden="true">
              {%- if benefit_icon_4 != blank -%}
                {{ benefit_icon_4 | image_url: width: 48 | image_tag: loading: 'lazy', alt: '', widths: '24, 48' }}
              {%- endif -%}
            </span>
            <span>{{ benefit_4 | escape }}</span>
          </li>
        {%- endif -%}
      </ul>
      <button
        type="button"
        class="bloomli-cart-subscription-upsell__cta"
        data-bloomli-cart-subscription-upsell-cta
        data-line="{{ item.index | plus: 1 }}"
        data-line-key="{{ item.key }}"
        data-quantity="{{ item.quantity }}"
        data-selling-plan="{{ target_plan_id }}"
      >
        <span data-bloomli-cart-subscription-upsell-cta-text>{{ cta_text | escape }}</span>
        <span class="loading__spinner hidden">
          {{- 'loading-spinner.svg' | inline_asset_content -}}
        </span>
      </button>
    </div>
  {%- endif -%}
{%- endif -%}
