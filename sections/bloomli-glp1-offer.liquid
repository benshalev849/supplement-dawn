{% comment %}
  Bloomli — GLP-1 offer.
  Embeds the real product purchase module (Bloomli Volume Tier) on a page
  template, pointed at a chosen product, so pricing and the subscribe/save
  offer match the product page exactly. Add one "Volume Tier" block.
{% endcomment %}

{%- liquid
  assign offer_product = section.settings.product
  assign emphasis = section.settings.emphasis_color
-%}

{%- style -%}
  .glp1-offer--{{ section.id }} { max-width: 44rem; margin: 0 auto; padding: 0 2.2rem; }
  .glp1-offer__head--{{ section.id }} { text-align: center; margin-bottom: 8px; }
  .glp1-offer__eyebrow--{{ section.id }} {
    font-size: 1.1rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: {{ section.settings.eyebrow_color }};
    margin: 0 0 14px;
  }
  .glp1-offer__title--{{ section.id }} {
    font-family: var(--font-heading-family);
    font-weight: 400;
    line-height: 1.08;
    letter-spacing: -0.015em;
    margin: 0 0 12px;
    text-wrap: balance;
    font-size: {{ section.settings.heading_size_mobile }}px;
  }
  .glp1-offer__title--{{ section.id }} em { font-style: italic; color: {{ emphasis }}; }
  .glp1-offer__sub--{{ section.id }} { opacity: 0.75; margin: 0 0 24px; line-height: 1.6; }
  .glp1-offer__module--{{ section.id }} { margin: 8px 0 0; }
  .glp1-offer__reassure--{{ section.id }} {
    text-align: center;
    line-height: 1.6;
    margin: 18px 0 0;
  }
  .glp1-offer__reassure--{{ section.id }} strong { color: {{ emphasis }}; }
  .glp1-offer__note--{{ section.id }} {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 9px;
    margin-top: 18px;
    background: {{ section.settings.note_background }};
    border: 1px dashed {{ section.settings.note_border }};
    border-radius: 6px;
    padding: 11px 16px;
  }
  .glp1-offer__note--{{ section.id }} span {
    font-size: 1.1rem;
    font-weight: 600;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    opacity: 0.7;
    text-align: center;
  }
  .glp1-offer__missing--{{ section.id }} {
    text-align: center;
    border: 1px dashed {{ section.settings.note_border }};
    border-radius: 12px;
    padding: 28px;
    opacity: 0.75;
  }
  @media screen and (min-width: 750px) {
    .glp1-offer__title--{{ section.id }} { font-size: {{ section.settings.heading_size }}px; }
  }
{%- endstyle -%}

<div id="glp1-offers" class="color-{{ section.settings.color_scheme }} gradient section-{{ section.id }}-padding">
  <div class="glp1-offer--{{ section.id }}">
    {%- if section.settings.heading != blank or section.settings.eyebrow != blank or section.settings.subtext != blank -%}
      <div class="glp1-offer__head--{{ section.id }}">
        {%- if section.settings.eyebrow != blank -%}
          <p class="glp1-offer__eyebrow--{{ section.id }}">{{ section.settings.eyebrow }}</p>
        {%- endif -%}
        {%- if section.settings.heading != blank -%}
          <h2 class="glp1-offer__title--{{ section.id }}">{{ section.settings.heading }}</h2>
        {%- endif -%}
        {%- if section.settings.subtext != blank -%}
          <div class="glp1-offer__sub--{{ section.id }} rte">{{ section.settings.subtext }}</div>
        {%- endif -%}
      </div>
    {%- endif -%}

    {%- if offer_product != blank -%}
      <div id="bloomli-product-form" class="glp1-offer__module--{{ section.id }}">
        {%- for block in section.blocks -%}
          {%- case block.type -%}
            {%- when 'volume_tier' -%}
              {%- render 'bloomli-volume-tier',
                block: block,
                product: offer_product,
                section_id: section.id
              -%}
          {%- endcase -%}
        {%- endfor -%}
      </div>

      {%- if section.settings.reassurance != blank -%}
        <div class="glp1-offer__reassure--{{ section.id }} rte">{{ section.settings.reassurance }}</div>
      {%- endif -%}

      {%- if section.settings.guarantee_note != blank -%}
        <div class="glp1-offer__note--{{ section.id }}">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="{{ section.settings.emphasis_color }}" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 3l8 3v6c0 5-3.5 8.5-8 10-4.5-1.5-8-5-8-10V6l8-3z"/><path d="M9 12l2 2 4-4"/></svg>
          <span>{{ section.settings.guarantee_note }}</span>
        </div>
      {%- endif -%}

      <script src="{{ 'product-form.js' | asset_url }}" defer="defer"></script>
    {%- else -%}
      <div class="glp1-offer__missing--{{ section.id }}">
        {{ 'onboarding.product_title' | t }} — select a product in this section's settings to show the live offer.
      </div>
    {%- endif -%}
  </div>
</div>

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }
  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

{% schema %}
{
  "name": "Bloomli — GLP-1 Offer",
  "tag": "section",
  "class": "section",
  "enabled_on": { "templates": ["page"] },
  "settings": [
    { "type": "color_scheme", "id": "color_scheme", "label": "t:sections.all.colors.label", "default": "scheme-1" },
    { "type": "product", "id": "product", "label": "Product", "info": "The live offer/pricing is pulled from this product." },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "The offer" },
    { "type": "inline_richtext", "id": "heading", "label": "Heading", "default": "Start your <em>hair-support ritual.</em>" },
    { "type": "richtext", "id": "subtext", "label": "Subtext", "default": "<p>Pick your supply. Subscribe and save, with free shipping.</p>" },
    { "type": "richtext", "id": "reassurance", "label": "Reassurance line", "default": "<p>Two passion-fruit gummies a day — a simple ritual that fits your new routine.</p>" },
    { "type": "text", "id": "guarantee_note", "label": "Guarantee note", "default": "30-day money-back guarantee" },
    { "type": "header", "content": "Colours" },
    { "type": "color", "id": "emphasis_color", "label": "Emphasis (italic / icons)", "default": "#7B2151" },
    { "type": "color", "id": "eyebrow_color", "label": "Eyebrow", "default": "#8A6678" },
    { "type": "color", "id": "note_background", "label": "Note background", "default": "#F5EDE4" },
    { "type": "color", "id": "note_border", "label": "Note border", "default": "#E8DED8" },
    { "type": "header", "content": "Typography" },
    { "type": "range", "id": "heading_size", "label": "Heading size desktop", "min": 24, "max": 48, "step": 2, "default": 34, "unit": "px" },
    { "type": "range", "id": "heading_size_mobile", "label": "Heading size mobile", "min": 22, "max": 40, "step": 2, "default": 28, "unit": "px" },
    { "type": "header", "content": "t:sections.all.padding.section_padding_heading" },
    { "type": "range", "id": "padding_top", "min": 0, "max": 120, "step": 4, "unit": "px", "label": "t:sections.all.padding.padding_top", "default": 60 },
    { "type": "range", "id": "padding_bottom", "min": 0, "max": 120, "step": 4, "unit": "px", "label": "t:sections.all.padding.padding_bottom", "default": 60 }
  ],
  "blocks": [
    {
      "type": "volume_tier",
      "name": "Bloomli — Volume Tier",
      "limit": 1,
      "settings": [
        { "type": "header", "content": "Heading" },
        { "type": "text", "id": "heading", "label": "\"Select Your Size\" label", "default": "Select Your Size:" },
        { "type": "image_picker", "id": "override_product_image", "label": "Override product image" },
        { "type": "header", "content": "Add to cart button" },
        { "type": "text", "id": "add_to_cart_label", "label": "Button label", "default": "Add to cart" },
        { "type": "text", "id": "sold_out_label", "label": "Sold-out label", "default": "Sold out" },
        { "type": "header", "content": "Save badge colors" },
        { "type": "color", "id": "save_badge_background", "label": "Save badge background", "default": "#B23A6F" },
        { "type": "color", "id": "save_badge_text_color", "label": "Save badge text", "default": "#FDFAF7" },
        { "type": "header", "content": "Tier tag colors" },
        { "type": "color", "id": "tier_tag_background", "label": "Tier tag background", "default": "#8A6678" },
        { "type": "color", "id": "tier_tag_text_color", "label": "Tier tag text", "default": "#FDFAF7" },
        { "type": "header", "content": "Desktop card typography" },
        { "type": "range", "id": "desktop_tier_title_size", "label": "Tier title font size", "min": 8, "max": 18, "step": 1, "default": 11, "unit": "px" },
        { "type": "range", "id": "desktop_tier_count_size", "label": "Count text font size", "min": 8, "max": 14, "step": 1, "default": 9, "unit": "px" },
        { "type": "range", "id": "desktop_tier_daily_size", "label": "Daily price font size", "min": 8, "max": 14, "step": 1, "default": 9, "unit": "px" },
        { "type": "header", "content": "Tier 1" },
        { "type": "checkbox", "id": "tier_1_show", "label": "Show this tier", "default": true },
        { "type": "number", "id": "tier_1_qty", "label": "Display supply count", "default": 1 },
        { "type": "product", "id": "tier_1_bundle_product", "label": "Product to add", "info": "Optional. Leave blank to add the section product." },
        { "type": "text", "id": "tier_1_bundle_product_handle", "label": "Product handle fallback", "info": "Optional. Use only if the product picker is empty." },
        { "type": "text", "id": "tier_1_label", "label": "Tier label", "default": "1 month" },
        { "type": "text", "id": "tier_1_count_text", "label": "Count text", "default": "60 Count" },
        { "type": "text", "id": "tier_1_daily_text", "label": "Daily price text" },
        { "type": "image_picker", "id": "tier_1_image", "label": "Tier image" },
        { "type": "text", "id": "tier_1_badge", "label": "Discount badge text (e.g. '20% OFF')" },
        { "type": "text", "id": "tier_1_tag", "label": "Side tag (e.g. 'Most popular')" },
        { "type": "number", "id": "tier_1_discount_pct", "label": "Volume discount % (one-time)", "default": 0, "info": "Must match the automatic discount you create in Shopify Admin → Discounts." },
        { "type": "text", "id": "tier_1_subscription_discount_pct", "label": "Subscription total discount %", "default": "20", "info": "Total subscription discount from product price, not compare-at price." },
        { "type": "text", "id": "tier_1_plan_filter", "label": "Appstle plan group filter", "default": "1-pack" },
        { "type": "checkbox", "id": "tier_1_default", "label": "Selected by default", "default": false },
        { "type": "header", "content": "Tier 2" },
        { "type": "checkbox", "id": "tier_2_show", "label": "Show this tier", "default": true },
        { "type": "number", "id": "tier_2_qty", "label": "Display supply count", "default": 3 },
        { "type": "product", "id": "tier_2_bundle_product", "label": "Product to add", "info": "Select the hidden product ending in 3 Months Supply." },
        { "type": "text", "id": "tier_2_bundle_product_handle", "label": "Product handle fallback", "info": "Optional. Use only if the product picker is empty or the inferred handle is different." },
        { "type": "text", "id": "tier_2_label", "label": "Tier label", "default": "3 months" },
        { "type": "text", "id": "tier_2_count_text", "label": "Count text", "default": "180 Count" },
        { "type": "text", "id": "tier_2_daily_text", "label": "Daily price text" },
        { "type": "image_picker", "id": "tier_2_image", "label": "Tier image" },
        { "type": "text", "id": "tier_2_badge", "label": "Manual badge fallback text" },
        { "type": "text", "id": "tier_2_tag", "label": "Side tag", "default": "Most popular" },
        { "type": "number", "id": "tier_2_discount_pct", "label": "Volume discount % (one-time)", "default": 15 },
        { "type": "text", "id": "tier_2_subscription_discount_pct", "label": "Subscription total discount %", "default": "32", "info": "Total subscription discount from product price, not compare-at price." },
        { "type": "text", "id": "tier_2_plan_filter", "label": "Appstle plan group filter", "default": "3-pack" },
        { "type": "checkbox", "id": "tier_2_default", "label": "Selected by default", "default": true },
        { "type": "header", "content": "Tier 3" },
        { "type": "checkbox", "id": "tier_3_show", "label": "Show this tier", "default": true },
        { "type": "number", "id": "tier_3_qty", "label": "Display supply count", "default": 6 },
        { "type": "product", "id": "tier_3_bundle_product", "label": "Product to add", "info": "Select the hidden product ending in 6 Month Supply." },
        { "type": "text", "id": "tier_3_bundle_product_handle", "label": "Product handle fallback", "info": "Optional. Use only if the product picker is empty or the inferred handle is different." },
        { "type": "text", "id": "tier_3_label", "label": "Tier label", "default": "6 months" },
        { "type": "text", "id": "tier_3_count_text", "label": "Count text", "default": "360 Count" },
        { "type": "text", "id": "tier_3_daily_text", "label": "Daily price text" },
        { "type": "image_picker", "id": "tier_3_image", "label": "Tier image" },
        { "type": "text", "id": "tier_3_badge", "label": "Manual badge fallback text" },
        { "type": "text", "id": "tier_3_tag", "label": "Side tag", "default": "Best value" },
        { "type": "number", "id": "tier_3_discount_pct", "label": "Volume discount % (one-time)", "default": 20 },
        { "type": "text", "id": "tier_3_subscription_discount_pct", "label": "Subscription total discount %", "default": "36", "info": "Total subscription discount from product price, not compare-at price." },
        { "type": "text", "id": "tier_3_plan_filter", "label": "Appstle plan group filter", "default": "6-pack" },
        { "type": "checkbox", "id": "tier_3_default", "label": "Selected by default", "default": false },
        { "type": "header", "content": "Purchase mode" },
        { "type": "checkbox", "id": "subscribe_enabled", "label": "Show subscribe option", "default": true },
        { "type": "text", "id": "subscription_discount_pct", "label": "Static subscription discount %", "default": "20", "info": "Compounded with the selected tier's volume discount for subscription display." },
        { "type": "text", "id": "discount_badge_template", "label": "Pack discount badge template", "default": "SAVE [percent]%", "info": "Use [percent] and optionally [qty]. Subscription mode shows the compounded discount." },
        {
          "type": "select",
          "id": "default_mode",
          "label": "Default purchase mode",
          "default": "subscribe",
          "options": [
            { "value": "onetime", "label": "One-time" },
            { "value": "subscribe", "label": "Subscribe" }
          ]
        },
        { "type": "text", "id": "offer_section_label", "label": "\"Select Your Offer\" heading", "default": "Select Your Offer", "info": "Leave blank to hide." },
        { "type": "text", "id": "label_one_time", "label": "One-time label", "default": "One-Time Purchase" },
        { "type": "text", "id": "label_subscribe", "label": "Subscribe label", "default": "Subscribe & Save" },
        { "type": "header", "content": "Subscribe card" },
        { "type": "text", "id": "subscribe_popular_pill", "label": "Top bar text", "default": "Most Popular · Get [percent]% Off", "info": "Use [percent] for a dynamic discount vs compare-at price. Leave blank to hide the bar." },
        { "type": "checkbox", "id": "subscribe_show_perks", "label": "Show perks list", "default": true },
        { "type": "text", "id": "subscribe_perk_1", "label": "Perk 1", "default": "30-day money-back guarantee" },
        { "type": "text", "id": "subscribe_perk_2", "label": "Perk 2", "default": "Free shipping on every delivery" },
        { "type": "text", "id": "subscribe_perk_3", "label": "Perk 3", "default": "Pause or cancel anytime, no fees" },
        { "type": "header", "content": "Savings label" },
        { "type": "text", "id": "savings_label_prefix", "label": "Savings text prefix", "default": "You're saving ", "info": "Appears before the dollar amount." },
        { "type": "text", "id": "savings_label_suffix", "label": "Savings text suffix", "info": "Optional text after the dollar amount." },
        { "type": "header", "content": "One-time purchase caveats" },
        { "type": "text", "id": "onetime_caveat_1", "label": "Caveat line 1", "default": "One Time Discount" },
        { "type": "text", "id": "onetime_caveat_2", "label": "Caveat line 2", "default": "Free shipping unlocks at 3 packs" },
        { "type": "header", "content": "Footer" },
        { "type": "text", "id": "total_label", "label": "Total label", "default": "Total price:" }
      ]
    }
  ],
  "presets": [
    { "name": "Bloomli — GLP-1 Offer", "blocks": [{ "type": "volume_tier" }] }
  ]
}
{% endschema %}
