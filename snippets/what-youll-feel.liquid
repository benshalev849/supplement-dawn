{% doc %}
Renders the What You'll Feel product information block.

@param {block} block - The What You'll Feel block.

@example
{% render 'what-youll-feel', block: block %}
{% enddoc %}

<div class="what-youll-feel" {{ block.shopify_attributes }}>
  <div class="what-youll-feel__card">
    {%- if block.settings.heading != blank -%}
      <h2 class="what-youll-feel__heading">{{ block.settings.heading | escape }}</h2>
    {%- endif -%}

    <div class="what-youll-feel__rows">
      {%- if block.settings.show_benefit_1 -%}
        <div
          class="what-youll-feel__row what-youll-feel__row--1"
          {%- if block.settings.icon_tint_1 != blank -%}
            style="--wyf-icon-tint: {{ block.settings.icon_tint_1 }};"
          {%- endif -%}
        >
          <div class="what-youll-feel__icon-tile" aria-hidden="true">
            {%- if block.settings.image_1 != blank -%}
              {{
                block.settings.image_1
                | image_url: width: 88
                | image_tag:
                  class: 'what-youll-feel__image',
                  loading: 'lazy',
                  width: 44,
                  height: 44,
                  alt: ''
              }}
            {%- else -%}
              <i class="ti {{ block.settings.icon_class_1 | escape }}"></i>
            {%- endif -%}
          </div>
          <div class="what-youll-feel__copy">
            <p class="what-youll-feel__title">{{ block.settings.title_1 | escape }}</p>
            <p class="what-youll-feel__descriptor">{{ block.settings.descriptor_1 | escape }}</p>
          </div>
          <div class="what-youll-feel__stat">
            <span class="what-youll-feel__percent">{{ block.settings.percentage_1 | escape }}</span>
          </div>
        </div>
      {%- endif -%}

      {%- if block.settings.show_benefit_2 -%}
