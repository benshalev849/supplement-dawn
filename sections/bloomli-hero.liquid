{%- assign has_bg_image = false -%}
{%- if section.settings.desktop_image != blank -%}{%- assign has_bg_image = true -%}{%- endif -%}
{%- assign desktop_content_alignment = section.settings.content_alignment | default: 'left' -%}
{%- assign mobile_content_alignment = section.settings.content_alignment_mobile | default: 'inherit' -%}
{%- if mobile_content_alignment == 'inherit' -%}
  {%- assign mobile_content_alignment = desktop_content_alignment -%}
{%- endif -%}

<section
  class="bloomli-hero bloomli-section color-{{ section.settings.color_scheme }} gradient{% unless has_bg_image %}{% if section.settings.use_brand_gradient %} bloomli-hero--brand-gradient{% endif %}{% endunless %}{% if has_bg_image %} bloomli-hero--has-bg-image bloomli-hero--banner-fixed-height{% if section.settings.mobile_image == blank %} bloomli-hero--no-mobile-bg{% endif %}{% endif %}"
  style="
    --hero-min-height: {{ section.settings.min_height }}px;
    --hero-heading-size: {{ section.settings.heading_text_size }}px;
    --hero-subtext-size: {{ section.settings.subtext_text_size }}px;
    --hero-overlay-opacity: {{ section.settings.overlay_opacity | divided_by: 100.0 }};
    --section-padding-top: {{ section.settings.padding_top }}px;
    --section-padding-bottom: {{ section.settings.padding_bottom }}px;
    --section-padding-top-mobile: {{ section.settings.padding_top_mobile }}px;
    --section-padding-bottom-mobile: {{ section.settings.padding_bottom_mobile }}px;
    --hero-desktop-image-fit: {{ section.settings.desktop_image_fit | default: 'cover' }};
    --hero-desktop-image-position: {{ section.settings.desktop_image_position | default: 'center bottom' }};
    --hero-ultrawide-image-position: {{ section.settings.ultrawide_image_position | default: 'center bottom' }};
    --hero-mobile-image-fit: {{ section.settings.mobile_image_fit | default: 'contain' }};
    --hero-mobile-image-position: {{ section.settings.mobile_image_position | default: 'center bottom' }};
    --hero-headline2-color: {{ section.settings.headline_line2_color | default: '#b23a6f' }};
    {%- if section.settings.use_custom_text_color -%}
      --hero-text-color: {{ section.settings.text_color }};
    {%- endif -%}
    {%- if section.settings.use_custom_accent_color -%}
      --hero-accent-color: {{ section.settings.accent_color }};
    {%- endif -%}
  "
>
  {%- if has_bg_image -%}
    <div class="bloomli-hero__bg{% if section.settings.mobile_image != blank %} bloomli-hero__bg--has-mobile{% endif %}" aria-hidden="true">
      {%- comment -%}
        Single <picture> so each breakpoint downloads exactly one file:
        mobile must never fetch the desktop/ultrawide image and vice versa.
        The 768px breakpoint matches the hero CSS in bloomli-sections.css.
        When there is no mobile image the background is hidden below 768px,
        so a 1x1 data-URI source keeps mobile from fetching anything.
      {%- endcomment -%}
      <picture>
        {%- if section.settings.ultrawide_image != blank -%}
          <source
            media="(min-width: 2000px)"
            srcset="
              {{ section.settings.ultrawide_image | image_url: width: 2000 }} 2000w,
              {{ section.settings.ultrawide_image | image_url: width: 2560 }} 2560w,
              {{ section.settings.ultrawide_image | image_url: width: 3200 }} 3200w,
              {{ section.settings.ultrawide_image | image_url: width: 3840 }} 3840w
            "
            sizes="100vw"
          >
        {%- endif -%}
        <source
          media="(min-width: 768px)"
          srcset="
            {{ section.settings.desktop_image | image_url: width: 960 }} 960w,
            {{ section.settings.desktop_image | image_url: width: 1440 }} 1440w,
            {{ section.settings.desktop_image | image_url: width: 1920 }} 1920w
          "
          sizes="100vw"
        >
        {%- if section.settings.mobile_image != blank -%}
          {{
            section.settings.mobile_image
            | image_url: width: 900
            | image_tag:
              class: 'bloomli-hero__bg-img bloomli-hero__bg-img--desktop',
              alt: '',
              widths: '400, 600, 900',
              sizes: '100vw',
              loading: 'eager',
              fetchpriority: 'high',
              decoding: 'async'
          }}
        {%- else -%}
          <source
            media="(max-width: 767.98px)"
            srcset="data:image/gif;base64,R0lGODlhAQABAIAAAAAAAP///yH5BAEAAAAALAAAAAABAAEAAAIBRAA7"
          >
          {{
            section.settings.desktop_image
            | image_url: width: 1920
            | image_tag:
              class: 'bloomli-hero__bg-img bloomli-hero__bg-img--desktop',
              alt: '',
              widths: '960, 1440, 1920',
              sizes: '100vw',
              loading: 'eager',
              fetchpriority: 'high',
              decoding: 'async'
          }}
        {%- endif -%}
      </picture>
      <div class="bloomli-hero__overlay"></div>
    </div>
  {%- endif -%}

  <div class="bloomli-hero__inner bloomli-hero__inner--mobile-{{ section.settings.content_position_mobile }} bloomli-hero__inner--align-{{ desktop_content_alignment }} bloomli-hero__inner--mobile-align-{{ mobile_content_alignment }}">
    <div class="bloomli-hero__copy">
      {%- if section.settings.show_reviews -%}
        <div class="bloomli-hero__reviews">
          <span class="bloomli-hero__stars" aria-hidden="true">&#9733;&#9733;&#9733;&#9733;&#9733;</span>
          <span class="bloomli-hero__review-text">
            {{ section.settings.star_rating_text | default: '4.8 Stars · 2,400+ Reviews' }}
          </span>
        </div>
      {%- endif -%}

      {%- if section.settings.eyebrow != blank -%}
        <p class="bloomli-hero__eyebrow">{{ section.settings.eyebrow }}</p>
      {%- endif -%}

      {%- assign l2_style = section.settings.headline_line2_style | default: 'italic' -%}
      <h1 class="bloomli-hero__headline">
        {{ section.settings.headline_line1 }}<br>
        <span class="bloomli-hero__headline-l2--{{ l2_style }}">{{ section.settings.headline_line2 }}</span>
      </h1>

      {%- if section.settings.subtext != blank -%}
        <p class="bloomli-hero__subtext">
          {{ section.settings.subtext }}
        </p>
      {%- endif -%}

      {%- if section.settings.bullet_1 != blank or section.settings.bullet_2 != blank or section.settings.bullet_3 != blank -%}
        <ul class="bloomli-hero__bullets" role="list">
          {%- for i in (1..3) -%}
            {%- assign bullet_key = 'bullet_' | append: i -%}
            {%- assign bullet_text = section.settings[bullet_key] -%}
            {%- if bullet_text != blank -%}
              <li class="bloomli-hero__bullet">
                <i class="ti ti-circle-check" aria-hidden="true"></i>
                <span>{{ bullet_text }}</span>
              </li>
            {%- endif -%}
          {%- endfor -%}
        </ul>
      {%- endif -%}

      {%- if section.settings.bullets_note != blank -%}
        <p class="bloomli-hero__bullets-note">{{ section.settings.bullets_note }}</p>
      {%- endif -%}

      <div class="bloomli-hero__ctas color-{{ section.settings.button_color_scheme }}">
        {%- if section.settings.cta_primary_label != blank -%}
          {%- assign cta_primary_href = section.settings.cta_primary_url | default: routes.all_products_collection_url -%}
          <a href="{{ cta_primary_href }}" class="button button--primary">{{ section.settings.cta_primary_label }}</a>
        {%- endif -%}
        {%- if section.settings.cta_secondary_label != blank and section.settings.cta_secondary_url != blank -%}
          <a href="{{ section.settings.cta_secondary_url }}" class="button button--secondary">{{ section.settings.cta_secondary_label }}</a>
        {%- endif -%}
      </div>

      {%- if section.settings.show_cta_reassurance and section.settings.cta_reassurance_text != blank -%}
        <div class="bloomli-hero__reassurance">
          <span class="bloomli-hero__reassurance-icon" aria-hidden="true">
            <svg viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round">
              <path d="m5.5 10.2 3 3 6-6.4"/>
            </svg>
          </span>
          <span class="bloomli-hero__reassurance-text">{{ section.settings.cta_reassurance_text }}</span>
        </div>
      {%- endif -%}

      {%- if section.settings.trust_badge_1 != blank or section.settings.trust_badge_2 != blank or section.settings.trust_badge_3 != blank -%}
        <div class="bloomli-hero__trust-badges" aria-label="Trust badges">
          {%- if section.settings.trust_badge_1 != blank -%}
            <span class="bloomli-hero__trust-badge">
              <i class="ti ti-shield-check" aria-hidden="true"></i>
              <span>{{ section.settings.trust_badge_1 }}</span>
            </span>
          {%- endif -%}
          {%- if section.settings.trust_badge_2 != blank -%}
            <span class="bloomli-hero__trust-badge">
              <i class="ti ti-shield-check" aria-hidden="true"></i>
              <span>{{ section.settings.trust_badge_2 }}</span>
            </span>
          {%- endif -%}
          {%- if section.settings.trust_badge_3 != blank -%}
            <span class="bloomli-hero__trust-badge">
              <i class="ti ti-shield-check" aria-hidden="true"></i>
              <span>{{ section.settings.trust_badge_3 }}</span>
            </span>
          {%- endif -%}
          {%- if section.settings.trust_badge_4 != blank -%}
            <span class="bloomli-hero__trust-badge">
              <i class="ti ti-shield-check" aria-hidden="true"></i>
              <span>{{ section.settings.trust_badge_4 }}</span>
            </span>
          {%- endif -%}
        </div>
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Bloomli — Hero",
  "tag": "div",
  "class": "bloomli-hero-wrapper",
  "settings": [
    { "type": "header", "content": "Copy" },
    { "type": "color_scheme", "id": "color_scheme", "label": "Color scheme", "default": "scheme-6d8ba907-aae6-4c49-9120-e1031d9cdb3f" },
    { "type": "checkbox", "id": "use_brand_gradient", "label": "Use Bloomli brand gradient", "default": true },
    { "type": "text",     "id": "eyebrow",         "label": "Eyebrow (small uppercase line above headline)" },
    { "type": "text",     "id": "headline_line1",  "label": "Headline line 1",         "default": "Quiet science," },
    { "type": "text",     "id": "headline_line2",  "label": "Headline line 2",         "default": "visible results." },
    {
      "type": "select",
      "id": "headline_line2_style",
      "label": "Headline line 2 style",
      "default": "italic",
      "options": [
        { "value": "italic",        "label": "Italic serif (default)" },
        { "value": "accent",        "label": "Colored" },
        { "value": "accent_italic", "label": "Colored italic" }
      ]
    },
    {
      "type": "color",
      "id": "headline_line2_color",
      "label": "Headline line 2 color",
      "default": "#b23a6f",
      "visible_if": "{{ section.settings.headline_line2_style != 'italic' }}"
    },
    { "type": "textarea", "id": "subtext",         "label": "Subtext",                 "default": "Gummies, capsules, or strips — clinically-formulated hair support in the form that fits your ritual. Backed by science, designed for real life." },
    { "type": "text",     "id": "bullet_1",        "label": "Proof bullet 1", "info": "Optional check-icon bullets shown between the subtext and the CTA." },
    { "type": "text",     "id": "bullet_2",        "label": "Proof bullet 2" },
    { "type": "text",     "id": "bullet_3",        "label": "Proof bullet 3" },
    { "type": "inline_richtext", "id": "bullets_note", "label": "One-liner below bullets", "info": "Optional punchy line between the bullets and the CTA, e.g. \"No powder. No pills. Just 2 tasty gummies.\" Use bold for emphasis." },
    { "type": "range",    "id": "heading_text_size", "label": "Heading text size",      "min": 28, "max": 80, "step": 1, "default": 44, "unit": "px" },
    { "type": "range",    "id": "subtext_text_size", "label": "Subtext size",           "min": 12, "max": 24, "step": 1, "default": 15, "unit": "px" },
    { "type": "range",    "id": "min_height",      "label": "Min height (px)",         "min": 500, "max": 900, "step": 20, "default": 720 },
    { "type": "range",    "id": "padding_top",     "label": "Padding top",             "min": 0, "max": 176, "step": 8, "default": 80, "unit": "px" },
    { "type": "range",    "id": "padding_bottom",  "label": "Padding bottom",          "min": 0, "max": 176, "step": 8, "default": 80, "unit": "px" },
    { "type": "range",    "id": "padding_top_mobile", "label": "Padding top mobile",   "min": 0, "max": 176, "step": 8, "default": 56, "unit": "px" },
    { "type": "range",    "id": "padding_bottom_mobile", "label": "Padding bottom mobile", "min": 0, "max": 176, "step": 8, "default": 56, "unit": "px" },
    { "type": "header", "content": "CTAs" },
    { "type": "color_scheme", "id": "button_color_scheme", "label": "Button color scheme", "default": "scheme-6d8ba907-aae6-4c49-9120-e1031d9cdb3f" },
    { "type": "text", "id": "cta_primary_label",   "label": "CTA button label",    "default": "Start Your Ritual" },
    { "type": "url",  "id": "cta_primary_url",     "label": "CTA button URL" },
    { "type": "text", "id": "cta_secondary_label", "label": "Secondary button label",  "default": "Take the 2-min Quiz" },
    { "type": "url",  "id": "cta_secondary_url",   "label": "Secondary button URL" },
    { "type": "checkbox", "id": "show_cta_reassurance", "label": "Show reassurance below CTA", "default": false },
    { "type": "inline_richtext", "id": "cta_reassurance_text", "label": "Reassurance text", "default": "Try It <strong>Risk-Free For 30 Days</strong>", "visible_if": "{{ section.settings.show_cta_reassurance }}" },
    { "type": "header", "content": "Reviews badge" },
    { "type": "checkbox", "id": "show_reviews",    "label": "Show reviews badge", "default": true },
    { "type": "text",     "id": "star_rating_text", "label": "Star rating text",  "default": "4.8 Stars · 2,400+ Reviews" },
    { "type": "header", "content": "Trust badges" },
    { "type": "text", "id": "trust_badge_1", "label": "Badge 1 text", "default": "Third-Party Tested" },
    { "type": "text", "id": "trust_badge_2", "label": "Badge 2 text", "default": "NSF-Certified Facility" },
    { "type": "text", "id": "trust_badge_3", "label": "Badge 3 text", "default": "Made in the USA" },
    { "type": "text", "id": "trust_badge_4", "label": "Badge 4 text" },
    { "type": "header", "content": "Background image" },
    { "type": "image_picker", "id": "desktop_image", "label": "Desktop background (16:9 landscape)" },
    { "type": "image_picker", "id": "ultrawide_image", "label": "Ultrawide background (2000px+ screens, recommended 3200 × 950)" },
    {
      "type": "select",
      "id": "ultrawide_image_position",
      "label": "Ultrawide image position",
      "default": "center bottom",
      "visible_if": "{{ section.settings.ultrawide_image != blank }}",
      "options": [
        { "value": "center",        "label": "Center" },
        { "value": "center top",    "label": "Top" },
        { "value": "center bottom", "label": "Bottom" },
        { "value": "left center",   "label": "Left" },
        { "value": "right center",  "label": "Right" }
      ]
    },
    {
      "type": "select",
      "id": "desktop_image_layout",
      "label": "Desktop image layout",
      "default": "banner_fixed_height",
      "options": [
        { "value": "banner_fixed_height", "label": "Banner fixed height (recommended)" }
      ]
    },
    {
      "type": "select",
      "id": "desktop_image_fit",
      "label": "Desktop image fit",
      "default": "cover",
      "options": [
        { "value": "contain", "label": "Contain (show full image)" },
        { "value": "cover",   "label": "Cover (crop to fill)" }
      ]
    },
    {
      "type": "select",
      "id": "desktop_image_position",
      "label": "Desktop image position",
      "default": "center bottom",
      "options": [
        { "value": "center",        "label": "Center" },
        { "value": "center top",    "label": "Top" },
        { "value": "center bottom", "label": "Bottom" },
        { "value": "left center",   "label": "Left" },
        { "value": "right center",  "label": "Right" }
      ]
    },
    { "type": "image_picker", "id": "mobile_image",  "label": "Mobile background (3:4 portrait, optional — blank shows no image)" },
    {
      "type": "select",
      "id": "mobile_image_fit",
      "label": "Mobile image fit",
      "default": "contain",
      "options": [
        { "value": "contain", "label": "Contain (show full image)" },
        { "value": "cover",   "label": "Cover (crop to fill)" }
      ]
    },
    {
      "type": "select",
      "id": "mobile_image_position",
      "label": "Mobile image position",
      "default": "center bottom",
      "options": [
        { "value": "center",        "label": "Center" },
        { "value": "center top",    "label": "Top" },
        { "value": "center bottom", "label": "Bottom" },
        { "value": "left center",   "label": "Left" },
        { "value": "right center",  "label": "Right" }
      ]
    },
    { "type": "range",  "id": "overlay_opacity", "label": "Overlay opacity", "min": 0, "max": 80, "step": 5, "default": 45 },
    { "type": "checkbox", "id": "use_custom_text_color", "label": "Override hero text color", "default": false },
    { "type": "color",  "id": "text_color", "label": "Text color override", "default": "#2a2622" },
    { "type": "checkbox", "id": "use_custom_accent_color", "label": "Override hero accent color", "default": false },
    { "type": "color",  "id": "accent_color", "label": "Accent color override", "default": "#b23a6f" },
    {
      "type": "select",
      "id": "content_alignment",
      "label": "Content alignment — desktop",
      "default": "left",
      "options": [
        { "value": "left",   "label": "Left (default)" },
        { "value": "center", "label": "Center" },
        { "value": "right",  "label": "Right" }
      ]
    },
    {
      "type": "select",
      "id": "content_alignment_mobile",
      "label": "Content alignment — mobile",
      "default": "inherit",
      "options": [
        { "value": "inherit", "label": "Follow desktop" },
        { "value": "left",    "label": "Left" },
        { "value": "center",  "label": "Center" },
        { "value": "right",   "label": "Right" }
      ]
    },
    {
      "type": "select",
      "id": "content_position_mobile",
      "label": "Content position — mobile",
      "default": "top",
      "options": [
        { "value": "top",    "label": "Top" },
        { "value": "center", "label": "Center" },
        { "value": "bottom", "label": "Bottom" }
      ]
    }
  ],
  "presets": [{ "name": "Bloomli — Hero" }]
}
{% endschema %}
