{%- liquid
  assign agg_product = product
  if agg_product == blank
    assign agg_product = section.settings.product
  endif
-%}

{%- if agg_product != blank and agg_product.metafields.judgeme.badge != blank -%}
  {{ 'bloomli-first-order.css' | asset_url | stylesheet_tag }}

  <section
    class="bloomli-review-aggregate color-{{ section.settings.color_scheme }} gradient"
    style="
      --bra-padding-top: {{ section.settings.padding_top }}px;
      --bra-padding-bottom: {{ section.settings.padding_bottom }}px;
      --bra-padding-top-mobile: {{ section.settings.padding_top_mobile }}px;
      --bra-padding-bottom-mobile: {{ section.settings.padding_bottom_mobile }}px;
    "
  >
    <div class="bloomli-review-aggregate__inner">
      <div class="bloomli-review-aggregate__badge jdgm-widget jdgm-preview-badge" data-id="{{ agg_product.id }}">
        {{ agg_product.metafields.judgeme.badge }}
      </div>
      {%- if section.settings.tagline != blank -%}
        <p class="bloomli-review-aggregate__tagline">{{ section.settings.tagline }}</p>
      {%- endif -%}
    </div>
  </section>
{%- endif -%}

{% schema %}
{
  "name": "Bloomli review aggregate",
  "tag": "div",
  "class": "bloomli-review-aggregate-wrapper",
  "enabled_on": { "templates": ["page", "product", "index"] },
  "settings": [
    { "type": "color_scheme", "id": "color_scheme", "label": "Color scheme", "default": "scheme-1" },
    { "type": "product", "id": "product", "label": "Product for the Judge.me aggregate", "info": "Product templates use the current product automatically. The section renders nothing when Judge.me has no data for the product, so no placeholder numbers ever appear." },
    { "type": "text", "id": "tagline", "label": "Tagline", "default": "Rated by women who made Bloomli part of their daily routine." },
    { "type": "header", "content": "Spacing" },
    { "type": "range", "id": "padding_top", "min": 0, "max": 80, "step": 4, "unit": "px", "label": "Padding top", "default": 24 },
    { "type": "range", "id": "padding_bottom", "min": 0, "max": 80, "step": 4, "unit": "px", "label": "Padding bottom", "default": 24 },
    { "type": "range", "id": "padding_top_mobile", "min": 0, "max": 80, "step": 4, "unit": "px", "label": "Padding top mobile", "default": 20 },
    { "type": "range", "id": "padding_bottom_mobile", "min": 0, "max": 80, "step": 4, "unit": "px", "label": "Padding bottom mobile", "default": 20 }
  ],
  "presets": [{ "name": "Bloomli review aggregate" }]
}
{% endschema %}
