    "bloomli_faq_N48arU": {
      "type": "bloomli-faq",
      "blocks": {
        "question_yXD6xy": {
          "type": "question",
          "settings": {
            "question": "How long does it take to work?",
            "answer": "<p>Hair grows gradually, so results build over time rather than overnight. Most customers notice less shedding and improved texture within the first 4-8 weeks. Visible density and growth changes typically appear between months 3-6 with consistent daily use.</p>",
            "open_by_default": false
          }
        },
        "question_UfFpyj": {
          "type": "question",
          "settings": {
            "question": "How do I take it?",
            "answer": "<p>Two gummies a day, with or without food. Consistency matters more than timing. Pick a moment that fits your routine and stick to it.</p>",
            "open_by_default": false
          }
        },
        "question_h3AWWX": {
          "type": "question",
          "settings": {
            "question": "What makes Bloomli different from other hair gummies?",
            "answer": "<p>Most hair gummies are built around biotin alone. Bloomli combines 14 targeted nutrients at doses that actually do something, not the sprinkle amounts added just to earn a spot on the label.</p>",
            "open_by_default": false
          }
        },
        "question_DbFafF": {
          "type": "question",
          "settings": {
