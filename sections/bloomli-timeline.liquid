<script src="{{ 'bloomli-timeline.js' | asset_url }}" defer="defer"></script>

<section class="bloomli-timeline bloomli-journey bloomli-section color-{{ section.settings.color_scheme }} gradient" data-bloomli-journey style="--journey-progress: 0%; --journey-progress-color: {{ section.settings.timeline_icon_color | default: '#6F7A5A' }}; --timeline-icon-color: {{ section.settings.timeline_icon_color | default: '#6F7A5A' }}; --bloomli-padding-top: {{ section.settings.padding_top }}px; --bloomli-padding-bottom: {{ section.settings.padding_bottom }}px;">
  <div class="bloomli-section__inner">

    <div class="bloomli-timeline__header">
      <h2 class="bloomli-timeline__heading">
        {{ section.settings.heading }}
      </h2>
      {%- if section.settings.subheadline != blank -%}
        <div class="bloomli-timeline__subheadline">{{ section.settings.subheadline }}</div>
      {%- endif -%}
    </div>

    {%- assign circle_size = section.settings.circle_size | default: 60 -%}
    {%- assign connector_color = 'var(--bloomli-line)' -%}
    {%- assign connector_style = section.settings.connector_style | default: 'dashed' -%}
    {%- assign connector_width = section.settings.connector_width | default: 1 -%}

    <div class="bloomli-timeline__wrap bloomli-journey__wrap{% unless section.settings.show_connector %} bloomli-timeline__wrap--no-line{% endunless %}" style="--timeline-circle-size: {{ circle_size }}px; --timeline-gap: 32px; --timeline-line-color: {{ connector_color }}; --timeline-line-width: {{ connector_width }}px; --timeline-line-style: {{ connector_style }};">
      {%- if section.settings.show_connector -%}
        <div class="bloomli-timeline__track bloomli-journey__track" aria-hidden="true">
          <span class="bloomli-timeline__progress bloomli-journey__progress"></span>
        </div>
      {%- endif -%}
      <div class="bloomli-timeline__grid">
        {%- for block in section.blocks -%}
          <div class="bloomli-timeline__step bloomli-journey__step" {{ block.shopify_attributes }}>
            <div class="bloomli-timeline__circle" aria-hidden="true">
              <span class="bloomli-timeline__check"></span>
            </div>
            <div class="smallcaps bloomli-timeline__range">{{ block.settings.range }}</div>
            <h3 class="bloomli-timeline__title">{{ block.settings.title }}</h3>
            <p class="bloomli-timeline__copy">{{ block.settings.description }}</p>
          </div>
        {%- endfor -%}
      </div>
    </div>

  </div>
</section>

{% schema %}
{
  "name": "Bloomli — Timeline",
  "tag": "div",
  "max_blocks": 3,
  "settings": [
    { "type": "color_scheme", "id": "color_scheme", "label": "Color scheme", "default": "scheme-6d8ba907-aae6-4c49-9120-e1031d9cdb3f" },
    { "type": "color", "id": "timeline_icon_color", "label": "Timeline icon color", "default": "#6F7A5A" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Your ritual, over time." },
    { "type": "richtext", "id": "subheadline", "label": "Subheadline", "default": "<p>A simple month-by-month look at what consistency can support, from early scalp comfort to fuller-looking hair over time.</p>" },
    { "type": "header", "content": "Check circle" },
    { "type": "range", "id": "circle_size", "label": "Check circle size", "min": 60, "max": 120, "step": 4, "default": 60, "unit": "px" },
    { "type": "header", "content": "Connector line" },
    { "type": "checkbox", "id": "show_connector", "label": "Show connector line", "default": true },
    { "type": "select", "id": "connector_style", "label": "Connector style", "options": [
      { "value": "dashed", "label": "Dashed" },
      { "value": "dotted", "label": "Dotted" },
      { "value": "solid", "label": "Solid" }
    ], "default": "dashed" },
    { "type": "range", "id": "connector_width", "label": "Connector width", "min": 1, "max": 4, "step": 1, "default": 1, "unit": "px" },
    { "type": "header", "content": "Spacing" },
    { "type": "range", "id": "padding_top", "label": "Padding top (px)", "min": 48, "max": 160, "step": 8, "default": 128 },
    { "type": "range", "id": "padding_bottom", "label": "Padding bottom (px)", "min": 48, "max": 160, "step": 8, "default": 128 }
  ],
  "blocks": [
    {
      "type": "step",
      "name": "Step",
      "settings": [
        { "type": "header", "content": "Text" },
        { "type": "text", "id": "range", "label": "Month range", "default": "Month 1–3" },
        { "type": "text", "id": "title", "label": "Title", "default": "Foundation" },
        { "type": "textarea", "id": "description", "label": "Description", "default": "Nourishment reaches the follicle. Expect less shedding and a healthier scalp feel." }
      ]
    }
  ],
  "presets": [{
    "name": "Bloomli — Timeline",
    "settings": { "circle_size": 60, "subheadline": "<p>A simple month-by-month look at what consistency can support, from early scalp comfort to fuller-looking hair over time.</p>" },
    "blocks": [
      { "type": "step", "settings": { "range": "Month 1–3", "title": "Foundation", "description": "Nourishment reaches the follicle. Expect less shedding and a healthier scalp feel." } },
      { "type": "step", "settings": { "range": "Month 3–6", "title": "Visible Shift", "description": "New growth begins. Many see fuller density at the part line and temples." } },
      { "type": "step", "settings": { "range": "Month 6+", "title": "Full Bloom", "description": "Thicker, stronger, shinier hair. Results consolidate with consistent use." } }
    ]
  }]
}
{% endschema %}
