{% doc %}
  Renders a scoped Bloomli SVG icon.

  @param {string} icon - Icon name.
  @param {string} [class] - Optional class.
  @param {number} [size] - Icon size in pixels.

  @example
  {% render 'bloomli-icon', icon: 'leaf', class: 'bloomli-trust__icon', size: 24 %}
{% enddoc %}

{%- liquid
  assign icon_size = size | default: 32
  assign icon_class = class | default: ''
-%}

<svg
  {% if icon_class != blank %}class="{{ icon_class }}"{% endif %}
  width="{{ icon_size }}"
  height="{{ icon_size }}"
  viewBox="0 0 24 24"
  fill="none"
  stroke="currentColor"
  stroke-width="1.5"
  stroke-linecap="round"
  stroke-linejoin="round"
  aria-hidden="true"
  focusable="false"
>
  {%- case icon -%}
    {%- when 'truck' -%}
      <path d="M3 7h11v10H3z"/><path d="M14 10h4l3 3v4h-7z"/><circle cx="7" cy="18" r="1.5"/><circle cx="17" cy="18" r="1.5"/>
    {%- when 'refresh' -%}
      <path d="M3 12a9 9 0 0 1 15-6.7L21 8"/><path d="M21 3v5h-5"/><path d="M21 12a9 9 0 0 1-15 6.7L3 16"/><path d="M3 21v-5h5"/>
    {%- when 'shield' -%}
      <path d="M12 3l8 3v6c0 5-3.5 8.5-8 10-4.5-1.5-8-5-8-10V6l8-3z"/><path d="M9 12l2 2 4-4"/>
    {%- when 'leaf' -%}
      <path d="M5 19c0-8 6-14 14-14 0 8-6 14-14 14z"/><path d="M5 19c4-4 8-8 14-14"/>
    {%- when 'star' -%}
      <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/>
    {%- when 'check' -%}
      <circle cx="12" cy="12" r="9"/><path d="M9 12l2 2 4-4"/>
    {%- when 'globe' -%}
      <circle cx="12" cy="12" r="9"/><path d="M3 12h18M12 3v18M5 6h14M5 18h14"/>
    {%- when 'flask' -%}
      <path d="M9 3h6M10 3v6l-5 10a2 2 0 0 0 1.8 3h10.4A2 2 0 0 0 19 19L14 9V3"/><path d="M7.5 14h9"/>
    {%- when 'sparkle' -%}
      <path d="M12 3v6M12 15v6M3 12h6M15 12h6"/><path d="M6 6l3 3M15 15l3 3M18 6l-3 3M9 15l-3 3"/>
  {%- endcase -%}
</svg>
