{{ 'bloomli-faq.css' | asset_url | stylesheet_tag }}
{{ 'bloomli-beneath-surface.css' | asset_url | stylesheet_tag }}
<script src="{{ 'bloomli-faq.js' | asset_url }}" defer="defer"></script>

<section
  id="BloomliBeneathSurface-{{ section.id }}"
  class="bloomli-beneath-surface bloomli-beneath-surface--{{ section.settings.desktop_layout }} color-{{ section.settings.color_scheme }} gradient"
  style="
    --section-padding-top: {{ section.settings.padding_top }}px;
    --section-padding-bottom: {{ section.settings.padding_bottom }}px;
    --section-padding-top-mobile: {{ section.settings.padding_top_mobile }}px;
    --section-padding-bottom-mobile: {{ section.settings.padding_bottom_mobile }}px;
  "
>
  <div class="page-width">
    <div class="bloomli-beneath-surface__header{% if section.settings.show_supporting_image and section.settings.supporting_image != blank %} bloomli-beneath-surface__header--with-media{% endif %}">
      <div class="bloomli-beneath-surface__intro">
        {%- if section.settings.heading != blank -%}
          <h2 class="bloomli-beneath-surface__heading h1">
            {{ section.settings.heading | escape }}
          </h2>
        {%- endif -%}

        {%- if section.settings.subtext != blank -%}
          <div class="bloomli-beneath-surface__subtext rte">
            {{ section.settings.subtext }}
          </div>
        {%- endif -%}
      </div>

      {%- if section.settings.show_supporting_image and section.settings.supporting_image != blank -%}
        <div class="bloomli-beneath-surface__media">
          {{
            section.settings.supporting_image
            | image_url: width: 900
            | image_tag:
              widths: '360, 540, 720, 900',
              sizes: '(min-width: 990px) 25vw, 100vw',
              loading: 'lazy',
              class: 'bloomli-beneath-surface__image'
          }}
        </div>
      {%- endif -%}
    </div>

    {%- if section.blocks.size > 0 -%}
      <div class="bloomli-beneath-surface__grid" role="list">
        {%- for block in section.blocks -%}
          {%- liquid
            assign concern_icon = block.settings.icon | default: 'sparkles'
            assign show_concern_visual = false
            assign show_concern_image = false
            if section.settings.visual_style != 'none'
              assign show_concern_visual = true
            endif
            if section.settings.visual_style == 'custom_images' and block.settings.image != blank
              assign show_concern_image = true
            endif
            assign is_featured = false
            if section.settings.desktop_layout == 'feature_first' and forloop.first
              assign is_featured = true
            endif
          -%}
          <article
            class="bloomli-beneath-surface__card{% if is_featured %} bloomli-beneath-surface__card--featured{% endif %}"
            role="listitem"
            {{ block.shopify_attributes }}
          >
            <div class="bloomli-beneath-surface__card-top">
              {%- if show_concern_visual -%}
                <span
                  class="bloomli-beneath-surface__icon{% if show_concern_image %} bloomli-beneath-surface__icon--image{% endif %}"
                  aria-hidden="true"
                >
                  {%- if show_concern_image -%}
                    {{
                      block.settings.image
                      | image_url: width: 160
                      | image_tag:
                        widths: '80, 120, 160',
                        sizes: '46px',
                        loading: 'lazy',
                        alt: '',
                        class: 'bloomli-beneath-surface__icon-image'
                    }}
                  {%- else -%}
                    <i class="ti ti-{{ concern_icon }}" aria-hidden="true"></i>
                  {%- endif -%}
                </span>
              {%- endif -%}
              <span class="bloomli-beneath-surface__number" aria-hidden="true">
                {{ forloop.index | prepend: '0' }}
              </span>
            </div>

            <div class="bloomli-beneath-surface__card-heading">
              <h3 class="bloomli-beneath-surface__card-title h2">
                {{ block.settings.title | escape }}
              </h3>
              {%- if block.settings.subtitle != blank -%}
                <p class="bloomli-beneath-surface__card-subtitle">
                  {{ block.settings.subtitle | escape }}
                </p>
              {%- endif -%}
            </div>

            <div class="bloomli-beneath-surface__details">
              <div class="bloomli-beneath-surface__detail">
                <h4 class="bloomli-beneath-surface__detail-label">What may be happening</h4>
                <p>{{ block.settings.what_text | escape }}</p>
              </div>

              <div class="bloomli-beneath-surface__detail bloomli-beneath-surface__detail--support">
                <h4 class="bloomli-beneath-surface__detail-label">How Bloomli supports it</h4>
                <p>{{ block.settings.how_text | escape }}</p>
              </div>
            </div>
          </article>
        {%- endfor -%}
      </div>

      <div
        class="bloomli-beneath-surface__mobile bloomli-faq__items"
        data-bloomli-faq
      >
        {%- for block in section.blocks -%}
          {%- liquid
            assign concern_icon = block.settings.icon | default: 'sparkles'
            assign show_concern_visual = false
            assign show_concern_image = false
            if section.settings.visual_style != 'none'
              assign show_concern_visual = true
            endif
            if section.settings.visual_style == 'custom_images' and block.settings.image != blank
              assign show_concern_image = true
            endif
            assign mobile_button_id = 'BloomliBeneathSurface-' | append: section.id | append: '-mobile-button-' | append: forloop.index
            assign mobile_panel_id = 'BloomliBeneathSurface-' | append: section.id | append: '-mobile-panel-' | append: forloop.index
          -%}
          <article
            class="bloomli-faq__item bloomli-beneath-surface__mobile-item"
            {{ block.shopify_attributes }}
          >
            <button
              id="{{ mobile_button_id }}"
              class="bloomli-faq__question bloomli-beneath-surface__mobile-question"
              type="button"
              aria-expanded="false"
              aria-controls="{{ mobile_panel_id }}"
              data-bloomli-faq-button
            >
              <span class="bloomli-beneath-surface__mobile-lead">
                {%- if show_concern_visual -%}
                  <span
                    class="bloomli-beneath-surface__mobile-icon{% if show_concern_image %} bloomli-beneath-surface__mobile-icon--image{% endif %}"
                    aria-hidden="true"
                  >
                    {%- if show_concern_image -%}
                      {{
                        block.settings.image
                        | image_url: width: 120
                        | image_tag:
                          widths: '64, 96, 120',
                          sizes: '40px',
                          loading: 'lazy',
                          alt: '',
                          class: 'bloomli-beneath-surface__mobile-icon-image'
                      }}
                    {%- else -%}
                      <i class="ti ti-{{ concern_icon }}" aria-hidden="true"></i>
                    {%- endif -%}
                  </span>
                {%- endif -%}

                <span class="bloomli-beneath-surface__mobile-copy">
                  <span class="bloomli-beneath-surface__mobile-title">
                    {{ block.settings.title | escape }}
                  </span>
                  {%- if block.settings.subtitle != blank -%}
                    <span class="bloomli-beneath-surface__mobile-subtitle">
                      {{ block.settings.subtitle | escape }}
                    </span>
                  {%- endif -%}
                </span>
              </span>

              <span class="bloomli-faq__plus bloomli-beneath-surface__mobile-plus" aria-hidden="true"></span>
            </button>

            <div
              id="{{ mobile_panel_id }}"
              class="bloomli-faq__panel bloomli-beneath-surface__mobile-panel"
              role="region"
              aria-labelledby="{{ mobile_button_id }}"
              hidden
            >
              <div class="bloomli-faq__panel-inner bloomli-beneath-surface__mobile-panel-inner">
                <div class="bloomli-beneath-surface__mobile-detail">
                  <h4 class="bloomli-beneath-surface__mobile-label">What may be happening</h4>
                  <p>{{ block.settings.what_text | escape }}</p>
                </div>

                <div class="bloomli-beneath-surface__mobile-detail bloomli-beneath-surface__mobile-detail--support">
                  <h4 class="bloomli-beneath-surface__mobile-label">How Bloomli supports it</h4>
                  <p>{{ block.settings.how_text | escape }}</p>
                </div>
              </div>
            </div>
          </article>
        {%- endfor -%}
      </div>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Bloomli - Beneath Surface",
  "tag": "section",
  "class": "section",
  "enabled_on": {
    "templates": ["index", "page", "product"]
  },
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-6d8ba907-aae6-4c49-9120-e1031d9cdb3f"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "What’s happening to your hair starts beneath the surface."
    },
    {
      "type": "richtext",
      "id": "subtext",
      "label": "Subtext",
      "default": "<p>Five common concerns, explained simply — and how Bloomli supports a consistent hair wellness routine.</p>"
    },
    {
      "type": "select",
      "id": "visual_style",
      "label": "Concern visuals",
      "options": [
        {
          "value": "custom_images",
          "label": "Custom images"
        },
        {
          "value": "tabler_icons",
          "label": "Tabler icons"
        },
        {
          "value": "none",
          "label": "No visuals"
        }
      ],
      "default": "custom_images"
    },
    {
      "type": "select",
      "id": "desktop_layout",
      "label": "Desktop layout",
      "options": [
        {
          "value": "feature_first",
          "label": "Feature first concern"
        },
        {
          "value": "balanced",
          "label": "Balanced grid"
        }
      ],
      "default": "feature_first"
    },
    {
      "type": "checkbox",
      "id": "show_supporting_image",
      "label": "Show supporting image",
      "default": false
    },
    {
      "type": "image_picker",
      "id": "supporting_image",
      "label": "Supporting image",
      "visible_if": "{{ section.settings.show_supporting_image }}"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "min": 0,
      "max": 120,
      "step": 8,
      "default": 88
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "min": 0,
      "max": 120,
      "step": 8,
      "default": 88
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "label": "Padding top mobile",
      "min": 0,
      "max": 120,
      "step": 8,
      "default": 56
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "label": "Padding bottom mobile",
      "min": 0,
      "max": 120,
      "step": 8,
      "default": 56
    }
  ],
  "blocks": [
    {
      "type": "concern",
      "name": "Concern",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Custom image",
          "info": "Used when Concern visuals is set to Custom images. The selected Tabler icon is used as a fallback."
        },
        {
          "type": "select",
          "id": "icon",
          "label": "Icon",
          "options": [
            {
              "value": "pill",
              "label": "Nutrients"
            },
            {
              "value": "droplets",
              "label": "Shedding"
            },
            {
              "value": "scissors",
              "label": "Breakage"
            },
            {
              "value": "plant-2",
              "label": "Scalp"
            },
            {
              "value": "heartbeat",
              "label": "Lifestyle"
            },
            {
              "value": "sparkles",
              "label": "General"
            }
          ],
          "default": "sparkles"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Nutrient gaps"
        },
        {
          "type": "text",
          "id": "subtitle",
          "label": "Subtitle",
          "default": "Daily support from within"
        },
        {
          "type": "textarea",
          "id": "what_text",
          "label": "What may be happening",
          "default": "Hair follicles rely on steady nutrients to support the normal growth cycle. When your routine is inconsistent, hair can look weaker, thinner, or more fragile."
        },
        {
          "type": "textarea",
          "id": "how_text",
          "label": "How Bloomli supports it",
          "default": "Bloomli provides daily beauty nutrients chosen to support hair from within, helping your routine stay simple and consistent."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Bloomli - Beneath Surface",
      "blocks": [
        {
          "type": "concern",
          "settings": {
            "icon": "pill",
            "title": "Nutrient gaps",
            "subtitle": "Daily support from within",
            "what_text": "Hair follicles rely on steady nutrients to support the normal growth cycle. When your routine is inconsistent, hair can look weaker, thinner, or more fragile.",
            "how_text": "Bloomli provides daily beauty nutrients chosen to support hair from within, helping your routine stay simple and consistent."
          }
        },
        {
          "type": "concern",
          "settings": {
            "icon": "droplets",
            "title": "Shedding",
            "subtitle": "When hair feels less full",
            "what_text": "Shedding can make hair feel thinner before visible density changes. Consistency matters because hair changes slowly over time.",
            "how_text": "Bloomli supports your daily hair wellness routine with nutrients that help nourish hair from within."
          }
        },
        {
          "type": "concern",
          "settings": {
            "icon": "scissors",
            "title": "Breakage",
            "subtitle": "When strands feel fragile",
            "what_text": "When strands become dry or fragile, hair can look thinner through the lengths even when growth is still happening at the root.",
            "how_text": "Bloomli supports stronger-feeling strands from within, while botanical scalp care complements the routine from the outside."
          }
        },
        {
          "type": "concern",
          "settings": {
            "icon": "plant-2",
            "title": "Scalp environment",
            "subtitle": "The foundation of the ritual",
            "what_text": "Your scalp is the foundation for fuller-looking hair. Dryness, buildup, and imbalance can make your routine feel less effective.",
            "how_text": "Pair daily nutrients with botanical scalp care to support a simple inside-out and outside-in ritual."
          }
        },
        {
          "type": "concern",
          "settings": {
            "icon": "heartbeat",
            "title": "Lifestyle stress",
            "subtitle": "When life shows up in your hair",
            "what_text": "Busy seasons, stress, styling, and inconsistent routines can all affect how your hair looks and feels over time.",
            "how_text": "Bloomli keeps hair wellness simple with an easy daily ritual designed to fit into real life."
          }
        }
      ]
    }
  ]
}
{% endschema %}
